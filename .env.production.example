# LittleStars — production env. Copie para .env.production (local) e preencha.
# Never commit .env.production.

# --- Deploy: Dokploy-nativo (servidor 192.168.1.13) ---
# Deploy gerenciado pelo Dokploy (Compose service), disparado via API.
# Pegue a API key em Dokploy → Settings → Profile. O composeId/projectId
# aparecem na URL do serviço/projeto no painel do Dokploy.
DOKPLOY_URL=http://your.dokploy.host:3000
DOKPLOY_API_KEY=your-dokploy-api-token
DOKPLOY_COMPOSE_ID=your-compose-id
DOKPLOY_PROJECT_ID=your-project-id

# --- Acesso SSH ao host (opcional: admin / tail de logs de deploy) ---
DEPLOY_HOST=your.server.host
DEPLOY_USER=youruser
DEPLOY_PORT=22

# --- Domínio (Traefik routing + ActionMailer/host authorization via APP_HOST) ---
DOMAIN_LITTLESTARS=stars.iacomcafe.com

# --- Postgres ---
PROD_POSTGRES_PASSWORD=replace_me_with_strong_password

# --- Rails ---
# Tem que casar com config/credentials.yml.enc.
RAILS_MASTER_KEY=

# --- SMTP (mailer) ---
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_DOMAIN=stars.iacomcafe.com
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=no-reply@stars.iacomcafe.com

# --- Academy LLM (OpenRouter) — chatbot "O Guia" ---
# Sem OPENROUTER_API_KEY, o botão 🦉 some e a aula funciona normal.
OPENROUTER_API_KEY=
ACADEMY_LLM_MODEL=deepseek/deepseek-v4-flash
ACADEMY_LLM_TEMPERATURE=0.7
ACADEMY_LLM_MAX_TOKENS=900
