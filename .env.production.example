# LittleStars Production Environment — template
# Copy to .env.production and fill secrets. Never commit .env.production.

# Deployment (SSH target — same Dokploy server as study-flix)
DEPLOY_HOST=app.iacomcafe.com
DEPLOY_USER=root
DEPLOY_PORT=22
DEPLOY_DIR=/opt/littlestars
# SSH_KEY_PATH=/path/to/private/key

# Domain (Traefik + ActionMailer host)
DOMAIN_LITTLESTARS=stars.iacomcafe.com

# Database
PROD_POSTGRES_PASSWORD=replace_me_with_strong_password

# Rails
RAILS_MASTER_KEY=read_from_config_master_key

# SMTP (mailer)
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_DOMAIN=stars.iacomcafe.com
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=no-reply@stars.iacomcafe.com
