{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "academy/lens/first_person.json",
  "title": "First-Person Lens Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["action_prompt", "sensory_anchor", "expected_time_seconds", "reveal"],
  "properties": {
    "action_prompt": { "type": "string", "minLength": 40, "maxLength": 280 },
    "sensory_anchor": { "type": "string", "minLength": 30, "maxLength": 220 },
    "expected_time_seconds": { "type": "integer", "minimum": 10, "maximum": 90 },
    "reveal": { "type": "string", "minLength": 60, "maxLength": 320 }
  }
}
