{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "academy/lens/ethical.json",
  "title": "Ethical Lens Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["dilemma", "case_a", "case_b", "anchor_question", "reveal"],
  "properties": {
    "dilemma": { "type": "string", "minLength": 60, "maxLength": 320 },
    "case_a": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body"],
      "properties": {
        "title": { "type": "string", "minLength": 10, "maxLength": 100 },
        "body": { "type": "string", "minLength": 80, "maxLength": 360 }
      }
    },
    "case_b": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body"],
      "properties": {
        "title": { "type": "string", "minLength": 10, "maxLength": 100 },
        "body": { "type": "string", "minLength": 80, "maxLength": 360 }
      }
    },
    "anchor_question": { "type": "string", "minLength": 30, "maxLength": 220 },
    "reveal": { "type": "string", "minLength": 80, "maxLength": 360 }
  }
}
