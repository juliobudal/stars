{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "academy/lens/analogy_bridge.json",
  "title": "Analogy Bridge Lens Payload",
  "type": "object",
  "additionalProperties": false,
  "required": ["source_domain", "target_domain", "mapping", "transfer_question"],
  "properties": {
    "source_domain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "elements"],
      "properties": {
        "name": { "type": "string", "minLength": 3, "maxLength": 60 },
        "elements": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": { "type": "string", "minLength": 15, "maxLength": 100 }
        }
      }
    },
    "target_domain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "elements"],
      "properties": {
        "name": { "type": "string", "minLength": 3, "maxLength": 60 },
        "elements": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": { "type": "string", "minLength": 15, "maxLength": 100 }
        }
      }
    },
    "mapping": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "minLength": 10, "maxLength": 80 },
          "to": { "type": "string", "minLength": 10, "maxLength": 80 }
        }
      }
    },
    "transfer_question": { "type": "string", "minLength": 30, "maxLength": 240 }
  }
}
