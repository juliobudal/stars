<div class="screen animate-slide-in flex flex-col items-center justify-center p-10">
  <%= render "shared/bg_shapes" %>

  <div class="max-w-[430px] mx-auto px-5 pt-8 pb-12 flex flex-col items-center text-center relative z-[1] md:max-w-[768px] w-full"
       data-controller="picker-tabs"
       data-picker-tabs-flash-value="<%= flash[:alert].present? %>">

    <%= render Ui::LogoMark::Component.new(size: 56) %>
    <h1 class="font-display text-[32px] leading-[1.1] font-extrabold tracking-[-0.02em] text-foreground">Bem-vindo ao LittleStars</h1>

    <div class="flex gap-4 justify-center mb-6" role="tablist">
      <button type="button"
              class="bg-transparent border-none px-4 py-2 rounded-full font-display font-extrabold text-[14px] text-muted-foreground cursor-pointer transition-all duration-150"
              data-picker-tabs-target="tab"
              data-action="click->picker-tabs#switch"
              data-tab="kids"
              role="tab"
              aria-selected="true">Crianças</button>
      <button type="button"
              class="bg-transparent border-none px-4 py-2 rounded-full font-display font-extrabold text-[14px] text-muted-foreground cursor-pointer transition-all duration-150"
              data-picker-tabs-target="tab"
              data-action="click->picker-tabs#switch"
              data-tab="parents"
              role="tab"
              aria-selected="false">Pais</button>
    </div>

    <div data-picker-tabs-target="panel" data-tab="kids" role="tabpanel">
      <p class="text-[14px] text-muted-foreground font-medium">Escolha seu perfil para começar</p>
      <div class="grid grid-cols-1 gap-3 mt-8 w-full text-left items-stretch sm:grid-cols-2">
        <% @profiles.each do |profile| %>
          <%= render Ui::ProfileCard::Component.new(profile: profile, url: sessions_path) %>
        <% end %>

        <%= link_to new_parent_profile_path, class: "flex items-center gap-5 px-6 py-5 border-2 border-dashed border-hairline rounded-md bg-transparent text-muted-foreground font-bold text-[15px] hover:border-primary hover:text-primary no-underline" do %>
          <div class="w-13 h-13 shrink-0 rounded-full grid place-items-center text-xl font-extrabold bg-surface-2 border-[3px] border-hairline text-text-soft">+</div>
          <span>Adicionar perfil</span>
        <% end %>
      </div>
    </div>

    <div data-picker-tabs-target="panel" data-tab="parents" role="tabpanel" hidden>
      <p class="text-[14px] text-muted-foreground font-medium">Acesso para pais</p>

      <% if flash[:alert] %>
        <p class="text-destructive text-center mb-4"><%= flash[:alert] %></p>
      <% end %>

      <%= form_with url: sessions_path, method: :post, local: true, class: "flex flex-col gap-3 max-w-[320px] mx-auto" do |f| %>
        <%= f.email_field :email, placeholder: "Email", required: true,
            class: "w-full px-3 py-2 rounded-md border border-hairline bg-white font-body text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary-soft" %>
        <%= f.password_field :password, placeholder: "Senha (mín. 12 caracteres)", required: true,
            class: "w-full px-3 py-2 rounded-md border border-hairline bg-white font-body text-foreground focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary-soft" %>
        <%= render Ui::Btn::Component.new(variant: "primary", size: "md", type: "submit") do %>Entrar<% end %>
      <% end %>

      <div class="text-center mt-4">
        <%= link_to "Criar conta", new_registration_path, class: "text-primary font-bold" %> ·
        <%= link_to "Esqueci minha senha", new_password_reset_path, class: "text-primary font-bold" %>
      </div>
    </div>
  </div>
</div>
