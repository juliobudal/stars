<div class="screen screen-enter picker-screen">
  <%= render "shared/bg_shapes" %>

  <div class="picker-wrap">
    <%= render "shared/star_mascot", size: 44 %>
    <h1 class="h-display picker-heading">Quem vai brilhar hoje?</h1>
    <p class="picker-lead">Escolha seu perfil para começar</p>

    <div class="picker-grid">
      <% @profiles.each do |profile| %>
        <%= render Ui::ProfileCard::Component.new(profile: profile, url: sessions_path) %>
      <% end %>

      <%= link_to new_parent_profile_path, class: "picker-ghost-card" do %>
        <div class="picker-avatar">+</div>
        <span>Adicionar perfil</span>
      <% end %>
    </div>

    <%= link_to parent_root_path, class: "picker-footer-link" do %>
      Modo pais <span aria-hidden="true">→</span>
    <% end %>
  </div>
</div>
