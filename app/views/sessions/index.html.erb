<div class="max-w-4xl mx-auto py-16 px-4 sm:px-6 lg:px-8">
  <div class="text-center mb-16">
    <div class="inline-block px-4 py-1.5 mb-4 rounded-2xl bg-brand-yellow/10 border-2 border-brand-yellow/20 text-brand-yellow text-xs font-black uppercase tracking-widest italic">
      Bem-vindo de volta!
    </div>
    <h1 class="text-5xl font-black text-gray-900 tracking-tight italic mb-4">
      Família <span class="text-brand-blue"><%= @family&.name || "LittleStars" %></span>
    </h1>
    <p class="text-xl font-black text-gray-400 uppercase tracking-widest flex items-center justify-center gap-2">
      <%= icon_tag "users", class: "w-6 h-6 text-gray-300" %>
      Quem está acessando agora?
    </p>
  </div>

  <% if @profiles.any? %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <% @profiles.each do |profile| %>
        <%= form_with url: sessions_path, method: :post, class: "h-full" do |f| %>
          <%= f.hidden_field :profile_id, value: profile.id %>
          <button type="submit" class="group relative w-full h-full focus:outline-none">
            <div class="relative flex flex-col items-center justify-center p-8 h-full rounded-3xl border-2 border-border bg-white transition-all duration-150 transform group-hover:border-brand-blue group-active:translate-y-1 group-active:shadow-none shadow-[0_4px_0_0_rgb(229,229,229)] group-hover:shadow-[0_4px_0_0_rgba(28,176,246,0.3)]">
              
              <% if profile.parent? %>
                <div class="absolute -top-3 -right-3 bg-brand-yellow border-2 border-brand-yellow-depth text-white text-[10px] px-2 py-1 rounded-xl font-black shadow-[0_2px_0_0_rgba(0,0,0,0.1)] flex items-center gap-1">
                  <%= icon_tag "academic-cap", class: "w-3 h-3 text-white" %> RESPONSÁVEL
                </div>
              <% end %>

              <div class="mb-6 relative">
                <div class="w-24 h-24 rounded-full border-4 border-white shadow-xl overflow-hidden bg-gray-50 flex items-center justify-center text-4xl transform transition-transform group-hover:scale-110 group-hover:rotate-6">
                  <%= profile.avatar.presence || icon_tag("user-circle", class: "text-gray-300 w-16 h-16") %>
                </div>
              </div>
              
              <h3 class="text-xl font-black text-gray-900 text-center tracking-tight capitalize"><%= profile.name %></h3>
              
              <div class="mt-3">
                <% if profile.parent? %>
                  <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest italic">Papai / Mamãe</span>
                <% else %>
                  <div class="flex items-center gap-1 bg-brand-yellow/10 px-3 py-1 rounded-xl border-2 border-brand-yellow/20">
                    <%= icon_tag "star", class: "w-4 h-4 text-brand-yellow animate-star-pulse" %>
                    <span class="text-brand-yellow font-black text-sm"><%= profile.points %></span>
                  </div>
                <% end %>
              </div>
            </div>
          </button>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center p-12 bg-white rounded-3xl border-2 border-border border-dashed">
      <p class="text-gray-400 font-bold uppercase tracking-widest">Nenhum perfil encontrado.</p>
    </div>
  <% end %>

  <div class="mt-16 text-center">
    <p class="text-xs font-black text-gray-300 uppercase tracking-widest flex items-center justify-center gap-2">
      LittleStars &copy; <%= Time.current.year %> &bull; Feito com <%= icon_tag "heart", class: "w-3 h-3 text-brand-red inline-block" %> e <%= icon_tag "sparkles", class: "w-3 h-3 text-brand-yellow inline-block" %>
    </p>
  </div>
</div>
