<% disc_colors = {
  "primary" => "rgba(167, 139, 250, 0.15)",
  "peach"   => "rgba(244, 114, 182, 0.15)",
  "rose"    => "rgba(236, 72, 153, 0.15)",
  "mint"    => "rgba(52, 211, 153, 0.15)",
  "sky"     => "rgba(56, 189, 248, 0.15)",
  "lilac"   => "rgba(167, 139, 250, 0.15)",
  "coral"   => "rgba(236, 72, 153, 0.15)"
} %>

<div class="screen screen-enter" style="justify-content: flex-start; align-items: center; padding-top: 28px; background: var(--bg-deep);">
  <div style="z-index: 2; width: 100%; max-width: 960px; text-align: center;">
    <div class="mb-4 center col" style="gap: 6px;">
      <%= render Ui::Lumi::Component.new(size: 72, mood: "excited") %>
      <div class="eyebrow mt-2">LittleStars</div>
      <h1 class="h-display display" style="font-size: 36px;">Quem vai brilhar hoje?</h1>
      <p class="subtitle" style="max-width: 460px; font-size: 15px; margin: 0 auto;">Escolha seu perfil para começar a aventura</p>
    </div>

    <div class="grid-auto" style="gap: 14px; margin-top: 20px;">
      <% @profiles.each_with_index do |profile, i| %>
        <% color = profile.try(:color).presence || "primary" %>
        <% disc_color = disc_colors[color] || disc_colors["primary"] %>
        <% streak = profile.try(:streak).presence || 0 %>

        <%= form_with url: sessions_path, method: :post, class: "h-full" do |f| %>
          <%= f.hidden_field :profile_id, value: profile.id %>
          <button type="submit" class="card pop-on-tap card-tap w-full h-full" style="
            cursor: pointer;
            background: white;
            box-shadow: var(--shadow-card);
            border: none;
            padding: 24px 18px;
            border-radius: var(--r-lg);
            transition: transform 0.12s;
            animation: slideInCard 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) <%= i * 0.05 %>s both;
            text-align: center;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px;
            font-family: var(--font-body);
            font-weight: 700;
            color: var(--text);
          ">
            <div style="width: 100px; height: 100px; border-radius: 50%; background: <%= disc_color %>; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
              <%= render Ui::KidAvatar::Component.new(kid: profile, size: 80) %>
            </div>

            <div class="h-display" style="font-size: 20px;"><%= profile.name %></div>

            <% if profile.child? %>
              <%= render Ui::Badge::Component.new(variant: "star", icon: "star") do %>
                <%= profile.points %>
              <% end %>
              <% if streak > 0 %>
                <span style="
                  display: inline-flex;
                  align-items: center;
                  gap: 4px;
                  background: rgba(251, 146, 60, 0.12);
                  color: #EA580C;
                  font-size: 12px;
                  font-weight: 700;
                  padding: 3px 10px;
                  border-radius: 99px;
                ">🔥 <%= streak %> dias</span>
              <% end %>
            <% else %>
              <%= render Ui::Badge::Component.new(variant: "primary") do %>
                Responsável
              <% end %>
            <% end %>
          </button>
        <% end %>
      <% end %>

      <%= link_to new_parent_profile_path, class: "card pop-on-tap card-tap", style: "
        border: 2px dashed var(--hairline);
        background: transparent;
        box-shadow: none;
        padding: 24px 18px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        color: var(--text-muted);
        min-height: 160px;
      " do %>
        <div style="width: 48px; height: 48px; border-radius: 50%; border: 2px dashed var(--hairline); display: flex; align-items: center; justify-content: center;">
          <%= render Ui::Icon::Component.new("plus", size: 24, color: "var(--text-muted)") %>
        </div>
        <span style="font-weight: 700; font-size: 13px;">Adicionar perfil</span>
      <% end %>
    </div>

    <div style="margin-top: 32px; text-align: center;">
      <%= link_to parent_root_path, style: "font-size: 14px; font-weight: 700; color: var(--text-muted); text-decoration: none;" do %>
        Área dos pais <span aria-hidden="true">→</span>
      <% end %>
    </div>
  </div>
</div>
