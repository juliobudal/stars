<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "LittleStars | Kid" %></title>
    <%= render "shared/head" %>
    <%= yield :head %>
  </head>

  <body class="min-h-screen bg-bg-deep overflow-x-hidden" data-palette="<%= palette_for(current_profile) %>" data-controller="fx">
    <%= render "shared/kid_nav" %>
    <%= render "kid/shared/fx_stage" %>
    <main class="p-6 w-full max-w-[430px] md:max-w-[560px] lg:max-w-[720px] mx-auto pb-24 md:pb-10">
      <%= render Ui::Flash::Component.new %>
      <%= yield %>
    </main>
    <%= render Ui::InstallPrompt::Component.new %>
    <%= render Ui::IosInstallHint::Component.new %>
    <div hidden
         data-controller="pwa-update"
         class="fixed bottom-4 left-1/2 -translate-x-1/2 z-50 max-w-[420px] w-[calc(100%-2rem)] rounded-[14px] border-2 border-black/10 bg-white text-foreground shadow-[0_4px_0_rgba(0,0,0,0.12)] p-4 flex items-center gap-3 font-bold">
      <span class="flex-1">Atualização disponível.</span>
      <button type="button" data-action="pwa-update#apply"
              class="px-4 py-2 rounded-[12px] bg-primary text-primary-foreground font-extrabold border-2 border-black/10 shadow-btn-primary">
        Atualizar
      </button>
      <button type="button" data-action="pwa-update#dismiss"
              class="px-3 py-2 rounded-[12px] text-muted-foreground font-bold">
        Depois
      </button>
    </div>
  </body>
</html>
