<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "LittleStars | Painel Responsável" %></title>
    <%= render "shared/head" %>
    <%= yield :head %>
  </head>

  <body class="min-h-screen flex flex-col bg-bg-deep overflow-x-hidden" data-palette="sky">
    <%= turbo_stream_from current_profile.family, "approvals" %>
    <%= render "shared/parent_nav" %>
    <div class="flex-1 p-6 overflow-y-auto w-full max-w-[500px] mx-auto relative z-1 pb-24 lg:pb-0">
      <%= render Ui::Flash::Component.new %>
      <%= yield %>
    </div>
  </body>
</html>
