<%# Mobile sticky header — hidden on desktop via CSS %>
<%# Mobile sticky header — hidden on desktop via CSS %>
<div data-controller="sidebar-toggle">
<div class="flex lg:hidden items-center justify-between px-4 h-[64px] bg-white border-b border-hairline sticky top-0 z-40">
  <div class="flex items-center gap-2.5">
    <%= render Ui::LogoMark::Component.new(size: 20) %>
    <span class="font-display font-extrabold tracking-tight text-[18px] text-foreground">LittleStars</span>
  </div>
  <button type="button" id="sidebar-toggle"
          data-action="click->sidebar-toggle#open"
          class="flex items-center justify-center w-9 h-9 rounded-[10px] bg-muted border-none cursor-pointer text-foreground">
    <%= render Ui::Icon::Component.new("list", size: 20) %>
  </button>
</div>

<%# Sidebar %>
<%# Sidebar %>
<nav class="flex flex-col fixed left-0 top-0 bottom-0 w-[220px] bg-surface border-r-2 border-hairline z-50 -translate-x-full transition-transform duration-300 ease-in-out lg:translate-x-0" id="parent-sidebar" data-sidebar-toggle-target="sidebar" aria-label="Principal">
  <%# Brand %>
  <div class="px-[14px] pt-5 pb-[18px]">
    <div class="flex items-center gap-2.5">
      <div class="w-8 h-8 grid place-items-center rounded-[10px]" style="background: var(--star); box-shadow: 0 3px 0 var(--star-2);">
        <%= render Ui::Icon::Component.new("star", size: 18, color: "white") %>
      </div>
      <div class="flex flex-col leading-tight">
        <span class="font-extrabold text-[17px]" style="color: var(--text);">LittleStars</span>
        <span class="text-[10px] font-bold tracking-[1px] uppercase" style="color: var(--text-soft);">Modo pais</span>
      </div>
    </div>
  </div>

  <%# Nav items %>
  <div class="flex flex-col gap-1 px-[14px] flex-1 overflow-y-auto">
    <%
      items = [
        { icon: "house", path: parent_root_path, label: "Início" },
        { icon: "users", path: parent_profiles_path, label: "Crianças" },
        { icon: "list-checks", path: parent_global_tasks_path, label: "Missões" },
        { icon: "bag", path: parent_rewards_path, label: "Prêmios" },
        { icon: "bookmark-01", path: parent_categories_path, label: "Categorias" },
        { icon: "clock", path: parent_approvals_path, label: "Aprovações", badge: pending_approvals_count.positive? ? pending_approvals_count : nil },
        { icon: "gear", path: parent_settings_path, label: "Configurações" }
      ]
    %>
    <% items.each do |item| %>
      <% active = current_page?(item[:path]) %>
      <%= link_to item[:path],
          class: "flex items-center gap-3 px-3 py-2.5 rounded-[14px] transition-colors font-extrabold text-[14px] border-2 #{active ? 'bg-accent text-accent-foreground border-primary' : 'text-muted-foreground border-transparent hover:bg-muted hover:text-foreground'}",
          title: item[:label],
          aria: { current: active ? "page" : nil } do %>
        <%= render Ui::Icon::Component.new(item[:icon], size: 18, color: "currentColor") %>
        <span><%= item[:label] %></span>
        <% if item[:badge] %>
          <span class="ml-auto bg-danger text-white text-[11px] font-extrabold px-2 py-0.5 rounded-[10px] min-w-[24px] text-center" style="box-shadow: 0 2px 0 var(--danger-2);"><%= item[:badge] %></span>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# Footer: profile + switch profile %>
  <div class="px-[14px] pb-5 pt-3">
    <%= link_to edit_parent_profile_path(current_profile),
          class: "flex items-center gap-2.5 p-3 rounded-[14px] border-2 no-underline hover:scale-[1.01] transition-transform",
          style: "background: var(--surface-muted); border-color: var(--hairline);",
          aria: { label: "Editar meu perfil" } do %>
      <%= render Ui::SmileyAvatar::Component.new(kid: current_profile, size: 34) %>
      <div class="flex-1 min-w-0">
        <div class="text-[13px] font-extrabold overflow-hidden text-ellipsis whitespace-nowrap" style="color: var(--text);"><%= current_profile.name %></div>
        <div class="text-[11px] font-bold" style="color: var(--text-soft);">Responsável · Editar</div>
      </div>
      <%= render Ui::Icon::Component.new("edit", size: 14, color: "var(--text-soft)") %>
    <% end %>
    <div data-controller="switch-profile" class="mt-2">
      <%= form_with url: profile_session_path, method: :delete, local: true,
                    data: { switch_profile_target: "form" } do %>
        <%= render Ui::Btn::Component.new(variant: "ghost", size: "sm", block: true,
              type: "button",
              data: { action: "click->switch-profile#confirm" }) do %>
          <%= render Ui::Icon::Component.new("logout", size: 14, color: "currentColor") %>
          Trocar perfil
        <% end %>
      <% end %>
    </div>
  </div>
</nav>

<%# Sidebar backdrop (mobile) %>
<div id="sidebar-backdrop" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-40 hidden"
     data-sidebar-toggle-target="backdrop"
     data-action="click->sidebar-toggle#close"></div>

</div><%# end data-controller="sidebar-toggle" %>

<div class="fixed bottom-0 left-0 right-0 h-[72px] bg-white/80 backdrop-blur-lg border-t border-hairline flex justify-around items-center px-4 z-40 lg:hidden">
  <%
    mobile_nav_items = [
      { icon: "house", path: parent_root_path, label: "Início" },
      { icon: "clock", path: parent_approvals_path, label: "Pendências", badge: pending_approvals_count.positive? ? pending_approvals_count : nil },
      { icon: "list-checks", path: parent_global_tasks_path, label: "Missões" },
      { icon: "bag", path: parent_rewards_path, label: "Prêmios" }
    ]
  %>
  <% mobile_nav_items.each do |item| %>
    <% active = current_page?(item[:path]) %>
    <%= link_to item[:path], class: "flex flex-col items-center justify-center gap-1 flex-1 py-2 relative", title: item[:label] do %>
      <span class="flex flex-col items-center gap-1 px-3 py-1 rounded-[12px] border-2 transition-colors #{active ? 'bg-accent text-accent-foreground border-primary' : 'text-muted-foreground border-transparent'}">
        <%= render Ui::Icon::Component.new(item[:icon], size: 22, color: "currentColor") %>
        <span class="text-[10px] font-extrabold tracking-[0.5px] uppercase"><%= item[:label] %></span>
      </span>
      <% if item[:badge] %>
        <span class="absolute top-1 right-1/4 -translate-x-1 bg-danger text-white text-[9px] font-extrabold px-1 rounded-full min-w-[16px] h-4 flex items-center justify-center border-2 border-white"><%= item[:badge] %></span>
      <% end %>
    <% end %>
  <% end %>
</div>

