<%
  pending_count = current_profile.family.profile_tasks.awaiting_approval.count +
                  Redemption.pending.joins(:profile).where(profiles: { family_id: current_profile.family_id }).count
%>

<nav class="side-nav" aria-label="Principal">
  <%# Brand mark %>
  <div class="brand-mark">
    <div class="row">
      <%= render Ui::LogoMark::Component.new(size: 24) %>
      <div>
        <span class="h-display" style="font-size: 20px; font-style: normal; color: var(--text); display: block;">LittleStars</span>
        <span style="font-size: 12px; color: var(--text-muted); font-weight: 700;"><%= current_profile.family.name %></span>
        <%
          parents_count = current_profile.family.profiles.parent.count
          children_count = current_profile.family.profiles.child.count
        %>
        <span style="font-size: 11px; color: var(--text-muted);">
          <%= parents_count == 1 ? '1 pai' : "#{parents_count} pais" %> · <%= children_count == 1 ? '1 filho' : "#{children_count} filhos" %>
        </span>
      </div>
    </div>
  </div>

  <%# Nav items %>
  <div class="col" style="gap: 2px; padding: 0 var(--space-3); flex: 1;">
    <%= link_to parent_root_path,
        class: "nav-item #{current_page?(parent_root_path) ? 'active' : ''}",
        title: "Início",
        aria: { current: current_page?(parent_root_path) ? "page" : nil } do %>
      <%= render Ui::Icon::Component.new("house", size: 22) %>
      <span>Início</span>
    <% end %>

    <%= link_to parent_profiles_path,
        class: "nav-item #{current_page?(parent_profiles_path) ? 'active' : ''}",
        title: "Filhos",
        aria: { current: current_page?(parent_profiles_path) ? "page" : nil } do %>
      <%= render Ui::Icon::Component.new("users", size: 22) %>
      <span>Filhos</span>
    <% end %>

    <%= link_to parent_global_tasks_path,
        class: "nav-item #{current_page?(parent_global_tasks_path) ? 'active' : ''}",
        title: "Missões",
        aria: { current: current_page?(parent_global_tasks_path) ? "page" : nil } do %>
      <%= render Ui::Icon::Component.new("list-checks", size: 22) %>
      <span>Missões</span>
    <% end %>

    <%= link_to parent_rewards_path,
        class: "nav-item #{current_page?(parent_rewards_path) ? 'active' : ''}",
        title: "Prêmios",
        aria: { current: current_page?(parent_rewards_path) ? "page" : nil } do %>
      <%= render Ui::Icon::Component.new("bag", size: 22) %>
      <span>Prêmios</span>
    <% end %>

    <%= link_to parent_approvals_path,
        class: "nav-item #{current_page?(parent_approvals_path) ? 'active' : ''} relative",
        title: "Aprovações",
        aria: { current: current_page?(parent_approvals_path) ? "page" : nil } do %>
      <%= render Ui::Icon::Component.new("clock", size: 22) %>
      <span>Aprovações</span>
      <% if pending_count > 0 %>
        <span style="
          min-width: 18px; height: 18px;
          background: var(--c-peach);
          color: white;
          font-size: 11px;
          font-weight: 800;
          border-radius: var(--r-full);
          display: flex; align-items: center; justify-content: center;
          padding: 0 5px;
          margin-left: auto;
        "><%= pending_count %></span>
      <% end %>
    <% end %>

    <%= link_to parent_settings_path,
        class: "nav-item #{current_page?(parent_settings_path) ? 'active' : ''}",
        title: "Configurações",
        aria: { current: current_page?(parent_settings_path) ? "page" : nil } do %>
      <%= render Ui::Icon::Component.new("gear", size: 22) %>
      <span>Configurações</span>
    <% end %>
  </div>

  <%# Identity + logout at bottom %>
  <div style="padding: var(--space-2) var(--space-3); border-top: 1px solid var(--hairline); margin-top: var(--space-2);">
    <div class="row" style="gap: 8px; align-items: center; margin-bottom: 8px;">
      <%= render Ui::SmileyAvatar::Component.new(kid: current_profile, size: 34) %>
      <div>
        <div style="font-size: 13px; font-weight: 700; color: var(--text);"><%= current_profile.name %></div>
        <div style="font-size: 11px; color: var(--text-muted);">Administrador(a)</div>
      </div>
    </div>
    <%= button_to sessions_path, method: :delete, class: "nav-item w-full",
        style: "background: transparent; border: none; cursor: pointer; color: var(--text-muted); text-align: left;",
        title: "Sair" do %>
      <%= render Ui::Icon::Component.new("logout", size: 22) %>
      <span>Sair</span>
    <% end %>
  </div>
</nav>

<div class="bottom-nav">
  <%
    nav_item = ->(icon_name, path, title) {
      active = current_page?(path)
      link_to path, class: "nav-item #{active ? 'active' : ''}", title: title do
        render Ui::Icon::Component.new(icon_name, size: 26)
      end
    }
  %>
  <%= nav_item.call("house", parent_root_path, "Início") %>

  <%= link_to parent_approvals_path,
      class: "nav-item #{current_page?(parent_approvals_path) ? 'active' : ''} relative",
      title: "Aprovações" do %>
    <%= render Ui::Icon::Component.new("clock", size: 26) %>
    <% if pending_count > 0 %>
      <span style="
        position: absolute;
        top: 6px; right: 6px;
        min-width: 16px; height: 16px;
        background: var(--c-peach);
        color: white;
        font-size: 10px;
        font-weight: 800;
        border-radius: var(--r-full);
        display: flex; align-items: center; justify-content: center;
        padding: 0 4px;
        line-height: 1;
      "><%= pending_count %></span>
    <% end %>
  <% end %>

  <%= nav_item.call("list-checks", parent_global_tasks_path, "Missões") %>
  <%= nav_item.call("bag", parent_rewards_path, "Prêmios") %>
</div>
