<%# Mobile sticky header · hidden on desktop via CSS %>
<div data-controller="sidebar-toggle">
<div class="flex lg:hidden items-center justify-between px-4 h-[64px] bg-surface border-b border-hairline sticky top-0 z-40"
     style="padding-top: env(safe-area-inset-top); height: calc(64px + env(safe-area-inset-top));">
  <div class="flex items-center gap-2.5">
    <%= render Ui::LogoMark::Component.new(size: 20) %>
    <span class="font-display font-extrabold tracking-tight text-[18px] text-foreground">LittleStars</span>
  </div>
  <button type="button" id="sidebar-toggle"
          data-action="click->sidebar-toggle#open"
          aria-label="Abrir menu" aria-expanded="false" aria-controls="parent-sidebar"
          class="flex items-center justify-center w-11 h-11 rounded-[12px] bg-surface border border-hairline cursor-pointer text-foreground transition-colors hover:bg-muted">
    <%= render Ui::Icon::Component.new("list", size: 22) %>
  </button>
</div>

<%# Sidebar (mobile drawer + desktop rail). Active state uses sky — the parent
    nav accent (DESIGN.md §2) — so "where I am" never reads as a green action. %>
<nav class="flex flex-col fixed left-0 top-0 bottom-0 w-[224px] bg-surface border-r border-hairline z-50 -translate-x-full lg:translate-x-0"
     id="parent-sidebar"
     data-sidebar-toggle-target="sidebar"
     aria-label="Principal"
     style="padding-top: env(safe-area-inset-top); padding-bottom: env(safe-area-inset-bottom); transition: transform var(--dur-base) var(--ease-snap);">
  <%# Brand %>
  <div class="px-[14px] pt-5 pb-[18px]">
    <div class="flex items-center gap-2.5">
      <div class="w-8 h-8 grid place-items-center rounded-[10px]" style="background: var(--star); box-shadow: 0 4px 0 var(--star-2);">
        <%= render Ui::Icon::Component.new("star", size: 18, color: "white") %>
      </div>
      <div class="flex flex-col leading-tight">
        <span class="font-extrabold text-[17px]" style="color: var(--text);">LittleStars</span>
        <span class="text-[10px] font-bold tracking-[1px] uppercase" style="color: var(--text-muted);">Modo pais</span>
      </div>
    </div>
  </div>

  <%# Nav items %>
  <div class="flex flex-col gap-0.5 px-[14px] flex-1 overflow-y-auto">
    <%
      items = [
        { icon: "house", path: parent_root_path, label: "Início" },
        { icon: "users", path: parent_profiles_path, label: "Crianças" },
        { icon: "sparkle", path: parent_academy_dashboard_path, label: "Academia" },
        { icon: "list-checks", path: parent_global_tasks_path, label: "Missões" },
        { icon: "bag", path: parent_rewards_path, label: "Prêmios" },
        { icon: "bookmark-01", path: parent_categories_path, label: "Categorias" },
        { icon: "clock", path: parent_approvals_path, label: "Aprovações", badge: pending_approvals_count.positive? ? pending_approvals_count : nil },
        { icon: "gear", path: parent_settings_path, label: "Configurações" }
      ]
    %>
    <% items.each do |item| %>
      <% active = current_page?(item[:path]) %>
      <% is_approvals = item[:path] == parent_approvals_path %>
      <%= link_to item[:path],
          class: "flex items-center gap-3 px-2.5 py-2 rounded-[12px] transition-colors font-extrabold text-[14px] no-underline #{active ? '' : 'hover:bg-muted'}",
          title: item[:label],
          style: ("background: var(--c-info-100);" if active),
          aria: { current: active ? "page" : nil } do %>
        <span class="grid place-items-center w-8 h-8 rounded-[9px] shrink-0 transition-colors"
              style="<%= "background: var(--c-info-500);" if active %>">
          <%= render Ui::Icon::Component.new(item[:icon], size: 18, color: active ? "white" : "var(--text-muted)") %>
        </span>
        <span style="color: <%= active ? "var(--text)" : "var(--text-muted)" %>;"><%= item[:label] %></span>
        <% if is_approvals %>
          <%= render "shared/parent_approvals_badge", count: pending_approvals_count, variant: :sidebar %>
        <% elsif item[:badge] %>
          <span class="ml-auto bg-danger text-white text-[11px] font-extrabold px-2 py-0.5 rounded-[10px] min-w-[24px] text-center" style="box-shadow: 0 2px 0 var(--danger-2);"><%= item[:badge] %></span>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# Footer: profile + switch profile %>
  <div class="px-[14px] pb-5 pt-3">
    <%= link_to edit_parent_profile_path(current_profile),
          class: "flex items-center gap-2.5 p-3 rounded-[14px] border no-underline transition-colors hover:bg-muted",
          style: "background: var(--surface-muted); border-color: var(--hairline);",
          aria: { label: "Editar meu perfil" } do %>
      <%= render Ui::SmileyAvatar::Component.new(kid: current_profile, size: 34, decorative: true) %>
      <div class="flex-1 min-w-0">
        <div class="text-[13px] font-extrabold overflow-hidden text-ellipsis whitespace-nowrap" style="color: var(--text);"><%= current_profile.name %></div>
        <div class="text-[11px] font-bold" style="color: var(--text-muted);">Responsável · Editar</div>
      </div>
      <%= render Ui::Icon::Component.new("edit", size: 14, color: "var(--text-muted)") %>
    <% end %>
    <div data-controller="switch-profile" class="mt-2">
      <%= form_with url: profile_session_path, method: :delete, local: true,
                    data: { switch_profile_target: "form" } do %>
        <%= render Ui::Btn::Component.new(variant: "ghost", size: "sm", block: true,
              type: "button",
              data: { action: "click->switch-profile#confirm" }) do %>
          <%= render Ui::Icon::Component.new("logout", size: 14, color: "currentColor") %>
          Trocar perfil
        <% end %>
      <% end %>
    </div>
  </div>
</nav>

<%# Sidebar backdrop (mobile). Sits above the bottom bar (z-40) so the open
    drawer reads as one clean overlay, not stacked on top of the tab bar. %>
<div id="sidebar-backdrop" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[45] hidden"
     data-sidebar-toggle-target="backdrop"
     data-action="click->sidebar-toggle#close"></div>

<%# Bottom tab bar (mobile). Active tab = soft-sky lozenge behind the icon. %>
<div class="fixed bottom-0 left-0 right-0 bg-surface border-t border-hairline flex justify-around items-stretch px-2 z-40 lg:hidden"
     style="padding-bottom: env(safe-area-inset-bottom); min-height: calc(72px + env(safe-area-inset-bottom));">
  <%
    mobile_nav_items = [
      { icon: "house",       path: parent_root_path,             label: "Início" },
      { icon: "sparkle",     path: parent_academy_dashboard_path, label: "Academia" },
      { icon: "clock",       path: parent_approvals_path,        label: "Aprovações", badge: pending_approvals_count.positive? ? pending_approvals_count : nil },
      { icon: "list-checks", path: parent_global_tasks_path,     label: "Missões" }
    ]
  %>
  <% mobile_nav_items.each do |item| %>
    <% active = current_page?(item[:path]) %>
    <% is_approvals = item[:path] == parent_approvals_path %>
    <%= link_to item[:path],
          class: "flex flex-col items-center justify-center gap-1 flex-1 py-2 relative min-h-[44px] no-underline",
          title: item[:label],
          aria: { current: active ? "page" : nil, label: item[:label] } do %>
      <span class="grid place-items-center w-12 h-7 rounded-full transition-colors"
            style="<%= "background: var(--c-info-100);" if active %>">
        <%= render Ui::Icon::Component.new(item[:icon], size: 21, color: active ? "var(--c-info-600)" : "var(--text-muted)") %>
      </span>
      <span class="text-[10px] font-extrabold tracking-[0.2px] whitespace-nowrap"
            style="color: <%= active ? "var(--text)" : "var(--text-muted)" %>;"><%= item[:label] %></span>
      <% if is_approvals %>
        <%= render "shared/parent_approvals_badge", count: pending_approvals_count, variant: :mobile %>
      <% elsif item[:badge] %>
        <span class="absolute top-1 right-1/4 -translate-x-1 bg-danger text-white text-[9px] font-extrabold px-1 rounded-full min-w-[16px] h-4 flex items-center justify-center border border-white"><%= item[:badge] %></span>
      <% end %>
    <% end %>
  <% end %>

  <%# "Mais" · opens the drawer to reach Crianças / Categorias / Configurações %>
  <button type="button"
          data-action="click->sidebar-toggle#open"
          aria-label="Mais opções" aria-expanded="false" aria-controls="parent-sidebar"
          class="flex flex-col items-center justify-center gap-1 flex-1 py-2 min-h-[44px] bg-transparent border-0 cursor-pointer">
    <span class="grid place-items-center w-12 h-7 rounded-full">
      <%= render Ui::Icon::Component.new("list", size: 21, color: "var(--text-muted)") %>
    </span>
    <span class="text-[10px] font-extrabold tracking-[0.2px] whitespace-nowrap" style="color: var(--text-muted);">Mais</span>
  </button>
</div>

</div><%# end data-controller="sidebar-toggle" %>
