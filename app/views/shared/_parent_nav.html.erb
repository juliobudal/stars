<%
  pending_count = current_profile.family.profile_tasks.awaiting_approval.count +
                  Redemption.pending.joins(:profile).where(profiles: { family_id: current_profile.family_id }).count
%>

<nav class="side-nav">
  <%# Brand mark %>
  <div style="padding: 0 var(--space-4) var(--space-4); border-bottom: 1px solid var(--hairline); margin-bottom: var(--space-3);">
    <div class="row" style="gap: 10px; align-items: center;">
      <%= render Ui::Icon::Component.new("star", size: 28, color: "var(--star)") %>
      <span class="h-display" style="font-size: 20px; font-style: normal; color: var(--text);">LittleStars</span>
    </div>
    <div style="font-size: 12px; color: var(--text-muted); font-weight: 700; margin-top: 6px; padding-left: 38px;">
      <%= current_profile.family.name %>
    </div>
  </div>

  <%# Nav items %>
  <div class="col" style="gap: 2px; padding: 0 var(--space-3); flex: 1;">
    <%= link_to parent_root_path,
        class: "nav-item #{current_page?(parent_root_path) ? 'active' : ''}",
        title: "Início",
        style: "display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: var(--r-md);" do %>
      <%= render Ui::Icon::Component.new("house", size: 22) %>
      <span style="font-weight: 700; font-size: 14px;">Início</span>
    <% end %>

    <%= link_to parent_approvals_path,
        class: "nav-item #{current_page?(parent_approvals_path) ? 'active' : ''} relative",
        title: "Aprovações",
        style: "display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: var(--r-md);" do %>
      <%= render Ui::Icon::Component.new("clock", size: 22) %>
      <span style="font-weight: 700; font-size: 14px;">Aprovações</span>
      <% if pending_count > 0 %>
        <span style="
          min-width: 18px; height: 18px;
          background: var(--c-peach);
          color: white;
          font-size: 11px;
          font-weight: 800;
          border-radius: var(--r-full);
          display: flex; align-items: center; justify-content: center;
          padding: 0 5px;
          margin-left: auto;
        "><%= pending_count %></span>
      <% end %>
    <% end %>

    <%= link_to parent_global_tasks_path,
        class: "nav-item #{current_page?(parent_global_tasks_path) ? 'active' : ''}",
        title: "Missões",
        style: "display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: var(--r-md);" do %>
      <%= render Ui::Icon::Component.new("list-checks", size: 22) %>
      <span style="font-weight: 700; font-size: 14px;">Missões</span>
    <% end %>

    <%= link_to parent_rewards_path,
        class: "nav-item #{current_page?(parent_rewards_path) ? 'active' : ''}",
        title: "Loja",
        style: "display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: var(--r-md);" do %>
      <%= render Ui::Icon::Component.new("bag", size: 22) %>
      <span style="font-weight: 700; font-size: 14px;">Loja</span>
    <% end %>

    <%= link_to parent_profiles_path,
        class: "nav-item #{current_page?(parent_profiles_path) ? 'active' : ''}",
        title: "Filhos",
        style: "display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: var(--r-md);" do %>
      <%= render Ui::Icon::Component.new("users", size: 22) %>
      <span style="font-weight: 700; font-size: 14px;">Filhos</span>
    <% end %>
  </div>

  <%# Logout at bottom %>
  <div style="padding: var(--space-3); border-top: 1px solid var(--hairline); margin-top: var(--space-3);">
    <%= button_to sessions_path, method: :delete, class: "nav-item w-full",
        style: "display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: var(--r-md); width: 100%; text-align: left; background: transparent; border: none; cursor: pointer; color: var(--text-muted);",
        title: "Sair" do %>
      <%= render Ui::Icon::Component.new("logout", size: 22) %>
      <span style="font-weight: 700; font-size: 14px;">Sair</span>
    <% end %>
  </div>
</nav>

<div class="bottom-nav">
  <%
    nav_item = ->(icon_name, path, title) {
      active = current_page?(path)
      link_to path, class: "nav-item #{active ? 'active' : ''}", title: title do
        render Ui::Icon::Component.new(icon_name, size: 26)
      end
    }
  %>
  <%= nav_item.call("house", parent_root_path, "Início") %>

  <%= link_to parent_approvals_path,
      class: "nav-item #{current_page?(parent_approvals_path) ? 'active' : ''} relative",
      title: "Aprovações" do %>
    <%= render Ui::Icon::Component.new("clock", size: 26) %>
    <% if pending_count > 0 %>
      <span style="
        position: absolute;
        top: 6px; right: 6px;
        min-width: 16px; height: 16px;
        background: var(--c-peach);
        color: white;
        font-size: 10px;
        font-weight: 800;
        border-radius: var(--r-full);
        display: flex; align-items: center; justify-content: center;
        padding: 0 4px;
        line-height: 1;
      "><%= pending_count %></span>
    <% end %>
  <% end %>

  <%= nav_item.call("list-checks", parent_global_tasks_path, "Missões") %>
  <%= nav_item.call("bag", parent_rewards_path, "Loja") %>
</div>
