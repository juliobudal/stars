<%
  variant ||= "blue"
  colors = case variant
           when "warm" then ['var(--shape-warm-1)', 'var(--shape-warm-2)', 'var(--shape-warm-3)']
           when "cool" then ['var(--shape-cool-1)', 'var(--shape-cool-2)', 'var(--shape-cool-3)']
           else ['var(--shape-blue-1)', 'var(--shape-blue-2)', 'var(--shape-blue-3)']
           end
%>
<div class="bg-shape" style="top: -8%; right: -10%; width: 45%; height: 45%; background: <%= colors[0] %>"></div>
<div class="bg-shape" style="bottom: -12%; left: -8%; width: 50%; height: 50%; background: <%= colors[1] %>"></div>
<div class="bg-shape" style="top: 30%; left: 50%; width: 30%; height: 30%; background: <%= colors[2] %>; opacity: 0.35"></div>
