<%
  nav_items = [
    { icon: "target", path: kid_root_path,          label: "Jornada" },
    { icon: "bag",    path: kid_rewards_path,       label: "Lojinha" },
    { icon: "book",   path: kid_wallet_index_path,  label: "Diário"  },
  ]
%>

<nav class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-white rounded-[28px] px-6 py-3 flex items-center gap-8 z-40" style="box-shadow:0 4px 24px rgba(44,42,58,.14)">
  <% nav_items.each do |item| %>
    <% active = current_page?(item[:path]) %>
    <%= link_to item[:path], class: "flex flex-col items-center gap-1 #{active ? 'text-primary' : 'text-muted-foreground'}", title: item[:label] do %>
      <%= render Ui::Icon::Component.new(item[:icon], size: 22) %>
      <span class="text-[10px] font-display font-extrabold tracking-wider uppercase"><%= item[:label] %></span>
    <% end %>
  <% end %>
  <%= button_to sessions_path, method: :delete, class: "flex flex-col items-center gap-1 text-muted-foreground", title: "Sair" do %>
    <%= render Ui::Icon::Component.new("logout", size: 22) %>
    <span class="text-[10px] font-display font-extrabold tracking-wider uppercase">Sair</span>
  <% end %>
</nav>
