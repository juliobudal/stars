<div class="screen animate-slide-in flex flex-col items-center justify-center p-10">
  <div class="max-w-[430px] mx-auto px-5 pt-8 pb-12 flex flex-col items-center text-center relative z-[1] md:max-w-[768px] w-full">
    <%= render Ui::Heading::Component.new(size: :h1) do %>Recuperar senha<% end %>

    <% if flash[:notice] %>
      <p style="text-align:center;margin-bottom:1rem;color:var(--success);"><%= flash[:notice] %></p>
    <% end %>

    <%= form_with url: password_reset_path, method: :post, local: true,
        style: "display:flex;flex-direction:column;gap:0.75rem;max-width:360px;margin:0 auto;" do |f| %>
      <%= f.email_field :email, placeholder: "Seu email", required: true,
          style: "padding:var(--space-2);border:1px solid var(--hairline);border-radius:var(--r-sm);" %>
      <%= f.submit "Enviar instruções", style: "padding:var(--space-2);background:var(--primary);color:white;border:none;border-radius:var(--r-sm);cursor:pointer;" %>
    <% end %>

    <div style="text-align:center;margin-top:1rem;">
      <%= link_to "Voltar", root_path %>
    </div>
  </div>
</div>
