<div class="screen animate-slide-in flex flex-col items-center justify-center p-10">
  <div class="max-w-[430px] mx-auto px-5 pt-8 pb-12 flex flex-col items-center text-center relative z-[1] md:max-w-[768px] w-full">
    <%= render Ui::Heading::Component.new(size: :h1) do %>Recuperar senha<% end %>

    <% if flash[:notice] %>
      <p class="mb-4 font-bold" style="color: var(--success);"><%= flash[:notice] %></p>
    <% end %>

    <%= form_with url: password_reset_path, method: :post, local: true,
        class: "flex flex-col gap-3 max-w-[360px] w-full mx-auto mt-4" do |f| %>
      <%= f.email_field :email, placeholder: "Seu email", required: true,
          class: "w-full px-4 py-3 rounded-[14px] border-2 border-hairline bg-white text-[15px] font-bold focus:outline-none focus:border-primary" %>
      <%= render Ui::Btn::Component.new(variant: "primary", size: "md", type: "submit") do %>Enviar instruções<% end %>
    <% end %>

    <div class="mt-4 text-center">
      <%= link_to "Voltar", root_path, class: "text-[12px] font-extrabold uppercase tracking-[0.5px] no-underline", style: "color: var(--c-info-600);" %>
    </div>
  </div>
</div>
