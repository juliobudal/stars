<div class="screen animate-slide-in flex flex-col items-center justify-center p-10">
  <div class="max-w-[430px] mx-auto px-5 pt-8 pb-12 flex flex-col items-center text-center relative z-[1] md:max-w-[768px] w-full">
    <%= render Ui::Heading::Component.new(size: :h1) do %>Nova senha<% end %>

    <% if flash[:alert] %>
      <p style="color:var(--danger);text-align:center;margin-bottom:1rem;"><%= flash[:alert] %></p>
    <% end %>

    <%= form_with url: password_reset_path(token: @token), method: :patch, local: true,
        style: "display:flex;flex-direction:column;gap:0.75rem;max-width:360px;margin:0 auto;" do |f| %>
      <%= hidden_field_tag :token, @token %>
      <%= f.password_field :password, placeholder: "Nova senha (mín. 12 caracteres)", required: true,
          style: "padding:var(--space-2);border:1px solid var(--hairline);border-radius:var(--r-sm);" %>
      <%= f.password_field :password_confirmation, placeholder: "Confirmar nova senha", required: true,
          style: "padding:var(--space-2);border:1px solid var(--hairline);border-radius:var(--r-sm);" %>
      <%= f.submit "Salvar nova senha", style: "padding:var(--space-2);background:var(--primary);color:white;border:none;border-radius:var(--r-sm);cursor:pointer;" %>
    <% end %>
  </div>
</div>
