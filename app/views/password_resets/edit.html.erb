<div class="screen animate-slide-in flex flex-col items-center justify-center p-10">
  <div class="max-w-[430px] mx-auto px-5 pt-8 pb-12 flex flex-col items-center text-center relative z-[1] md:max-w-[768px] w-full">
    <div class="mb-6">
      <%= render Ui::Brand::Component.new(size: :md, tagline: "Nova senha") %>
    </div>
    <%= render Ui::Heading::Component.new(size: :h1) do %>Nova senha<% end %>

    <% if flash[:alert] %>
      <p role="alert" class="mb-4 font-bold" style="color: var(--danger);"><%= flash[:alert] %></p>
    <% end %>

    <div class="max-w-[360px] w-full mx-auto">
      <%= render Ui::FormErrors::Component.new(record: @family) %>
    </div>

    <%= form_with url: password_reset_path(token: @token), method: :patch, local: true,
        class: "flex flex-col gap-4 max-w-[360px] w-full mx-auto mt-4" do |f| %>
      <div class="form-field">
        <%= label_tag :password, "Nova senha", class: "form-label sr-only" %>
        <%= f.password_field :password, placeholder: "Nova senha", required: true,
            autocomplete: "new-password",
            class: "form-input" %>
        <p class="text-[12px] font-bold" style="color: var(--text-muted);">Mínimo 12 caracteres</p>
      </div>
      <div class="form-field">
        <%= label_tag :password_confirmation, "Confirmar nova senha", class: "form-label sr-only" %>
        <%= f.password_field :password_confirmation, placeholder: "Confirmar nova senha", required: true,
            autocomplete: "new-password",
            class: "form-input" %>
      </div>
      <%= render Ui::Btn::Component.new(variant: "primary", size: "md", type: "submit") do %>Salvar nova senha<% end %>
    <% end %>
  </div>
</div>
