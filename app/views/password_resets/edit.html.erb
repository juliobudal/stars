<div class="screen screen-enter relative">
  <%= render Ui::BgShapes::Component.new(variant: "cool") %>

  <div class="relative z-2 flex flex-col items-center justify-center p-10 pt-12">
    <%# Brand lockup %>
    <div class="mb-6">
      <%= render Ui::Brand::Component.new(size: :md, tagline: "Nova senha") %>
    </div>

    <h1 class="text-[26px] font-extrabold mb-1 text-center" style="color: var(--text);">
      Nova senha
    </h1>
    <p class="mb-6 text-[14px] font-bold text-center max-w-[360px]" style="color: var(--text-muted);">
      Escolhe uma senha nova pra entrar
    </p>

    <% if flash[:alert] %>
      <p role="alert" class="mb-4 font-bold" style="color: var(--danger);"><%= flash[:alert] %></p>
    <% end %>

    <div class="w-full max-w-[360px]">
      <%= render Ui::FormErrors::Component.new(record: @family) %>
    </div>

    <%# Form anchored in card %>
    <div class="ls-card-3d w-full max-w-[360px]"
         style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 16px; padding: 20px; box-shadow: var(--shadow-card);">
      <%= form_with url: password_reset_path(token: @token), method: :patch, local: true,
          class: "flex flex-col gap-4" do |f| %>
        <div class="form-field">
          <%= label_tag :password, "Nova senha", class: "form-label sr-only" %>
          <%= f.password_field :password, placeholder: "Nova senha", required: true,
              autocomplete: "new-password",
              class: "form-input" %>
          <p class="text-[12px] font-bold" style="color: var(--text-muted);">Mínimo 12 caracteres</p>
        </div>
        <div class="form-field">
          <%= label_tag :password_confirmation, "Confirmar nova senha", class: "form-label sr-only" %>
          <%= f.password_field :password_confirmation, placeholder: "Confirmar nova senha", required: true,
              autocomplete: "new-password",
              class: "form-input" %>
        </div>
        <%= render Ui::Btn::Component.new(variant: "primary", size: "md", type: "submit") do %>Salvar nova senha<% end %>
      <% end %>
    </div>
  </div>
</div>
