<div class="screen flex flex-col items-center justify-start p-10 pt-12">
  <div class="flex items-center gap-3 mb-2">
    <div class="w-12 h-12 grid place-items-center rounded-[14px]" style="background: var(--star); box-shadow: 0 4px 0 var(--star-2);">
      <%= render Ui::Icon::Component.new("star", size: 26, color: "white") %>
    </div>
    <div class="text-[22px] font-extrabold leading-none" style="color: var(--text);">LittleStars</div>
  </div>

  <h1 class="mt-6 mb-1.5 text-[28px] font-extrabold text-center" style="color: var(--text);">Quem é você?</h1>
  <p class="mb-9 text-[14px] font-bold text-center" style="color: var(--text-muted);">Toque no seu rostinho pra entrar</p>

  <%= render Ui::ProfilePicker::Component.new(profiles: @profiles, selected: @selected_profile) %>
</div>
