<div class="screen screen-enter relative">
  <%= render Ui::BgShapes::Component.new(variant: "warm") %>

  <div class="relative z-2 flex flex-col items-center justify-start p-10 pt-10">
    <%# Brand lockup %>
    <div class="mb-6">
      <%= render Ui::Brand::Component.new(size: :md, tagline: "Bora começar!") %>
    </div>

    <%# Mascot — bounces in %>
    <% mascot_kid = @profiles&.first %>
    <% if mascot_kid %>
      <div class="ls-mascot-bounce mb-4">
        <%= render Ui::SmileyAvatar::Component.new(kid: mascot_kid, size: 96) %>
      </div>
    <% end %>

    <%# Hero %>
    <h1 class="font-display text-[26px] font-extrabold tracking-[-0.01em] text-center mb-1.5"
        style="color: var(--text);">Quem é você?</h1>
    <p class="mb-8 text-[14px] font-bold text-center" style="color: var(--text-muted);">
      Toque no seu rostinho pra entrar
    </p>

    <%= render Ui::ProfilePicker::Component.new(profiles: @profiles, selected: @selected_profile) %>
  </div>
</div>
