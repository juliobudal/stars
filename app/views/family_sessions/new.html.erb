<div class="screen flex flex-col items-center justify-center p-10">
  <div class="flex items-center gap-3 mb-6">
    <div class="w-12 h-12 grid place-items-center rounded-[14px]" style="background: var(--star); box-shadow: 0 4px 0 var(--star-2);">
      <%= render Ui::Icon::Component.new("star", size: 26, color: "#fff") %>
    </div>
    <div class="text-[22px] font-extrabold leading-none" style="color: var(--text);">LittleStars</div>
  </div>

  <h1 class="text-[26px] font-extrabold mb-6" style="color: var(--text);">Entrar na família</h1>

  <% if flash[:alert] %>
    <p class="text-destructive mb-4 font-bold"><%= flash[:alert] %></p>
  <% end %>

  <%= form_with url: family_session_path, method: :post, local: true,
                class: "flex flex-col gap-3 max-w-[320px] w-full" do |f| %>
    <%= f.email_field :email, placeholder: "Email da família", required: true,
        class: "w-full px-4 py-3 rounded-[14px] border-2 border-hairline bg-white text-[15px] font-bold focus:outline-none focus:border-primary" %>
    <%= f.password_field :password, placeholder: "Senha", required: true,
        class: "w-full px-4 py-3 rounded-[14px] border-2 border-hairline bg-white text-[15px] font-bold focus:outline-none focus:border-primary" %>
    <%= render Ui::Btn::Component.new(variant: "primary", size: "md", type: "submit") do %>
      Entrar
    <% end %>
  <% end %>

  <div class="text-center mt-4 text-sm flex items-center gap-2 font-bold">
    <%= link_to "Criar família", new_registration_path, class: "text-primary uppercase tracking-[0.5px] text-[12px] font-extrabold no-underline" %>
    <span style="color: var(--text-soft);">·</span>
    <%= link_to "Esqueci a senha", new_password_reset_path, class: "text-primary uppercase tracking-[0.5px] text-[12px] font-extrabold no-underline" %>
  </div>
</div>
