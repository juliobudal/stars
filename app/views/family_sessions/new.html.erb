<div class="screen screen-enter relative">
  <%= render Ui::BgShapes::Component.new(variant: "cool") %>

  <div class="relative z-2 flex flex-col items-center justify-center p-10 pt-12">
    <%# Brand lockup %>
    <div class="mb-6">
      <%= render Ui::Brand::Component.new(size: :lg, tagline: "Família LittleStars") %>
    </div>

    <%# Greeting copy %>
    <h1 class="text-[26px] font-extrabold mb-1 text-center" style="color: var(--text);">
      Bem-vindo de volta!
    </h1>
    <p class="mb-6 text-[14px] font-bold text-center" style="color: var(--text-muted);">
      Entra pra acompanhar as missões
    </p>

    <% if flash[:alert] %>
      <p class="text-destructive mb-4 font-bold"><%= flash[:alert] %></p>
    <% end %>

    <%# Form anchored in card %>
    <div class="ls-card-3d w-full max-w-[360px]"
         style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 16px; padding: 20px; box-shadow: var(--shadow-card);">
      <%= form_with url: family_session_path, method: :post, local: true,
                    class: "flex flex-col gap-3" do |f| %>
        <%= f.email_field :email, placeholder: "Email da família", required: true,
            "aria-label": "Email da família",
            class: "w-full px-4 py-3 rounded-[14px] border-2 border-hairline bg-white text-[15px] font-bold focus:outline-none focus:border-primary" %>
        <%= f.password_field :password, placeholder: "Senha", required: true,
            "aria-label": "Senha",
            class: "w-full px-4 py-3 rounded-[14px] border-2 border-hairline bg-white text-[15px] font-bold focus:outline-none focus:border-primary" %>
        <%= render Ui::Btn::Component.new(variant: "primary", size: "md", type: "submit") do %>
          Entrar
        <% end %>
      <% end %>
    </div>

    <%# Footer links %>
    <div class="text-center mt-5 flex items-center gap-2.5 font-bold">
      <%= link_to "Criar família", new_registration_path,
                  class: "text-primary uppercase tracking-[0.5px] text-[12px] font-extrabold no-underline" %>
      <span style="color: var(--text-soft);">·</span>
      <%= link_to "Esqueci a senha", new_password_reset_path,
                  class: "text-primary uppercase tracking-[0.5px] text-[12px] font-extrabold no-underline" %>
    </div>
  </div>
</div>
