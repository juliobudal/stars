<% content_for(:title) { "Editar lente · #{@row.concept.name} · #{@row.lens_type}" } %>

<div class="screen no-nav">
  <div class="mb-4">
    <%= link_to "← Voltar", admin_academy_lenses_path, class: "font-display text-[12px]", style: "color: var(--text-muted);" %>
  </div>

  <h1 class="font-display text-[20px] font-extrabold leading-tight mb-1 m-0" style="color: var(--text);">
    <%= @row.concept.name %> · <%= @row.lens_type.tr('_', ' ') %>
  </h1>
  <div class="font-display text-[11px] mb-4" style="color: var(--text-muted);">
    <%= @row.template_version %> · <%= @row.locale %> · <%= @row.age_band %>
  </div>

  <% if @row.errors.any? %>
    <div class="rounded-2xl p-3 mb-3"
         style="background: color-mix(in oklab, var(--c-danger) 12%, var(--surface)); border: 2px solid var(--c-danger);">
      <% @row.errors.full_messages.each do |m| %>
        <div class="font-display text-[12px]" style="color: var(--c-danger);"><%= m %></div>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: @row, url: admin_academy_lens_path(@row), method: :patch, scope: :lens_cache, local: true do |f| %>
    <label class="font-display text-[12px] font-extrabold tracking-[1px] uppercase mb-2 block"
           style="color: var(--text-muted);">
      Payload JSON (override)
    </label>
    <%= f.text_area :payload, value: JSON.pretty_generate(@row.payload),
                    rows: 24,
                    class: "w-full p-3 rounded-2xl font-mono text-[12px]",
                    style: "background: var(--surface); border: 2px solid var(--hairline); color: var(--text);" %>
    <p class="font-display text-[11px] mt-2 mb-4" style="color: var(--text-muted);">
      Edite o JSON acima para sobrescrever o output da LLM. Deve seguir o schema definido em
      <code>app/services/academy/lens/schemas/<%= @row.lens_type %>.json</code>.
    </p>

    <%= f.submit "Salvar override", class: "px-5 py-3 rounded-2xl font-display font-extrabold text-[14px]",
                 style: "background: var(--c-primary); color: white; box-shadow: 0 4px 0 var(--primary-2); border: none;" %>
  <% end %>
</div>
