<% content_for(:title) { @mission.title } %>

<div class="px-4 sm:px-6 py-6 max-w-3xl mx-auto">
  <%= link_to "← voltar à lista", admin_academy_missions_path,
              class: "inline-block mb-3 font-extrabold text-[12px]", style: "color: var(--c-primary-dark);" %>
  <h1 class="font-display text-[20px] font-extrabold m-0 mb-3" style="color: var(--text);">
    <%= @mission.title %>
  </h1>

  <p class="text-[14px] font-bold leading-snug mb-3" style="color: var(--text);">
    <strong>Área:</strong> <%= @mission.subject.name %><br>
    <strong>Conceito:</strong> <code><%= @mission.concept&.name %></code><br>
    <strong>Ativa:</strong> <%= @mission.active? ? "sim" : "·" %>
  </p>

  <%= link_to "editar →", edit_admin_academy_mission_path(@mission),
              class: "inline-block px-4 py-2 rounded-lg font-extrabold text-[13px]",
              style: "background: var(--primary); color: white; box-shadow: 0 3px 0 var(--primary-2);" %>
</div>
