<div class="screen flex flex-col items-center p-10">
  <div class="mb-6">
    <%= render Ui::Brand::Component.new(size: :md, tagline: "Convite recebido") %>
  </div>
  <h1 class="text-[26px] font-extrabold mb-6" style="color: var(--text);">Aceitar convite</h1>
  <p class="mb-6 text-center max-w-[400px] font-bold" style="color: var(--text-muted);">
    Você foi convidado para se juntar à família
    <strong style="color: var(--text);"><%= @invitation.family.name %></strong>.
  </p>
  <%= button_to "Aceitar convite", accept_invitation_path(token: @invitation.token), method: :post,
                class: "px-5 py-3 rounded-[14px] text-white text-[14px] font-extrabold uppercase tracking-[0.5px] cursor-pointer border-2",
                style: "background: var(--primary); border-color: var(--primary); box-shadow: 0 4px 0 var(--primary-2);" %>
</div>
