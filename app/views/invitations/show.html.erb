<div class="screen flex flex-col items-center p-10">
  <h1 class="font-display text-[28px] font-extrabold mb-6">Aceitar convite</h1>
  <p class="mb-4">
    Você foi convidado para se juntar à família
    <strong><%= @invitation.family.name %></strong>.
  </p>
  <%= button_to "Aceitar convite", accept_invitation_path(token: @invitation.token), method: :post,
                class: "px-4 py-2 rounded-md bg-primary text-white font-bold" %>
</div>
