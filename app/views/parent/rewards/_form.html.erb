<%= form_with(model: [:parent, reward], class: "col", style: "gap: 20px;") do |f| %>
  <% if reward.errors.any? %>
    <%= render Ui::Card::Component.new(variant: "flat", class: "bg-danger-soft text-danger p-4 mb-4") do %>
      <h3 class="h-display" style="font-size: 18px;">Ops! Algo deu errado:</h3>
      <ul class="subtitle" style="font-size: 14px; list-style: disc; margin-left: 20px;">
        <% reward.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%
    icon_options = %w[iceCream gamepad ferris blocks pizza film moon bookSolid gift heart]
  %>

  <div class="center mb-4">
    <div style="width: 100px; height: 100px; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center;">
      <%= render Ui::Icon::Component.new(reward.icon.presence || "gift", size: 58, color: "white") %>
    </div>
  </div>

  <div class="form-field">
    <%= f.label :title, "Nome da Recompensa", class: "form-label" %>
    <%= f.text_field :title, class: "form-input", placeholder: "Ex: Sorvete de chocolate" %>
  </div>

  <div class="form-field">
    <%= f.label :cost, "Custo (⭐)", class: "form-label" %>
    <%= f.number_field :cost, class: "form-input" %>
  </div>

  <div class="form-field">
    <%= f.label :category, "Categoria", class: "form-label" %>
    <%= f.select :category,
          Reward.categories.keys.map { |k| [Ui::Tokens.reward_category_for(k)[:label].capitalize, k] },
          {}, class: "form-select" %>
  </div>

  <div class="form-field">
    <label class="form-label">Ícone</label>
    <div class="row wrap" style="gap: 6px;">
      <% icon_options.each do |ic| %>
        <label class="cursor-pointer">
          <%= f.radio_button :icon, ic, class: "peer sr-only" %>
          <div class="peer-checked:bg-primary-soft peer-checked:border-primary border-2 border-transparent p-2 rounded-xl transition-all" style="width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: white; border: 2px solid rgba(26,42,74,0.1);">
            <%= render Ui::Icon::Component.new(ic, size: 24, color: "var(--primary)") %>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <div class="row mt-4" style="gap: 10px; justify-content: flex-end;">
    <%= link_to "Voltar", parent_rewards_path, class: "btn btn-secondary" %>
    <%= f.submit "Salvar Recompensa", class: "btn btn-primary" %>
  </div>
<% end %>
