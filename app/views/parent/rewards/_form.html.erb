<%= form_with(model: [:parent, reward], html: { data: { controller: "form-preview" } }, class: "block") do |f| %>
  <%= render Ui::FormErrors::Component.new(record: reward) %>

  <% current_icon = reward.icon.presence || Ui::IconPicker::Component::CONTEXT_GROUPS[:reward].first %>

  <div class="grid grid-cols-1 gap-[18px] max-w-[720px]">

    <%# ─── Título ─── %>
    <%= render Ui::FormSection::Component.new do %>
      <%= f.label :title,
            "Nome do prêmio",
            class: "block text-[12px] font-extrabold uppercase tracking-[0.5px] mb-[10px]",
            style: "color: var(--text-muted);" %>
      <%= f.text_field :title,
            class: "form-input w-full px-4 py-[14px] rounded-[14px] border-2 border-hairline font-bold text-[15px] outline-none box-border",
            style: "color: var(--text); font-family: inherit;",
            placeholder: "Ex: Sorvete de chocolate",
            data: { form_preview_field: "title" } %>
      <div class="text-[11px] font-bold mt-2" style="color: var(--text-muted);">
        Use frases curtas que a criança entenda.
      </div>
    <% end %>

    <%# ─── Ícone ─── %>
    <%= render Ui::FormSection::Component.new(title: "Escolha um ícone") do %>
      <%= render Ui::IconPicker::Component.new(
            field_name: "reward[icon]",
            value: current_icon,
            context: :reward,
            color: "var(--primary)",
            id: "reward_icon_picker",
            input_data: { form_preview_field: "icon" }
          ) %>
    <% end %>

    <%# ─── Custo ─── %>
    <%= render Ui::FormSection::Component.new do %>
      <%= f.label :cost,
            class: "flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.5px] mb-[10px]",
            style: "color: var(--text-muted);" do %>
        <%= render Ui::Icon::Component.new(:star, size: 14, color: "var(--star)") %>
        Quantas estrelinhas custa?
      <% end %>
      <%= f.number_field :cost,
            class: "form-input w-full px-4 py-[14px] rounded-[14px] border-2 border-hairline font-bold text-[15px] outline-none box-border",
            style: "color: var(--text); font-family: inherit;",
            min: 1,
            placeholder: "Ex: 10",
            data: { form_preview_field: "cost" } %>
    <% end %>

    <%# ─── Categoria ─── %>
    <%= render Ui::FormSection::Component.new do %>
      <%= f.label :category_id,
            "Categoria",
            class: "block text-[12px] font-extrabold uppercase tracking-[0.5px] mb-[12px]",
            style: "color: var(--text-muted);" %>
      <%= render Ui::Select::Component.new(
            name: "reward[category_id]",
            id: "reward_category_id",
            options: @categories.map { |c| [c.name, c.id] },
            selected: reward.category_id,
            size: :lg
          ) %>
    <% end %>

    <%# ─── Action bar ─── %>
    <div class="flex flex-row justify-end gap-[10px] py-1">
      <%= render Ui::Btn::Component.new(variant: "secondary", url: parent_rewards_path) do %>
        Cancelar
      <% end %>
      <%= render Ui::Btn::Component.new(variant: "primary", type: "submit") do %>
        <%= render Ui::Icon::Component.new("check", size: 14, color: "currentColor") %>
        Salvar prêmio
      <% end %>
    </div>
  </div>
<% end %>
