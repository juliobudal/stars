<%= form_with(model: [:parent, reward], class: "col gap-5") do |f| %>
  <% if reward.errors.any? %>
    <%= render Ui::Card::Component.new(variant: "flat", class: "bg-danger-soft text-danger p-4 mb-4") do %>
      <h3 class="font-display text-[32px] leading-[1.1] font-extrabold tracking-[-0.02em] text-foreground text-[18px]">Ops! Algo deu errado:</h3>
      <ul class="text-[17px] text-muted-foreground font-semibold text-[14px] list-disc ml-5">
        <% reward.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%
    icon_options = %w[iceCream gamepad ferris blocks pizza film moon bookSolid gift heart]
  %>

  <div class="flex items-center justify-center mb-4">
    <div class="flex items-center justify-center w-[100px] h-[100px] rounded-full bg-primary">
      <%= render Ui::Icon::Component.new(reward.icon.presence || "gift", size: 58, color: "white") %>
    </div>
  </div>

  <div class="mb-6 flex flex-col gap-2">
    <%= f.label :title, "Nome da Recompensa", class: "font-display font-extrabold text-[15px] text-foreground tracking-tight" %>
    <%= f.text_field :title, class: "w-full px-5 py-4 bg-white border-2 border-hairline rounded-2xl font-semibold text-[17px] text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-0 transition-all shadow-sm", placeholder: "Ex: Sorvete de chocolate" %>
  </div>

  <div class="mb-6 flex flex-col gap-2">
    <%= f.label :cost, class: "font-display font-extrabold text-[15px] text-foreground tracking-tight" do %>Custo (<%= render Ui::Icon::Component.new(:star, size: 14, color: "var(--color-amber-dark)") %>)<% end %>
    <%= f.number_field :cost, class: "w-full px-5 py-4 bg-white border-2 border-hairline rounded-2xl font-semibold text-[17px] text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-0 transition-all shadow-sm" %>
  </div>

  <div class="mb-6 flex flex-col gap-2">
    <%= f.label :category, "Categoria", class: "font-display font-extrabold text-[15px] text-foreground tracking-tight" %>
    <%= f.select :category,
          Reward.categories.keys.map { |k| [Ui::Tokens.reward_category_for(k)[:label].capitalize, k] },
          {}, class: "w-full px-5 py-4 bg-white border-2 border-hairline rounded-2xl font-semibold text-[17px] text-foreground focus:border-primary focus:ring-0 transition-all shadow-sm appearance-none" %>
  </div>

  <div class="mb-6 flex flex-col gap-2">
    <label class="font-display font-extrabold text-[15px] text-foreground tracking-tight">Ícone</label>
    <div class="row flex-wrap gap-1.5">
      <% icon_options.each do |ic| %>
        <label class="cursor-pointer">
          <%= f.radio_button :icon, ic, class: "peer sr-only" %>
          <div class="peer-checked:bg-primary-soft peer-checked:border-primary border-2 border-[rgba(26,42,74,0.1)] p-2 rounded-xl transition-all flex items-center justify-center w-11 h-11 bg-white">
            <%= render Ui::Icon::Component.new(ic, size: 24, color: "var(--primary)") %>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <div class="row mt-4 gap-2.5 justify-end">
    <%= render Ui::Btn::Component.new(variant: "secondary", url: parent_rewards_path) do %>Voltar<% end %>
    <%= render Ui::Btn::Component.new(variant: "primary", type: "submit") do %>Salvar Recompensa<% end %>
  </div>
<% end %>
