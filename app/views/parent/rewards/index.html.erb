<div class="page-enter">

  <%# ─── Header ─── %>
  <%= render Ui::PageHeader::Component.new(
        title: "Prêmios",
        subtitle: "#{@rewards.size} #{@rewards.size == 1 ? 'prêmio' : 'prêmios'} · precificados em estrelinhas"
      ) do |h| %>
    <% h.with_right_slot do %>
      <%= render Ui::Btn::Component.new(variant: "primary", url: new_parent_reward_path) do %>
        <%= render Ui::Icon::Component.new("plus", size: 14, color: "currentColor") %>
        Novo prêmio
      <% end %>
    <% end %>
  <% end %>

  <% unless @rewards.empty? %>
    <%
      chip_items = [{ id: "all", label: "Todos" }]
      @categories.each do |category|
        chip_items << { id: category.id.to_s, label: category.name }
      end
    %>
    <div data-controller="filter-tabs">
      <div class="mb-[20px]">
        <%= render Ui::FilterChips::Component.new(items: chip_items, active: "all", controller: "filter-tabs") %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-[14px]">
        <% @rewards.each do |reward| %>
          <div data-filter-tabs-target="item" data-panels="all <%= reward.category_id %>">
            <%= render Ui::RewardCatalogCard::Component.new(reward: reward) %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @rewards.empty? %>
    <div class="mt-4">
      <%= render Ui::Empty::Component.new(
        icon: "gift",
        title: "Loja vazia",
        subtitle: "Adicione recompensas para motivar seus filhos!",
        color: "rose"
      ) do %>
        <%= render Ui::Btn::Component.new(variant: "primary", size: "sm", url: new_parent_reward_path) do %>
          + Novo prêmio
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
