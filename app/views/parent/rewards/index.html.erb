<div class="screen screen-enter-right with-nav">
  <%= render Ui::BgShapes::Component.new(variant: "warm") %>

  <%= render Ui::TopBar::Component.new(
    title: "Lojinha",
    subtitle: "Catálogo de recompensas da família",
    back_url: parent_root_path
  ) do |bar| %>
    <% bar.with_right_slot do %>
      <%= link_to new_parent_reward_path, class: "btn btn-primary" do %>
        <%= render Ui::Icon::Component.new("plus", size: 18, color: "white") %> Nova
      <% end %>
    <% end %>
  <% end %>

  <div class="grid-2" style="gap: 12px; z-index: 2;">
    <% if @rewards.any? %>
      <% @rewards.each_with_index do |s, i| %>
        <% 
          color_idx = i % 6
          color_options = %w[peach rose mint sky lilac coral]
          color = color_options[color_idx]
          fg_var = "var(--c-#{color})"
        %>
        <div class="card pop-on-tap card-tap" style="padding: 16px; border: 2px solid <%= fg_var %>; box-shadow: 0 4px 0 <%= fg_var %>; text-align: center; animation: slideInCard 0.35s ease <%= i * 0.03 %>s both;">
          <div style="width: 64px; height: 64px; border-radius: 50%; background: <%= fg_var %>; margin: 0 auto 10px; display: flex; align-items: center; justify-content: center;">
            <%= render Ui::Icon::Component.new(s.icon.presence || "gift", size: 36, color: "white") %>
          </div>
          <div class="h-display" style="font-size: 15px;"><%= s.title %></div>
          <%= render Ui::Badge::Component.new(variant: "star", style: "font-size: 13px; padding: 5px 12px; margin-top: 8px;") do %>
            <%= render Ui::Icon::Component.new("star", size: 13, color: "var(--star-2)") %> <%= s.cost %>
          <% end %>
          <div class="row" style="gap: 8px; margin-top: 12px; justify-content: center;">
            <%= button_to parent_reward_path(s), method: :delete, class: "btn btn-ghost btn-sm", style: "color: var(--danger);", data: { turbo_confirm: "Remover a recompensa \"#{s.title}\"?" } do %>
              <%= render Ui::Icon::Component.new("trash", size: 16) %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="col-span-2">
        <%= render Ui::Empty::Component.new(
          icon: "gift",
          title: "Loja vazia",
          subtitle: "Adicione recompensas para motivar seus filhos!",
          color: "rose"
        ) %>
      </div>
    <% end %>
  </div>
</div>
