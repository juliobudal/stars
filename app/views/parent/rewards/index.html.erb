<div class="screen screen-enter with-nav">

  <%# ─── Header ─── %>
  <div class="flex items-start justify-between gap-4 mb-[22px] z-content shrink-0">
    <div class="min-w-0">
      <h1 class="text-[26px] font-extrabold leading-tight m-0 mb-1" style="color: var(--text);">
        Prêmios
      </h1>
      <p class="text-[14px] font-bold m-0" style="color: var(--text-muted);">
        <%= @rewards.size %> <%= @rewards.size == 1 ? "prêmio" : "prêmios" %> · precificados em estrelinhas
      </p>
    </div>
    <%= link_to new_parent_reward_path,
          class: "ls-btn-3d inline-flex items-center gap-2 px-5 py-3 rounded-[14px] text-white text-[14px] font-extrabold uppercase tracking-[0.5px] no-underline border-2 shrink-0",
          style: "background: var(--primary); border-color: var(--primary); box-shadow: 0 4px 0 var(--primary-2);" do %>
      <%= render Ui::Icon::Component.new("plus", size: 14, color: "currentColor") %>
      Novo prêmio
    <% end %>
  </div>

  <% unless @rewards.empty? %>
    <%
      chip_items = [{ id: "all", label: "Todos" }]
      @categories.each do |category|
        chip_items << { id: category.id.to_s, label: category.name }
      end
    %>
    <div data-controller="filter-tabs">
      <div class="mb-[20px] z-content">
        <%= render Ui::FilterChips::Component.new(items: chip_items, active: "all", controller: "filter-tabs") %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-[14px] z-content">
        <% @rewards.each do |reward| %>
          <div data-filter-tabs-target="item" data-panels="all <%= reward.category_id %>">
            <%= render Ui::RewardCatalogCard::Component.new(reward: reward) %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @rewards.empty? %>
    <div class="mt-4 z-content">
      <%= render Ui::Empty::Component.new(
        icon: "gift",
        title: "Loja vazia",
        subtitle: "Adicione recompensas para motivar seus filhos!",
        color: "rose"
      ) do %>
        <%= render Ui::Btn::Component.new(variant: "primary", size: "sm", url: new_parent_reward_path) do %>
          + Novo prêmio
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
