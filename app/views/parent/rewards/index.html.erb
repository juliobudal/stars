<div class="screen screen-enter-right with-nav" data-controller="tabs">
  <%= render Ui::BgShapes::Component.new(variant: "warm") %>

  <%= render Ui::TopBar::Component.new(
    title: "Prêmios da lojinha",
    subtitle: "#{@rewards.size} #{@rewards.size == 1 ? "prêmio" : "prêmios"} · precificados em estrelas",
  ) do |bar| %>
    <% bar.with_right_slot do %>
      <%= render Ui::Btn::Component.new(variant: "primary", size: "sm", url: new_parent_reward_path) do %>
        <%= render Ui::Icon::Component.new("plus", size: 16, color: "white") %> Novo prêmio
      <% end %>
    <% end %>
  <% end %>

  <% unless @rewards.empty? %>
    <%
      chip_items = [{ id: "all", label: "Todos" }]
      Ui::Tokens::REWARD_CATEGORIES.each do |key, meta|
        chip_items << { id: key, label: meta[:label].capitalize }
      end
    %>
    <div class="mb-3.5 z-2">
      <%= render Ui::FilterChips::Component.new(items: chip_items, active: "all") %>
    </div>

    <div class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-[clamp(14px,2vw,28px)] z-2 mt-1">
      <% @rewards.each do |reward| %>
        <%= render Ui::RewardCatalogCard::Component.new(reward: reward) %>
      <% end %>

      <%= link_to new_parent_reward_path, class: "ghost-add-card", data: { panels: "all" } do %>
        <div class="w-9 h-9 rounded-full bg-surface-2 flex items-center justify-center">
          <%= render Ui::Icon::Component.new("plus", size: 18, color: "currentColor") %>
        </div>
        <span class="font-display text-[32px] leading-[1.1] font-extrabold tracking-[-0.02em] text-foreground text-[13px]">Novo prêmio</span>
      <% end %>
    </div>
  <% end %>

  <% if @rewards.empty? %>
    <div class="mt-4 z-2">
      <%= render Ui::Empty::Component.new(
        icon: "gift",
        title: "Loja vazia",
        subtitle: "Adicione recompensas para motivar seus filhos!",
        color: "rose"
      ) %>
    </div>
  <% end %>
</div>

<script>
  (function(){
    document.addEventListener("click", function(e){
      const btn = e.target.closest(".screen .tab[data-tabs-id-param]");
      if (!btn) return;
      const scope = btn.closest(".screen");
      if (!scope) return;
      const key = btn.dataset.tabsIdParam;
      scope.querySelectorAll(".tab").forEach(t => t.classList.toggle("active", t === btn));
      scope.querySelectorAll(".reward-catalog-card, .ghost-add-card").forEach(card => {
        const panels = (card.dataset.panels || "all").split(/\s+/);
        card.style.display = (key === "all" || panels.includes(key)) ? "" : "none";
      });
    });
  })();
</script>
