<div class="page-enter">

  <%# ─── Header ─── %>
  <%= render Ui::PageHeader::Component.new(
        title: "Categorias",
        subtitle: "#{@categories.size} #{@categories.size == 1 ? 'categoria' : 'categorias'} · organize seus prêmios em grupos"
      ) do |h| %>
    <% h.with_right_slot do %>
      <%= render Ui::Btn::Component.new(variant: "primary", url: new_parent_category_path) do %>
        <%= render Ui::Icon::Component.new("plus", size: 14, color: "currentColor") %>
        Nova categoria
      <% end %>
    <% end %>
  <% end %>

  <% reward_counts = Reward.where(family_id: current_profile.family_id).group(:category_id).count %>

  <% if @categories.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-[14px]">
      <% @categories.each do |category| %>
        <%= render Ui::CategoryRow::Component.new(category: category, reward_count: reward_counts[category.id].to_i) %>
      <% end %>
    </div>
  <% else %>
    <%= render Ui::Empty::Component.new(
      icon: "bookmark-01",
      title: "Nenhuma categoria",
      subtitle: "Crie categorias para agrupar seus prêmios.",
      color: "lilac"
    ) do %>
      <%= render Ui::Btn::Component.new(variant: "primary", size: "sm", url: new_parent_category_path) do %>
        + Criar categoria
      <% end %>
    <% end %>
  <% end %>
</div>
