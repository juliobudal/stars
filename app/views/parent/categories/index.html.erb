<div class="screen screen-enter with-nav">

  <%# ─── Header ─── %>
  <div class="flex items-start justify-between gap-4 mb-[22px] z-content shrink-0">
    <div class="min-w-0">
      <h1 class="text-[26px] font-extrabold leading-tight m-0 mb-1" style="color: var(--text);">
        Categorias
      </h1>
      <p class="text-[14px] font-bold m-0" style="color: var(--text-muted);">
        <%= @categories.size %> <%= @categories.size == 1 ? "categoria" : "categorias" %> · organize seus prêmios em grupos
      </p>
    </div>
    <%= link_to new_parent_category_path,
          class: "ls-btn-3d inline-flex items-center gap-2 px-5 py-3 rounded-[14px] text-white text-[14px] font-extrabold uppercase tracking-[0.5px] no-underline border-2 shrink-0",
          style: "background: var(--primary); border-color: var(--primary); box-shadow: 0 4px 0 var(--primary-2);" do %>
      <%= render Ui::Icon::Component.new("plus", size: 14, color: "currentColor") %>
      Nova categoria
    <% end %>
  </div>

  <% reward_counts = Reward.where(family_id: current_profile.family_id).group(:category_id).count %>

  <% if @categories.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-[14px] z-content">
      <% @categories.each do |category| %>
        <%= render Ui::CategoryRow::Component.new(category: category, reward_count: reward_counts[category.id].to_i) %>
      <% end %>
    </div>
  <% else %>
    <%= render Ui::Empty::Component.new(
      icon: "bookmark-01",
      title: "Nenhuma categoria",
      subtitle: "Crie categorias para agrupar seus prêmios.",
      color: "lilac"
    ) do %>
      <%= render Ui::Btn::Component.new(variant: "primary", size: "sm", url: new_parent_category_path) do %>
        + Criar categoria
      <% end %>
    <% end %>
  <% end %>
</div>
