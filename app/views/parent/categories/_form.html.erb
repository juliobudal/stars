<%= form_with(model: [:parent, category], class: "block") do |f| %>
  <%= render Ui::FormErrors::Component.new(record: category) %>

  <div class="grid grid-cols-1 gap-[18px] max-w-[720px]">

    <%# ─── Nome ─── %>
    <%= render Ui::FormSection::Component.new do %>
      <%= f.label :name,
            "Nome da categoria",
            class: "block text-[12px] font-extrabold uppercase tracking-[0.5px] mb-[10px]",
            style: "color: var(--text-muted);" %>
      <%= f.text_field :name,
            class: "form-input w-full px-4 py-[14px] rounded-[14px] border-2 border-hairline font-bold text-[15px] outline-none box-border",
            style: "color: var(--text); font-family: inherit;",
            placeholder: "Ex: Música" %>
    <% end %>

    <%# ─── Ícone ─── %>
    <%= render Ui::FormSection::Component.new(title: "Escolha um ícone") do %>
      <%= render Ui::IconPicker::Component.new(
            field_name: "category[icon]",
            value: category.icon.presence || "bookmark-01",
            context: :reward,
            color: "var(--primary)",
            id: "category_icon_picker"
          ) %>
    <% end %>

    <%# ─── Cor ─── %>
    <%= render Ui::FormSection::Component.new(title: "Cor da categoria") do %>
      <%= render Ui::ColorSwatchPicker::Component.new(
            field_name: "category[color]",
            value: category.color.presence || "lilac"
          ) %>
    <% end %>

    <%# ─── Action bar ─── %>
    <div class="flex flex-row justify-end gap-[10px] py-1">
      <%= link_to parent_categories_path,
            class: "ls-btn-3d inline-flex items-center px-[22px] py-3 rounded-[14px] text-[13px] font-extrabold uppercase tracking-[0.5px] no-underline border-2",
            style: "background: var(--surface); color: var(--text-muted); border-color: var(--hairline); box-shadow: 0 4px 0 var(--hairline);" do %>
        Cancelar
      <% end %>
      <button type="submit"
              class="ls-btn-3d inline-flex items-center gap-2 px-[26px] py-3 rounded-[14px] text-white text-[13px] font-extrabold uppercase tracking-[0.5px] border-2 cursor-pointer"
              style="background: var(--primary); border-color: var(--primary); box-shadow: 0 4px 0 var(--primary-2); font-family: inherit;">
        <%= render Ui::Icon::Component.new("check", size: 14, color: "currentColor") %>
        Salvar categoria
      </button>
    </div>
  </div>
<% end %>
