<%= render Ui::Card::Component.new(padding: "p-5") do %>
  <%= render Ui::Heading::Component.new(size: :h3, class: "mb-3.5") do %>Regras do sistema<% end %>
  <div class="col gap-0">
    <%
      rules = [
        { key: :require_photo,  title: "Exigir foto na conclusão", desc: "Criança precisa anexar uma foto para marcar missão como feita" },
        { key: :decay_enabled,  title: "Estrelas expiram",         desc: "Estrelas não usadas expiram após 30 dias" },
        { key: :allow_negative, title: "Permitir saldo negativo",  desc: "Crianças podem ficar 'devendo' estrelas por rejeições" }
      ]
    %>
    <% rules.each_with_index do |rule, idx| %>
      <div class="row justify-between items-center py-3.5 <%= 'border-t border-hairline' unless idx.zero? %>">
        <div class="col gap-0.5">
          <div class="text-[14px] font-bold text-foreground"><%= rule[:title] %></div>
          <div class="text-[12px] text-muted-foreground"><%= rule[:desc] %></div>
        </div>
        <% checked = !!family.public_send(rule[:key]) %>
        <%= render Ui::Toggle::Component.new(name: "family[#{rule[:key]}]", checked: checked) %>
      </div>
    <% end %>

    <div class="row justify-between items-center py-3.5 border-t border-hairline">
      <div class="col gap-0.5">
        <div class="text-[14px] font-bold text-foreground">Auto-aprovar missões até</div>
        <div class="text-[12px] text-muted-foreground">Missões de valor baixo são aprovadas automaticamente (deixe em branco para desativar)</div>
      </div>
      <input type="number" name="family[auto_approve_threshold]" value="<%= family.auto_approve_threshold %>"
             placeholder="—" min="0"
             class="w-[90px] py-1.5 px-2.5 rounded-lg border border-hairline bg-surface-2 text-right font-bold" />
    </div>
  </div>
<% end %>
