<div class="card" style="padding: 20px;">
  <div class="h-display" style="font-size: 18px; margin-bottom: 14px;">Regras do sistema</div>
  <div class="col" style="gap: 0;">
    <%
      rules = [
        { key: :require_photo,  title: "Exigir foto na conclusão", desc: "Criança precisa anexar uma foto para marcar missão como feita" },
        { key: :decay_enabled,  title: "Estrelas expiram",         desc: "Estrelas não usadas expiram após 30 dias" },
        { key: :allow_negative, title: "Permitir saldo negativo",  desc: "Crianças podem ficar 'devendo' estrelas por rejeições" }
      ]
    %>
    <% rules.each_with_index do |rule, idx| %>
      <div class="row" style="justify-content: space-between; align-items: center; padding: 14px 0; <%= 'border-top: 1px solid var(--hairline);' unless idx.zero? %>">
        <div class="col" style="gap: 2px;">
          <div style="font-size: 14px; font-weight: 700; color: var(--text);"><%= rule[:title] %></div>
          <div style="font-size: 12px; color: var(--text-muted);"><%= rule[:desc] %></div>
        </div>
        <% checked = !!family.public_send(rule[:key]) %>
        <label class="toggle <%= 'is-checked' if checked %>">
          <input type="hidden" name="family[<%= rule[:key] %>]" value="0" />
          <input type="checkbox" name="family[<%= rule[:key] %>]" value="1" <%= 'checked' if checked %> />
          <span class="toggle-track"><span class="toggle-thumb"></span></span>
        </label>
      </div>
    <% end %>

    <div class="row" style="justify-content: space-between; align-items: center; padding: 14px 0; border-top: 1px solid var(--hairline);">
      <div class="col" style="gap: 2px;">
        <div style="font-size: 14px; font-weight: 700; color: var(--text);">Auto-aprovar missões até</div>
        <div style="font-size: 12px; color: var(--text-muted);">Missões de valor baixo são aprovadas automaticamente (deixe em branco para desativar)</div>
      </div>
      <input type="number" name="family[auto_approve_threshold]" value="<%= family.auto_approve_threshold %>"
             placeholder="—" min="0"
             style="width: 90px; padding: 6px 10px; border-radius: 8px; border: 1px solid var(--hairline); background: var(--surface-2); text-align: right; font-weight: 700;" />
    </div>
  </div>
</div>
