<%= render Ui::FormSection::Component.new(title: "Regras do sistema") do %>
  <div class="flex flex-col">
    <%
      rules = [
        { key: :require_photo,  title: "Exigir foto na conclusão", desc: "Criança precisa anexar uma foto para marcar missão como feita" },
        { key: :decay_enabled,  title: "Estrelas expiram",         desc: "Estrelas não usadas expiram após 30 dias" },
        { key: :allow_negative, title: "Permitir saldo negativo",  desc: "Crianças podem ficar 'devendo' estrelas por rejeições" }
      ]
    %>
    <% rules.each_with_index do |rule, idx| %>
      <div class="flex justify-between items-center gap-4 py-3.5 <%= 'border-t-2 border-hairline' unless idx.zero? %>">
        <div class="flex flex-col gap-0.5 min-w-0">
          <div class="text-[14px] font-extrabold" style="color: var(--text);"><%= rule[:title] %></div>
          <div class="text-[12px] font-bold" style="color: var(--text-muted);"><%= rule[:desc] %></div>
        </div>
        <% checked = !!family.public_send(rule[:key]) %>
        <%= render Ui::Toggle::Component.new(name: "family[#{rule[:key]}]", checked: checked) %>
      </div>
    <% end %>

    <div class="flex justify-between items-center gap-4 py-3.5 border-t-2 border-hairline">
      <div class="flex flex-col gap-0.5 min-w-0">
        <div class="text-[14px] font-extrabold" style="color: var(--text);">Auto-aprovar missões até</div>
        <div class="text-[12px] font-bold" style="color: var(--text-muted);">Missões de valor baixo são aprovadas automaticamente (deixe em branco para desativar)</div>
      </div>
      <input type="number" name="family[auto_approve_threshold]" value="<%= family.auto_approve_threshold %>"
             placeholder="—" min="0"
             class="form-input w-[90px] !py-2 !px-2.5 !rounded-[10px] text-right" />
    </div>
  </div>
<% end %>
