<%= render Ui::Card::Component.new(padding: "p-5") do %>
  <%= render Ui::Heading::Component.new(size: :h3, class: "mb-4") do %>Família<% end %>
  <div class="flex flex-col gap-0">

    <div class="row justify-between items-center py-2.5 border-b border-hairline">
      <div>
        <div class="text-[13px] font-bold text-foreground">Nome da família</div>
        <div class="text-[11px] text-muted-foreground">Aparece no app das crianças</div>
      </div>
      <div class="font-display font-bold text-[14px] text-foreground italic">
        <%= family.name %>
      </div>
    </div>

    <div class="row justify-between items-center py-2.5 border-b border-hairline">
      <div class="text-[13px] font-bold text-foreground">Idioma</div>
      <select name="family[locale]" class="py-1.5 px-2.5 rounded-lg border border-hairline bg-surface-2 text-foreground font-body text-[13px] font-bold cursor-pointer">
        <% [["pt-BR", "Português (BR)"], ["en", "English"]].each do |val, lbl| %>
          <option value="<%= val %>" <%= 'selected' if family.locale == val %>><%= lbl %></option>
        <% end %>
      </select>
    </div>

    <div class="row justify-between items-center py-2.5 border-b border-hairline">
      <div class="text-[13px] font-bold text-foreground">Fuso horário</div>
      <select name="family[timezone]" class="py-1.5 px-2.5 rounded-lg border border-hairline bg-surface-2 text-foreground font-body text-[13px] font-bold cursor-pointer">
        <% [["America/Sao_Paulo", "São Paulo (GMT-3)"], ["America/New_York", "New York (GMT-4)"], ["Europe/Lisbon", "Lisboa (GMT+1)"]].each do |val, lbl| %>
          <option value="<%= val %>" <%= 'selected' if family.timezone == val %>><%= lbl %></option>
        <% end %>
      </select>
    </div>

    <div class="row justify-between items-center py-2.5">
      <div class="text-[13px] font-bold text-foreground">Início de semana</div>
      <div class="row gap-1 bg-surface-2 rounded-full p-0.5">
        <% [[0, "dom"], [1, "seg"]].each do |val, lbl|
          active = family.week_start == val %>
          <label class="cursor-pointer relative">
            <input type="radio" name="family[week_start]" value="<%= val %>" <%= 'checked' if active %> class="absolute opacity-0" />
            <span class="inline-block py-1 px-2.5 rounded-full font-body text-[12px] font-extrabold <%= active ? 'bg-foreground text-white' : 'bg-transparent text-muted-foreground' %>"><%= lbl %></span>
          </label>
        <% end %>
      </div>
    </div>

  </div>
<% end %>
