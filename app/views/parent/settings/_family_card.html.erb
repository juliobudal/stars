<section class="bg-surface rounded-[16px] border-2 border-hairline p-[18px]"
         style="box-shadow: var(--shadow-card);">
  <div class="text-[12px] font-extrabold uppercase tracking-[0.5px] mb-3" style="color: var(--text-muted);">
    Família
  </div>
  <div class="flex flex-col">

    <div class="flex justify-between items-center gap-3 py-3 border-b-2 border-hairline">
      <div class="min-w-0">
        <div class="text-[14px] font-extrabold" style="color: var(--text);">Nome da família</div>
        <div class="text-[11px] font-bold" style="color: var(--text-muted);">Aparece no app das crianças</div>
      </div>
      <div class="text-[14px] font-extrabold truncate" style="color: var(--text);">
        <%= family.name %>
      </div>
    </div>

    <div class="flex justify-between items-center gap-3 py-3 border-b-2 border-hairline">
      <div class="text-[14px] font-extrabold shrink-0" style="color: var(--text);">Idioma</div>
      <div class="w-[200px]">
        <%= render Ui::Select::Component.new(
              name: "family[locale]",
              id: "family_locale",
              options: [["Português (BR)", "pt-BR"], ["English", "en"]],
              selected: family.locale,
              size: :sm
            ) %>
      </div>
    </div>

    <div class="flex justify-between items-center gap-3 py-3 border-b-2 border-hairline">
      <div class="text-[14px] font-extrabold shrink-0" style="color: var(--text);">Fuso horário</div>
      <div class="w-[220px]">
        <%= render Ui::Select::Component.new(
              name: "family[timezone]",
              id: "family_timezone",
              options: [
                ["São Paulo (GMT-3)",  "America/Sao_Paulo"],
                ["New York (GMT-4)",   "America/New_York"],
                ["Lisboa (GMT+1)",     "Europe/Lisbon"]
              ],
              selected: family.timezone,
              size: :sm
            ) %>
      </div>
    </div>

    <div class="flex justify-between items-center gap-3 py-3">
      <div class="text-[14px] font-extrabold" style="color: var(--text);">Início de semana</div>
      <div class="flex gap-1 p-1 rounded-[12px] border-2 border-hairline" style="background: var(--surface-2);">
        <% [[0, "DOM"], [1, "SEG"]].each do |val, lbl|
          active = family.week_start == val %>
          <label class="cursor-pointer">
            <input type="radio" name="family[week_start]" value="<%= val %>" <%= 'checked' if active %> class="absolute opacity-0 sr-only" />
            <span class="inline-block py-1.5 px-3.5 rounded-[10px] text-[11px] font-extrabold uppercase tracking-[0.5px] transition-colors"
                  style="<%= active ? 'background: var(--primary); color: white; box-shadow: 0 2px 0 var(--primary-2);' : 'background: transparent; color: var(--text-muted);' %>">
              <%= lbl %>
            </span>
          </label>
        <% end %>
      </div>
    </div>

  </div>
</section>
