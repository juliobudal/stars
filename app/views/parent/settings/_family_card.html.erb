<div class="card" style="padding: 20px;">
  <div class="h-display" style="font-size: 18px; margin-bottom: 16px;">Família</div>
  <div class="col-tight">

    <div class="row" style="justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--hairline);">
      <div>
        <div style="font-size: 13px; font-weight: 700; color: var(--text);">Nome da família</div>
        <div style="font-size: 11px; color: var(--text-muted);">Aparece no app das crianças</div>
      </div>
      <div style="font-family: var(--font-display); font-weight: 700; font-size: 14px; color: var(--text); font-style: italic;">
        <%= family.name %>
      </div>
    </div>

    <div class="row" style="justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--hairline);">
      <div style="font-size: 13px; font-weight: 700; color: var(--text);">Idioma</div>
      <select name="family[locale]" style="padding: 6px 10px; border-radius: 8px; border: 1px solid var(--hairline); background: var(--surface-2); color: var(--text); font-family: var(--font-body); font-size: 13px; font-weight: 700; cursor: pointer;">
        <% [["pt-BR", "Português (BR)"], ["en", "English"]].each do |val, lbl| %>
          <option value="<%= val %>" <%= 'selected' if family.locale == val %>><%= lbl %></option>
        <% end %>
      </select>
    </div>

    <div class="row" style="justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--hairline);">
      <div style="font-size: 13px; font-weight: 700; color: var(--text);">Fuso horário</div>
      <select name="family[timezone]" style="padding: 6px 10px; border-radius: 8px; border: 1px solid var(--hairline); background: var(--surface-2); color: var(--text); font-family: var(--font-body); font-size: 13px; font-weight: 700; cursor: pointer;">
        <% [["America/Sao_Paulo", "São Paulo (GMT-3)"], ["America/New_York", "New York (GMT-4)"], ["Europe/Lisbon", "Lisboa (GMT+1)"]].each do |val, lbl| %>
          <option value="<%= val %>" <%= 'selected' if family.timezone == val %>><%= lbl %></option>
        <% end %>
      </select>
    </div>

    <div class="row" style="justify-content: space-between; align-items: center; padding: 10px 0;">
      <div style="font-size: 13px; font-weight: 700; color: var(--text);">Início de semana</div>
      <div class="row" style="gap: 4px; background: var(--surface-2); border-radius: var(--r-full); padding: 3px;">
        <% [[0, "dom"], [1, "seg"]].each do |val, lbl|
          active = family.week_start == val %>
          <label style="cursor: pointer;">
            <input type="radio" name="family[week_start]" value="<%= val %>" <%= 'checked' if active %> style="position: absolute; opacity: 0;" />
            <span style="display: inline-block; padding: 4px 10px; border-radius: var(--r-full); background: <%= active ? 'var(--text)' : 'transparent' %>; color: <%= active ? 'white' : 'var(--text-muted)' %>; font-family: var(--font-body); font-size: 12px; font-weight: 800;"><%= lbl %></span>
          </label>
        <% end %>
      </div>
    </div>

  </div>
</div>
