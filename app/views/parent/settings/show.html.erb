<div class="screen screen-enter-right with-nav">
  <%= render Ui::BgShapes::Component.new(variant: "blue") %>

  <%# ─── Header ─── %>
  <%= render Ui::PageHeader::Component.new(
        title: "Configurações",
        subtitle: "Família, responsáveis e regras do sistema."
      ) %>

  <%= form_with url: parent_settings_path, method: :patch, local: true, class: "flex flex-col gap-[18px] z-content" do |f| %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-[18px]">
      <%= render partial: "family_card", locals: { family: @family } %>
      <%= render partial: "responsibles_card", locals: { family: @family } %>
    </div>

    <%= render partial: "rules_card", locals: { family: @family } %>

    <div class="flex items-center justify-end gap-2.5 pt-2 pb-1">
      <button type="submit"
              class="ls-btn-3d inline-flex items-center gap-2 px-6 py-3 rounded-[14px] text-white text-[13px] font-extrabold uppercase tracking-[0.5px] border-2"
              style="background: var(--primary); border-color: var(--primary); box-shadow: 0 4px 0 var(--primary-2);">
        <%= render Ui::Icon::Component.new("check", size: 14, color: "currentColor") %>
        Salvar alterações
      </button>
    </div>
  <% end %>

  <%# ─── PINs dos perfis ─── %>
  <section class="mt-8 z-content">
    <%= render Ui::FormSection::Component.new(title: "PINs dos perfis") do %>
      <ul class="flex flex-col gap-2">
        <% current_family.profiles.order(:name).each do |profile| %>
          <li class="flex items-center justify-between gap-3 py-2.5 px-3 rounded-[12px] border-2 border-hairline"
              style="background: var(--surface-2);">
            <div class="flex items-center gap-3 min-w-0">
              <%= render Ui::SmileyAvatar::Component.new(kid: profile, size: 32) %>
              <div class="min-w-0">
                <div class="text-[14px] font-extrabold truncate" style="color: var(--text);"><%= profile.name %></div>
                <div class="text-[11px] font-bold uppercase tracking-[0.5px]" style="color: var(--text-muted);">
                  <%= profile.parent? ? "Responsável" : "Criança" %>
                </div>
              </div>
            </div>
            <%= form_with url: reset_pin_parent_profile_path(profile), method: :patch, local: true,
                          class: "flex gap-2 shrink-0" do |pf| %>
              <%= pf.text_field :pin, pattern: "\\d{4}", maxlength: 4, inputmode: "numeric",
                  autocomplete: "off", placeholder: "Novo PIN", required: true,
                  class: "w-[110px] px-3 py-2 border-2 border-hairline rounded-[10px] font-extrabold text-center bg-white focus:outline-none",
                  style: "color: var(--text);" %>
              <button type="submit"
                      class="ls-btn-3d inline-flex items-center px-3 py-2 rounded-[10px] text-[11px] font-extrabold uppercase tracking-[0.5px] border-2"
                      style="background: var(--surface); color: var(--text-muted); border-color: var(--hairline); box-shadow: 0 3px 0 var(--hairline);">
                Resetar
              </button>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </section>

  <%# ─── Sair desta família ─── %>
  <section class="mt-6 z-content">
    <%= button_to family_session_path, method: :delete,
          class: "ls-btn-3d inline-flex items-center gap-2 px-4 py-2.5 rounded-[12px] text-white text-[12px] font-extrabold uppercase tracking-[0.5px] border-2 cursor-pointer",
          form: { class: "" },
          style: "background: var(--danger); border-color: var(--danger); box-shadow: 0 3px 0 var(--danger-2);" do %>
      Sair desta família neste dispositivo
    <% end %>
  </section>
</div>
