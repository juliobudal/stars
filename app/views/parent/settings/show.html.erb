<div class="page-enter-right">

  <%# ─── Header ─── %>
  <%= render Ui::PageHeader::Component.new(
        title: "Configurações",
        subtitle: "Família, responsáveis e regras do sistema."
      ) %>

  <%= form_with url: parent_settings_path, method: :patch, local: true, class: "flex flex-col gap-[18px]" do |f| %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-[18px]">
      <%= render partial: "family_card", locals: { family: @family } %>
      <%= render partial: "responsibles_card", locals: { family: @family } %>
    </div>

    <%= render partial: "rules_card", locals: { family: @family } %>

    <div class="flex items-center justify-end gap-2.5 pt-2 pb-1">
      <%= render Ui::Btn::Component.new(variant: "primary", type: "submit") do %>
        <%= render Ui::Icon::Component.new("check", size: 14, color: "currentColor") %>
        Salvar alterações
      <% end %>
    </div>
  <% end %>

  <%# ─── PINs dos perfis ─── %>
  <section class="mt-8">
    <%= render Ui::FormSection::Component.new(title: "PINs dos perfis") do %>
      <ul class="flex flex-col gap-2">
        <% current_family.profiles.order(:name).each do |profile| %>
          <li class="flex items-center justify-between gap-3 py-2.5 px-3 rounded-[12px] border-2 border-hairline"
              style="background: var(--surface-2);">
            <div class="flex items-center gap-3 min-w-0">
              <%= render Ui::SmileyAvatar::Component.new(kid: profile, size: 32) %>
              <div class="min-w-0">
                <div class="text-[14px] font-extrabold truncate" style="color: var(--text);"><%= profile.name %></div>
                <div class="text-[11px] font-bold uppercase tracking-[0.5px]" style="color: var(--text-muted);">
                  <%= profile.parent? ? "Responsável" : "Criança" %>
                </div>
              </div>
            </div>
            <%= form_with url: reset_pin_parent_profile_path(profile), method: :patch, local: true,
                          class: "flex gap-2 shrink-0" do |pf| %>
              <%= pf.text_field :pin, pattern: "\\d{4}", maxlength: 4, inputmode: "numeric",
                  autocomplete: "off", placeholder: "Novo PIN", required: true,
                  class: "form-input w-[110px] !px-3 !py-2 !rounded-[10px] text-center" %>
              <%= render Ui::Btn::Component.new(variant: "danger", size: "sm", type: "submit") do %>
                Resetar
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </section>

  <%# ─── Sair desta família ─── %>
  <section class="mt-6">
    <%= render Ui::Btn::Component.new(
          variant: "danger",
          size: "sm",
          url: family_session_path,
          method: :delete
        ) do %>
      Sair desta família neste dispositivo
    <% end %>
  </section>
</div>
