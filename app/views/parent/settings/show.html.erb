<div class="screen screen-enter-right with-nav">
  <%= render Ui::BgShapes::Component.new(variant: "blue") %>

  <%= render Ui::TopBar::Component.new(
    title: "Configurações",
    subtitle: "Preferências da família",
    back_url: parent_root_path
  ) %>

  <%= form_with url: parent_settings_path, method: :patch, local: true, class: "col", style: "gap: 16px; z-index: 2;" do |f| %>

    <div class="grid-2" style="gap: 16px;">
      <%# --- Família card --- %>
      <div class="card" style="padding: 20px;">
        <div class="h-display" style="font-size: 18px; margin-bottom: 14px;">Família</div>
        <div class="col" style="gap: 14px;">
          <div class="col" style="gap: 6px;">
            <label class="label" style="font-size: 11px; font-weight: 800; letter-spacing: .1em; color: var(--text-muted); text-transform: uppercase;">Nome</label>
            <input type="text" value="<%= @family.name %>" readonly class="input" style="padding: 10px 12px; border-radius: 10px; border: 1px solid var(--hairline); background: var(--surface-2); color: var(--text);" />
          </div>

          <div class="col" style="gap: 6px;">
            <label class="label" style="font-size: 11px; font-weight: 800; letter-spacing: .1em; color: var(--text-muted); text-transform: uppercase;">Idioma</label>
            <%# TODO: persist locale preference %>
            <select class="input" style="padding: 10px 12px; border-radius: 10px; border: 1px solid var(--hairline); background: var(--surface); color: var(--text);">
              <option value="pt-BR" selected>Português (Brasil)</option>
              <option value="en">English</option>
            </select>
          </div>

          <div class="col" style="gap: 6px;">
            <label class="label" style="font-size: 11px; font-weight: 800; letter-spacing: .1em; color: var(--text-muted); text-transform: uppercase;">Fuso horário</label>
            <%# TODO: persist timezone %>
            <select class="input" style="padding: 10px 12px; border-radius: 10px; border: 1px solid var(--hairline); background: var(--surface); color: var(--text);">
              <option value="America/Sao_Paulo" selected>America/Sao_Paulo</option>
              <option value="America/New_York">America/New_York</option>
              <option value="Europe/Lisbon">Europe/Lisbon</option>
            </select>
          </div>

          <div class="row" style="justify-content: space-between; align-items: center; padding: 10px 0;">
            <div>
              <div class="h-display" style="font-size: 14px;">Semana começa no domingo</div>
              <div style="font-size: 12px; color: var(--text-muted);">Caso contrário, inicia na segunda</div>
            </div>
            <%# TODO: bind to family setting %>
            <label style="display: inline-block; width: 44px; height: 24px; position: relative;">
              <input type="checkbox" style="opacity: 0; width: 0; height: 0;" />
              <span style="display: block; width: 44px; height: 24px; border-radius: 999px; background: var(--hairline); position: relative;">
                <span style="position: absolute; top: 2px; left: 2px; width: 20px; height: 20px; border-radius: 50%; background: white;"></span>
              </span>
            </label>
          </div>
        </div>
      </div>

      <%# --- Responsáveis card --- %>
      <div class="card" style="padding: 20px;">
        <div class="h-display" style="font-size: 18px; margin-bottom: 14px;">Responsáveis</div>
        <div class="col" style="gap: 10px;">
          <% @family.profiles.parent.each do |p| %>
            <div class="row" style="gap: 12px; align-items: center; padding: 10px; border-radius: 12px; background: var(--surface-2);">
              <%= render Ui::KidAvatar::Component.new(kid: p, size: 40) %>
              <div class="col fg1" style="gap: 2px;">
                <div class="h-display" style="font-size: 14px;"><%= p.name %></div>
                <div style="font-size: 12px; color: var(--text-muted);">Responsável</div>
              </div>
            </div>
          <% end %>

          <%# TODO: enable parent invite flow %>
          <button type="button" class="btn btn-ghost" style="justify-content: center; border: 1px dashed var(--hairline); padding: 10px;">
            <%= render Ui::Icon::Component.new("plus", size: 16, color: "var(--text-muted)") %>
            Convidar responsável
          </button>
        </div>
      </div>
    </div>

    <%# --- Regras (full-width) --- %>
    <div class="card" style="padding: 20px;">
      <div class="h-display" style="font-size: 18px; margin-bottom: 14px;">Regras</div>
      <div class="col" style="gap: 4px;">
        <% [
          ["Exigir foto de comprovação", "Pedir foto ao concluir missão"],
          ["Decaimento de estrelas", "Estrelas expiram após um período"],
          ["Permitir saldo negativo", "Crianças podem ficar com saldo devedor"],
          ["Aprovação automática", "Missões diárias liberam sem revisão"]
        ].each_with_index do |(title, desc), idx| %>
          <div class="row" style="justify-content: space-between; align-items: center; padding: 14px 0; <%= 'border-top: 1px solid var(--hairline);' unless idx.zero? %>">
            <div class="col" style="gap: 2px;">
              <div class="h-display" style="font-size: 14px;"><%= title %></div>
              <div style="font-size: 12px; color: var(--text-muted);"><%= desc %></div>
            </div>
            <%# TODO: bind to family rule setting %>
            <label style="display: inline-block; width: 44px; height: 24px; position: relative;">
              <input type="checkbox" style="opacity: 0; width: 0; height: 0;" />
              <span style="display: block; width: 44px; height: 24px; border-radius: 999px; background: var(--hairline); position: relative;">
                <span style="position: absolute; top: 2px; left: 2px; width: 20px; height: 20px; border-radius: 50%; background: white;"></span>
              </span>
            </label>
          </div>
        <% end %>
      </div>
    </div>

    <div class="row" style="justify-content: flex-end; gap: 8px;">
      <%= f.submit "Salvar alterações", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
