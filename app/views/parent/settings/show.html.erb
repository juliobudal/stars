<div class="screen screen-enter-right with-nav">
  <%= render Ui::BgShapes::Component.new(variant: "blue") %>

  <%= render Ui::TopBar::Component.new(
    title: "Configurações",
    subtitle: "Família, responsáveis e regras do sistema.",
    back_url: parent_root_path
  ) %>

  <%= form_with url: parent_settings_path, method: :patch, local: true, class: "col", style: "gap: 16px; z-index: 2;" do |f| %>

    <div class="grid-2" style="gap: 16px;">
      <%= render partial: "family_card", locals: { family: @family } %>
      <%= render partial: "responsibles_card", locals: { family: @family } %>
    </div>

    <%= render partial: "rules_card", locals: { family: @family } %>

    <div class="row" style="justify-content: flex-end; gap: 8px; padding-bottom: 8px;">
      <%= f.submit "Salvar alterações", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
