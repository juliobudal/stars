<%= render Ui::FormSection::Component.new(title: "Responsáveis") do %>
  <div class="flex flex-col gap-2">
    <% family.profiles.parent.each do |p| %>
      <div class="flex items-center gap-3 py-2.5 px-3 rounded-[12px] border border-hairline"
           style="background: var(--surface-2);">
        <%= render Ui::SmileyAvatar::Component.new(kid: p, size: 36, decorative: true) %>
        <div class="flex flex-col flex-1 gap-0.5 min-w-0">
          <div class="text-[14px] font-extrabold truncate" style="color: var(--text);"><%= p.name %></div>
          <div class="text-[11px] font-bold truncate" style="color: var(--text-muted);">
            <%= p.email.presence || "Responsável" %>
          </div>
        </div>
        <%= link_to edit_parent_profile_path(p),
                class: "bg-transparent cursor-pointer w-11 h-11 -mr-1.5 shrink-0 rounded-[8px] flex items-center justify-center no-underline",
                aria: { label: "Editar #{p.name}" } do %>
          <%= render Ui::Icon::Component.new("pencil", size: 16, color: "var(--text-muted)") %>
        <% end %>
      </div>
    <% end %>

    <%= render Ui::Btn::Component.new(
          variant: "primary",
          size: "sm",
          url: new_parent_invitation_path,
          class: "justify-center mt-1"
        ) do %>
      <%= render Ui::Icon::Component.new("plus", size: 14, color: "currentColor") %>
      Convidar responsável
    <% end %>
  </div>
<% end %>
