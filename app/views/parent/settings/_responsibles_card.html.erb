<div class="bg-surface rounded-md p-7 shadow-card relative border-none p-5">
  <div class="font-display text-[32px] leading-[1.1] font-extrabold tracking-[-0.02em] text-foreground text-[18px] mb-4">Responsáveis</div>
  <div class="flex flex-col gap-2">
    <% family.profiles.parent.each do |p| %>
      <div class="flex items-center gap-3 py-2.5 px-3 rounded-xl bg-surface-2">
        <%= render Ui::SmileyAvatar::Component.new(kid: p, size: 36) %>
        <div class="flex flex-col flex-1 gap-0.5">
          <div class="text-[14px] font-bold text-foreground"><%= p.name %></div>
          <div class="text-[11px] text-muted-foreground">
            <%= p.name.downcase.parameterize(separator: ".") %>@familia.com · Administrador<%= "a" if p.name.ends_with?("a") || p.name.ends_with?("e") %>
          </div>
        </div>
        <button type="button" class="bg-transparent border-none cursor-pointer text-muted-foreground p-1 flex items-center">
          <%= render Ui::Icon::Component.new("pencil", size: 14, color: "var(--text-muted)") %>
        </button>
      </div>
    <% end %>

    <%= render Ui::Btn::Component.new(variant: "secondary", size: "sm", url: new_parent_invitation_path) do %>+ Convidar responsável<% end %>
  </div>
</div>
