<div class="card" style="padding: 20px;">
  <div class="h-display" style="font-size: 18px; margin-bottom: 16px;">Responsáveis</div>
  <div class="col" style="gap: 8px;">
    <% family.profiles.parent.each do |p| %>
      <div class="row" style="gap: 12px; align-items: center; padding: 10px 12px; border-radius: 12px; background: var(--surface-2);">
        <%= render Ui::SmileyAvatar::Component.new(kid: p, size: 36) %>
        <div class="col fg1" style="gap: 1px;">
          <div style="font-size: 14px; font-weight: 700; color: var(--text);"><%= p.name %></div>
          <div style="font-size: 11px; color: var(--text-muted);">
            <%= p.name.downcase.parameterize(separator: ".") %>@familia.com · Administrador<%= "a" if p.name.ends_with?("a") || p.name.ends_with?("e") %>
          </div>
        </div>
        <button type="button" style="background: none; border: none; cursor: pointer; color: var(--text-muted); padding: 4px; display: flex; align-items: center;">
          <%= render Ui::Icon::Component.new("pencil", size: 14, color: "var(--text-muted)") %>
        </button>
      </div>
    <% end %>

    <%= link_to new_parent_invitation_path, class: "btn btn-ghost btn-sm", style: "justify-content: center; width: 100%; border: 1.5px solid var(--hairline); border-style: dashed; border-radius: 10px; padding: 10px; color: var(--text-muted); font-family: var(--font-body); font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 6px;" do %>
      <%= render Ui::Icon::Component.new("plus", size: 14, color: "var(--text-muted)") %>
      Convidar responsável
    <% end %>
  </div>
</div>
