<%# Parent Dashboard — LittleStars Design System %>
<div class="screen screen-enter">

  <%# ─── Header ─── %>
  <div class="row mb-5" style="justify-content: space-between; z-index: 2; flex-shrink: 0;">
    <div class="row" style="gap: 12px;">
      <div style="width: 56px; height: 56px; border-radius: 50%; background: var(--primary-soft); border: 3px solid var(--primary); display: flex; align-items: center; justify-content: center;">
        <span style="font-size: 28px;"><%= current_profile.avatar.presence || "👤" %></span>
      </div>
      <div class="col" style="gap: 0;">
        <div class="eyebrow">Olá,</div>
        <div class="h-display" style="font-size: 24px;"><%= current_profile.name %></div>
      </div>
    </div>
    <%= button_to sessions_path, method: :delete, class: "btn btn-secondary btn-icon" do %>
      <i class="ph-bold ph-sign-out" style="font-size: 20px;"></i>
    <% end %>
  </div>

  <%# ─── KPIs ─── %>
  <div class="grid-3 mb-5" style="gap: 12px; z-index: 2;">
    <div class="card" style="padding: 18px; text-align: center;">
      <div class="row center" style="gap: 6px;">
        <i class="ph-fill ph-star" style="font-size: 22px; color: var(--star);"></i>
        <div class="h-display" style="font-size: 28px; color: var(--star-2);"><%= @stats[:total_stars] %></div>
      </div>
      <div class="eyebrow" style="margin-top: 4px;">Estrelinhas</div>
    </div>

    <div class="card" style="padding: 18px; text-align: center;">
      <div class="row center" style="gap: 6px;">
        <i class="ph-bold ph-clock" style="font-size: 22px; color: var(--c-peach);"></i>
        <div class="h-display" style="font-size: 28px; color: var(--c-peach);" id="pending_approvals_kpi"><%= @stats[:pending_approvals] %></div>
      </div>
      <div class="eyebrow" style="margin-top: 4px;">Aguardando</div>
    </div>

    <div class="card" style="padding: 18px; text-align: center;">
      <div class="row center" style="gap: 6px;">
        <i class="ph-bold ph-users" style="font-size: 22px; color: var(--primary);"></i>
        <div class="h-display" style="font-size: 28px; color: var(--primary);"><%= @stats[:children] %></div>
      </div>
      <div class="eyebrow" style="margin-top: 4px;">Crianças</div>
    </div>
  </div>

  <%# ─── Kids overview ─── %>
  <div class="mb-5" style="z-index: 2;">
    <div class="row mb-3" style="justify-content: space-between; align-items: center;">
      <h3 class="h-display" style="font-size: 20px;">Visão Geral</h3>
      <%= link_to new_parent_profile_path, class: "btn btn-secondary btn-sm" do %>
        <i class="ph-bold ph-plus" style="font-size: 14px;"></i> Filho
      <% end %>
    </div>

    <% if @children.any? %>
      <div class="col" style="gap: 10px;">
        <% @children.each_with_index do |child, i| %>
          <% child_tasks = child.profile_tasks.where(created_at: Time.current.beginning_of_day..) rescue [] %>
          <% done_count = child_tasks.respond_to?(:count) ? (child_tasks.where(status: [:approved, :pending_approval]).count rescue 0) : 0 %>
          <% total_count = child_tasks.respond_to?(:count) ? (child_tasks.count rescue 0) : 0 %>
          <% pct = total_count.zero? ? 0 : (done_count.to_f / total_count * 100).round %>
          <div class="card pop-on-tap" style="padding: 16px; animation: slideInCard 0.4s ease <%= i * 0.05 %>s both; border: 2px solid rgba(26,42,74,0.08);">
            <div class="row" style="gap: 14px;">
              <%= render Ui::KidAvatar::Component.new(kid: child, size: 54) %>
              <div class="col fg1" style="gap: 6px;">
                <div class="row" style="justify-content: space-between; align-items: baseline;">
                  <div class="h-display" style="font-size: 18px;"><%= child.name %></div>
                  <div class="row" style="gap: 4px; align-items: center;">
                    <i class="ph-fill ph-star" style="font-size: 14px; color: var(--star);"></i>
                    <span class="h-display" style="color: var(--star-2); font-size: 15px;"><%= child.points %></span>
                  </div>
                </div>
                <div class="progress-track" style="height: 10px;">
                  <div class="progress-fill" style="width: <%= pct %>%;"></div>
                </div>
                <div style="font-size: 12px; color: var(--text-muted); font-weight: 700;">
                  <%= done_count %>/<%= total_count %> missões hoje
                </div>
              </div>
            </div>
            <div class="row" style="gap: 8px; margin-top: 12px; justify-content: flex-end;">
              <%= link_to "Editar", edit_parent_profile_path(child), class: "btn btn-ghost btn-sm" %>
              <%= button_to parent_profile_path(child), method: :delete, class: "btn btn-ghost btn-sm",
                  style: "color: var(--danger);",
                  data: { turbo_confirm: "Tem certeza? Isso apaga todas as tarefas e histórico deste perfil." } do %>
                <i class="ph-bold ph-trash" style="font-size: 14px;"></i>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="center col" style="padding: 40px; text-align: center; gap: 14px;">
        <div style="width: 80px; height: 80px; border-radius: var(--r-md); background: var(--primary-soft); color: var(--primary); display: flex; align-items: center; justify-content: center;">
          <i class="ph-bold ph-users" style="font-size: 44px;"></i>
        </div>
        <h3 class="h-display" style="font-size: 22px; margin-top: 8px;">Nenhuma criança adicionada</h3>
        <p class="subtitle">Para começar as missões, adicione o primeiro filho(a).</p>
        <%= link_to "Adicionar Filho", new_parent_profile_path, class: "btn btn-primary btn-sm" %>
      </div>
    <% end %>
  </div>

  <%# ─── Navigation tiles ─── %>
  <div style="z-index: 2;">
    <h3 class="h-display mb-3" style="font-size: 20px;">Gerenciar</h3>
    <div class="grid-auto" style="gap: 12px;">
      <%
        tiles = [
          { label: "Aprovações", icon: "check-circle", color_bg: "var(--c-mint-soft)", color_fg: "var(--c-mint)", path: :parent_approvals_path, badge: @stats[:pending_approvals] },
          { label: "Missões",    icon: "target",       color_bg: "var(--primary-soft)", color_fg: "var(--primary)", path: :parent_global_tasks_path },
          { label: "Recompensas",icon: "gift",         color_bg: "var(--c-peach-soft)", color_fg: "var(--c-peach)", path: :parent_rewards_path },
          { label: "Extrato",    icon: "scroll",       color_bg: "var(--c-lilac-soft)", color_fg: "var(--c-lilac)", path: :parent_activity_logs_path },
        ]
      %>
      <% tiles.each_with_index do |tile, i| %>
        <%= link_to send(tile[:path]), class: "card pop-on-tap", style: "padding: 18px; cursor: pointer; text-align: left; position: relative; border: 2px solid #{tile[:color_fg]}; box-shadow: 0 4px 0 #{tile[:color_fg]}; animation: slideInCard 0.4s ease #{0.2 + i * 0.04}s both; display: block; text-decoration: none;" do %>
          <% if tile[:badge].to_i > 0 %>
            <div style="position: absolute; top: -6px; right: -6px; width: 28px; height: 28px; border-radius: 50%; background: var(--danger); color: white; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800; border: 3px solid white; box-shadow: 0 2px 0 rgba(26,42,74,0.15);" id="pending_approvals_count">
              <%= tile[:badge] %>
            </div>
          <% end %>
          <div style="width: 46px; height: 46px; border-radius: var(--r-md); background: <%= tile[:color_bg] %>; color: <%= tile[:color_fg] %>; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
            <i class="ph-bold ph-<%= tile[:icon] %>" style="font-size: 26px;"></i>
          </div>
          <div class="h-display" style="font-size: 15px; color: var(--text);"><%= tile[:label] %></div>
        <% end %>
      <% end %>
    </div>
  </div>

</div>
