<div class="page-enter">

  <%# ─── Header ─── %>
  <%
    awaiting_children = @children.select { |c| @child_awaiting[c.id].to_i > 0 }
    awaiting_names    = awaiting_children.map(&:name)

    dashboard_subtitle = if awaiting_children.any?
                          subject = case awaiting_names.size
                                    when 1 then awaiting_names.first
                                    when 2 then awaiting_names.join(" e ")
                                    else        "Suas crianças"
                                    end
                          verb = awaiting_names.size == 1 ? "tem" : "têm"
                          "#{subject} #{verb} missões esperando sua aprovação"
                        elsif @children.any?
                          if @children.size == 1
                            "#{@children.first.name} está em dia com as missões"
                          else
                            "Suas crianças estão em dia com as missões"
                          end
                        else
                          "Adicione sua primeira criança para começar"
                        end
    top_streak = @children.map { |c| c.respond_to?(:streak) ? c.streak.to_i : 0 }.max.to_i
  %>
  <%= render Ui::PageHeader::Component.new(title: "Olá, #{current_profile.name}! 👋", subtitle: dashboard_subtitle) do |h| %>
    <% h.with_right_slot do %>
      <div class="flex items-center gap-3 shrink-0">
        <% if top_streak > 0 %>
          <%= render Ui::HeaderStatChip::Component.new(label: "DIAS", value: top_streak, icon: "flame", variant: :warning) %>
        <% end %>
        <%= render Ui::Btn::Component.new(variant: "primary", url: new_parent_global_task_path) do %>
          <%= render Ui::Icon::Component.new("plus", size: 14, color: "currentColor") %>
          Nova missão
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# ─── Stats grid ─── %>
  <div class="z-10 relative grid grid-cols-2 lg:grid-cols-4 gap-3 mb-[22px]">
    <%= render Ui::StatCard::Component.new(value: @stats[:total_stars],       label: "Estrelinhas",     icon: "star",   tint: "reward") %>
    <%= render Ui::StatCard::Component.new(value: @stats[:active_missions],   label: "Missões ativas",  icon: "target", tint: "info") %>
    <%= render Ui::StatCard::Component.new(value: @stats[:rewards_count],     label: "Prêmios",         icon: "bag",    tint: "prize") %>
    <%= render Ui::StatCard::Component.new(value: @stats[:pending_approvals], label: "Pendentes →",     icon: "clock",  tint: "danger") %>
  </div>

  <%# ─── Suas crianças ─── %>
  <section class="mb-[22px]">
    <div class="flex items-center justify-between mb-[14px]">
      <h2 class="text-[16px] font-extrabold m-0" style="color: var(--text);">Suas crianças</h2>
      <%= render Ui::Btn::Component.new(variant: "primary", size: "sm", url: parent_profiles_path) do %>
        + Adicionar
      <% end %>
    </div>

    <% if @children.any? %>
      <div class="grid grid-cols-1 lg:grid-cols-1 gap-3">
        <% @children.each do |child| %>
          <%= render Ui::KidProgressCard::Component.new(
                kid: child,
                awaiting_count: @child_awaiting[child.id].to_i,
                missions_count: @child_missions[child.id].to_i
              ) %>
        <% end %>
      </div>
    <% else %>
      <%= render Ui::Empty::Component.new(
        icon: "users",
        title: "Nenhuma criança adicionada",
        subtitle: "Para começar as missões, adicione a primeira criança."
      ) do %>
        <%= render Ui::Btn::Component.new(variant: "primary", size: "sm", url: parent_profiles_path) do %>Adicionar Criança<% end %>
      <% end %>
    <% end %>
  </section>

  <%# ─── Aprovações pendentes ─── %>
  <section>
    <div class="flex items-center justify-between mb-[14px]">
      <h2 class="text-[16px] font-extrabold m-0" style="color: var(--text);">Aprovações pendentes</h2>
      <%= link_to "Ver tudo", parent_approvals_path, class: "text-[12px] font-extrabold uppercase tracking-[0.5px] no-underline", style: "color: var(--c-info-600);" %>
    </div>
    <% if @pending_tasks.any? %>
      <div class="flex flex-col gap-2.5">
        <% @pending_tasks.each do |task| %>
          <%= render Ui::ApprovalRow::Component.new(
                dom_id: dom_id(task),
                kid: task.profile,
                title: task.title,
                kid_chip_text: task.profile&.name,
                category: task.category,
                meta: "há #{time_ago_in_words(task.updated_at)}",
                points: task.points,
                points_sign: "+",
                approve_url: approve_parent_approval_path(task),
                reject_url: reject_parent_approval_path(task),
                reject_confirm: "Rejeitar esta missão?",
                compact: true
              ) %>
        <% end %>
      </div>
    <% else %>
      <%= render Ui::Empty::Component.new(
        icon: "check",
        title: "Tudo em dia!",
        subtitle: "Nenhuma missão aguardando aprovação."
      ) %>
    <% end %>
  </section>

</div>
