<div class="screen screen-enter with-nav">

  <%# ─── Header ─── %>
  <div class="flex items-start justify-between gap-4 mb-[22px] z-content shrink-0">
    <div class="min-w-0">
      <h1 class="text-[26px] font-extrabold leading-tight m-0 mb-1" style="color: var(--text);">
        Olá, <%= current_profile.name %>! 👋
      </h1>
      <p class="text-[14px] font-bold m-0" style="color: var(--text-muted);">
        <% if @stats[:pending_approvals].to_i > 0 %>
          <%= @children.first&.name || "Sua família" %> tem missões esperando sua aprovação
        <% elsif @children.any? %>
          <%= @children.size == 1 ? @children.first.name : "Suas crianças" %> está em dia com as missões
        <% else %>
          Adicione sua primeira criança para começar
        <% end %>
      </p>
    </div>
    <div class="flex items-center gap-3 shrink-0">
      <% top_streak = @children.map { |c| c.respond_to?(:streak) ? c.streak.to_i : 0 }.max.to_i %>
      <% if top_streak > 0 %>
        <div class="flex items-center gap-1.5 px-3.5 py-2 rounded-[14px] border-2"
             style="background: var(--star-soft); border-color: var(--star); box-shadow: 0 3px 0 var(--star-2);">
          <%= render Ui::Icon::Component.new("flame", size: 20, color: "var(--c-streak)") %>
          <div>
            <div class="text-[18px] font-extrabold leading-none" style="color: var(--c-streak);"><%= top_streak %></div>
            <div class="text-[9px] font-extrabold tracking-[0.5px]" style="color: var(--c-amber-dark);">DIAS</div>
          </div>
        </div>
      <% end %>
      <%= link_to new_parent_global_task_path,
            class: "ls-btn-3d inline-flex items-center gap-2 px-5 py-3 rounded-[14px] text-white text-[14px] font-extrabold uppercase tracking-[0.5px] no-underline border-2",
            style: "background: var(--primary); border-color: var(--primary); box-shadow: 0 4px 0 var(--primary-2);" do %>
        <%= render Ui::Icon::Component.new("plus", size: 14, color: "currentColor") %>
        Nova missão
      <% end %>
    </div>
  </div>

  <%# ─── Stats grid ─── %>
  <div class="z-10 relative grid grid-cols-2 lg:grid-cols-4 gap-3 mb-[22px]">
    <%= render Ui::StatCard::Component.new(value: @stats[:total_stars],       label: "Estrelinhas",     icon: "star",   tint: "reward") %>
    <%= render Ui::StatCard::Component.new(value: @stats[:active_missions],   label: "Missões ativas",  icon: "target", tint: "info") %>
    <%= render Ui::StatCard::Component.new(value: @stats[:rewards_count],     label: "Prêmios",         icon: "bag",    tint: "prize") %>
    <%= render Ui::StatCard::Component.new(value: @stats[:pending_approvals], label: "Pendentes →",     icon: "clock",  tint: "danger") %>
  </div>

  <%# ─── Suas crianças ─── %>
  <section class="mb-[22px] z-content">
    <div class="flex items-center justify-between mb-[14px]">
      <h2 class="text-[16px] font-extrabold m-0" style="color: var(--text);">Suas crianças</h2>
      <%= link_to parent_profiles_path,
            class: "ls-btn-3d inline-flex items-center px-3.5 py-2 rounded-[12px] text-[12px] font-extrabold uppercase tracking-[0.5px] no-underline border-2",
            style: "background: var(--surface); color: var(--text-muted); border-color: var(--hairline); box-shadow: 0 3px 0 var(--hairline);" do %>
        + Adicionar
      <% end %>
    </div>

    <% if @children.any? %>
      <div class="grid grid-cols-1 lg:grid-cols-1 gap-3">
        <% @children.each do |child| %>
          <%= render Ui::KidProgressCard::Component.new(
                kid: child,
                awaiting_count: @child_awaiting[child.id].to_i,
                missions_count: @child_missions[child.id].to_i
              ) %>
        <% end %>
      </div>
    <% else %>
      <%= render Ui::Empty::Component.new(
        icon: "users",
        title: "Nenhuma criança adicionada",
        subtitle: "Para começar as missões, adicione a primeira criança."
      ) do %>
        <%= render Ui::Btn::Component.new(variant: "primary", size: "sm", url: parent_profiles_path) do %>Adicionar Criança<% end %>
      <% end %>
    <% end %>
  </section>

  <%# ─── Aprovações pendentes ─── %>
  <section class="z-content">
    <div class="flex items-center justify-between mb-[14px]">
      <h2 class="text-[16px] font-extrabold m-0" style="color: var(--text);">Aprovações pendentes</h2>
      <%= link_to "Ver tudo", parent_approvals_path, class: "text-[12px] font-extrabold uppercase tracking-[0.5px] no-underline", style: "color: var(--c-info-600);" %>
    </div>
    <% if @pending_tasks.any? %>
      <div class="flex flex-col gap-2.5">
        <% @pending_tasks.each do |task| %>
          <%= render Ui::ApprovalRow::Component.new(
                dom_id: dom_id(task),
                kid: task.profile,
                title: task.title,
                kid_chip_text: task.profile&.name,
                category: task.category,
                meta: "há #{time_ago_in_words(task.updated_at)}",
                points: task.points,
                points_sign: "+",
                approve_url: approve_parent_approval_path(task),
                reject_url: reject_parent_approval_path(task),
                reject_confirm: "Rejeitar esta missão?",
                compact: true
              ) %>
        <% end %>
      </div>
    <% else %>
      <%= render Ui::Empty::Component.new(
        icon: "check",
        title: "Tudo em dia!",
        subtitle: "Nenhuma missão aguardando aprovação."
      ) %>
    <% end %>
  </section>

</div>
