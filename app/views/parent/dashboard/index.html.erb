<div class="screen screen-enter with-nav">
  <%= render Ui::BgShapes::Component.new(variant: "blue") %>

  <%# ─── Header ─── %>
  <div class="row mb-5" style="justify-content: space-between; z-index: 2; flex-shrink: 0;">
    <div class="row" style="gap: 12px;">
      <div style="width: 56px; height: 56px; border-radius: 50%; background: var(--primary-soft); border: 3px solid var(--primary); display: flex; align-items: center; justify-content: center;">
        <%= render Ui::Icon::Component.new(current_profile.avatar.presence || "faceParent", size: 52, color: "var(--primary)") %>
      </div>
      <div class="col" style="gap: 0;">
        <div class="eyebrow">Olá,</div>
        <div class="h-display" style="font-size: 24px;"><%= current_profile.name %></div>
      </div>
    </div>
    <%= button_to sessions_path, method: :delete, class: "btn btn-secondary btn-icon" do %>
      <%= render Ui::Icon::Component.new("logout", size: 20) %>
    <% end %>
  </div>

  <%# ─── KPIs ─── %>
  <div class="grid-3 mb-5" style="gap: 12px; z-index: 2;">
    <div class="card" style="padding: 18px; text-align: center;">
      <div class="row center" style="gap: 6px;">
        <%= render Ui::Icon::Component.new("star", size: 22, color: "var(--star)") %>
        <div class="h-display" style="font-size: 28px; color: var(--star-2);"><%= @stats[:total_stars] %></div>
      </div>
      <div class="eyebrow" style="margin-top: 4px;">Estrelinhas</div>
    </div>

    <div class="card" style="padding: 18px; text-align: center;">
      <div class="row center" style="gap: 6px;">
        <%= render Ui::Icon::Component.new("clock", size: 22, color: "var(--c-peach)") %>
        <div class="h-display" style="font-size: 28px; color: var(--c-peach);" id="pending_approvals_kpi"><%= @stats[:pending_approvals] %></div>
      </div>
      <div class="eyebrow" style="margin-top: 4px;">Aguardando</div>
    </div>

    <div class="card" style="padding: 18px; text-align: center;">
      <div class="row center" style="gap: 6px;">
        <%= render Ui::Icon::Component.new("users", size: 22, color: "var(--primary)") %>
        <div class="h-display" style="font-size: 28px; color: var(--primary);"><%= @stats[:children] %></div>
      </div>
      <div class="eyebrow" style="margin-top: 4px;">Crianças</div>
    </div>
  </div>

  <%# ─── Kids overview ─── %>
  <div class="mb-5" style="z-index: 2;">
    <h3 class="h-display mb-3" style="font-size: 20px;">Visão Geral</h3>

    <% if @children.any? %>
      <div class="col" style="gap: 10px;">
        <% @children.each_with_index do |child, i| %>
          <%
            # Get counts from the pre-calculated hash
            done_count = (@child_stats[[child.id, "approved"]] || 0) + (@child_stats[[child.id, "awaiting_approval"]] || 0)
            total_count = @child_stats.select { |k, v| k[0] == child.id }.values.sum
            pct = total_count.zero? ? 0 : (done_count.to_f / total_count * 100).round
            color = child.color.presence || "primary"
            fg_var = color == "primary" ? "var(--primary)" : "var(--c-#{color})"
          %>

          <%= link_to parent_approvals_path, class: "card pop-on-tap card-tap w-full text-left", style: "padding: 16px; animation: slideInCard 0.4s ease #{i * 0.05}s both; border: 2px solid rgba(26,42,74,0.08); text-decoration: none; display: block;" do %>
            <div class="row" style="gap: 14px;">
              <%= render Ui::KidAvatar::Component.new(kid: child, size: 54) %>
              <div class="col fg1" style="gap: 6px;">
                <div class="row" style="justify-content: space-between; align-items: baseline;">
                  <div class="h-display" style="font-size: 18px; color: var(--text);"><%= child.name %></div>
                  <div class="row" style="gap: 4px; align-items: center;">
                    <%= render Ui::Icon::Component.new("star", size: 14, color: "var(--star)") %>
                    <span class="h-display" style="color: var(--star-2); font-size: 15px;"><%= child.points %></span>
                  </div>
                </div>
                <div class="progress-track" style="height: 10px;">
                  <div class="progress-fill" style="width: <%= pct %>%; background: <%= fg_var %>;"></div>
                </div>
                <div style="font-size: 12px; color: var(--text-muted); font-weight: 700;">
                  <%= done_count %>/<%= total_count %> missões hoje
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%= render Ui::Empty::Component.new(
        icon: "users",
        title: "Nenhuma criança adicionada",
        subtitle: "Para começar as missões, adicione o primeiro filho(a)."
      ) do %>
        <%= link_to "Adicionar Filho", parent_profiles_path, class: "btn btn-primary btn-sm" %>
      <% end %>
    <% end %>
  </div>

  <%# ─── Navigation tiles ─── %>
  <div style="z-index: 2;">
    <h3 class="h-display mb-3" style="font-size: 20px;">Gerenciar</h3>
    <div class="grid-auto" style="gap: 12px;">
      <%
        tiles = [
          { label: "Aprovações", icon: "check",  color: "mint",  path: parent_approvals_path, badge: @stats[:pending_approvals] },
          { label: "Missões",    icon: "target", color: "primary", path: parent_global_tasks_path },
          { label: "Crianças",   icon: "users",  color: "peach", path: parent_profiles_path },
          { label: "Lojinha",    icon: "bag",    color: "rose",  path: parent_rewards_path },
          { label: "Extrato",    icon: "scroll", color: "lilac", path: parent_activity_logs_path },
        ]
      %>
      <% tiles.each_with_index do |tile, i| %>
        <% c_fg = "var(--c-#{tile[:color]})" %>
        <% c_fg = "var(--primary)" if tile[:color] == "primary" %>
        <% c_bg = "var(--c-#{tile[:color]}-soft)" %>
        <% c_bg = "var(--primary-soft)" if tile[:color] == "primary" %>

        <%= link_to tile[:path], class: "card pop-on-tap card-tap", style: "padding: 18px; cursor: pointer; text-align: left; position: relative; border: 2px solid #{c_fg}; box-shadow: 0 4px 0 #{c_fg}; animation: slideInCard 0.4s ease #{0.2 + i * 0.04}s both; display: block; text-decoration: none;" do %>
          <% if tile[:badge].to_i > 0 %>
            <div style="position: absolute; top: -6px; right: -6px; width: 28px; height: 28px; border-radius: 50%; background: var(--danger); color: white; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 800; border: 3px solid white; box-shadow: 0 2px 0 rgba(26,42,74,0.15);">
              <%= tile[:badge] %>
            </div>
          <% end %>
          <div style="width: 46px; height: 46px; border-radius: var(--r-md); background: <%= c_bg %>; color: <%= c_fg %>; display: flex; align-items: center; justify-content: center; margin-bottom: 10px;">
            <%= render Ui::Icon::Component.new(tile[:icon], size: 26, color: c_fg) %>
          </div>
          <div class="h-display" style="font-size: 15px; color: var(--text);"><%= tile[:label] %></div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
