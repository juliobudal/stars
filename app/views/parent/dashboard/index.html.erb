<div class="screen screen-enter with-nav">

  <%# ─── Header ─── %>
  <div class="row mb-5 between z-content" style="flex-shrink: 0; align-items: flex-start;">
    <div>
      <h1 class="h-display" style="font-size: 26px; margin-bottom: 4px;">Olá, <%= current_profile.name %> ✨</h1>
      <p style="font-size: 13px; font-weight: 600; color: var(--text-muted); margin: 0;">
        Você tem <strong><%= @stats[:pending_approvals] %></strong> aprovações aguardando e <strong><%= @stats[:children] %></strong> crianças ativas.
      </p>
    </div>
    <%= link_to new_parent_global_task_path, class: "btn btn-primary btn-sm", style: "white-space: nowrap; flex-shrink: 0;" do %>
      + Nova missão
    <% end %>
  </div>

  <%# ─── Pending approvals banner ─── %>
  <% if @stats[:pending_approvals].to_i > 0 %>
    <div class="banner-approvals z-content" style="flex-shrink: 0;">
      <div class="banner-approvals__icon">
        <%= render Ui::Icon::Component.new("bell", size: 26, color: "white") %>
      </div>
      <div style="flex: 1;">
        <div class="banner-approvals__title" id="pending_approvals_kpi"><%= @stats[:pending_approvals] %> aprovações aguardando</div>
        <div class="banner-approvals__meta"><%= @stats[:active_missions] %> missões · <%= @stats[:rewards_count] %> prêmios</div>
      </div>
      <%= link_to "Ver aprovações →", parent_approvals_path, class: "banner-approvals__cta" %>
    </div>
  <% end %>

  <%# ─── Stats grid (2-col mobile → 4-col desktop) ─── %>
  <div class="stats-grid z-content" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 28px;">
    <%= render Ui::StatCard::Component.new(value: @stats[:total_stars],     label: "Estrelas em circulação", icon: "star",   tint: "star") %>
    <%= render Ui::StatCard::Component.new(value: @stats[:active_missions], label: "Missões ativas",         icon: "target", tint: "primary") %>
    <%= render Ui::StatCard::Component.new(value: @stats[:rewards_count],   label: "Prêmios no catálogo",    icon: "bag",    tint: "rose") %>
    <%= render Ui::StatCard::Component.new(value: @stats[:children],        label: "Crianças ativas",        icon: "users",  tint: "mint") %>
  </div>

  <%# ─── Kid cards ─── %>
  <div class="mb-5 z-content">
    <div class="row mb-3 between">
      <h2 class="h-display" style="font-size: 22px; margin: 0;">Suas crianças</h2>
      <%= link_to "+ Adicionar filho", parent_profiles_path, class: "btn btn-secondary btn-sm" %>
    </div>

    <% if @children.any? %>
      <div class="kids-grid" style="display: grid; grid-template-columns: repeat(1, 1fr); gap: 16px;">
        <% @children.each do |child| %>
          <%= render Ui::KidProgressCard::Component.new(
                kid: child,
                awaiting_count: @child_awaiting[child.id].to_i,
                missions_count: @child_missions[child.id].to_i
              ) %>
        <% end %>
      </div>
    <% else %>
      <%= render Ui::Empty::Component.new(
        icon: "users",
        title: "Nenhuma criança adicionada",
        subtitle: "Para começar as missões, adicione o primeiro filho(a)."
      ) do %>
        <%= link_to "Adicionar Filho", parent_profiles_path, class: "btn btn-primary btn-sm" %>
      <% end %>
    <% end %>
  </div>

  <%# ─── Atividade recente ─── %>
  <div class="z-content">
    <div class="row mb-3 between">
      <h2 class="h-display" style="font-size: 22px; margin: 0;">Atividade recente</h2>
      <%= link_to "Ver tudo", parent_activity_logs_path, style: "font-size: 13px; font-weight: 700; color: var(--primary); text-decoration: none;" %>
    </div>
    <% if @recent_activity.any? %>
      <div class="card" style="padding: 14px 20px;">
        <% @recent_activity.each_with_index do |log, i| %>
          <%= render Ui::ActivityRow::Component.new(log: log, with_divider: i < @recent_activity.size - 1) %>
        <% end %>
      </div>
    <% else %>
      <div class="card" style="padding: 24px; text-align: center; color: var(--text-muted); font-size: 13px; font-weight: 700;">
        Nenhuma atividade ainda.
      </div>
    <% end %>
  </div>
</div>
