<div class="screen screen-enter-right">
  <%= render Ui::BgShapes::Component.new(variant: "cool") %>

  <%# ─── Top Bar ─── %>
  <%= render Ui::TopBar::Component.new(
    title: "Extrato",
    subtitle: "Histórico completo da família",
  ) %>

  <%
    total_earn = @activity_logs.select(&:earn?).sum(&:points)
    total_spend = @activity_logs.reject(&:earn?).sum(&:points)
  %>

  <%# Summary %>
  <div class="grid-2 mb-4" style="gap: 12px; z-index: 2;">
    <div class="card-stat-earned">
      <div class="row" style="gap: 10px;">
        <div class="flex-center" style="width: 40px; height: 40px; border-radius: var(--r-md); background: var(--success);">
          <%= render Ui::Icon::Component.new("arrowUp", size: 22, color: "white") %>
        </div>
        <div class="col-tight">
          <div class="eyebrow" style="color: var(--c-mint-dark);">Ganhou</div>
          <div class="h-display" style="font-size: 22px; color: var(--c-mint-dark);">+<%= total_earn %> ⭐</div>
        </div>
      </div>
    </div>
    <div class="card-stat-spent">
      <div class="row" style="gap: 10px;">
        <div class="flex-center" style="width: 40px; height: 40px; border-radius: var(--r-md); background: var(--c-rose);">
          <%= render Ui::Icon::Component.new("arrowDown", size: 22, color: "white") %>
        </div>
        <div class="col-tight">
          <div class="eyebrow" style="color: var(--c-rose-dark);">Gastou</div>
          <div class="h-display" style="font-size: 22px; color: var(--c-rose-dark);">−<%= total_spend %> ⭐</div>
        </div>
      </div>
    </div>
  </div>

  <div class="col" style="gap: 10px; z-index: 2;">
    <% if @activity_logs.any? %>
      <% @activity_logs.each_with_index do |h, i| %>
        <% earn = h.earn? %>
        <% color = h.profile&.color || "primary" %>
        <div class="card" style="padding: 14px; border: 2px solid rgba(26,42,74,0.06); animation: slideInCard 0.3s ease <%= i * 0.02 %>s both;">
          <div class="row" style="gap: 14px;">
            <div class="flex-center" style="width: 48px; height: 48px; border-radius: var(--r-md); background: <%= earn ? 'var(--c-mint-soft)' : 'var(--c-rose-soft)' %>; color: <%= earn ? 'var(--success)' : 'var(--c-rose)' %>;">
              <%= render Ui::Icon::Component.new(earn ? "sparkle" : "gift", size: 26, color: "currentColor") %>
            </div>
            <div class="col fg1" style="gap: 2px;">
              <div class="h-display" style="font-size: 16px;"><%= h.title %></div>
              <div class="row" style="gap: 6px;">
                <%= render Ui::Badge::Component.new(variant: color, size: "sm") do %>
                  <%= h.profile&.name %>
                <% end %>
                <span style="font-size: 12px; color: var(--text-muted); font-weight: 700;"><%= l(h.created_at, format: :short).upcase %></span>
              </div>
            </div>
            <div class="h-display" style="font-size: 18px; color: <%= earn ? 'var(--success)' : 'var(--c-rose)' %>;">
              <%= earn ? '+' : '−' %><%= h.points %> ⭐
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <%= render Ui::Empty::Component.new(
        icon: "scroll",
        title: "Nada no extrato ainda",
        subtitle: "Complete missões ou faça resgates pra começar o histórico",
        color: "lilac"
      ) %>
    <% end %>
  </div>
</div>
