<div class="page-enter-right">

  <%# ─── Header ─── %>
  <%
    total_earn = @activity_logs.select(&:earn?).sum(&:points)
    total_spend = @activity_logs.reject(&:earn?).sum { |log| log.points.abs }
    grouped = @activity_logs.group_by { |log| log.created_at.to_date }
  %>
  <%= render Ui::PageHeader::Component.new(title: "Extrato", subtitle: "Histórico completo da família") do |h| %>
    <% if @activity_logs.any? %>
      <% h.with_right_slot do %>
        <%= render Ui::HeaderStatChip::Component.new(label: "EVENTOS", value: @activity_logs.size, icon: "scroll", variant: :warning) %>
      <% end %>
    <% end %>
  <% end %>

  <%# ─── Summary ─── %>
  <div class="grid grid-cols-1 sm:grid-cols-2 mb-[18px] gap-3 relative z-10">
    <div class="border-2 p-4 rounded-[16px]"
         style="background: var(--c-info-100); border-color: var(--c-info-500); box-shadow: var(--shadow-card);">
      <div class="flex items-center gap-2.5">
        <div class="flex items-center justify-center w-10 h-10 rounded-[10px] border-2"
             style="background: var(--c-info-500); border-color: var(--c-info-600);">
          <%= render Ui::Icon::Component.new("arrowUp", size: 22, color: "white") %>
        </div>
        <div class="flex flex-col gap-0">
          <div class="text-[11px] font-extrabold tracking-[0.5px] uppercase" style="color: var(--c-info-600);">Ganhou</div>
          <div class="text-[20px] font-extrabold leading-tight tracking-[-0.02em]" style="color: var(--c-info-600);">+<%= total_earn %> ★</div>
        </div>
      </div>
    </div>
    <div class="border-2 p-4 rounded-[16px]"
         style="background: var(--c-rose-soft); border-color: var(--c-rose); box-shadow: var(--shadow-card);">
      <div class="flex items-center gap-2.5">
        <div class="flex items-center justify-center w-10 h-10 rounded-[10px] border-2"
             style="background: var(--c-rose); border-color: var(--c-rose-dark);">
          <%= render Ui::Icon::Component.new("arrowDown", size: 22, color: "white") %>
        </div>
        <div class="flex flex-col gap-0">
          <div class="text-[11px] font-extrabold tracking-[0.5px] uppercase" style="color: var(--c-rose-dark);">Gastou</div>
          <div class="text-[20px] font-extrabold leading-tight tracking-[-0.02em]" style="color: var(--c-rose-dark);">−<%= total_spend %> ★</div>
        </div>
      </div>
    </div>
  </div>

  <%# ─── Day-grouped activity cards ─── %>
  <div class="flex flex-col gap-3 relative z-10">
    <% if grouped.any? %>
      <% grouped.each_with_index do |(day, logs), gi| %>
        <div class="bg-surface rounded-[16px] border-2 border-hairline overflow-hidden"
             style="box-shadow: var(--shadow-card); animation: slideInCard 0.3s ease #{gi * 0.03}s both;">
          <%# Day header %>
          <div class="flex items-center justify-between px-4 py-2.5 border-b-2"
               style="background: var(--surface-muted); border-color: var(--hairline);">
            <div class="text-[11px] font-extrabold tracking-[0.5px] uppercase" style="color: var(--text-muted);">
              <%= l(day, format: :long) %>
            </div>
            <div class="text-[11px] font-extrabold tracking-[0.5px] uppercase" style="color: var(--text-muted);">
              <%= logs.size %> <%= logs.size == 1 ? "evento" : "eventos" %>
            </div>
          </div>

          <%# Rows %>
          <div class="flex flex-col">
            <% logs.each_with_index do |log, i| %>
              <% earn = log.earn? %>
              <% chip_bg = earn ? "var(--star-soft)" : "var(--c-rose-soft)" %>
              <% chip_fg = earn ? "var(--c-amber-dark)" : "var(--c-rose-dark)" %>
              <% chip_border = earn ? "var(--star)" : "var(--c-rose)" %>
              <div class="flex items-center gap-3 px-4 py-3 <%= 'border-t-2 border-hairline' unless i.zero? %>">
                <div class="w-10 h-10 rounded-[10px] grid place-items-center shrink-0 border-2"
                     style="background: <%= chip_bg %>; border-color: <%= chip_border %>;">
                  <%= render Ui::Icon::Component.new(earn ? "sparkle" : "gift", size: 20, color: chip_fg) %>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-[14px] leading-tight font-extrabold truncate" style="color: var(--text);">
                    <%= log.title %>
                  </div>
                  <div class="flex items-center gap-1.5 mt-1">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-[10px] text-[11px] font-extrabold border-2"
                          style="background: <%= chip_bg %>; color: <%= chip_fg %>; border-color: <%= chip_border %>;">
                      <%= log.profile&.name %>
                    </span>
                    <span class="text-[11px] font-bold" style="color: var(--text-muted);">
                      <%= l(log.created_at, format: :short).upcase %>
                    </span>
                  </div>
                </div>
                <div class="text-[15px] font-extrabold tracking-[-0.02em] shrink-0" style="color: <%= chip_fg %>;">
                  <%= earn ? "+" : "−" %><%= log.points.abs %> ★
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <%= render Ui::Empty::Component.new(
        icon: "scroll",
        title: "Nada no extrato ainda",
        subtitle: "Complete missões ou faça resgates pra começar o histórico",
        color: "lilac"
      ) %>
    <% end %>
  </div>
</div>
