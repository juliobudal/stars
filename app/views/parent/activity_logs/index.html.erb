<div class="screen screen-enter-right">
  <%= render Ui::BgShapes::Component.new(variant: "cool") %>

  <%# ─── Top Bar ─── %>
  <%= render Ui::TopBar::Component.new(
    title: "Extrato",
    subtitle: "Histórico completo da família",
  ) %>

  <%
    total_earn = @activity_logs.select(&:earn?).sum(&:points)
    total_spend = @activity_logs.reject(&:earn?).sum { |log| log.points.abs }
  %>

  <%# Summary %>
  <div class="grid grid-cols-1 sm:grid-cols-2 mb-4 gap-3 relative z-10">
    <div class="border-2 border-success bg-mint-soft p-4 rounded-xl">
      <div class="flex items-center gap-2.5">
        <div class="flex items-center justify-center w-10 h-10 rounded-md bg-success">
          <%= render Ui::Icon::Component.new("arrowUp", size: 22, color: "white") %>
        </div>
        <div class="flex flex-col gap-0">
          <div class="font-display text-[11px] font-bold tracking-[0.08em] uppercase text-primary text-mint-dark">Ganhou</div>
          <%= render Ui::StarValue::Component.new(value: total_earn, prefix: "+", size: :lg, color: :gold, class: "tracking-[-0.02em] text-mint-dark") %>
        </div>
      </div>
    </div>
    <div class="border-2 border-rose bg-rose-soft p-4 rounded-xl">
      <div class="flex items-center gap-2.5">
        <div class="flex items-center justify-center w-10 h-10 rounded-md bg-rose">
          <%= render Ui::Icon::Component.new("arrowDown", size: 22, color: "white") %>
        </div>
        <div class="flex flex-col gap-0">
          <div class="font-display text-[11px] font-bold tracking-[0.08em] uppercase text-primary text-rose-dark">Gastou</div>
          <%= render Ui::StarValue::Component.new(value: total_spend, prefix: "−", size: :lg, color: :gold, class: "tracking-[-0.02em] text-rose-dark") %>
        </div>
      </div>
    </div>
  </div>

  <div class="flex flex-col gap-2.5 relative z-10">
    <% if @activity_logs.any? %>
      <% @activity_logs.each_with_index do |h, i| %>
        <% earn = h.earn? %>
        <% color = h.profile&.color || "primary" %>
        <%= render Ui::Card::Component.new(padding: "p-3.5", class: "border-2 border-[rgba(26,42,74,0.06)]", style: "animation: slideInCard 0.3s ease #{i * 0.02}s both;") do %>
          <div class="flex items-center gap-3.5">
            <div class="flex items-center justify-center w-12 h-12 rounded-md <%= earn ? 'bg-mint-soft text-success' : 'bg-rose-soft text-rose' %>">
              <%= render Ui::Icon::Component.new(earn ? "sparkle" : "gift", size: 26, color: "currentColor") %>
            </div>
            <div class="flex flex-col flex-1 gap-0.5">
              <div class="font-display text-[16px] leading-tight font-extrabold tracking-[-0.02em] text-foreground"><%= h.title %></div>
              <div class="flex items-center gap-1.5">
                <%= render Ui::Badge::Component.new(variant: color, size: "sm") do %>
                  <%= h.profile&.name %>
                <% end %>
                <span class="text-[12px] text-muted-foreground font-bold"><%= l(h.created_at, format: :short).upcase %></span>
              </div>
            </div>
            <%= render Ui::StarValue::Component.new(value: h.points.abs, prefix: (earn ? '+' : '−'), size: :md, color: :gold, class: "tracking-[-0.02em] #{earn ? 'text-success' : 'text-rose'}") %>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <%= render Ui::Empty::Component.new(
        icon: "scroll",
        title: "Nada no extrato ainda",
        subtitle: "Complete missões ou faça resgates pra começar o histórico",
        color: "lilac"
      ) %>
    <% end %>
  </div>
</div>
