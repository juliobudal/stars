<%# Activity Logs — LittleStars Design System %>
<div class="screen screen-enter">

  <%# ─── Top Bar ─── %>
  <%= render Ui::TopBar::Component.new(
    title: "Extrato",
    subtitle: "Histórico de missões e prêmios",
    back_url: parent_root_path
  ) %>

  <div style="z-index: 2;">
    <% if @activity_logs.any? %>
      <div class="col" style="gap: 10px;">
        <% @activity_logs.each_with_index do |log, i| %>
          <div class="card" style="padding: 14px; animation: slideInCard 0.4s ease <%= i * 0.03 %>s both;">
            <div class="row" style="gap: 14px;">
              <div style="width: 52px; height: 52px; border-radius: 50%; background: var(--primary-soft); border: 3px solid var(--primary); overflow: hidden; flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                <span style="font-size: 26px;"><%= log.profile.avatar.presence || "👤" %></span>
              </div>
              <div class="col fg1" style="gap: 2px;">
                <div style="font-size: 12px; font-weight: 800; color: var(--primary); text-transform: uppercase; letter-spacing: 0.08em;"><%= log.profile.name %></div>
                <div class="h-display" style="font-size: 16px;"><%= log.title %></div>
              </div>
              <div style="text-align: right; flex-shrink: 0;">
                <div class="row" style="gap: 6px; justify-content: flex-end;">
                  <span style="font-size: 18px; font-weight: 800; color: <%= log.earn? ? 'var(--success)' : 'var(--danger)' %>;">
                    <%= log.earn? ? "+" : "-" %><%= log.points %>
                  </span>
                  <i class="ph-fill ph-star" style="font-size: 18px; color: var(--star);"></i>
                </div>
                <div style="font-size: 11px; color: var(--text-soft); font-weight: 700; margin-top: 2px;"><%= l(log.created_at, format: :short).upcase %></div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="center col" style="padding: 40px; text-align: center; gap: 14px;">
        <div style="width: 80px; height: 80px; border-radius: var(--r-md); background: var(--c-lilac-soft); color: var(--c-lilac); display: flex; align-items: center; justify-content: center;">
          <i class="ph-bold ph-scroll" style="font-size: 44px;"></i>
        </div>
        <h3 class="h-display" style="font-size: 22px; margin-top: 8px;">Nenhuma atividade registrada</h3>
        <p class="subtitle" style="max-width: 320px;">Quando as crianças completarem missões ou resgatarem prêmios, aparecerá aqui.</p>
      </div>
    <% end %>
  </div>

</div>
