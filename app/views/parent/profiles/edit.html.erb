<div class="screen screen-enter-right">
  <%= render Ui::BgShapes::Component.new(variant: "warm") %>

  <%# ─── Header ─── %>
  <div class="flex items-center gap-3.5 mb-[22px] z-content">
    <%= link_to parent_profiles_path,
          class: "ls-btn-3d inline-flex items-center justify-center w-10 h-10 rounded-[12px] no-underline border-2 shrink-0",
          style: "background: var(--surface); border-color: var(--hairline); box-shadow: 0 3px 0 var(--hairline);",
          aria: { label: "Voltar" } do %>
      <%= render Ui::Icon::Component.new("arrow-left", size: 18, color: "var(--text-muted)") %>
    <% end %>
    <div class="min-w-0">
      <h1 class="text-[24px] font-extrabold leading-tight m-0 mb-0.5" style="color: var(--text);">
        Editar <%= @profile.name %>
      </h1>
      <p class="text-[13px] font-bold m-0" style="color: var(--text-muted);">
        Personalize o perfil da criança.
      </p>
    </div>
  </div>

  <div class="z-content">
    <%= render 'form', profile: @profile %>
  </div>
</div>
