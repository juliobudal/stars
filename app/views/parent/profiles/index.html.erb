<div class="screen screen-enter-right with-nav">
  <%= render Ui::BgShapes::Component.new(variant: "warm") %>

  <%# ─── Header ─── %>
  <%= render Ui::PageHeader::Component.new(
        title: "Crianças",
        subtitle: "Gerencie as crianças da família. Adicione novas, mude cor, nome ou expressão."
      ) do |h| %>
    <% h.with_right_slot do %>
      <%= render Ui::Btn::Component.new(variant: "primary", url: new_parent_profile_path) do %>
        <%= render Ui::Icon::Component.new("plus", size: 14, color: "currentColor") %>
        Nova criança
      <% end %>
    <% end %>
  <% end %>

  <% if @profiles.any? %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 z-content">
      <% @profiles.each do |k| %>
        <%= render Ui::KidProgressCard::Component.new(
              kid: k,
              awaiting_count: k.profile_tasks.select(&:awaiting_approval?).size,
              missions_count: k.profile_tasks.select(&:pending?).size,
              manage: true
            ) %>
      <% end %>
    </div>

    <div class="mt-4 z-content">
      <%= link_to new_parent_profile_path,
            class: "ls-btn-3d flex items-center justify-center gap-2 w-full py-4 rounded-[16px] text-[14px] font-extrabold uppercase tracking-[0.5px] no-underline border-2 border-dashed",
            style: "background: var(--surface); color: var(--text-muted); border-color: var(--hairline);" do %>
        <%= render Ui::Icon::Component.new("plus", size: 14, color: "currentColor") %>
        Adicionar outra criança
      <% end %>
    </div>
  <% else %>
    <%= render Ui::Empty::Component.new(
      icon: "users",
      title: "Nenhum perfil",
      subtitle: "Adicione sua primeira criança para começar!",
      color: "peach"
    ) do %>
      <%= render Ui::Btn::Component.new(variant: "primary", size: "sm", url: new_parent_profile_path) do %>
        + Nova criança
      <% end %>
    <% end %>
  <% end %>
</div>
