<div class="screen screen-enter-right with-nav">
  <%= render Ui::BgShapes::Component.new(variant: "warm") %>

  <%= render Ui::TopBar::Component.new(
    title: "Filhos",
    subtitle: "Gerencia as crianças da família. Adicione novas, mude cor, nome ou expressão.",
    back_url: parent_root_path
  ) do |bar| %>
    <% bar.with_right_slot do %>
      <%= link_to new_parent_profile_path, class: "btn btn-primary" do %>
        <%= render Ui::Icon::Component.new("star", size: 16, color: "white") %> Adicionar filho
      <% end %>
    <% end %>
  <% end %>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; z-index: 2; align-items: start;">
    <% if @profiles.any? %>
      <% @profiles.each do |k| %>
        <%= render Ui::KidManagementCard::Component.new(
              kid: k,
              balance: k.points,
              missions_count: k.profile_tasks.select(&:pending?).size
            ) %>
      <% end %>
    <% end %>

    <%= link_to new_parent_profile_path, class: "ghost-add-card" do %>
      <div style="width: 40px; height: 40px; border-radius: 50%; border: 2px dashed currentColor; display: flex; align-items: center; justify-content: center; font-size: 22px; font-weight: 300; line-height: 1;">+</div>
      <span style="font-size: 13px; font-weight: 700;">Adicionar filho</span>
    <% end %>

    <% if @profiles.empty? %>
      <div style="grid-column: 1 / -1;">
        <%= render Ui::Empty::Component.new(
          icon: "users",
          title: "Nenhum perfil",
          subtitle: "Adicione seu primeiro filho para começar!",
          color: "peach"
        ) %>
      </div>
    <% end %>
  </div>
</div>
