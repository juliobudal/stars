<div class="screen screen-enter-right with-nav">
  <%= render Ui::BgShapes::Component.new(variant: "warm") %>

  <%= render Ui::TopBar::Component.new(
    title: "Crianças",
    subtitle: "Gerencie as crianças da família. Adicione novas, mude cor, nome ou expressão.",
  ) do |bar| %>
    <% bar.with_right_slot do %>
      <%= render Ui::Btn::Component.new(variant: "primary", url: new_parent_profile_path) do %>
        <%= render Ui::Icon::Component.new("star", size: 16, color: "white") %> + Adicionar criança
      <% end %>
    <% end %>
  <% end %>

  <div class="grid grid-cols-[repeat(auto-fill,minmax(240px,1fr))] gap-4 z-2 items-start">
    <% if @profiles.any? %>
      <% @profiles.each do |k| %>
        <%= render Ui::KidManagementCard::Component.new(
              kid: k,
              balance: k.points,
              missions_count: k.profile_tasks.select(&:pending?).size
            ) %>
      <% end %>
    <% end %>

    <%= render Ui::KidPlaceholderCard::Component.new(href: new_parent_profile_path) %>

    <% if @profiles.empty? %>
      <div class="col-[1/-1]">
        <%= render Ui::Empty::Component.new(
          icon: "users",
          title: "Nenhum perfil",
          subtitle: "Adicione sua primeira criança para começar!",
          color: "peach"
        ) %>
      </div>
    <% end %>
  </div>
</div>
