<div class="screen screen-enter-right">
  <%= render Ui::BgShapes::Component.new(variant: "warm") %>

  <%= render Ui::TopBar::Component.new(
    title: "Crianças",
    subtitle: "Gerencie perfis e saldos",
    back_url: parent_root_path
  ) do |bar| %>
    <% bar.with_right_slot do %>
      <%= link_to new_parent_profile_path, class: "btn btn-primary" do %>
        <%= render Ui::Icon::Component.new("plus", size: 18, color: "white") %> Adicionar
      <% end %>
    <% end %>
  <% end %>

  <div class="grid-3" style="gap: 16px; z-index: 2;">
    <% @profiles.each_with_index do |k, i| %>
      <%
        color = k.color.presence || "primary"
        fg_var = color == "primary" ? "var(--primary)" : "var(--c-#{color})"
        palette = smiley_palette(k)
        pending = k.profile_tasks.where(status: :pending).size
      %>
      <div class="card kid-card" style="position: relative; padding: 0; overflow: hidden; border: 2px solid <%= fg_var %>; box-shadow: 0 4px 0 <%= fg_var %>; animation: slideInCard 0.35s ease <%= i * 0.05 %>s both;">
        <div class="kid-card-band" style="background: <%= palette[:fill] %>; padding: 20px 16px 16px; display: flex; justify-content: center; position: relative;">
          <%= link_to edit_parent_profile_path(k), class: "kid-card-edit", style: "position: absolute; top: 10px; right: 10px; display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; background: rgba(255,255,255,0.7); color: #{palette[:ink]};", aria: { label: "Editar #{k.name}" } do %>
            <%= render Ui::Icon::Component.new("pencil", size: 16, color: palette[:ink]) %>
          <% end %>
          <%= render Ui::KidAvatar::Component.new(kid: k, size: 72) %>
        </div>

        <div class="col" style="gap: 10px; padding: 14px 16px 16px;">
          <div class="h-display" style="font-size: 18px; text-align: center; color: var(--text);"><%= k.name %></div>

          <div class="grid-2" style="gap: 10px;">
            <div class="stat-mini" style="padding: 10px; border-radius: 12px; background: var(--surface-2); text-align: center;">
              <div class="label" style="font-size: 10px; font-weight: 800; letter-spacing: .1em; color: var(--text-muted);">SALDO</div>
              <div class="row" style="gap: 4px; justify-content: center; align-items: center; margin-top: 4px;">
                <%= render Ui::Icon::Component.new("star", size: 14, color: "var(--star)") %>
                <span class="h-display" style="font-size: 16px; color: var(--star-2);"><%= k.points %></span>
              </div>
            </div>
            <div class="stat-mini" style="padding: 10px; border-radius: 12px; background: var(--surface-2); text-align: center;">
              <div class="label" style="font-size: 10px; font-weight: 800; letter-spacing: .1em; color: var(--text-muted);">MISSÕES</div>
              <div class="h-display" style="font-size: 16px; color: var(--text); margin-top: 4px;"><%= pending %></div>
            </div>
          </div>

          <div class="row" style="gap: 8px; margin-top: 4px;">
            <%= link_to "Ver jornada", parent_activity_logs_path(profile_id: k.id), class: "btn btn-ghost btn-sm fg1", style: "justify-content: center;" %>
            <%= button_to parent_profile_path(k), method: :delete, class: "btn btn-ghost btn-sm", style: "color: var(--danger);", data: { turbo_confirm: "Remover o perfil \"#{k.name}\"?" } do %>
              Remover
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%= link_to new_parent_profile_path, class: "card", style: "min-height: 300px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; border: 2px dashed var(--hairline); background: transparent; box-shadow: none; color: var(--text-muted); text-decoration: none;" do %>
      <div style="width: 56px; height: 56px; border-radius: 50%; background: var(--surface-2); display: flex; align-items: center; justify-content: center;">
        <%= render Ui::Icon::Component.new("plus", size: 28, color: "var(--text-muted)") %>
      </div>
      <div class="h-display" style="font-size: 15px;">Adicionar filho</div>
    <% end %>
  </div>

  <% if @profiles.empty? %>
    <div style="margin-top: 16px;">
      <%= render Ui::Empty::Component.new(
        icon: "users",
        title: "Nenhum perfil",
        subtitle: "Adicione seu primeiro filho para começar!",
        color: "peach"
      ) %>
    </div>
  <% end %>
</div>
