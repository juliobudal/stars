<%= form_with(model: [:parent, profile], html: { data: { controller: "form-preview" } }, class: "block") do |f| %>
  <% if profile.errors.any? %>
    <%= render Ui::Card::Component.new(variant: "flat", class: "bg-danger-soft text-danger p-4 mb-4") do %>
      <%= render Ui::Heading::Component.new(size: :h3) do %>Ops! Algo deu errado:<% end %>
      <ul class="text-[14px] text-muted-foreground font-semibold list-disc ml-5">
        <% profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%
    color_options = %w[peach rose mint sky lilac coral]
    current_color = profile.color.presence || color_options.first
    current_avatar = profile.avatar.presence || (profile.parent? ? "user-circle" : "happy-01")
  %>

  <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8 items-start">
    <div class="flex flex-col gap-5">
      <div class="flex flex-col gap-2">
        <%= f.label :name, "Nome", class: "font-display font-extrabold text-[15px] text-foreground tracking-tight" %>
        <%= f.text_field :name,
              class: "w-full px-5 py-4 bg-white border-2 border-hairline rounded-2xl font-semibold text-[17px] text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-0 transition-all shadow-sm",
              placeholder: "Ex: Lila",
              data: { form_preview_field: "name" } %>
      </div>

      <div class="flex flex-col gap-2">
        <label class="font-display font-extrabold text-[15px] text-foreground tracking-tight">Avatar</label>
        <%= render Ui::IconPicker::Component.new(
              field_name: "profile[avatar]",
              value: current_avatar,
              context: :avatar,
              color: "var(--primary)",
              id: "profile_avatar_picker",
              input_data: { form_preview_field: "avatar" }
            ) %>
      </div>

      <%= render Ui::ColorPicker::Component.new(form: f, field: :color, options: color_options, label: "Cor", input_data: { form_preview_field: "color" }) %>

      <div class="flex flex-col gap-2">
        <%= f.label :pin, "PIN (4 dígitos)", class: "font-display font-extrabold text-[15px] text-foreground tracking-tight" %>
        <%= f.text_field :pin, pattern: "\\d{4}", maxlength: 4, inputmode: "numeric",
              autocomplete: "off", required: action_name == "new",
              class: "w-full px-5 py-4 bg-white border-2 border-hairline rounded-2xl font-semibold text-[17px] text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-0 transition-all shadow-sm" %>
      </div>

      <% if params[:onboarding].present? %>
        <%= hidden_field_tag :onboarding, params[:onboarding] %>
      <% end %>
      <% if params[:invited].present? %>
        <%= hidden_field_tag :invited, params[:invited] %>
      <% end %>

      <div class="flex flex-row mt-4 gap-2.5 justify-end">
        <%= render Ui::Btn::Component.new(variant: "secondary", url: (params[:onboarding].present? ? parent_root_path : parent_profiles_path)) do %>Voltar<% end %>
        <%= render Ui::Btn::Component.new(variant: "primary", type: "submit") do %>Salvar Perfil<% end %>
      </div>
    </div>

    <aside class="hidden lg:block">
      <div class="sticky top-6">
        <%= render Ui::Card::Component.new(class: "p-6 flex flex-col items-center gap-4 text-center") do %>
          <div data-form-preview-target="color" data-form-preview-palette="true" data-palette="<%= current_color %>"
               class="flex flex-col items-center gap-4">
            <div class="w-32 h-32 rounded-full flex items-center justify-center shrink-0"
                 style="background: var(--primary-soft); border: 4px solid var(--primary);">
              <i data-form-preview-target="avatar" data-form-preview-icon="true"
                 class="hgi-stroke hgi-<%= current_avatar %>"
                 style="font-size:80px; line-height:1; color: var(--primary); display:inline-flex; align-items:center; justify-content:center; width:80px; height:80px;"
                 aria-hidden="true"></i>
            </div>
            <div class="flex flex-col gap-1 w-full">
              <div data-form-preview-target="name" data-form-preview-fallback="Pré-visualização"
                   class="font-display font-extrabold text-[20px] text-foreground truncate"><%= profile.name.presence || "Pré-visualização" %></div>
              <div class="text-[12px] text-muted-foreground font-semibold uppercase tracking-wider">
                <%= profile.parent? ? "Responsável" : "Criança" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </aside>
  </div>

  <% unless profile.new_record? %>
    <div class="mt-8 pt-6 border-t-2 border-border">
      <% confirm_msg = profile.parent? ? "Remover este responsável? Esta ação é permanente." : "Remover #{profile.name}? Todas as missões e histórico serão perdidos." %>
      <%= render Ui::Btn::Component.new(variant: "danger", size: "sm", url: parent_profile_path(profile), method: :delete, data: { turbo_confirm: confirm_msg }) do %>
        <%= render Ui::Icon::Component.new("trash", size: 16, color: "white") %> Remover Perfil
      <% end %>
    </div>
  <% end %>
<% end %>
