<%= form_with(model: [:parent, profile], class: "col", style: "gap: 20px;") do |f| %>
  <% if profile.errors.any? %>
    <%= render Ui::Card::Component.new(variant: "flat", class: "bg-danger-soft text-danger p-4 mb-4") do %>
      <h3 class="h-display" style="font-size: 18px;">Ops! Algo deu errado:</h3>
      <ul class="subtitle" style="font-size: 14px; list-style: disc; margin-left: 20px;">
        <% profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%
    icon_options = %w[faceFox faceHero facePrincess faceKid faceParent]
    color_options = %w[peach rose mint sky lilac coral]
    current_color = profile.color.presence || "peach"
  %>

  <div class="center mb-4">
    <%= render Ui::KidAvatar::Component.new(kid: profile, size: 100) %>
  </div>

  <div class="form-field">
    <%= f.label :name, "Nome", class: "form-label" %>
    <%= f.text_field :name, class: "form-input", placeholder: "Ex: Lila" %>
  </div>

  <div class="form-field">
    <label class="form-label">Avatar</label>
    <div class="row wrap" style="gap: 8px;">
      <% icon_options.each do |ic| %>
        <label class="cursor-pointer">
          <%= f.radio_button :avatar, ic, class: "peer sr-only" %>
          <div class="peer-checked:bg-primary-soft peer-checked:border-primary border-2 border-transparent p-1 rounded-full transition-all" style="width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; background: white; border: 2px solid rgba(26,42,74,0.1);">
            <%= render Ui::Icon::Component.new(ic, size: 48, color: "var(--primary)") %>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <div class="form-field">
    <label class="form-label">Cor</label>
    <div class="row wrap" style="gap: 10px;">
      <% color_options.each do |col| %>
        <label class="cursor-pointer">
          <%= f.radio_button :color, col, class: "peer sr-only" %>
          <div class="peer-checked:border-text border-3 border-transparent rounded-full transition-all" style="width: 40px; height: 40px; background: var(--c-<%= col %>);"></div>
        </label>
      <% end %>
    </div>
  </div>

  <div class="row mt-4" style="gap: 10px; justify-content: flex-end;">
    <%= link_to "Cancelar", parent_root_path, class: "btn btn-secondary" %>
    <%= f.submit "Salvar Perfil", class: "btn btn-primary" %>
  </div>

  <% unless profile.new_record? %>
    <div class="mt-8 pt-6 border-t-2 border-border">
      <%= button_to parent_profile_path(profile), method: :delete, class: "btn btn-danger btn-sm", data: { turbo_confirm: "Tem certeza? Isso apagará todas as tarefas e histórico deste perfil." } do %>
        <%= render Ui::Icon::Component.new("trash", size: 16, color: "white") %> Remover Perfil
      <% end %>
    </div>
  <% end %>
<% end %>
