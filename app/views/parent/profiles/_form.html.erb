<%= form_with(model: [:parent, profile], class: "col gap-5") do |f| %>
  <% if profile.errors.any? %>
    <%= render Ui::Card::Component.new(variant: "flat", class: "bg-danger-soft text-danger p-4 mb-4") do %>
      <%= render Ui::Heading::Component.new(size: :h3) do %>Ops! Algo deu errado:<% end %>
      <ul class="text-[14px] text-muted-foreground font-semibold list-disc ml-5">
        <% profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%
    icon_options = profile.parent? ? %w[faceParent faceHero faceFox] : %w[faceFox faceHero facePrincess faceKid]
    color_options = %w[peach rose mint sky lilac coral]
    current_color = profile.color.presence || "peach"
  %>

  <div class="flex items-center justify-center mb-4">
    <% if profile.parent? %>
      <%= render Ui::SmileyAvatar::Component.new(kid: profile, size: 100) %>
    <% else %>
      <%= render Ui::KidAvatar::Component.new(kid: profile, size: 100) %>
    <% end %>
  </div>

  <div class="mb-6 flex flex-col gap-2">
    <%= f.label :name, "Nome", class: "font-display font-extrabold text-[15px] text-foreground tracking-tight" %>
    <%= f.text_field :name, class: "w-full px-5 py-4 bg-white border-2 border-hairline rounded-2xl font-semibold text-[17px] text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-0 transition-all shadow-sm", placeholder: "Ex: Lila" %>
  </div>

  <div class="mb-6 flex flex-col gap-2">
    <label class="font-display font-extrabold text-[15px] text-foreground tracking-tight">Avatar</label>
    <div class="row flex-wrap gap-2">
      <% icon_options.each do |ic| %>
        <label class="cursor-pointer">
          <%= f.radio_button :avatar, ic, class: "peer sr-only" %>
          <div class="peer-checked:bg-primary-soft peer-checked:border-primary border-2 border-[rgba(26,42,74,0.1)] p-1 rounded-full transition-all flex items-center justify-center w-14 h-14 bg-white">
            <%= render Ui::Icon::Component.new(ic, size: 48, color: "var(--primary)") %>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <div class="mb-6 flex flex-col gap-2">
    <label class="font-display font-extrabold text-[15px] text-foreground tracking-tight">Cor</label>
    <div class="row flex-wrap gap-2.5">
      <% color_options.each do |col| %>
        <label class="cursor-pointer">
          <%= f.radio_button :color, col, class: "peer sr-only" %>
          <div class="peer-checked:border-text border-3 border-transparent rounded-full transition-all w-10 h-10" style="background: var(--c-<%= col %>);"></div>
        </label>
      <% end %>
    </div>
  </div>

  <div class="mb-6 flex flex-col gap-2">
    <%= f.label :pin, "PIN (4 dígitos)", class: "font-display font-extrabold text-[15px] text-foreground tracking-tight" %>
    <%= f.text_field :pin, pattern: "\\d{4}", maxlength: 4, inputmode: "numeric",
        autocomplete: "off", required: action_name == "new",
        class: "w-full px-5 py-4 bg-white border-2 border-hairline rounded-2xl font-semibold text-[17px] text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-0 transition-all shadow-sm" %>
  </div>

  <% if params[:onboarding].present? %>
    <%= hidden_field_tag :onboarding, params[:onboarding] %>
  <% end %>
  <% if params[:invited].present? %>
    <%= hidden_field_tag :invited, params[:invited] %>
  <% end %>

  <div class="row mt-4 gap-2.5 justify-end">
    <%= render Ui::Btn::Component.new(variant: "secondary", url: (params[:onboarding].present? ? parent_root_path : parent_profiles_path)) do %>Voltar<% end %>
    <%= render Ui::Btn::Component.new(variant: "primary", type: "submit") do %>Salvar Perfil<% end %>
  </div>

  <% unless profile.new_record? %>
    <div class="mt-8 pt-6 border-t-2 border-border">
      <% confirm_msg = profile.parent? ? "Remover este responsável? Esta ação é permanente." : "Tem certeza? Isso apagará todas as tarefas e histórico deste perfil." %>
      <%= render Ui::Btn::Component.new(variant: "danger", size: "sm", url: parent_profile_path(profile), method: :delete, data: { turbo_confirm: confirm_msg }) do %>
        <%= render Ui::Icon::Component.new("trash", size: 16, color: "white") %> Remover Perfil
      <% end %>
    </div>
  <% end %>
<% end %>
