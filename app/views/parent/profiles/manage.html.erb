<div class="page-enter-right">

  <%= render Ui::PageHeader::Component.new(
        title: @child.name,
        subtitle: "Tudo sobre #{@child.name} num só lugar"
      ) do |h| %>
    <% h.with_right_slot do %>
      <div class="flex items-center gap-2 flex-wrap justify-end">
        <%= render Ui::Btn::Component.new(variant: "secondary", size: "sm", url: parent_root_path) do %>
          <%= render Ui::Icon::Component.new("back", size: 14, color: "currentColor") %>
          Início
        <% end %>
        <%= render Ui::Btn::Component.new(variant: "secondary", size: "sm", url: edit_parent_profile_path(@child)) do %>
          <%= render Ui::Icon::Component.new("pencil", size: 14, color: "currentColor") %>
          Editar perfil
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# ── Snapshot ── %>
  <div class="mb-5">
    <%= render Ui::KidProgressCard::Component.new(kid: @child, awaiting_count: @awaiting_count, missions_count: @today_count) %>
  </div>

  <% if @awaiting_count.positive? %>
    <%= link_to parent_approvals_path,
          class: "flex items-center justify-between gap-3 mb-5 px-4 py-3 rounded-[14px] border-2 no-underline",
          style: "background: var(--c-rose-soft); border-color: var(--danger); box-shadow: 0 3px 0 var(--danger-2);" do %>
      <span class="text-[13px] font-extrabold inline-flex items-center gap-2" style="color: var(--danger-2);">
        <%= render Ui::Icon::Component.new("clock", size: 16, color: "var(--danger)") %>
        <%= @awaiting_count %> <%= @awaiting_count == 1 ? "missão aguardando" : "missões aguardando" %> aprovação
      </span>
      <%= render Ui::Icon::Component.new("chevron", size: 16, color: "var(--danger-2)") %>
    <% end %>
  <% end %>

  <%# ── Missões desta criança ── %>
  <section data-controller="child-assign" class="relative">
    <div data-child-assign-target="toast" hidden
         class="fixed bottom-[96px] lg:bottom-6 left-1/2 -translate-x-1/2 z-[500] px-5 py-3 rounded-full text-white font-display font-extrabold text-[14px] shadow-lift bg-destructive anim-pop-in"></div>

    <div class="flex items-center justify-between mb-3">
      <h2 class="text-[16px] font-extrabold m-0" style="color: var(--text);">Missões de <%= @child.name %></h2>
      <%= link_to "Catálogo →", parent_global_tasks_path, class: "text-[12px] font-extrabold uppercase tracking-[0.5px] no-underline", style: "color: var(--c-info-600);" %>
    </div>

    <% if @missions.any? %>
      <p class="text-[12px] font-bold mb-3" style="color: var(--text-soft);">Ative para incluir esta criança na missão.</p>
      <div class="flex flex-col gap-2.5">
        <% @missions.each do |mission| %>
          <%= render "manage_mission_row", mission: mission, child: @child, saved: false %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-surface rounded-[16px] border-2 p-5" style="border-color: var(--hairline); box-shadow: var(--shadow-card);">
        <%= render Ui::Empty::Component.new(
              icon: "target", color: "primary",
              title: "Nenhuma missão ainda",
              subtitle: "Crie missões ou use a biblioteca para começar."
            ) do %>
          <%= render Ui::Btn::Component.new(variant: "primary", size: "sm", url: library_parent_global_tasks_path) do %>Abrir biblioteca<% end %>
        <% end %>
      </div>
    <% end %>
  </section>
</div>
