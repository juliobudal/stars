<%#
  One mission toggle on the per-child management panel. Re-rendered (turbo
  replace) on every toggle so it reflects committed state.
  Locals: mission, child, saved (bool).
%>
<%
  assigned = mission.assigned_to_all? || mission.assigned_profiles.map(&:id).include?(child.id)
  cm = Ui::Tokens.category_for(mission.category)
  fm = Ui::Tokens.frequency_for(mission.frequency)
  tint_soft = Ui::Tokens.tint_soft(cm[:tint])
  tint_fg   = Ui::Tokens.tint_fg(cm[:tint])
%>
<label id="manage_mission_<%= mission.id %>"
       class="group flex items-center gap-3 p-3 rounded-[14px] border cursor-pointer transition-colors
              has-[:checked]:border-[var(--primary)] has-[:checked]:bg-[var(--primary-soft)]"
       style="background: var(--surface); border-color: var(--hairline); <%= 'opacity:.6;' unless mission.active? %>">
  <input type="checkbox" class="peer sr-only" value="<%= mission.id %>" <%= "checked" if assigned %>
         data-url="<%= toggle_mission_parent_profile_path(child) %>"
         data-action="change->child-assign#toggle"
         aria-label="<%= mission.title %>">

  <div class="w-11 h-11 rounded-[12px] flex items-center justify-center shrink-0 border"
       style="background: <%= tint_soft %>; border-color: <%= tint_fg %>;">
    <%= render Ui::Icon::Component.new(cm[:icon], size: 22, color: tint_fg) %>
  </div>

  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-1.5">
      <span class="text-[14px] font-extrabold truncate" style="color: var(--text);"><%= mission.title %></span>
      <% unless mission.active? %>
        <span class="text-[9px] font-extrabold uppercase px-1.5 py-0.5 rounded-[5px] shrink-0"
              style="background: var(--star-soft); color: var(--c-reward-text);">pausada</span>
      <% end %>
    </div>
    <div class="flex items-center gap-1.5 mt-0.5">
      <span class="text-[11px] font-bold" style="color: var(--text-muted);"><%= fm[:label] %> · <%= mission.points %>★</span>
      <% if saved %>
        <span data-saved-chip class="anim-pop-in inline-flex items-center gap-0.5 text-[11px] font-extrabold" style="color: var(--text);">
          <%= render Ui::Icon::Component.new("check", size: 12, color: "var(--primary)") %> salvo
        </span>
      <% end %>
    </div>
  </div>

  <%# Track + thumb (group-has so nesting works) %>
  <span class="shrink-0 w-[52px] h-[30px] rounded-full relative transition-colors bg-[var(--hairline)] group-has-[:checked]:bg-[var(--primary)]
               peer-focus-visible:ring-2 peer-focus-visible:ring-[var(--primary)] peer-focus-visible:ring-offset-2"
        style="box-shadow: inset 0 -3px 0 rgba(0,0,0,0.15);">
    <span class="absolute top-[3px] left-[3px] w-6 h-6 rounded-full bg-white transition-transform group-has-[:checked]:translate-x-[22px]"
          style="box-shadow: 0 2px 0 rgba(0,0,0,0.15);"></span>
  </span>
</label>
