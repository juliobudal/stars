<%# Parent Approvals — LittleStars Design System %>
<div class="screen screen-enter-right">

  <%# ─── Top Bar ─── %>
  <%= render Ui::TopBar::Component.new(
    title: "Aprovações",
    subtitle: "Confira e libere as estrelinhas",
    back_url: parent_root_path
  ) do |bar|
    bar.with_right_slot do %>
      <div class="chip chip-peach" style="font-size: 14px; padding: 8px 14px;" id="pending_approvals_count">
        <i class="ph-bold ph-clock" style="font-size: 15px; color: currentColor;"></i>
        <%= (@profile_tasks.count + @redemptions.count) %>
      </div>
    <% end
  end %>

  <%= turbo_frame_tag "approvals_list" do %>
    <% if @profile_tasks.any? || @redemptions.any? %>

      <%# Group by child %>
      <% grouped = @profile_tasks.group_by(&:profile) %>
      <div class="col" style="gap: 20px; z-index: 2;">

        <% grouped.each_with_index do |(child, tasks), gi| %>
          <div style="animation: slideInCard 0.4s ease <%= gi * 0.06 %>s both;">
            <div class="row mb-3" style="gap: 12px;">
              <%= render Ui::KidAvatar::Component.new(kid: child, size: 44) %>
              <div class="h-display" style="font-size: 20px;"><%= child.name %></div>
              <div class="chip chip-outline"><%= tasks.count %> pedido<%= tasks.count > 1 ? "s" : "" %></div>
            </div>

            <div class="col" style="gap: 10px;">
              <% tasks.each do |task| %>
                <div id="<%= dom_id(task) %>" class="card" style="padding: 14px; border: 2px solid rgba(26,42,74,0.08); transition: all 0.2s;">
                  <div class="row" style="gap: 14px;">
                    <div class="icon-tile" style="width: 52px; height: 52px; background: var(--primary-soft); color: var(--primary);">
                      <i class="ph-bold ph-target" style="font-size: 28px;"></i>
                    </div>
                    <div class="col fg1" style="gap: 4px;">
                      <div class="h-display" style="font-size: 17px;"><%= task.title %></div>
                      <div class="row" style="gap: 6px;">
                        <div class="chip chip-primary" style="font-size: 11px; padding: 4px 10px;"><%= task.global_task&.category %></div>
                        <div class="chip chip-star" style="font-size: 12px; padding: 4px 10px;">
                          <i class="ph-fill ph-star" style="font-size: 12px; color: var(--star-2);"></i>+<%= task.points %>
                        </div>
                      </div>
                    </div>
                    <div class="row" style="gap: 8px;">
                      <%= button_to reject_parent_approval_path(task), method: :patch,
                          class: "btn btn-danger btn-icon",
                          data: { turbo_frame: "approvals_list", turbo_confirm: "Rejeitar esta tarefa? Ela voltará para a lista do filho." } do %>
                        <i class="ph-bold ph-x" style="font-size: 20px; color: white;"></i>
                      <% end %>
                      <%= button_to approve_parent_approval_path(task), method: :patch,
                          class: "btn btn-success btn-icon",
                          data: { turbo_frame: "approvals_list" } do %>
                        <i class="ph-bold ph-check" style="font-size: 22px; color: white;"></i>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if @redemptions.any? %>
          <div>
            <h3 class="h-display mb-3" style="font-size: 18px;">Resgates de Loja</h3>
            <div class="col" style="gap: 10px;">
              <% @redemptions.each do |redemption| %>
                <div id="<%= dom_id(redemption) %>" class="card" style="padding: 14px;">
                  <div class="row" style="gap: 14px;">
                    <div class="icon-tile" style="width: 52px; height: 52px; background: var(--star-soft); color: var(--star-2);">
                      <i class="ph-bold ph-gift" style="font-size: 28px;"></i>
                    </div>
                    <div class="col fg1" style="gap: 4px;">
                      <div class="h-display" style="font-size: 17px;"><%= redemption.reward&.title %></div>
                      <div class="row" style="gap: 6px;">
                        <div class="chip chip-star" style="font-size: 12px; padding: 4px 10px;">
                          <i class="ph-fill ph-star" style="font-size: 12px; color: var(--star-2);"></i>-<%= redemption.reward&.points_required %>
                        </div>
                        <span style="font-size: 12px; color: var(--text-muted); font-weight: 700;"><%= redemption.profile&.name %></span>
                      </div>
                    </div>
                    <div class="row" style="gap: 8px;">
                      <%= button_to reject_redemption_parent_approval_path(redemption), method: :patch,
                          class: "btn btn-danger btn-icon",
                          data: { turbo_frame: "approvals_list", turbo_confirm: "Rejeitar este resgate?" } do %>
                        <i class="ph-bold ph-x" style="font-size: 20px; color: white;"></i>
                      <% end %>
                      <%= button_to approve_redemption_parent_approval_path(redemption), method: :patch,
                          class: "btn btn-success btn-icon",
                          data: { turbo_frame: "approvals_list" } do %>
                        <i class="ph-bold ph-check" style="font-size: 22px; color: white;"></i>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

      </div>
    <% else %>
      <div class="center col" style="padding: 40px; text-align: center; gap: 14px; z-index: 2;">
        <div style="width: 80px; height: 80px; border-radius: var(--r-md); background: var(--c-mint-soft); color: var(--c-mint); display: flex; align-items: center; justify-content: center;">
          <i class="ph-bold ph-check-circle" style="font-size: 44px;"></i>
        </div>
        <h3 class="h-display" style="font-size: 22px; margin-top: 8px;">Tudo em dia!</h3>
        <p class="subtitle" style="max-width: 320px;">Nenhuma missão aguardando aprovação agora.</p>
      </div>
    <% end %>
  <% end %>

</div>
