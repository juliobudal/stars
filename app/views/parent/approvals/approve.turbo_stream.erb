<%= turbo_stream.remove @profile_task %>

<%# Trigger confetti via fx controller (auto-fires on insert via MutationObserver) %>
<%= turbo_stream.append "body" do %>
  <div data-fx-event="celebrate" data-fx-tier="big" class="hidden"></div>
<% end %>

<%= turbo_stream.update :flash do %>
  <%= render "parent/approvals/success_toast", message: "Tarefa aprovada com sucesso!" %>
<% end %>

<%
  family_redemptions_pending = Redemption.joins(:profile).where(profiles: { family_id: current_profile.family_id }).pending.count
%>
<% if current_profile.family.profile_tasks.awaiting_approval.count == 0 && family_redemptions_pending == 0 %>
  <%= turbo_stream.replace "approvals_list" do %>
    <%= turbo_frame_tag "approvals_list" do %>
      <%= render Ui::Empty::Component.new(
            icon: "party",
            title: "Tudo em dia!",
            subtitle: "Não há pendências no momento."
          ) %>
    <% end %>
  <% end %>
<% end %>

<%= render "parent/approvals/count_streams" %>
