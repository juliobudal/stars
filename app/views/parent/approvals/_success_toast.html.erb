<%# Self-dismissing success toast used by approve / approve_redemption turbo_streams.
    Locals: message (String, required), icon (Symbol/String, default :check). %>
<% icon ||= :check %>
<div
  data-controller="flash"
  data-flash-dismiss-after-value="2200"
  class="pointer-events-auto inline-flex items-center gap-2 px-5 py-3 rounded-[14px] border text-white font-extrabold text-[14px] uppercase tracking-[0.5px] anim-pop-in"
  style="background: var(--primary); border-color: var(--primary); box-shadow: 0 4px 0 var(--primary-2);"
>
  <%= render Ui::Icon::Component.new(icon, size: 18, color: "white") %>
  <span class="inline-flex items-center gap-1"><%= message %><%= yield if block_given? %></span>
</div>
