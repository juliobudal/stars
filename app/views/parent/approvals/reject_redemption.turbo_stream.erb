<%= turbo_stream.remove @redemption %>

<%= turbo_stream.update :flash do %>
  <div
    data-controller="flash"
    data-flash-dismiss-after-value="2200"
    class="pointer-events-auto inline-flex items-center gap-2 px-5 py-3 rounded-[14px] border-2 text-white font-extrabold text-[14px] uppercase tracking-[0.5px] anim-pop-in"
    style="background: var(--danger); border-color: var(--danger); box-shadow: 0 4px 0 var(--danger-2);"
  >
    <%= render Ui::Icon::Component.new("close", size: 18, color: "white") %>
    <span>Resgate rejeitado e pontos devolvidos.</span>
  </div>
<% end %>

<% pending_tasks = current_profile.family.profile_tasks.awaiting_approval.count %>
<% pending_redemptions = current_profile.family.redemptions.pending.count %>
<% if pending_tasks == 0 && pending_redemptions == 0 %>
  <%= turbo_stream.replace "approvals_list" do %>
    <%= turbo_frame_tag "approvals_list" do %>
      <%= render Ui::Empty::Component.new(
            icon: "check",
            title: "Tudo em dia!",
            subtitle: "Não há missões ou resgates aguardando aprovação."
          ) %>
    <% end %>
  <% end %>
<% end %>

<%= turbo_stream.update "pending_approvals_kpi" do %>
  <%= current_profile.family.profile_tasks.awaiting_approval.count + current_profile.family.redemptions.pending.count %>
<% end %>
