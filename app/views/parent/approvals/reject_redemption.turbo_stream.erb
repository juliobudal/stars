<%= turbo_stream.remove @redemption %>

<%= turbo_stream.update :flash do %>
  <div class="relative w-full py-3 pl-4 pr-12 text-sm bg-red-600 text-white rounded-xl">
    Resgate rejeitado e pontos devolvidos.
  </div>
<% end %>

<% if current_profile.family.profile_tasks.awaiting_approval.count == 0 && Redemption.pending.joins(:profile).where(profiles: { family_id: current_profile.family_id }).count == 0 %>
  <%= turbo_stream.replace "approvals_list" do %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-12 text-center">
      <div class="text-5xl mb-4">💤</div>
      <h3 class="text-xl font-bold text-gray-900 mb-2">Tudo em dia!</h3>
      <p class="text-gray-500 max-w-xs mx-auto">Não há missões ou resgates aguardando aprovação no momento. Que tal aproveitar o descanso?</p>
    </div>
  <% end %>
<% end %>
