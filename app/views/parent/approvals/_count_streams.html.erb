<%# Shared turbo_stream fragment emitted after every approve/reject action.
     Keeps the page header subtitle, nav badges (sidebar + mobile), and the
     HeaderStatChip KPI in sync without re-rendering the whole layout. %>
<%
  pending_tasks = local_assigns.fetch(:pending_tasks) { current_profile.family.profile_tasks.awaiting_approval.count }
  pending_redemptions = local_assigns.fetch(:pending_redemptions) { current_profile.family.redemptions.pending.count }
  pending_total = pending_tasks + pending_redemptions
  subtitle_text = pending_total.positive? ? "#{pending_total} #{pending_total == 1 ? 'pendência aguardando' : 'pendências aguardando'} sua revisão" : "Nenhuma pendência no momento"
%>
<%= turbo_stream.update "pending_approvals_kpi" do %><%= pending_total %><% end %>

<%= turbo_stream.replace "parent_approvals_subtitle" do %>
  <span id="parent_approvals_subtitle"><%= subtitle_text %></span>
<% end %>

<%= turbo_stream.replace "parent_approvals_badge_sidebar" do %>
  <%= render "shared/parent_approvals_badge", count: pending_total, variant: :sidebar %>
<% end %>

<%= turbo_stream.replace "parent_approvals_badge_mobile" do %>
  <%= render "shared/parent_approvals_badge", count: pending_total, variant: :mobile %>
<% end %>
