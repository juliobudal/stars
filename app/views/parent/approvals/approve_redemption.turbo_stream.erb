<%= turbo_stream.remove @redemption %>

<%= turbo_stream.append "body" do %>
  <div data-fx-event="celebrate" data-fx-tier="big" class="hidden"></div>
<% end %>

<%= turbo_stream.update :flash do %>
  <div
    data-controller="flash"
    data-flash-dismiss-after-value="2200"
    class="pointer-events-auto flex items-center gap-2 px-5 py-3 rounded-full text-white font-extrabold text-[15px] shadow-lift animate-popIn bg-success"
  >
    <%= render Ui::Icon::Component.new("check", size: 18, color: "white") %>
    <span class="row gap-1">Resgate aprovado! <%= render Ui::Icon::Component.new(:gift, size: 16, color: "white") %></span>
  </div>
<% end %>

<%
  family_redemptions_pending = Redemption.joins(:profile).where(profiles: { family_id: current_profile.family_id }).pending.count
%>
<% if family_redemptions_pending == 0 && current_profile.family.profile_tasks.awaiting_approval.count == 0 %>
  <%= turbo_stream.replace "approvals_list" do %>
    <%= turbo_frame_tag "approvals_list" do %>
      <%= render Ui::Card::Component.new(padding: "p-10", class: "text-center") do %>
        <div class="flex items-center justify-center mb-2"><%= render Ui::Icon::Component.new(:sparkle, size: 36, color: "var(--c-amber-dark)") %></div>
        <%= render Ui::Heading::Component.new(size: :h2, class: "mb-1") do %>Tudo Limpo!<% end %>
        <div class="text-[14px] text-muted-foreground font-semibold">Nenhuma pendência. Trabalho incrível!</div>
      <% end %>
    <% end %>
  <% end %>
<% end %>

<%= turbo_stream.update "pending_approvals_kpi" do %>
  <%= current_profile.family.profile_tasks.awaiting_approval.count + family_redemptions_pending %>
<% end %>
