<%= turbo_stream.remove @redemption %>

<%= turbo_stream.append "body" do %>
  <div data-controller="celebration" data-celebration-auto-fire-value="true" class="hidden">
    <div data-celebration-target="layer" class="confetti-layer"></div>
  </div>
<% end %>

<%= turbo_stream.update :flash do %>
  <div
    data-controller="flash"
    data-flash-dismiss-after-value="2200"
    class="pointer-events-auto flex items-center gap-2 px-5 py-3 rounded-full text-white font-extrabold text-[15px] shadow-lift animate-popIn"
    style="background-color: var(--success);"
  >
    <%= render Ui::Icon::Component.new("check", size: 18, color: "white") %>
    <span>Resgate aprovado! 🎁</span>
  </div>
<% end %>

<%
  family_redemptions_pending = Redemption.joins(:profile).where(profiles: { family_id: current_profile.family_id }).pending.count
%>
<% if family_redemptions_pending == 0 && current_profile.family.profile_tasks.awaiting_approval.count == 0 %>
  <%= turbo_stream.replace "approvals_list" do %>
    <%= turbo_frame_tag "approvals_list" do %>
      <div class="card" style="padding: 40px; text-align: center;">
        <div style="font-size: 36px; margin-bottom: 8px;">✨</div>
        <div class="h-display" style="font-size: 22px; margin-bottom: 4px;">Tudo Limpo!</div>
        <div class="subtitle" style="font-size: 14px;">Nenhuma pendência. Trabalho incrível!</div>
      </div>
    <% end %>
  <% end %>
<% end %>

<%= turbo_stream.update "pending_approvals_kpi" do %>
  <%= current_profile.family.profile_tasks.awaiting_approval.count + family_redemptions_pending %>
<% end %>
