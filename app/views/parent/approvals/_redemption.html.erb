<%# Superseded — see index.html.erb for current rendering %>
<div id="<%= dom_id(redemption) %>" class="bg-white rounded-3xl border-2 border-border shadow-[0_4px_0_0_rgba(0,0,0,0.05)] overflow-hidden flex flex-col transition hover:shadow-[0_8px_0_0_rgba(0,0,0,0.05)] hover:-translate-y-1">
  <div class="p-5 border-b-2 border-border flex items-center justify-between bg-gray-50/50">
    <div class="flex items-center gap-3">
      <div class="w-12 h-12 rounded-xl bg-white border-2 border-border flex items-center justify-center shadow-[0_4px_0_0_var(--border)]">
        <%= icon_tag "gift", class: "w-8 h-8 text-brand-green" %>
      </div>
      <div>
        <p class="text-sm font-black text-gray-900 uppercase tracking-tight italic"><%= redemption.profile_name %></p>
        <p class="text-[10px] uppercase text-brand-blue font-black tracking-widest">Resgate de Prêmio</p>
      </div>
    </div>
    <div class="text-right flex items-center gap-1">
      <span class="text-lg font-black text-brand-red">-<%= redemption.points %></span>
      <%= icon_tag "star", class: "w-5 h-5 text-brand-yellow" %>
    </div>
  </div>

  <div class="p-6 flex-grow">
    <h3 class="font-black text-gray-800 text-xl leading-tight uppercase tracking-tight mb-2"><%= redemption.title %></h3>
    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Solicitado <%= time_ago_in_words(redemption.created_at) %> atrás</p>
  </div>

  <div class="p-4 bg-gray-50 flex gap-3 border-t-2 border-border">
    <%= button_to approve_redemption_parent_approval_path(redemption), method: :patch,
        class: "btn btn-success flex-1",
        data: { turbo_frame: "approvals_list" } do %>
      Aprovar
    <% end %>

    <%= button_to reject_redemption_parent_approval_path(redemption), method: :patch,
        class: "btn btn-secondary flex-1",
        data: { turbo_frame: "approvals_list" } do %>
      Recusar
    <% end %>
  </div>
</div>
