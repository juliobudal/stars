<%# Parent — Approvals redemption partial (LittleStars / Berry Pop design) %>
<% c = smiley_palette(redemption.profile.color) %>
<div id="<%= dom_id(redemption) %>" class="card" style="padding: 18px; display: flex; align-items: center; gap: 18px;">
  <input type="checkbox" aria-label="Selecionar" style="width: 18px; height: 18px; accent-color: var(--primary); cursor: pointer; flex-shrink: 0;">

  <%= render Ui::SmileyAvatar::Component.new(kid: redemption.profile, size: 48) %>

  <div style="flex: 1; min-width: 0;">
    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 4px; flex-wrap: wrap;">
      <span class="h-display" style="font-size: 17px;"><%= redemption.title %></span>
      <span style="background: <%= c[:fill] %>; color: <%= c[:ink] %>; padding: 2px 10px; border-radius: 999px; font-size: 11px; font-weight: 800;"><%= redemption.profile.name %></span>
    </div>
    <div style="font-size: 12px; font-weight: 700; color: var(--text-muted);">
      Solicitado <%= time_ago_in_words(redemption.created_at) %> atrás
    </div>
  </div>

  <span class="h-display" style="font-size: 16px; color: var(--text); flex-shrink: 0;">−<%= redemption.points %> ⭐</span>

  <%= button_to reject_redemption_parent_approval_path(redemption), method: :patch,
      style: "background:#FEE2E2; color:#991B1B; border:none; border-radius:var(--r-sm); padding:8px 14px; font-weight:800; font-size:12px; cursor:pointer; display:inline-flex; align-items:center; gap:8px;",
      data: { turbo_frame: "approvals_list", turbo_confirm: "Cancelar este resgate?" } do %>
    Recusar
  <% end %>

  <%= button_to approve_redemption_parent_approval_path(redemption), method: :patch,
      style: "background:#D1FAE5; color:#047857; border:none; border-radius:var(--r-sm); padding:8px 14px; font-weight:800; font-size:12px; cursor:pointer; display:inline-flex; align-items:center; gap:8px;",
      data: { turbo_frame: "approvals_list" } do %>
    Aprovar
  <% end %>
</div>
