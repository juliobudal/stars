<%= turbo_stream.remove @profile_task %>

<%= turbo_stream.update :flash do %>
  <div class="relative w-full py-3 pl-4 pr-12 text-sm bg-red-600 text-white rounded-xl">
    Tarefa rejeitada.
  </div>
<% end %>

<% if current_profile.family.profile_tasks.awaiting_approval.count == 0 %>
  <%= turbo_stream.replace "approvals_list" do %>
    <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-12 text-center">
      <div class="text-5xl mb-4">💤</div>
      <h3 class="text-xl font-bold text-gray-900 mb-2">Tudo em dia!</h3>
      <p class="text-gray-500 max-w-xs mx-auto">Não há missões aguardando aprovação no momento. Que tal aproveitar o descanso?</p>
    </div>
  <% end %>
<% end %>

<%= turbo_stream.update "pending_approvals_count" do %>
  <%= current_profile.family.profile_tasks.awaiting_approval.count %>
<% end %>
