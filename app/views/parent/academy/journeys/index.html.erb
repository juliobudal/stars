<% content_for(:title) { "Trilhas · Academy" } %>

<div class="screen no-nav">
  <div class="flex items-center gap-3 mb-4">
    <h1 class="font-display text-[22px] font-extrabold leading-tight m-0" style="color: var(--text);">
      Trilhas e ângulos
    </h1>
  </div>

  <% if @kids.size > 1 %>
    <div class="flex flex-wrap gap-2 mb-4">
      <% @kids.each do |kid| %>
        <%= link_to kid.name, parent_academy_journeys_path(kid: kid.id),
                    class: "px-3 py-1.5 rounded-full font-display text-[12px] font-extrabold anim-press",
                    style: "background: #{kid.id == @selected_kid&.id ? 'var(--c-primary)' : 'var(--surface)'}; " +
                           "color: #{kid.id == @selected_kid&.id ? 'white' : 'var(--text)'}; " +
                           "border: 2px solid #{kid.id == @selected_kid&.id ? 'var(--c-primary)' : 'var(--hairline)'};" %>
      <% end %>
    </div>
  <% end %>

  <% if @selected_kid.nil? %>
    <p class="font-display text-[14px]" style="color: var(--text-muted);">
      Nenhum filho ainda. Crie um perfil para começar.
    </p>
  <% elsif @recent_progresses.blank? %>
    <div class="rounded-3xl p-6 text-center"
         style="background: var(--surface); border: 2px solid var(--hairline); box-shadow: 0 4px 0 rgba(0,0,0,0.06);">
      <p class="font-display text-[14px] leading-snug" style="color: var(--text-muted);">
        <%= @selected_kid.name %> ainda não atravessou nenhum ângulo de aprendizado.
        Volte aqui depois da primeira missão.
      </p>
    </div>
  <% else %>
    <div class="flex flex-col gap-3">
      <% @recent_progresses.each do |progress| %>
        <%
          mission = progress.mission
          color_var = "var(--academy-pokedex-#{mission.concept&.pokedex_color_key.presence || 'cognitivo'})"
          visits = @visits_by_progress[progress.id] || []
          status_label = case progress.status
                         when "completed", "mastered" then "Completa"
                         when "in_progress"           then "Em curso"
                         else                              progress.status.humanize
                         end
        %>
        <article class="rounded-2xl p-4"
                 style="background: var(--surface); border: 2px solid var(--hairline); box-shadow: 0 3px 0 rgba(0,0,0,0.06);">
          <div class="flex items-baseline justify-between gap-2 mb-1">
            <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase truncate"
                 style="color: <%= color_var %>;">
              <%= mission.subject&.name %>
            </div>
            <div class="font-display text-[10px] font-extrabold tracking-[1px] uppercase shrink-0"
                 style="color: var(--text-muted);">
              <%= status_label %>
            </div>
          </div>
          <h2 class="font-display text-[15px] font-extrabold leading-tight mb-1 m-0" style="color: var(--text);">
            <%= mission.title %>
          </h2>
          <% if mission.concept %>
            <div class="font-display text-[12px] mb-2" style="color: var(--text-muted);">
              Conceito: <%= mission.concept.name %>
            </div>
          <% end %>

          <% if visits.any? %>
            <div class="font-display text-[10px] font-extrabold tracking-[1px] uppercase mt-3 mb-1"
                 style="color: var(--text-muted);">
              Ângulos atravessados
            </div>
            <div class="flex flex-wrap gap-1.5">
              <% visits.each do |visit| %>
                <% closed = visit.closed_at.present? %>
                <span class="px-2 py-1 rounded-full font-display text-[10px] font-extrabold tracking-[0.5px]"
                      style="background: <%= closed ? "color-mix(in oklab, #{color_var} 14%, var(--surface))" : 'var(--surface)' %>;
                             border: 1.5px solid <%= closed ? color_var : 'var(--hairline)' %>;
                             color: <%= closed ? 'var(--text)' : 'var(--text-muted)' %>;">
                  <%= Academy::Lens::Catalog.parent_label(visit.lens_type) %>
                </span>
              <% end %>
            </div>
          <% else %>
            <div class="font-display text-[11px] mt-2" style="color: var(--text-muted);">
              Sem ângulos registrados (missão migrada do v4).
            </div>
          <% end %>
        </article>
      <% end %>
    </div>
  <% end %>
</div>
