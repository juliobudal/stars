<% content_for(:title) { "Academia" } %>

<div class="screen-enter">
  <%= render Ui::PageHeader::Component.new(
        title: "Progresso nas trilhas",
        subtitle: "Acompanhe como cada criança avança nas pílulas de conhecimento."
      ) %>

  <% if @children.empty? %>
    <%= render Ui::Empty::Component.new(icon: "users", title: "Nenhuma criança ainda", subtitle: "Adicione um perfil de criança para acompanhar o aprendizado.") %>
  <% elsif @trails.empty? %>
    <%= render Ui::Empty::Component.new(icon: "sparkle", title: "Sem trilhas ativas", subtitle: "As trilhas aparecem aqui assim que forem publicadas.") %>
  <% else %>
    <div class="grid gap-6 md:grid-cols-2">
      <% @children.each do |child| %>
        <% prog = @progress_by_child[child] %>
        <section class="p-5" style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 16px; box-shadow: 0 4px 0 rgba(0,0,0,0.06);">
          <h2 class="font-display text-[17px] font-extrabold leading-tight m-0 mb-4" style="color: var(--text);">
            <%= child.name %>
          </h2>
          <ul class="flex flex-col gap-3 list-none p-0 m-0">
            <% @trails.each do |trail| %>
              <%
                p = prog[trail.id] || { total: 0, done: 0 }
                total = p[:total]; done = p[:done]
                ratio = total.zero? ? 0 : (done.to_f / total * 100).round
              %>
              <li class="flex items-center gap-3">
                <span class="text-[18px] shrink-0"><%= trail.emoji.presence || "🔍" %></span>
                <div class="flex-1 min-w-0">
                  <div class="font-display text-[14px] font-extrabold truncate" style="color: var(--text);"><%= trail.title %></div>
                  <div class="h-2 rounded-full overflow-hidden mt-1" style="background: var(--surface-2);">
                    <div class="h-full rounded-full" style="width: <%= ratio %>%; background: var(--primary);"></div>
                  </div>
                </div>
                <span class="font-display text-[12px] font-extrabold shrink-0" style="color: var(--text-muted);"><%= done %>/<%= total %></span>
              </li>
            <% end %>
          </ul>
        </section>
      <% end %>
    </div>
  <% end %>
</div>
