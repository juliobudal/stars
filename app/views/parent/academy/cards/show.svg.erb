<%
  subject = @card.mission.subject
  bg = subject.color.presence || "#58CC02"
  date = @card.minted_at.strftime("%d/%m/%Y")
%>
<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1080 1080" width="1080" height="1080">
  <defs>
    <linearGradient id="bgGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="<%= bg %>" stop-opacity="1"/>
      <stop offset="100%" stop-color="<%= bg %>" stop-opacity="0.78"/>
    </linearGradient>
  </defs>

  <rect width="1080" height="1080" fill="url(#bgGrad)"/>
  <rect x="60" y="60" width="960" height="960" rx="48" ry="48" fill="#ffffff" opacity="0.96"/>

  <%# Subject chip %>
  <g transform="translate(110,140)">
    <rect width="<%= 60 + (subject.name.length * 22) %>" height="64" rx="22" fill="<%= bg %>"/>
    <text x="32" y="42" font-family="Nunito, system-ui, sans-serif" font-weight="800"
          font-size="26" fill="#ffffff" letter-spacing="1.5">
      <%= subject.name.upcase %>
    </text>
  </g>

  <%# Headline — wrapped via foreignObject %>
  <foreignObject x="110" y="260" width="860" height="520">
    <div xmlns="http://www.w3.org/1999/xhtml"
         style="font-family: Nunito, system-ui, sans-serif; font-weight: 800; color: #1c1c1e;
                font-size: 72px; line-height: 1.1; letter-spacing: -0.02em;">
      <%= ERB::Util.html_escape(@card.headline) %>
    </div>
  </foreignObject>

  <%# Central insight (optional) %>
  <% if @card.try(:central_insight).present? %>
    <foreignObject x="110" y="790" width="860" height="140">
      <div xmlns="http://www.w3.org/1999/xhtml"
           style="font-family: Nunito, system-ui, sans-serif; font-weight: 700; color: #4a4a4f;
                  font-size: 30px; line-height: 1.3;">
        <%= ERB::Util.html_escape(@card.central_insight.to_s.truncate(220)) %>
      </div>
    </foreignObject>
  <% end %>

  <%# Footer: kid name + date + LittleStars brand %>
  <g transform="translate(110,960)">
    <text font-family="Nunito, system-ui, sans-serif" font-weight="800"
          font-size="22" fill="#6a6a72" letter-spacing="1.5">
      <%= @kid.name.upcase %> · <%= date %>
    </text>
  </g>
  <g transform="translate(820,940)">
    <circle cx="32" cy="32" r="32" fill="<%= bg %>"/>
    <text x="32" y="44" text-anchor="middle"
          font-family="Nunito, system-ui, sans-serif" font-weight="800"
          font-size="36" fill="#ffffff">★</text>
    <text x="80" y="42" font-family="Nunito, system-ui, sans-serif" font-weight="800"
          font-size="22" fill="#1c1c1e">LittleStars</text>
  </g>
</svg>
