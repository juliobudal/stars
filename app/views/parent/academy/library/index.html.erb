<% content_for(:title) { "Biblioteca de Pílulas" } %>

<div class="px-4 sm:px-6 py-6">
  <div class="mb-5 flex items-start gap-3 flex-wrap">
    <div class="flex-1 min-w-0">
      <h1 class="font-display text-[24px] font-extrabold leading-tight m-0" style="color: var(--text);">
        Biblioteca de Pílulas
      </h1>
      <p class="text-[14px] font-bold mt-1" style="color: var(--text-muted);">
        Todas as aulas do catálogo · <strong><%= @missions.size %></strong> de
        <%= ::Academy::Mission.active.count %> pílulas ativas · fontes, frameworks
        e sacadas curados.
      </p>
    </div>
    <%= link_to "← Dashboard", parent_academy_dashboard_path,
                class: "font-extrabold text-[13px]",
                style: "color: var(--text-muted);" %>
  </div>

  <%# ── Filtros ──────────────────────────────────────────── %>
  <%= form_with url: parent_academy_library_path, method: :get, local: true,
                data: { loading: "off" },
                class: "ls-card-3d mb-5 flex flex-wrap gap-3 items-end",
                style: "background: var(--surface); border: 2px solid var(--hairline); border-radius: 14px; padding: 14px 16px; box-shadow: 0 3px 0 rgba(0,0,0,0.05);" do %>
    <div class="flex-1 min-w-[160px]">
      <label class="block font-display text-[10px] font-extrabold uppercase tracking-[1px] mb-1" style="color: var(--text-muted);">Área</label>
      <select name="area" class="w-full px-3 py-2 rounded-lg text-[13px] font-bold"
              style="background: var(--surface); border: 2px solid var(--hairline); color: var(--text);">
        <option value="">Todas</option>
        <% @subjects.each do |s| %>
          <option value="<%= s.slug %>" <%= 'selected' if @selected_subject == s.slug %>><%= s.name %></option>
        <% end %>
      </select>
    </div>
    <div class="flex-1 min-w-[160px]">
      <label class="block font-display text-[10px] font-extrabold uppercase tracking-[1px] mb-1" style="color: var(--text-muted);">Fonte / Autor</label>
      <select name="source" class="w-full px-3 py-2 rounded-lg text-[13px] font-bold"
              style="background: var(--surface); border: 2px solid var(--hairline); color: var(--text);">
        <option value="">Todos</option>
        <% @available_sources.each do |src| %>
          <option value="<%= src %>" <%= 'selected' if @selected_source == src %>><%= src %></option>
        <% end %>
      </select>
    </div>
    <div class="flex-1 min-w-[160px]">
      <label class="block font-display text-[10px] font-extrabold uppercase tracking-[1px] mb-1" style="color: var(--text-muted);">Framework</label>
      <select name="framework" class="w-full px-3 py-2 rounded-lg text-[13px] font-bold"
              style="background: var(--surface); border: 2px solid var(--hairline); color: var(--text);">
        <option value="">Todos</option>
        <% @available_frameworks.each do |fw| %>
          <option value="<%= fw %>" <%= 'selected' if @selected_framework == fw %>><%= fw %></option>
        <% end %>
      </select>
    </div>
    <div class="flex gap-2">
      <%= render Ui::Btn::Component.new(variant: "primary", size: "md", type: "submit") { "Filtrar" } %>
      <% if @selected_subject || @selected_source || @selected_framework %>
        <%= link_to "Limpar", parent_academy_library_path,
                    class: "px-3 py-2 rounded-lg font-extrabold text-[13px] flex items-center",
                    style: "color: var(--text-muted);" %>
      <% end %>
    </div>
  <% end %>

  <% if @grouped.empty? %>
    <%= render Ui::Empty::Component.new(title: "Nenhuma pílula encontrada",
                                         body: "Tente ajustar os filtros acima.") %>
  <% else %>
    <% @grouped.each do |subject, missions| %>
      <section class="mb-6">
        <div class="flex items-center gap-2.5 mb-3">
          <div class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0"
               style="background: <%= subject.color %>; box-shadow: 0 2px 0 rgba(0,0,0,0.08);">
            <%= render Ui::Icon::Component.new(subject.icon.to_sym, size: 18, color: "white") %>
          </div>
          <h2 class="font-display text-[18px] font-extrabold m-0" style="color: var(--text);">
            <%= subject.name %>
          </h2>
          <span class="text-[12px] font-bold" style="color: var(--text-muted);">
            <%= missions.size %> pílula<%= 's' if missions.size != 1 %>
          </span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
          <% missions.each do |mission| %>
            <div class="ls-card-3d"
                 style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 14px; padding: 14px 16px; box-shadow: 0 3px 0 rgba(0,0,0,0.05);">
              <div class="flex items-start gap-3">
                <div class="flex-1 min-w-0">
                  <div class="font-display text-[15px] font-extrabold leading-tight m-0" style="color: var(--text);">
                    <%= mission.title %>
                  </div>
                  <% if mission.hook.present? %>
                    <div class="text-[12px] font-bold italic mt-0.5" style="color: var(--text-muted);">
                      "<%= mission.hook %>"
                    </div>
                  <% end %>
                </div>
              </div>

              <% if mission.sacada.present? %>
                <div class="mt-2.5 px-3 py-2 rounded-[12px] text-[13px] font-bold leading-snug border-2"
                     style="background: var(--primary-soft); color: var(--text); border-color: var(--primary);">
                  <strong>Sacada:</strong> <%= mission.sacada %>
                </div>
              <% end %>

              <div class="flex items-center gap-2 flex-wrap mt-2.5">
                <% if mission.source.present? %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md font-display font-extrabold text-[10px] tracking-wide uppercase"
                        style="background: var(--c-sky-soft); color: var(--c-sky-dark);">
                    <%= render Ui::Icon::Component.new(:book, size: 11, color: "var(--c-sky-dark)") %>
                    <%= mission.source %>
                  </span>
                <% end %>
                <% if mission.framework.present? %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md font-display font-extrabold text-[10px] tracking-wide uppercase"
                        style="background: var(--hairline); color: var(--text);">
                    <%= mission.framework %>
                  </span>
                <% end %>
              </div>

              <% if mission.learning_objective.present? %>
                <div class="text-[12px] font-bold mt-2.5 leading-snug" style="color: var(--text-muted);">
                  <strong style="color: var(--text);">Objetivo:</strong> <%= mission.learning_objective %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  <% end %>
</div>
