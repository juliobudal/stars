<div class="page-enter-right">

  <%= render Ui::PageHeader::Component.new(
        title: "Biblioteca de missões",
        subtitle: "Marque as missões prontas e adicione todas de uma vez"
      ) do |h| %>
    <% h.with_right_slot do %>
      <%= render Ui::Btn::Component.new(variant: "secondary", size: "sm", url: parent_global_tasks_path) do %>
        <%= render Ui::Icon::Component.new("back", size: 14, color: "currentColor") %>
        Catálogo
      <% end %>
    <% end %>
  <% end %>

  <%= form_with url: add_from_template_parent_global_tasks_path, method: :post do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-24">
      <% @templates.each do |tpl| %>
        <% cm = Ui::Tokens.category_for(tpl[:category]) %>
        <% fm = Ui::Tokens.frequency_for(tpl[:frequency]) %>
        <% tint_soft = Ui::Tokens.tint_soft(cm[:tint]) %>
        <% tint_fg = Ui::Tokens.tint_fg(cm[:tint]) %>
        <% already = @existing_titles.include?(tpl[:title]) %>
        <label class="relative block rounded-[16px] p-4 border transition-all
                      <%= already ? 'cursor-default' : 'cursor-pointer' %>
                      has-[:checked]:border-[var(--primary)] has-[:checked]:bg-[var(--primary-soft)]"
               style="background: var(--surface); border-color: var(--hairline); box-shadow: var(--shadow-card); <%= 'opacity:.55;' if already %>">
          <input type="checkbox" name="keys[]" value="<%= tpl[:key] %>" class="peer sr-only" <%= "disabled" if already %>>
          <div class="flex items-start gap-3.5">
            <div class="w-12 h-12 rounded-[14px] flex items-center justify-center shrink-0 border"
                 style="background: <%= tint_soft %>; border-color: <%= tint_fg %>;">
              <%= render Ui::Icon::Component.new(tpl[:icon], size: 24, color: tint_fg) %>
            </div>
            <div class="flex-1 min-w-0 pr-8">
              <div class="text-[15px] font-extrabold mb-0.5 truncate" style="color: var(--text);"><%= tpl[:title] %></div>
              <div class="text-[12px] font-bold mb-1.5" style="color: var(--text-muted);"><%= tpl[:description] %></div>
              <div class="flex items-center gap-1.5 flex-wrap">
                <span class="text-[10px] font-extrabold uppercase tracking-[0.5px] rounded-[6px] px-2 py-0.5"
                      style="color: <%= tint_fg %>; background: <%= tint_soft %>;"><%= cm[:label] %></span>
                <span class="inline-flex items-center gap-1 text-[11px] font-bold" style="color: var(--text-muted);"><%= fm[:label] %> · <%= tpl[:points] %><%= render Ui::Icon::Component.new(:star, size: 11, color: "var(--star)") %></span>
              </div>
            </div>
          </div>
          <%# selected indicator (hidden once it's already in the catalog) %>
          <% if already %>
            <span class="absolute top-3 right-3 text-[9px] font-extrabold uppercase px-2 py-1 rounded-full"
                  style="background: var(--surface-muted); color: var(--text-muted);">no catálogo</span>
          <% else %>
            <span class="absolute top-3 right-3 w-7 h-7 rounded-full border flex items-center justify-center text-transparent
                         border-[var(--hairline)] peer-checked:border-[var(--primary)] peer-checked:bg-[var(--primary)] peer-checked:text-white">
              <%= render Ui::Icon::Component.new("check", size: 14, color: "currentColor") %>
            </span>
          <% end %>
        </label>
      <% end %>
    </div>

    <%# Sticky action bar %>
    <div class="fixed bottom-[calc(72px+env(safe-area-inset-bottom))] lg:bottom-0 left-0 right-0 lg:left-[220px] z-40 px-6 py-4 border-t-2"
         style="background: var(--surface); border-color: var(--hairline); padding-bottom: calc(env(safe-area-inset-bottom) + 16px);">
      <div class="max-w-[1100px] mx-auto flex items-center justify-between gap-3">
        <span class="hidden sm:block text-[13px] font-bold" style="color: var(--text-muted);">Selecione e adicione ao catálogo</span>
        <%= render Ui::Btn::Component.new(variant: "primary", type: "submit") do %>
          <%= render Ui::Icon::Component.new("plus", size: 14, color: "currentColor") %>
          Adicionar selecionadas
        <% end %>
      </div>
    </div>
  <% end %>
</div>
