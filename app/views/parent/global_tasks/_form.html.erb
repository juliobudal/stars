<%= form_with(model: global_task, url: global_task.new_record? ? parent_global_tasks_path : parent_global_task_path(global_task), class: "space-y-8 max-w-xl bg-white rounded-3xl border-2 border-border p-8 shadow-[0_4px_0_0_rgba(0,0,0,0.05)]") do |f| %>
  <% if global_task.errors.any? %>
    <div class="rounded-2xl bg-brand-red/10 p-4 border-2 border-brand-red/20 mb-6">
      <div class="ml-3">
        <h3 class="text-sm font-black text-brand-red uppercase tracking-tight italic">Ops! Algo deu errado:</h3>
        <ul class="mt-2 text-xs font-bold text-brand-red/80 uppercase tracking-widest list-disc pl-5">
          <% global_task.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Título da Missão", class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-2" %>
    <%= f.text_field :title, required: true, placeholder: "Ex: Lavar a louça", class: "block w-full rounded-2xl border-2 border-border px-4 py-3 placeholder-gray-300 focus:border-brand-blue focus:ring-0 text-gray-900 font-bold shadow-inner" %>
  </div>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <div>
      <%= f.label :points, class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-2" do %>
        Estrelinhas (<%= icon_tag "star", class: "w-3 h-3 inline-block" %>)
      <% end %>
      <%= f.number_field :points, min: 1, required: true, class: "block w-full rounded-2xl border-2 border-border px-4 py-3 focus:border-brand-blue focus:ring-0 text-gray-900 font-bold shadow-inner" %>
    </div>

    <div>
      <%= f.label :category, "Categoria", class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-2" %>
      <%= f.select :category,
          [["Escola", "escola"], ["Casa", "casa"], ["Rotina", "rotina"], ["Outro", "outro"]],
          { prompt: "Selecione..." },
          class: "block w-full rounded-2xl border-2 border-border px-4 py-3 focus:border-brand-blue focus:ring-0 text-gray-900 font-bold bg-white shadow-inner appearance-none" %>
    </div>
  </div>

  <div>
    <%= f.label :frequency, "Frequência", class: "block text-xs font-black text-gray-400 uppercase tracking-widest mb-2" %>
    <%= f.select :frequency,
        [["Diária", "daily"], ["Semanal", "weekly"]],
        { prompt: "Selecione..." },
        class: "block w-full rounded-2xl border-2 border-border px-4 py-3 focus:border-brand-blue focus:ring-0 text-gray-900 font-bold bg-white shadow-inner appearance-none",
        data: { action: "change->global-task-form#toggleWeekdays" } %>
  </div>

  <fieldset>
    <legend class="text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Dias da Semana <span class="text-[10px] opacity-60">(semanal)</span></legend>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <% [["Dom", "sunday"], ["Seg", "monday"], ["Ter", "tuesday"], ["Qua", "wednesday"], ["Qui", "thursday"], ["Sex", "friday"], ["Sáb", "saturday"]].each do |label, value| %>
        <div class="relative">
          <%= check_box_tag "global_task[days_of_week][]", value,
              Array(global_task.days_of_week).include?(value),
              id: "day_#{value}",
              class: "peer sr-only" %>
          <label for="day_<%= value %>" class="flex items-center justify-center px-3 py-2 rounded-xl border-2 border-border font-bold text-xs uppercase tracking-widest cursor-pointer peer-checked:bg-brand-blue peer-checked:border-brand-blue-depth peer-checked:text-white transition-all shadow-[0_2px_0_0_rgba(0,0,0,0.05)] hover:bg-gray-50 active:translate-y-1 active:shadow-none">
            <%= label %>
          </label>
        </div>
      <% end %>
    </div>
  </fieldset>

  <div class="flex justify-end gap-4 pt-6 border-t-2 border-border mt-8">
    <%= link_to "Cancelar", parent_global_tasks_path, class: "btn btn-secondary btn-md" %>
    <%= f.submit "Salvar Missão", class: "btn btn-default btn-md" %>
  </div>
<% end %>
