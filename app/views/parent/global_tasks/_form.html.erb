<%
  cat_name = global_task.category.presence || "casa"
  cat_data = Ui::Tokens.category_for(cat_name)
  current_icon = global_task.icon.presence || Ui::IconPicker::Component::CONTEXT_GROUPS[:mission].first
  current_points = (global_task.points.presence || 3).to_i.clamp(1, 10)
  current_freq = global_task.frequency.to_s.presence || "daily"
  kids = @kids || current_profile.family.profiles.child.order(:name)
  selected_kid_ids = global_task.assigned_profile_ids.map(&:to_i)
  freq_options = [
    { key: "daily",   label: "Diária",    helper: "Todo dia",        icon: "clock" },
    { key: "weekly",  label: "Semanal",   helper: "Uma vez/semana",  icon: "scroll" },
    { key: "monthly", label: "Mensal",    helper: "Uma vez/mês",     icon: "scroll" },
    { key: "once",   label: "Única",      helper: "Só uma vez",      icon: "check" }
  ]
%>

<%= form_with(model: global_task,
              url: global_task.new_record? ? parent_global_tasks_path : parent_global_task_path(global_task),
              html: { data: { controller: "form-preview" } },
              class: "block") do |f| %>

  <%= render Ui::FormErrors::Component.new(record: global_task) %>

  <div class="flex flex-col gap-[18px] max-w-[720px] lg:max-w-none">

    <%# Title section %>
    <%= render Ui::FormSection::Component.new do %>
      <%= f.label :title, "Título da missão", class: "form-label mb-2.5" %>
      <%= f.text_field :title,
            class: "form-input",
            placeholder: "Ex: Arrumar a cama",
            data: { form_preview_field: "title" } %>
      <div class="text-[11px] font-bold mt-2" style="color: var(--text-muted);">Use frases curtas que a criança entenda.</div>
    <% end %>

    <%# Icon picker %>
    <%= render Ui::FormSection::Component.new(title: "Escolha um ícone") do %>
      <%= render Ui::IconPicker::Component.new(
            field_name: "global_task[icon]",
            value: current_icon,
            context: :mission,
            color: Ui::Tokens.tint_fg(cat_data[:tint]),
            id: "global_task_icon_picker",
            input_data: { form_preview_field: "icon" }
          ) %>
    <% end %>

    <%# Stars (points) %>
    <%= render Ui::FormSection::Component.new do %>
      <label class="flex items-center gap-2 text-[12px] font-extrabold uppercase tracking-[0.5px] mb-3.5"
             style="color: var(--text-muted);">
        <%= render Ui::Icon::Component.new("star", size: 14, color: "var(--star)") %>
        Quantas estrelinhas vale?
      </label>
      <div class="flex gap-1.5 items-center"
           data-controller="star-picker"
           data-star-picker-value-value="<%= current_points %>"
           data-star-picker-input-value="global_task_points">
        <% (1..10).each do |i| %>
          <% filled = i <= current_points %>
          <button type="button"
                  class="ls-star-cell flex-1 aspect-square rounded-[10px] flex items-center justify-center border-2 cursor-pointer"
                  data-action="click->star-picker#select"
                  data-star-picker-target="cell"
                  data-value="<%= i %>"
                  style="<%= filled ? 'background: var(--star-soft); border-color: var(--star); box-shadow: 0 3px 0 var(--star-2);' : 'background: var(--surface-muted); border-color: var(--hairline);' %>"
                  aria-label="<%= i %> <%= 'estrelinha'.pluralize(i == 1 ? 1 : 2) %>">
            <%= render Ui::Icon::Component.new("star", size: 18, color: filled ? "var(--star)" : "var(--text-soft)") %>
          </button>
        <% end %>
      </div>
      <%= f.hidden_field :points, value: current_points, id: "global_task_points", data: { form_preview_field: "points" } %>
      <div class="flex justify-between items-center mt-3">
        <span class="text-[11px] font-bold" style="color: var(--text-soft);">Tarefa fácil</span>
        <span class="text-[13px] font-extrabold" data-star-picker-target="readout"
              style="color: var(--c-reward-text);"><%= current_points %> <%= "estrelinha".pluralize(current_points == 1 ? 1 : 2) %></span>
        <span class="text-[11px] font-bold" style="color: var(--text-soft);">Tarefa difícil</span>
      </div>
    <% end %>

    <%# Frequency %>
    <%= render Ui::FormSection::Component.new(title: "Frequência") do %>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2.5" data-controller="selectable-group">
        <% freq_options.each do |opt|
             selected = current_freq == opt[:key]
             selected_style   = "background: var(--c-info-100); border-color: var(--c-info-500); box-shadow: 0 3px 0 var(--c-info-600); color: var(--c-info-600);"
             unselected_style = "background: var(--surface); border-color: var(--hairline); color: var(--text-muted);"
        %>
          <label class="ls-icon-cell rounded-[12px] p-3.5 text-center border-2 cursor-pointer flex flex-col items-center gap-1.5"
                 data-selectable-group-target="option"
                 data-selected-style="<%= selected_style %>"
                 data-unselected-style="<%= unselected_style %>"
                 style="<%= selected ? selected_style : unselected_style %>">
            <%= f.radio_button :frequency, opt[:key],
                  class: "sr-only",
                  data: { action: "change->fields#enable", controls: "day_of_month_field" } %>
            <%= render Ui::Icon::Component.new(opt[:icon], size: 22, color: "currentColor") %>
            <div class="text-[13px] font-extrabold"><%= opt[:label] %></div>
            <div class="text-[10px] font-bold"><%= opt[:helper] %></div>
          </label>
        <% end %>
      </div>

      <fieldset id="day_of_month_field" class="flex flex-col gap-2 mt-4 <%= 'hidden' unless global_task.monthly? %>" <%= "disabled" unless global_task.monthly? %>>
        <legend class="form-label">Dia do mês</legend>
        <%= f.number_field :day_of_month,
              class: "form-input",
              min: 1, max: 31, placeholder: "Ex: 15" %>
        <p class="text-[11px] font-bold" style="color: var(--text-muted);">Dia do mês em que a missão será criada (1–31).</p>
      </fieldset>
    <% end %>

    <%# Repetível no período %>
    <%
      current_max = (global_task.max_completions_per_period.presence || 1).to_i
      repeatable_initial = current_max > 1
    %>
    <%= render Ui::FormSection::Component.new(title: "Repetível no período") do %>
      <div data-controller="repeatable" data-repeatable-default-max-value="3">
        <label class="flex items-center justify-between gap-3 cursor-pointer select-none group">
          <span class="text-[13px] font-extrabold flex-1" style="color: var(--text);">
            Permitir mais de uma execução por período
          </span>
          <input type="checkbox"
                 class="sr-only peer"
                 data-repeatable-target="toggle"
                 data-action="change->repeatable#toggle"
                 <%= "checked" if repeatable_initial %>
                 <%= "disabled" if global_task.frequency.to_s == "once" %>
                 aria-controls="repeatable_field"
                 aria-label="Permitir múltiplas execuções por período" />
          <span class="w-[52px] h-[30px] rounded-full bg-hairline transition-colors duration-200 relative peer-checked:bg-primary peer-disabled:opacity-50"
                style="box-shadow: inset 0 -3px 0 rgba(0,0,0,0.15);">
            <span class="w-[24px] h-[24px] rounded-full bg-white absolute top-[3px] left-[3px] transition-transform duration-200 peer-checked:translate-x-[22px]"
                  style="box-shadow: 0 2px 0 rgba(0,0,0,0.15);"></span>
          </span>
        </label>

        <fieldset id="repeatable_field"
                  data-repeatable-target="field"
                  class="flex flex-col gap-2 mt-3 <%= 'hidden' unless repeatable_initial %>">
          <%= f.label :max_completions_per_period,
                "Quantas vezes por dia?",
                class: "form-label",
                data: { repeatable_target: "helper" } %>
          <%= f.number_field :max_completions_per_period,
                value: current_max,
                min: 1,
                max: 20,
                class: "form-input",
                data: { repeatable_target: "input" } %>
          <p class="text-[11px] font-bold" style="color: var(--text-muted);">
            Cap de execuções por período. Por exemplo: escovar dentes 3x/dia.
          </p>
        </fieldset>
      </div>
    <% end %>

    <%# Category %>
    <%= render Ui::FormSection::Component.new(title: "Categoria") do %>
      <div class="flex flex-wrap gap-2" data-controller="selectable-group">
        <% Ui::Tokens::MISSION_CATEGORIES.each do |key, data|
             next if key == "geral"
             selected = cat_name == key
             tint_soft = Ui::Tokens.tint_soft(data[:tint])
             tint_fg   = Ui::Tokens.tint_fg(data[:tint])
             selected_style   = "background: #{tint_soft}; color: #{tint_fg}; border-color: #{tint_fg}; box-shadow: 0 3px 0 #{tint_fg};"
             unselected_style = "background: var(--surface); color: var(--text-muted); border-color: var(--hairline); box-shadow: 0 3px 0 var(--hairline);"
        %>
          <label class="ls-btn-3d inline-flex items-center gap-1.5 px-3.5 py-2 rounded-[12px] border-2 text-[12px] font-extrabold uppercase tracking-[0.5px] cursor-pointer"
                 data-selectable-group-target="option"
                 data-selected-style="<%= selected_style %>"
                 data-unselected-style="<%= unselected_style %>"
                 style="<%= selected ? selected_style : unselected_style %>">
            <%= f.radio_button :category, key, class: "sr-only" %>
            <%= render Ui::Icon::Component.new(data[:icon], size: 13, color: "currentColor") %>
            <%= data[:label] %>
          </label>
        <% end %>
      </div>
    <% end %>

    <%# Children assignment %>
    <% if kids.any? %>
      <%= render Ui::FormSection::Component.new do %>
        <label class="block text-[12px] font-extrabold uppercase tracking-[0.5px] mb-1"
               style="color: var(--text-muted);">Para quem é essa missão?</label>
        <p class="text-[11px] font-bold mb-3" style="color: var(--text-soft);">Selecione uma ou mais crianças. Deixe em branco para atribuir a todas.</p>
        <div class="flex flex-wrap gap-2.5" data-controller="selectable-group">
          <%= hidden_field_tag "global_task[assigned_profile_ids][]", "" %>
          <% kids.each do |kid|
               checked = selected_kid_ids.include?(kid.id)
               palette = Ui::SmileyAvatar::Component::COLOR_MAP[kid.color.to_s] || Ui::SmileyAvatar::Component::COLOR_MAP["primary"]
               # TODO: route through Ui::Tokens var helper once palette object exposes vars
               selected_style   = "background: #{palette[:tile]}; border-color: #{palette[:ring]}; box-shadow: 0 3px 0 #{palette[:ink]};"
               unselected_style = "background: var(--surface); border-color: var(--hairline); box-shadow: 0 3px 0 var(--hairline);"
               name_selected_style   = "color: #{palette[:ink]};"
               name_unselected_style = "color: var(--text);"
               check_bg_selected   = "background: var(--primary); box-shadow: 0 2px 0 var(--primary-2);"
               check_bg_unselected = "background: var(--surface-muted); border: 2px solid var(--hairline);"
          %>
            <label class="ls-icon-cell relative inline-flex items-center gap-2.5 pl-2 pr-9 py-2 rounded-[14px] border-2 cursor-pointer"
                   data-selectable-group-target="option"
                   data-selected-style="<%= selected_style %>"
                   data-unselected-style="<%= unselected_style %>"
                   data-selected-text-style="<%= name_selected_style %>"
                   data-unselected-text-style="<%= name_unselected_style %>"
                   style="<%= checked ? selected_style : unselected_style %>">
              <%= check_box_tag "global_task[assigned_profile_ids][]", kid.id, checked, class: "sr-only" %>
              <span class="w-9 h-9 rounded-full flex items-center justify-center shrink-0"
                    style="background: <%= palette[:ring] %>;">
                <%= render Ui::Icon::Component.new("happy-01", size: 20, color: palette[:ink]) %>
              </span>
              <span class="text-[13px] font-extrabold"
                    data-selectable-text
                    style="<%= checked ? name_selected_style : name_unselected_style %>"><%= kid.name %></span>
              <span class="absolute top-1/2 right-2 -translate-y-1/2 w-5 h-5 rounded-full flex items-center justify-center"
                    data-selectable-check-bg
                    data-selected-style="<%= check_bg_selected %>"
                    data-unselected-style="<%= check_bg_unselected %>"
                    style="<%= checked ? check_bg_selected : check_bg_unselected %>">
                <span data-selectable-check style="<%= 'display: none;' unless checked %>">
                  <%= render Ui::Icon::Component.new("check", size: 12, color: "white") %>
                </span>
              </span>
            </label>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%# Active toggle %>
    <%= render Ui::FormSection::Component.new(class: "flex items-center justify-between gap-3") do %>
      <div class="flex-1 min-w-0">
        <div class="text-[14px] font-extrabold mb-0.5" style="color: var(--text);">Missão ativa</div>
        <div class="text-[12px] font-bold" style="color: var(--text-muted);">Missões pausadas não aparecem para a criança</div>
      </div>
      <%= render Ui::Toggle::Component.new(name: "global_task[active]", checked: global_task.active?) %>
    <% end %>

    <%# Action bar %>
    <div class="flex flex-wrap justify-end gap-2.5 pt-1 pb-2">
      <%= render Ui::Btn::Component.new(variant: "secondary", url: parent_global_tasks_path) do %>
        Cancelar
      <% end %>
      <%= render Ui::Btn::Component.new(variant: "primary", type: "submit") do %>
        <%= render Ui::Icon::Component.new("check", size: 14, color: "currentColor") %>
        Salvar missão
      <% end %>
    </div>

    <% unless global_task.new_record? %>
      <div class="pt-4 mt-2 border-t-2" style="border-color: var(--hairline);">
        <%= render Ui::Btn::Component.new(
              variant: "danger",
              size: "sm",
              url: parent_global_task_path(global_task),
              method: :delete,
              data: { turbo_confirm: "Remover esta missão de todas as crianças? Esta ação não pode ser desfeita." }
            ) do %>
          <%= render Ui::Icon::Component.new("trash", size: 14, color: "currentColor") %>
          Remover missão
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
