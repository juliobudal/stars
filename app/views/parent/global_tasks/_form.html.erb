<%= form_with(model: global_task, url: global_task.new_record? ? parent_global_tasks_path : parent_global_task_path(global_task), class: "col", style: "gap: 20px;") do |f| %>
  <% if global_task.errors.any? %>
    <%= render Ui::Card::Component.new(variant: "flat", class: "bg-danger-soft text-danger p-4 mb-4") do %>
      <h3 class="h-display" style="font-size: 18px;">Ops! Algo deu errado:</h3>
      <ul class="subtitle" style="font-size: 14px; list-style: disc; margin-left: 20px;">
        <% global_task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%
    cat_name = global_task.category || "geral"
    cat_data = Ui::MissionCard::Component::CATEGORIES[cat_name.to_s] || Ui::MissionCard::Component::CATEGORIES["geral"]
    icon_options = %w[bed brush book dish bookOpen bear paw music sun home graduationCap muscle]
  %>

  <div class="center mb-4">
    <%= render Ui::IconTile::Component.new(icon: global_task.icon.presence || "target", color: cat_data[:color], size: 80) %>
  </div>

  <div class="form-field">
    <%= f.label :title, "Título", class: "form-label" %>
    <%= f.text_field :title, class: "form-input", placeholder: "Ex: Arrumar a cama" %>
  </div>

  <div class="grid-2" style="gap: 12px;">
    <div class="form-field">
      <%= f.label :points, "Estrelinhas", class: "form-label" %>
      <%= f.number_field :points, class: "form-input" %>
    </div>
    <div class="form-field">
      <%= f.label :frequency, "Frequência", class: "form-label" %>
      <%= f.select :frequency, [["Diária", "daily"], ["Semanal", "weekly"]], {}, class: "form-select" %>
    </div>
  </div>

  <div class="form-field">
    <label class="form-label">Categoria</label>
    <div class="row wrap" style="gap: 8px;">
      <% Ui::MissionCard::Component::CATEGORIES.each do |key, data| %>
        <% next if data[:label] == "Geral" %>
        <label class="cursor-pointer">
          <%= f.radio_button :category, key, class: "peer sr-only" %>
          <div class="chip chip-<%= data[:color] %> peer-checked:outline peer-checked:outline-3 peer-checked:outline-offset-2" style="outline-color: var(--c-<%= data[:color] %>);">
            <%= render Ui::Icon::Component.new(data[:icon], size: 14) %>
            <%= data[:label] %>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <div class="form-field">
    <label class="form-label">Ícone</label>
    <div class="row wrap" style="gap: 6px;">
      <% icon_options.each do |ic| %>
        <label class="cursor-pointer">
          <%= f.radio_button :icon, ic, class: "peer sr-only" %>
          <div class="peer-checked:bg-primary-soft peer-checked:border-primary border-2 border-transparent p-2 rounded-xl transition-all" style="width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: white; border: 2px solid rgba(26,42,74,0.1);">
            <%= render Ui::Icon::Component.new(ic, size: 24, color: "var(--primary)") %>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <%# Active toggle %>
  <div class="row" style="justify-content: space-between; align-items: center; padding: 12px 0; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline);">
    <div>
      <div style="font-size: 13px; font-weight: 700; color: var(--text);">Missão ativa</div>
      <div style="font-size: 11px; color: var(--text-muted);">Missões inativas não aparecem para as crianças</div>
    </div>
    <label class="toggle <%= 'is-checked' if global_task.active? %>">
      <%= f.hidden_field :active, value: "0" %>
      <input type="checkbox" name="global_task[active]" value="1" <%= "checked" if global_task.active? %> />
      <span class="toggle-track"><span class="toggle-thumb"></span></span>
    </label>
  </div>

  <%# Assign to kids %>
  <% family = global_task.family || current_profile.family %>
  <% kids = family.profiles.child.order(:name) %>
  <% if kids.any? %>
    <div class="form-field">
      <label class="form-label">Atribuir a</label>
      <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 8px;">Deixe em branco para atribuir a todas as crianças.</div>
      <div class="row wrap" style="gap: 8px;">
        <% kids.each do |kid| %>
          <% checked = global_task.assigned_profile_ids.include?(kid.id) %>
          <label class="cursor-pointer">
            <%= check_box_tag "global_task[assigned_profile_ids][]", kid.id, checked, class: "peer sr-only" %>
            <div class="chip" style="background: <%= checked ? 'var(--primary-soft)' : 'var(--surface-2)' %>; color: <%= checked ? 'var(--primary)' : 'var(--text)' %>; border: 1px solid <%= checked ? 'var(--primary)' : 'var(--hairline)' %>;">
              <%= kid.name %>
            </div>
          </label>
        <% end %>
      </div>
      <%# ensure empty array when none selected %>
      <%= hidden_field_tag "global_task[assigned_profile_ids][]", "" %>
    </div>
  <% end %>

  <%# Out-of-scope recurrence chips (disabled) %>
  <div class="form-field" style="opacity: .5;">
    <label class="form-label">Outras recorrências (em breve)</label>
    <div class="row wrap" style="gap: 6px;">
      <% %w[Mensal Única-vez].each do |lbl| %>
        <div class="chip" style="cursor: not-allowed;" aria-disabled="true"><%= lbl %></div>
      <% end %>
    </div>
  </div>

  <div class="row mt-4" style="gap: 10px; justify-content: flex-end;">
    <%= link_to "Voltar", parent_global_tasks_path, class: "btn btn-secondary" %>
    <%= f.submit "Salvar Missão", class: "btn btn-primary" %>
  </div>

  <% unless global_task.new_record? %>
    <div class="mt-8 pt-6 border-t-2 border-border">
      <%= button_to parent_global_task_path(global_task), method: :delete, class: "btn btn-danger btn-sm", data: { turbo_confirm: "Tem certeza? Isso removerá a missão permanentemente." } do %>
        <%= render Ui::Icon::Component.new("trash", size: 16, color: "white") %> Remover Missão
      <% end %>
    </div>
  <% end %>
<% end %>
