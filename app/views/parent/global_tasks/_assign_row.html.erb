<%#
  One mission row of the assignment matrix. Re-rendered (turbo replace) on
  every toggle so the checkboxes always reflect committed server state.
  Locals: mission, kids, saved (bool).

  A mission with zero explicit assignments is implicitly assigned to ALL
  children — so every box shows checked and a "Todas" pill marks the row.
%>
<%
  assigned = mission.assigned_profiles.to_a
  all_assigned = assigned.empty?
  assigned_ids = all_assigned ? kids.map(&:id) : assigned.map(&:id)
  cm = Ui::Tokens.category_for(mission.category)
  fm = Ui::Tokens.frequency_for(mission.frequency)
  tint_soft = Ui::Tokens.tint_soft(cm[:tint])
  tint_fg   = Ui::Tokens.tint_fg(cm[:tint])
%>
<div id="assign_row_<%= mission.id %>" data-assign-row data-assign-url="<%= assignment_parent_global_task_path(mission) %>"
     class="flex items-stretch border-t-2" style="border-color: var(--surface-muted);">

  <%# ── Sticky mission cell ── %>
  <div class="assign-col-task flex items-center gap-3 px-4 py-3 shrink-0"
       style="width: 240px; position: sticky; left: 0; background: var(--surface); z-index: 1; box-shadow: 1px 0 0 var(--surface-muted);">
    <div class="w-10 h-10 rounded-[12px] flex items-center justify-center shrink-0 border"
         style="background: <%= tint_soft %>; border-color: <%= tint_fg %>; opacity: <%= mission.active? ? 1 : 0.5 %>;">
      <%= render Ui::Icon::Component.new(cm[:icon], size: 20, color: tint_fg) %>
    </div>
    <div class="min-w-0">
      <div class="flex items-center gap-1.5">
        <span class="text-[14px] font-extrabold truncate" style="color: var(--text);"><%= mission.title %></span>
        <% unless mission.active? %>
          <span class="text-[9px] font-extrabold uppercase px-1.5 py-0.5 rounded-[5px] shrink-0"
                style="background: var(--star-soft); color: var(--c-reward-text);">pausada</span>
        <% end %>
      </div>
      <div class="flex items-center gap-1.5 mt-0.5">
        <span class="text-[11px] font-bold" style="color: var(--text-muted);"><%= fm[:label] %> · <%= mission.points %>★</span>
        <% if all_assigned %>
          <span data-all-pill class="text-[9px] font-extrabold uppercase px-1.5 py-0.5 rounded-[5px]"
                style="background: var(--primary-soft); color: var(--primary-2);">todas</span>
        <% end %>
        <% if saved %>
          <span data-saved-chip class="anim-pop-in inline-flex items-center gap-0.5 text-[11px] font-extrabold" style="color: var(--text);">
            <%= render Ui::Icon::Component.new("check", size: 12, color: "var(--primary)") %> salvo
          </span>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── One toggle per child ── %>
  <% kids.each do |kid| %>
    <% checked = assigned_ids.include?(kid.id) %>
    <label class="assign-col-kid flex items-center justify-center shrink-0 cursor-pointer py-3"
           style="width: 72px;">
      <input type="checkbox" name="profile_ids[]" value="<%= kid.id %>" <%= "checked" if checked %>
             class="peer sr-only" data-action="change->assignment-matrix#save"
             aria-label="<%= mission.title %> para <%= kid.name %>">
      <span class="w-9 h-9 rounded-[11px] border flex items-center justify-center text-transparent
                   border-[var(--hairline)] bg-[var(--surface-muted)]
                   peer-checked:border-[var(--primary)] peer-checked:bg-[var(--primary)] peer-checked:text-white
                   peer-focus-visible:ring-2 peer-focus-visible:ring-[var(--primary)]"
            style="transition: background-color var(--dur-fast) ease, border-color var(--dur-fast) ease, color var(--dur-fast) ease;"
            data-check-box>
        <%= render Ui::Icon::Component.new("check", size: 18, color: "currentColor") %>
      </span>
    </label>
  <% end %>
</div>
