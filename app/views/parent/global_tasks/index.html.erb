<%
  freq_meta = {
    "daily"   => { label: "Diária",  soft: "var(--mint-soft, #D1FAE5)", dark: "var(--mint-dark, #047857)" },
    "weekly"  => { label: "Semanal", soft: "var(--sky-soft, #E0F2FE)",  dark: "var(--sky-dark, #0369A1)" },
    "monthly" => { label: "Mensal",  soft: "var(--lilac-soft, #EDE9FE)", dark: "var(--lilac-dark, #6D28D9)" },
    "once"    => { label: "Única",   soft: "var(--peach-soft, #FCE7F3)", dark: "var(--peach-dark, #BE185D)" }
  }
  kids = Profile.where(family_id: current_profile.family_id).child.order(:name).to_a
%>
<div class="screen screen-enter-right with-nav" data-controller="tabs">
  <%= render Ui::BgShapes::Component.new(variant: "blue") %>

  <%= render Ui::TopBar::Component.new(
    title: "Banco de Missões",
    subtitle: "Crie tarefas que as crianças podem cumprir",
    back_url: parent_root_path
  ) do |bar| %>
    <% bar.with_right_slot do %>
      <%= link_to new_parent_global_task_path, class: "btn btn-primary" do %>
        <%= render Ui::Icon::Component.new("plus", size: 18, color: "white") %> Nova
      <% end %>
    <% end %>
  <% end %>

  <div class="filter-chips row" style="gap: 8px; flex-wrap: wrap; margin-bottom: 14px; z-index: 2;">
    <% [["all","Todas"],["daily","Diárias"],["weekly","Semanais"],["monthly","Mensais"],["once","Únicas"],["inactive","Inativas"]].each_with_index do |(key,label), idx| %>
      <button type="button"
              class="chip <%= 'active' if idx == 0 %>"
              data-tabs-target="tab"
              data-action="click->tabs#show"
              data-tabs-id-param="<%= key %>"
              style="padding: 8px 14px; border-radius: 999px; border: 1px solid var(--hairline); background: <%= idx == 0 ? 'var(--primary)' : 'var(--surface)' %>; color: <%= idx == 0 ? 'white' : 'var(--text)' %>; font-weight: 700; font-size: 13px; cursor: pointer;">
        <%= label %>
      </button>
    <% end %>
  </div>

  <div class="card" style="padding: 0; overflow: hidden; z-index: 2;">
    <% if @global_tasks.any? %>
      <div style="background: var(--surface-2); padding: 14px 20px; display: grid; grid-template-columns: 2fr 1.3fr 0.8fr 1.5fr 100px 60px; font-size: 11px; font-weight: 800; letter-spacing: .1em; color: var(--text-muted); text-transform: uppercase;">
        <div>Missão</div>
        <div>Recorrência</div>
        <div>Pontos</div>
        <div>Atribuída</div>
        <div>Ativa</div>
        <div></div>
      </div>

      <% @global_tasks.each do |m|
        freq_key = m.frequency.to_s
        fm = freq_meta[freq_key] || freq_meta["daily"]
        is_active = m.respond_to?(:active?) ? m.active? : true
        panel_keys = ["all", freq_key]
        panel_keys << "inactive" unless is_active
      %>
        <div class="mission-row"
             data-panels="<%= panel_keys.join(' ') %>"
             style="display: grid; grid-template-columns: 2fr 1.3fr 0.8fr 1.5fr 100px 60px; align-items: center; padding: 14px 20px; border-top: 1px solid var(--hairline); gap: 10px;">
          <div class="h-display" style="font-size: 15px; color: var(--text);"><%= m.title %></div>
          <div>
            <span class="chip chip-sm" style="background: <%= fm[:soft] %>; color: <%= fm[:dark] %>;">
              <%= fm[:label] %>
            </span>
          </div>
          <div class="row" style="gap: 4px; align-items: center;">
            <%= render Ui::Icon::Component.new("star", size: 14, color: "var(--star)") %>
            <span class="h-display" style="font-size: 15px; color: var(--star-2);"><%= m.points %></span>
          </div>
          <div class="row" style="gap: -4px; align-items: center;">
            <% kids.first(4).each_with_index do |k, idx|
              c = k.color.presence || "primary"
              bg = c == "primary" ? "var(--primary)" : "var(--c-#{c})"
              initials = k.name.to_s.strip.split.first(2).map { |w| w[0] }.join.upcase
            %>
              <span title="<%= k.name %>" style="display: inline-flex; align-items: center; justify-content: center; width: 24px; height: 24px; border-radius: 50%; background: <%= bg %>; color: white; font-size: 10px; font-weight: 800; margin-left: <%= idx.zero? ? 0 : -6 %>px; border: 2px solid var(--surface);">
                <%= initials %>
              </span>
            <% end %>
          </div>
          <div>
            <span style="display: inline-block; width: 36px; height: 20px; border-radius: 999px; background: <%= is_active ? 'var(--primary)' : 'var(--hairline)' %>; position: relative;">
              <span style="position: absolute; top: 2px; <%= is_active ? 'right: 2px' : 'left: 2px' %>; width: 16px; height: 16px; border-radius: 50%; background: white;"></span>
            </span>
          </div>
          <div class="row" style="gap: 4px; justify-content: flex-end;">
            <%= link_to edit_parent_global_task_path(m), class: "btn btn-ghost btn-sm", style: "padding: 6px;", aria: { label: "Editar" } do %>
              <%= render Ui::Icon::Component.new("pencil", size: 16, color: "var(--text-soft)") %>
            <% end %>
            <%= button_to parent_global_task_path(m), method: :delete, class: "btn btn-ghost btn-sm", style: "padding: 6px; color: var(--danger);", data: { turbo_confirm: "Remover a missão \"#{m.title}\"?" } do %>
              <%= render Ui::Icon::Component.new("trash", size: 16) %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div style="padding: 20px;">
        <%= render Ui::Empty::Component.new(
          icon: "target",
          title: "Nenhuma missão cadastrada",
          subtitle: "Crie missões para os seus filhos ganharem estrelinhas!",
          color: "primary"
        ) %>
      </div>
    <% end %>
  </div>
</div>

<script>
  // Client-side chip filtering: toggle rows based on data-panels.
  (function(){
    document.addEventListener("click", function(e){
      const btn = e.target.closest("[data-tabs-id-param]");
      if (!btn) return;
      const scope = btn.closest(".screen");
      if (!scope) return;
      const key = btn.dataset.tabsIdParam;
      scope.querySelectorAll(".chip").forEach(c => {
        const active = c === btn;
        c.classList.toggle("active", active);
        c.style.background = active ? "var(--primary)" : "var(--surface)";
        c.style.color = active ? "white" : "var(--text)";
      });
      scope.querySelectorAll(".mission-row").forEach(row => {
        const panels = (row.dataset.panels || "").split(/\s+/);
        row.style.display = panels.includes(key) ? "grid" : "none";
      });
    });
  })();
</script>
