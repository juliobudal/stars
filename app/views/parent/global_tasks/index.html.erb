<div class="screen screen-enter-right with-nav" data-controller="tabs">
  <%= render Ui::BgShapes::Component.new(variant: "blue") %>

  <%= render Ui::TopBar::Component.new(
    title: "Missões",
    subtitle: "#{@global_tasks.size} missões no catálogo",
    back_url: parent_root_path
  ) do |bar| %>
    <% bar.with_right_slot do %>
      <%= link_to new_parent_global_task_path, class: "btn btn-primary", style: "text-transform: none" do %>
        <%= render Ui::Icon::Component.new("plus", size: 18, color: "white") %> Nova missão
      <% end %>
    <% end %>
  <% end %>

  <%
    chip_items = [
      { id: "all",      label: "Todas" },
      { id: "daily",    label: "Diárias" },
      { id: "weekly",   label: "Semanais" },
      { id: "inactive", label: "Inativas" }
    ]
  %>
  <div style="margin-bottom: 14px; z-index: 2;">
    <%= render Ui::FilterChips::Component.new(items: chip_items, active: "all") %>
  </div>

  <div class="card" style="padding: 0; overflow: hidden; z-index: 2;">
    <% if @global_tasks.any? %>
      <div class="mission-header" style="display: none; background: var(--surface-2); padding: 14px 20px; grid-template-columns: 2fr 1.3fr 0.8fr 1.4fr 80px 80px; font-size: 11px; font-weight: 800; letter-spacing: .1em; color: var(--text-muted); text-transform: uppercase; gap: 10px;">
        <div>Missão</div>
        <div>Recorrência</div>
        <div>Estrelas</div>
        <div>Atribuída a</div>
        <div style="text-align: center;">Ativa</div>
        <div></div>
      </div>

      <% @global_tasks.each do |m|
        assigned = m.assigned_profiles.any? ? m.assigned_profiles : @kids
      %>
        <%= render Ui::MissionListRow::Component.new(mission: m, assigned_profiles: assigned) %>
      <% end %>
    <% else %>
      <div style="padding: 20px;">
        <%= render Ui::Empty::Component.new(
          icon: "target",
          title: "Nenhuma missão cadastrada",
          subtitle: "Crie missões para os seus filhos ganharem estrelinhas!",
          color: "primary"
        ) %>
      </div>
    <% end %>
  </div>
</div>

<style>
  @media (min-width: 768px) {
    .mission-header { display: grid !important; }
  }
</style>

<script>
  (function(){
    document.addEventListener("click", function(e){
      const btn = e.target.closest(".screen .tab[data-tabs-id-param]");
      if (!btn) return;
      const scope = btn.closest(".screen");
      if (!scope) return;
      const key = btn.dataset.tabsIdParam;
      scope.querySelectorAll(".tab").forEach(t => t.classList.toggle("active", t === btn));
      scope.querySelectorAll(".mission-row").forEach(row => {
        const panels = (row.dataset.panels || "").split(/\s+/);
        row.style.display = (key === "all" || panels.includes(key)) ? "" : "none";
      });
    });
  })();
</script>
