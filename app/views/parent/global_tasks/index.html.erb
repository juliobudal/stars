<div class="screen screen-enter-right with-nav" data-controller="filter-tabs">
  <%= render Ui::BgShapes::Component.new(variant: "blue") %>

  <%= render Ui::TopBar::Component.new(
    title: "Missões",
    subtitle: "#{@global_tasks.size} missões no catálogo",
  ) do |bar| %>
    <% bar.with_right_slot do %>
      <%= render Ui::Btn::Component.new(url: new_parent_global_task_path, size: "md") do %>
        <%= render Ui::Icon::Component.new("plus", size: 18) %> Nova missão
      <% end %>
    <% end %>
  <% end %>

  <%
    chip_items = [
      { id: "all",      label: "Todas" },
      { id: "daily",    label: "Diárias" },
      { id: "weekly",   label: "Semanais" },
      { id: "inactive", label: "Inativas" }
    ]
  %>
  <div class="mb-3.5 z-2">
    <%= render Ui::FilterChips::Component.new(items: chip_items, active: "all", controller: "filter-tabs") %>
  </div>

  <div class="bg-surface rounded-card shadow-card relative border-none p-0 overflow-hidden z-2">
    <% if @global_tasks.any? %>
      <div class="hidden md:grid bg-muted/40 py-3.5 px-5 grid-cols-[2fr_1.3fr_0.8fr_1.4fr_80px_80px] text-[11px] font-extrabold tracking-widest text-muted-foreground uppercase gap-2.5">
        <div>Missão</div>
        <div>Recorrência</div>
        <div>Estrelas</div>
        <div>Atribuída a</div>
        <div class="text-center">Ativa</div>
        <div></div>
      </div>

      <% @global_tasks.each do |m|
        assigned = m.assigned_profiles.any? ? m.assigned_profiles : @kids
        panel_keys = [ "all", m.frequency.to_s ]
        panel_keys << "inactive" unless m.active?
      %>
        <div data-filter-tabs-target="item" data-panels="<%= panel_keys.join(' ') %>">
          <%= render Ui::MissionListRow::Component.new(mission: m, assigned_profiles: assigned) %>
        </div>
      <% end %>
    <% else %>
      <div class="p-5">
        <%= render Ui::Empty::Component.new(
          icon: "target",
          title: "Nenhuma missão cadastrada",
          subtitle: "Crie missões para os seus filhos ganharem estrelinhas!",
          color: "primary"
        ) %>
      </div>
    <% end %>
  </div>

  <%# Brand footer %>
  <div style="display: flex; align-items: center; justify-content: center; gap: 8px; padding: 24px 0 8px; opacity: 0.35;">
    <%= render Ui::LogoMark::Component.new(size: 16) %>
    <span style="font-size: 11px; font-weight: 800; letter-spacing: .12em; color: var(--text-muted); text-transform: uppercase;">LittleStars</span>
  </div>
</div>

