<div class="screen screen-enter-right with-nav">
  <%= render Ui::BgShapes::Component.new(variant: "blue") %>

  <%= render Ui::TopBar::Component.new(
    title: "Banco de Missões",
    subtitle: "Crie tarefas que as crianças podem cumprir",
    back_url: parent_root_path
  ) do |bar| %>
    <% bar.with_right_slot do %>
      <%= link_to new_parent_global_task_path, class: "btn btn-primary" do %>
        <%= render Ui::Icon::Component.new("plus", size: 18, color: "white") %> Nova
      <% end %>
    <% end %>
  <% end %>

  <div class="col" style="gap: 10px; z-index: 2;">
    <% if @global_tasks.any? %>
      <% @global_tasks.each_with_index do |m, i| %>
        <%
          cat_key = m.category.to_s.presence || "geral"
          cat_data = Ui::MissionCard::Component::CATEGORIES[cat_key] || Ui::MissionCard::Component::CATEGORIES["geral"]
        %>
        <%= link_to edit_parent_global_task_path(m), class: "card pop-on-tap card-tap", style: "padding: 14px; cursor: pointer; animation: slideInCard 0.35s ease #{i * 0.03}s both; border: 2px solid rgba(26,42,74,0.08); text-decoration: none; display: block;" do %>
          <div class="row" style="gap: 14px;">
            <%= render Ui::IconTile::Component.new(icon: cat_data[:icon], color: cat_data[:color], size: 52) %>
            <div class="col fg1" style="gap: 4px;">
              <div class="h-display" style="font-size: 17px; color: var(--text);"><%= m.title %></div>
              <div class="row" style="gap: 6px;">
                <%= render Ui::Badge::Component.new(variant: cat_data[:color], size: "sm", icon: cat_data[:icon]) do %>
                  <%= cat_data[:label] %>
                <% end %>

                <%= render Ui::Badge::Component.new(variant: "outline", size: "sm") do %>
                  <%= m.frequency == "daily" ? "Diária" : "Semanal" %>
                <% end %>
              </div>
            </div>
            <div class="row" style="gap: 4px; align-items: center;">
              <%= render Ui::Icon::Component.new("star", size: 20, color: "var(--star)") %>
              <div class="h-display" style="font-size: 20px; color: var(--star-2);"><%= m.points %></div>
            </div>
            <%= render Ui::Icon::Component.new("chevron", size: 18, color: "var(--text-soft)") %>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <%= render Ui::Empty::Component.new(
        icon: "target",
        title: "Nenhuma missão cadastrada",
        subtitle: "Crie missões para os seus filhos ganharem estrelinhas!",
        color: "primary"
      ) %>
    <% end %>
  </div>
</div>
