<div class="page-enter-right" data-controller="filter-tabs">

  <%
    total_count    = @global_tasks.size
    daily_count    = @global_tasks.count { |m| m.frequency.to_s == "daily" }
    weekly_count   = @global_tasks.count { |m| m.frequency.to_s == "weekly" }
    inactive_count = @global_tasks.count { |m| !m.active? }
    active_count   = total_count - inactive_count
    first_kid_name = @kids.first&.name
    subtitle = if total_count.zero?
                 "Crie a primeira missão para a família"
    else
                 base = "#{total_count} #{'missão'.pluralize(total_count == 1 ? 1 : 2)} no catálogo"
                 base += first_kid_name.present? ? " · #{active_count} ativas para #{first_kid_name}" : " · #{active_count} ativas"
                 base
    end
  %>

  <%# Header %>
  <%= render Ui::PageHeader::Component.new(title: "Missões", subtitle: subtitle) do |h| %>
    <% h.with_right_slot do %>
      <%= render Ui::Btn::Component.new(variant: "primary", url: new_parent_global_task_path) do %>
        <%= render Ui::Icon::Component.new("plus", size: 14, color: "currentColor") %>
        Nova missão
      <% end %>
    <% end %>
  <% end %>

  <%# Filter pills %>
  <%
    chip_items = [
      { id: "all",      label: "Todas",     count: total_count },
      { id: "daily",    label: "Diárias",   count: daily_count },
      { id: "weekly",   label: "Semanais",  count: weekly_count },
      { id: "inactive", label: "Inativas",  count: inactive_count }
    ]
  %>
  <div class="mb-[20px]">
    <%= render Ui::FilterChips::Component.new(items: chip_items, active: "all", controller: "filter-tabs") %>
  </div>

  <%# Mission grid %>
  <% if @global_tasks.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3.5">
      <% @global_tasks.each do |m| %>
        <%= render "mission_card", mission: m, assigned: (m.assigned_profiles.any? ? m.assigned_profiles : @kids) %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-surface rounded-[16px] border-2 p-5"
         style="border-color: var(--hairline); box-shadow: var(--shadow-card);">
      <%= render Ui::Empty::Component.new(
        icon: "target",
        title: "Nenhuma missão cadastrada",
        subtitle: "Crie missões para os seus filhos ganharem estrelinhas!",
        color: "primary"
      ) %>
    </div>
  <% end %>
</div>
