<div class="screen screen-enter with-nav">

  <%= render Ui::TopBar::Component.new(
        title: "Convidar responsável",
        subtitle: "Envie um convite por email para outro adulto da família",
        back_url: parent_settings_path
      ) %>

  <%= form_with model: @invitation, url: parent_invitations_path, method: :post, class: "block" do |f| %>
    <%= render Ui::FormErrors::Component.new(record: @invitation) %>

    <div class="grid grid-cols-1 gap-[18px] max-w-[720px]">
      <%= render Ui::FormSection::Component.new do %>
        <%= f.label :email, "Email do responsável", class: "form-label mb-[10px]" %>
        <%= f.email_field :email, placeholder: "email@exemplo.com", class: "form-input" %>
      <% end %>

      <div class="flex flex-row justify-end gap-[10px] py-1">
        <%= render Ui::Btn::Component.new(variant: "secondary", url: parent_settings_path) do %>
          Cancelar
        <% end %>
        <%= render Ui::Btn::Component.new(variant: "primary", type: "submit") do %>
          Enviar convite
        <% end %>
      </div>
    </div>
  <% end %>
</div>
