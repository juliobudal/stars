<%= render Ui::Card::Component.new(class: "max-w-[480px] mx-auto my-10") do %>
  <%= render Ui::Heading::Component.new(size: :h1, class: "mb-6") do %>Convidar responsável<% end %>

  <% if @invitation.errors.any? %>
    <div class="alert alert-error mb-4">
      <% @invitation.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: @invitation, url: parent_invitations_path, method: :post do |f| %>
    <div class="mb-5">
      <%= f.label :email, "Email do responsável", class: "block font-bold mb-1.5" %>
      <%= f.email_field :email, placeholder: "email@exemplo.com",
            class: "w-full py-2.5 px-3 border-1.5 border-hairline rounded-[10px] text-[14px]" %>
    </div>

    <div class="flex gap-3">
      <%= render Ui::Btn::Component.new(variant: "primary", size: "md", block: false, type: "submit", class: "flex-1") do %>
        Enviar convite
      <% end %>
      <%= render Ui::Btn::Component.new(variant: "ghost", size: "md", url: parent_settings_path, class: "flex-1 text-center") do %>
        Cancelar
      <% end %>
    </div>
  <% end %>
<% end %>
