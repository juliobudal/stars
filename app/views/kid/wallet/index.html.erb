<div class="screen screen-enter-right with-nav">
  <%= render Ui::BgShapes::Component.new(variant: "cool") %>

  <%# ─── Top Bar ─── %>
  <%= render Ui::TopBar::Component.new(back_url: kid_root_path) do |c| %>
    <% c.with_right_slot do %>
      <div class="row" style="gap: 8px; align-items: center;">
        <div style="display: flex; align-items: center; gap: 5px; background: var(--star-soft); border-radius: var(--r-full); padding: 5px 12px;">
          <%= render Ui::Icon::Component.new("star", size: 16, color: "var(--star-2)") %>
          <span class="h-display" style="font-size: 15px; color: var(--star-2);"><%= current_profile.points %></span>
        </div>
        <%= render Ui::SmileyAvatar::Component.new(kid: current_profile, size: 34) %>
      </div>
    <% end %>
  <% end %>
  <div style="margin-top: -12px; margin-bottom: 16px; padding-left: 4px;">
    <div class="eyebrow" style="font-size: 11px; color: var(--text-muted); letter-spacing: 0.1em;">DIÁRIO DE</div>
    <h2 class="h-display" style="font-size: 30px; margin: 0;"><%= current_profile.name %></h2>
  </div>

  <%# ─── Week Summary Cards (3-col) ─── %>
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 16px; z-index: 2; position: relative;">
    <%# Conquistado %>
    <div class="card" style="padding: 12px; background: var(--c-mint-soft); border: none;">
      <div class="eyebrow" style="color: var(--c-mint-dark); margin-bottom: 4px;">CONQUISTADO</div>
      <div class="h-display" style="font-size: 20px; color: var(--c-mint-dark);">+<%= @week_earned %> ⭐</div>
      <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">esta semana</div>
    </div>

    <%# Gasto %>
    <div class="card" style="padding: 12px; background: var(--c-rose-soft); border: none;">
      <div class="eyebrow" style="color: var(--c-rose-dark); margin-bottom: 4px;">GASTO</div>
      <div class="h-display" style="font-size: 20px; color: var(--c-rose-dark);">−<%= @week_spent %> ⭐</div>
      <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">em prêmios</div>
    </div>

    <%# Missões feitas %>
    <div class="card" style="padding: 12px; background: var(--c-lilac-soft); border: none;">
      <div class="eyebrow" style="color: var(--primary); margin-bottom: 4px;">MISSÕES FEITAS</div>
      <div class="h-display" style="font-size: 20px; color: var(--primary);"><%= @week_missions %></div>
      <div style="font-size: 11px; color: var(--text-muted); margin-top: 2px;">aprovadas</div>
    </div>
  </div>

  <%# ─── Section heading ─── %>
  <div style="margin-bottom: 12px; z-index: 2; position: relative;">
    <h3 class="h-display" style="font-size: 20px; margin: 0;">Tudo que rolou</h3>
  </div>

  <%# ─── Filter Chips ─── %>
  <div data-controller="tabs" style="z-index: 2; position: relative;">
    <div style="display: flex; gap: 8px; overflow-x: auto; padding-bottom: 12px; scrollbar-width: none; margin-bottom: 12px;">
      <button
        class="active"
        data-tabs-target="tab"
        data-action="click->tabs#show"
        data-tabs-id-param="all"
        style="border-radius: var(--r-full); padding: 6px 16px; font-size: 13px; font-weight: 700; cursor: pointer; border: none; white-space: nowrap; background: var(--primary); color: white;">
        Tudo
      </button>
      <button
        data-tabs-target="tab"
        data-action="click->tabs#show"
        data-tabs-id-param="earned"
        style="border-radius: var(--r-full); padding: 6px 16px; font-size: 13px; font-weight: 700; cursor: pointer; border: none; white-space: nowrap; background: var(--surface-2); color: var(--text-muted);">
        Conquistadas
      </button>
      <button
        data-tabs-target="tab"
        data-action="click->tabs#show"
        data-tabs-id-param="purchases"
        style="border-radius: var(--r-full); padding: 6px 16px; font-size: 13px; font-weight: 700; cursor: pointer; border: none; white-space: nowrap; background: var(--surface-2); color: var(--text-muted);">
        Compras
      </button>
      <button
        data-tabs-target="tab"
        data-action="click->tabs#show"
        data-tabs-id-param="pending"
        style="border-radius: var(--r-full); padding: 6px 16px; font-size: 13px; font-weight: 700; cursor: pointer; border: none; white-space: nowrap; background: var(--surface-2); color: var(--text-muted);">
        Aguardando
      </button>
      <button
        data-tabs-target="tab"
        data-action="click->tabs#show"
        data-tabs-id-param="rejected"
        style="border-radius: var(--r-full); padding: 6px 16px; font-size: 13px; font-weight: 700; cursor: pointer; border: none; white-space: nowrap; background: var(--surface-2); color: var(--text-muted);">
        Rejeitadas
      </button>
    </div>

    <%# Panel: Tudo %>
    <div id="panel-all" style="display: flex; flex-direction: column; gap: 0;">
      <% if @activity_logs.any? %>
        <%= render partial: "kid/wallet/day_groups", locals: { grouped: @all_grouped, today: @today } %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "scroll",
          title: "Nenhuma atividade ainda ⭐",
          subtitle: "Complete missões ou faça resgates pra começar o histórico",
          color: "lilac"
        ) %>
      <% end %>
    </div>

    <%# Panel: Conquistadas %>
    <div id="panel-earned" style="display: none; flex-direction: column; gap: 0;">
      <% if @earned_grouped.any? %>
        <%= render partial: "kid/wallet/day_groups", locals: { grouped: @earned_grouped, today: @today } %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "scroll",
          title: "Nenhuma conquista ainda ⭐",
          subtitle: "Complete missões para ganhar estrelinhas",
          color: "lilac"
        ) %>
      <% end %>
    </div>

    <%# Panel: Compras %>
    <div id="panel-purchases" style="display: none; flex-direction: column; gap: 0;">
      <% if @purchase_grouped.any? %>
        <%= render partial: "kid/wallet/day_groups", locals: { grouped: @purchase_grouped, today: @today } %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "scroll",
          title: "Nenhuma compra ainda ⭐",
          subtitle: "Resgate recompensas na loja",
          color: "lilac"
        ) %>
      <% end %>
    </div>

    <%# Panel: Aguardando (no ActivityLog status — honest empty state) %>
    <div id="panel-pending" style="display: none; flex-direction: column; gap: 0;">
      <%= render Ui::Empty::Component.new(
        icon: "clock",
        title: "Aguardando aprovação",
        subtitle: "Missões enviadas para aprovação aparecerão aqui em breve",
        color: "primary"
      ) %>
    </div>

    <%# Panel: Rejeitadas (no ActivityLog status — honest empty state) %>
    <div id="panel-rejected" style="display: none; flex-direction: column; gap: 0;">
      <%= render Ui::Empty::Component.new(
        icon: "scroll",
        title: "Nenhuma missão rejeitada",
        subtitle: "Ótimo trabalho! Missões rejeitadas aparecerão aqui",
        color: "rose"
      ) %>
    </div>
  </div>
</div>
