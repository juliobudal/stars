<div class="screen screen-enter-right with-nav">
  <%= render Ui::TopBar::Component.new(
    title: "Diário",
    subtitle: "Suas estrelinhas ganhas e gastas",
    back_url: kid_root_path
  ) %>

  <% if current_profile.points < 0 && current_profile.family.allow_negative? %>
    <div class="inline-flex items-center gap-1 bg-danger-soft text-danger border border-danger rounded-full py-0.5 px-2.5 text-[12px] font-bold mb-3 z-2 relative">
      em débito
    </div>
  <% end %>

  <%# Week Summary Cards (3-col) %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-2.5 mb-4 z-10 relative">
    <%= render Ui::StatMetric::Component.new(value: @week_earned,   label: "Conquistado", tint: "mint",    prefix: "+") %>
    <%= render Ui::StatMetric::Component.new(value: @week_spent,    label: "Gasto",       tint: "rose",    prefix: "−") %>
    <%= render Ui::StatMetric::Component.new(value: @week_missions, label: "Missões",     tint: "primary") %>
  </div>

  <div data-controller="tabs" class="z-2 relative">
    <%= render Ui::CategoryTabs::Component.new(
      items: [
        { id: "all",         label: "Tudo" },
        { id: "earned",      label: "Conquistadas" },
        { id: "purchases",   label: "Compras" },
        { id: "discoveries", label: "Descobertas" },
        { id: "pending",     label: "Esperando" },
        { id: "rejected",    label: "Refazer" }
      ],
      active: "all"
    ) %>

    <%# Panel: Tudo %>
    <div id="panel-all" class="flex flex-col gap-0">
      <% if @activity_logs.any? %>
        <%= render partial: "kid/wallet/day_groups", locals: { grouped: @all_grouped, today: @today } %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "scroll",
          title: "Nenhuma atividade ainda",
          subtitle: "Complete missões ou faça resgates pra começar o histórico",
          color: "lilac"
        ) %>
      <% end %>
    </div>

    <%# Panel: Conquistadas %>
    <div id="panel-earned" class="flex flex-col gap-0 hidden">
      <% if @earned_grouped.any? %>
        <%= render partial: "kid/wallet/day_groups", locals: { grouped: @earned_grouped, today: @today } %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "scroll",
          title: "Nenhuma conquista ainda",
          subtitle: "Complete missões para ganhar estrelinhas",
          color: "lilac"
        ) %>
      <% end %>
    </div>

    <%# Panel: Compras %>
    <div id="panel-purchases" class="flex flex-col gap-0 hidden">
      <% if @purchase_grouped.any? %>
        <%= render partial: "kid/wallet/day_groups", locals: { grouped: @purchase_grouped, today: @today } %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "scroll",
          title: "Nenhuma compra ainda",
          subtitle: "Resgate recompensas na loja",
          color: "lilac"
        ) %>
      <% end %>
    </div>

    <%# Panel: Descobertas — feed narrativo Academy v4 (cartas) %>
    <div id="panel-discoveries" class="flex flex-col gap-3 hidden">
      <% if @recent_cards.any? %>
        <h3 class="font-display text-[12px] font-extrabold tracking-[1.5px] uppercase mt-1 mb-1 px-1"
            style="color: var(--c-mint-dark);">CARTAS RECENTES</h3>
        <% @recent_cards.each do |card| %>
          <article class="ls-card-3d flex items-start gap-3"
                   style="background: var(--surface); border: 2px solid var(--hairline);
                          border-radius: 14px; padding: 12px 14px; box-shadow: 0 3px 0 rgba(0,0,0,0.06);">
            <div class="w-9 h-9 rounded-lg shrink-0 flex items-center justify-center"
                 style="background: <%= card.mission.subject.color.presence || 'var(--primary)' %>;">
              <%= render Ui::Icon::Component.new((card.illustration_key.presence || card.mission.subject.icon).to_sym, size: 16, color: "white") %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-display text-[13px] font-extrabold leading-tight" style="color: var(--text);">
                <%= card.headline %>
              </div>
              <div class="text-[11px] font-bold mt-0.5" style="color: var(--text-muted);">
                <%= card.mission.subject.name %> · <%= card.minted_at.strftime("%d/%m") %>
              </div>
            </div>
          </article>
        <% end %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "sparkle",
          title: "Sem descobertas ainda",
          subtitle: "Termine uma aula da Academia pra colecionar uma carta.",
          color: "primary"
        ) %>
      <% end %>
    </div>

    <%# Panel: Aguardando %>
    <div id="panel-pending" class="flex flex-col gap-5 hidden">
      <% if @pending_tasks.any? %>
        <% @pending_tasks.each_with_index do |task, i| %>
          <%= render Ui::MissionCard::Component.new(mission: task, status: "waiting", variant: "bubble", index: i) %>
        <% end %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "clock",
          title: "Esperando pai/mãe",
          subtitle: "Quando você terminar uma missão, ela espera aqui até um responsável confirmar",
          color: "primary"
        ) %>
      <% end %>
    </div>

    <%# Panel: Rejeitadas %>
    <div id="panel-rejected" class="flex flex-col gap-5 hidden">
      <% if @rejected_tasks.any? %>
        <% @rejected_tasks.each do |task| %>
          <%= render partial: "kid/wallet/rejected_task", locals: { rejected_task: task } %>
        <% end %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "scroll",
          title: "Nada pra refazer",
          subtitle: "Quando um responsável pedir pra refazer uma missão, ela aparece aqui",
          color: "rose"
        ) %>
      <% end %>
    </div>
  </div>
</div>
