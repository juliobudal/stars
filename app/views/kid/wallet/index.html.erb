<div class="screen screen-enter-right with-nav">
  <%= render Ui::BgShapes::Component.new(variant: "cool") %>

  <%= render Ui::TopBar::Component.new(
    title: "Diário",
    subtitle: "Suas estrelinhas ganhas e gastas",
    back_url: kid_root_path
  ) %>

  <% if current_profile.points < 0 && current_profile.family.allow_negative? %>
    <div style="display: inline-flex; align-items: center; gap: 4px; background: rgba(239,68,68,0.12); color: var(--danger); border: 1px solid var(--danger); border-radius: 999px; padding: 2px 10px; font-size: 12px; font-weight: 600; margin-bottom: 12px; z-index: 2; position: relative;">
      em débito
    </div>
  <% end %>

  <%# Week Summary Cards (3-col) %>
  <div class="grid-3" style="gap: 10px; margin-bottom: 16px; z-index: 2; position: relative;">
    <%= render Ui::StatMetric::Component.new(value: @week_earned,   label: "Conquistado", tint: "mint",    prefix: "+") %>
    <%= render Ui::StatMetric::Component.new(value: @week_spent,    label: "Gasto",       tint: "rose",    prefix: "−") %>
    <%= render Ui::StatMetric::Component.new(value: @week_missions, label: "Missões",     tint: "primary") %>
  </div>

  <div data-controller="tabs" style="z-index: 2; position: relative;">
    <%= render Ui::CategoryTabs::Component.new(
      items: [
        { id: "all",       label: "Tudo" },
        { id: "earned",    label: "Conquistadas" },
        { id: "purchases", label: "Compras" },
        { id: "pending",   label: "Aguardando" },
        { id: "rejected",  label: "Rejeitadas" }
      ],
      active: "all"
    ) %>

    <%# Panel: Tudo %>
    <div id="panel-all" class="col-tight">
      <% if @activity_logs.any? %>
        <%= render partial: "kid/wallet/day_groups", locals: { grouped: @all_grouped, today: @today } %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "scroll",
          title: "Nenhuma atividade ainda ⭐",
          subtitle: "Complete missões ou faça resgates pra começar o histórico",
          color: "lilac"
        ) %>
      <% end %>
    </div>

    <%# Panel: Conquistadas %>
    <div id="panel-earned" class="col-tight" style="display: none;">
      <% if @earned_grouped.any? %>
        <%= render partial: "kid/wallet/day_groups", locals: { grouped: @earned_grouped, today: @today } %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "scroll",
          title: "Nenhuma conquista ainda ⭐",
          subtitle: "Complete missões para ganhar estrelinhas",
          color: "lilac"
        ) %>
      <% end %>
    </div>

    <%# Panel: Compras %>
    <div id="panel-purchases" class="col-tight" style="display: none;">
      <% if @purchase_grouped.any? %>
        <%= render partial: "kid/wallet/day_groups", locals: { grouped: @purchase_grouped, today: @today } %>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "scroll",
          title: "Nenhuma compra ainda ⭐",
          subtitle: "Resgate recompensas na loja",
          color: "lilac"
        ) %>
      <% end %>
    </div>

    <%# Panel: Aguardando %>
    <div id="panel-pending" class="col-tight" style="display: none;">
      <%= render Ui::Empty::Component.new(
        icon: "clock",
        title: "Aguardando aprovação",
        subtitle: "Missões enviadas para aprovação aparecerão aqui em breve",
        color: "primary"
      ) %>
    </div>

    <%# Panel: Rejeitadas %>
    <div id="panel-rejected" class="col-tight" style="display: none;">
      <%= render Ui::Empty::Component.new(
        icon: "scroll",
        title: "Nenhuma missão rejeitada",
        subtitle: "Ótimo trabalho! Missões rejeitadas aparecerão aqui",
        color: "rose"
      ) %>
    </div>
  </div>
</div>
