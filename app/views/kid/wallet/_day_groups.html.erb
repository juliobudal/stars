<%# locals: (grouped:, today:) %>
<% grouped.each do |date, logs| %>
  <%
    day_label = if date == today
                  "Hoje"
                elsif date == today - 1
                  "Ontem"
                else
                  l(date, format: :short).capitalize
                end
    day_net = logs.sum { |l| l.earn? ? l.points : -(l.points) }
    net_color_class = day_net >= 0 ? "text-mint-dark" : "text-rose-dark"
    net_prefix = day_net >= 0 ? "+" : ""
  %>

  <%# Day header %>
  <div class="flex justify-between items-center px-1 pt-3.5 pb-1.5">
    <span class="font-display text-[16px] leading-tight font-extrabold tracking-[-0.02em] text-foreground italic"><%= day_label %></span>
    <span class="text-[12px] font-semibold text-muted-foreground row gap-1">Saldo: <span class="<%= net_color_class %>"><%= render Ui::StarValue::Component.new(value: day_net.abs, size: :xs, prefix: net_prefix, color: :current) %></span></span>
  </div>

  <%# Log entries — each is its own card via .history-entry %>
  <div class="mb-2">
    <% logs.each do |h| %>
      <%= render Ui::HistoryRow::Component.new(log: h, with_divider: false) %>
    <% end %>
  </div>
<% end %>
