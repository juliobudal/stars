<%= render Ui::ProgressSteps::Component.new(current: @step, total: 4) %>

<header class="mb-5">
  <h1 class="font-display text-[24px] leading-tight font-extrabold tracking-[-0.01em] m-0" style="color: var(--text);">
    O que você curte?
  </h1>
  <p class="text-[14px] font-bold mt-1.5 m-0" style="color: var(--text-muted);">
    Escolhe de <strong style="color: var(--primary);"><%= @min %> a <%= @max %></strong>. Vamos usar pra deixar as missões com a sua cara.
  </p>
</header>

<%= form_with url: kid_welcome_interests_path, method: :patch,
              data: { controller: "interest-picker",
                      "interest-picker-min-value": @min,
                      "interest-picker-max-value": @max },
              class: "flex-1 flex flex-col" do |f| %>

  <% if flash.now[:alert].present? %>
    <div class="rounded-2xl px-4 py-3 mb-3 font-bold text-sm"
         style="background: var(--c-rose-soft); color: var(--c-rose-dark);">
      <%= flash.now[:alert] %>
    </div>
  <% end %>

  <div class="grid grid-cols-3 gap-2.5 mb-5">
    <% @catalog.each do |entry| %>
      <% checked = @selected.include?(entry.key) %>
      <label class="interest-chip"
             data-interest-picker-target="chip"
             data-checked="<%= checked %>"
             style="
               position: relative;
               display:flex; flex-direction:column; align-items:center; justify-content:center;
               gap: 6px;
               padding: 10px 6px;
               min-height: 88px;
               border-radius: 14px;
               background: <%= checked ? 'var(--primary-soft)' : 'var(--surface-2)' %>;
               border: 2px solid <%= checked ? 'var(--primary)' : 'transparent' %>;
               box-shadow: <%= checked ? '0 4px 0 var(--primary-glow, rgba(0,0,0,0.08))' : 'none' %>;
               cursor: pointer;
               font-family: var(--font-display, Nunito), sans-serif;
               font-weight: 800;
               font-size: 12px;
               line-height: 1.2;
               text-align: center;
               color: <%= checked ? 'var(--primary)' : 'var(--text)' %>;
               user-select:none;
               transition: transform .05s;">
        <input type="checkbox"
               name="interest_keys[]"
               value="<%= entry.key %>"
               <%= "checked" if checked %>
               data-interest-picker-target="checkbox"
               style="position:absolute; opacity:0; pointer-events:none;">
        <span aria-hidden="true" style="font-size:28px; line-height:1;"><%= entry.emoji %></span>
        <span style="overflow-wrap: anywhere;"><%= entry.label %></span>
      </label>
    <% end %>
  </div>

  <div class="pt-2 pb-1">
    <div class="text-[12px] font-extrabold uppercase tracking-[0.5px] text-center mb-2.5"
         style="color: var(--text-muted);"
         data-interest-picker-target="count">
      <%= @selected.size %> de <%= @max %> escolhidas (mínimo <%= @min %>)
    </div>
    <%= f.button type: :submit,
                 class: "w-full ls-btn-3d inline-flex items-center justify-center gap-2 font-display font-extrabold uppercase tracking-[0.5px] border-0 cursor-pointer",
                 style: "padding: 14px 20px; border-radius: 14px; background: var(--primary); color: white; font-size: 16px; box-shadow: 0 4px 0 var(--primary-2);",
                 "data-testid": "interests-next" do %>
      Próximo
      <%= render Ui::Icon::Component.new("arrow-right-01", size: 18, color: "white") %>
    <% end %>
  </div>
<% end %>
