<%# Kid — Awaiting task partial (LittleStars design) %>
<%= render Ui::Card::Component.new(padding: "p-5", class: "pop-on-tap opacity-70") do %>
  <div class="flex items-center gap-3.5">
    <div class="flex items-center justify-center rounded-md shrink-0 w-[52px] h-[52px] bg-peach-soft text-peach">
      <i class="ph-bold ph-clock text-[28px]"></i>
    </div>
    <div class="flex flex-col flex-1 gap-1">
      <div class="font-display text-[16px] leading-tight font-extrabold tracking-[-0.02em] text-foreground line-through opacity-70"><%= awaiting_task.title %></div>
      <%= render Ui::Chip::Component.new(variant: "peach", class: "w-fit") do %>
        <i class="ph-bold ph-clock text-[12px] text-current"></i> Aguardando Aprovação
      <% end %>
    </div>
    <div class="flex flex-col items-center justify-center gap-0">
      <i class="ph-fill ph-star text-[18px] text-[var(--star)] opacity-50"></i>
      <div class="font-display text-[18px] leading-none font-extrabold tracking-[-0.02em] text-[var(--star-2)] opacity-50"><%= awaiting_task.points %></div>
    </div>
  </div>
<% end %>
