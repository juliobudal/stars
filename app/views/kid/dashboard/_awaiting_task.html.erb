<%# Kid — Awaiting task partial (LittleStars design) %>
<div class="card pop-on-tap" style="padding: 20px; opacity: 0.7; border: none;">
  <div class="row" style="gap: 14px;">
    <div class="icon-tile" style="width: 52px; height: 52px; background: var(--c-peach-soft); color: var(--c-peach);">
      <i class="ph-bold ph-clock" style="font-size: 28px;"></i>
    </div>
    <div class="col fg1" style="gap: 4px;">
      <div class="h-display" style="font-size: 16px; text-decoration: line-through; opacity: 0.7;"><%= awaiting_task.title %></div>
      <div class="chip" style="font-size: 11px; padding: 4px 10px; background: var(--c-peach-soft); color: var(--c-peach); width: fit-content;">
        <i class="ph-bold ph-clock" style="font-size: 12px; color: currentColor;"></i> Aguardando Aprovação
      </div>
    </div>
    <div class="col center" style="gap: 0;">
      <i class="ph-fill ph-star" style="font-size: 18px; color: var(--star); opacity: 0.5;"></i>
      <div class="h-display" style="font-size: 18px; color: var(--star-2); opacity: 0.5;"><%= awaiting_task.points %></div>
    </div>
  </div>
</div>
