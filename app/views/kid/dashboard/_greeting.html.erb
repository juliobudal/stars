<%# locals: remaining, awaiting_count, completed_today_count
     Lives outside the dashboard layout chrome so complete.turbo_stream can
     swap it in-place when a kid moves a task from pending → waiting. %>
<%
  hour     = Time.current.hour
  greeting = case hour when 5..11 then "Bom dia," when 12..17 then "Boa tarde," else "Boa noite," end
  total    = remaining.to_i + awaiting_count.to_i + completed_today_count.to_i
%>
<div id="kid_dashboard_greeting" class="flex items-center gap-4 mb-5 px-1 z-2 shrink-0">
  <div class="relative shrink-0">
    <div class="ls-mascot-bounce">
      <%= render Ui::SmileyAvatar::Component.new(kid: current_profile, size: 88, decorative: true) %>
    </div>
    <%= render Ui::Icon::Component.new(:star, size: 14, color: "var(--star)", class: "absolute -top-0.5 -right-1") %>
  </div>

  <div class="flex-1 min-w-0">
    <div class="font-display text-[11px] font-extrabold tracking-[1px] uppercase mb-1" style="color: var(--c-sky-dark);">
      <%= greeting %> <%= current_profile.name %>!
    </div>
    <h1 class="font-display text-[22px] leading-tight font-extrabold tracking-[-0.01em] m-0 inline-flex items-center gap-1.5 flex-wrap" style="color: var(--text);">
      <% if total.zero? %>
        <span>Por aqui agora,</span>
        <%= render Ui::Icon::Component.new(:star, size: 20, color: "var(--star)") %>
        <span>nada pra fazer!</span>
      <% elsif remaining.zero? && awaiting_count.positive? %>
        <span>Esperando o</span>
        <%= render Ui::Icon::Component.new(:check, size: 20, color: "var(--c-sky-dark)") %>
        <span>carimbo!</span>
      <% elsif remaining.zero? %>
        <span>Tudo feito!</span>
        <%= render Ui::Icon::Component.new(:party, size: 20, color: "var(--c-peach-dark)") %>
      <% else %>
        <span>Bora pegar mais</span>
        <%= render Ui::Icon::Component.new(:star, size: 20, color: "var(--star)") %>
        <span>hoje?</span>
      <% end %>
    </h1>
    <p class="text-[13px] font-bold mt-1.5 m-0 inline-flex items-center gap-1.5 flex-wrap" style="color: var(--text-muted);">
      <% if remaining.positive? %>
        <span>Você tem <strong style="color: var(--c-sky-dark);"><%= pluralize(remaining, "missão", plural: "missões") %></strong> pra completar</span>
      <% elsif awaiting_count.positive? %>
        <span><strong style="color: var(--c-sky-dark);"><%= pluralize(awaiting_count, "missão", plural: "missões") %></strong> esperando carimbo</span>
      <% elsif completed_today_count.positive? %>
        <span>Tudo feito por hoje!</span>
        <%= render Ui::Icon::Component.new(:party, size: 16, color: "var(--c-peach-dark)") %>
      <% else %>
        <span>Espera os pais soltarem missões pra você</span>
        <%= render Ui::Icon::Component.new(:eye, size: 16, color: "var(--text-muted)") %>
      <% end %>
    </p>
  </div>
</div>
