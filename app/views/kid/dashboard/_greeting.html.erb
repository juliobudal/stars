<%# locals: remaining, awaiting_count, completed_today_count
     Compact status line living inside the progress hero. Kept as its own
     partial + id so complete.turbo_stream can swap it in place when a kid
     moves a task pending → waiting. The avatar/balance/level around it are
     static and are NOT part of this swap. %>
<%
  hour     = Time.current.hour
  greeting = case hour when 5..11 then "Bom dia" when 12..17 then "Boa tarde" else "Boa noite" end
  remaining = remaining.to_i
  awaiting_count = awaiting_count.to_i
  completed_today_count = completed_today_count.to_i
  total = remaining + awaiting_count + completed_today_count

  if total.zero?
    headline, h_icon, h_color = "Tudo tranquilo agora", :star, "var(--star)"
  elsif remaining.zero? && awaiting_count.positive?
    headline, h_icon, h_color = "No aguardo do carimbo", :check, "var(--c-sky-dark)"
  elsif remaining.zero?
    headline, h_icon, h_color = "Tudo feito hoje!", :party, "var(--c-coral)"
  else
    headline, h_icon, h_color = "Bora pras missões!", :star, "var(--star)"
  end
%>
<div id="kid_dashboard_greeting" class="flex-1 min-w-0">
  <div class="font-display text-[11px] font-extrabold tracking-[0.5px] uppercase truncate" style="color: var(--c-sky-dark);">
    <%= greeting %>, <%= current_profile.name %>
  </div>
  <div class="font-display text-[17px] leading-tight font-extrabold mt-0.5 flex items-center gap-1.5 min-w-0" style="color: var(--text);">
    <span class="truncate"><%= headline %></span>
    <%= render Ui::Icon::Component.new(h_icon, size: 18, color: h_color, class: "shrink-0") %>
  </div>
</div>
