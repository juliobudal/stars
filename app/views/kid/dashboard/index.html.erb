<%
  total      = @profile_tasks.count + @awaiting_tasks.count + @completed_today.count
  done_count = @awaiting_tasks.count + @completed_today.count
  remaining  = @profile_tasks.count
%>

<div class="screen screen-enter with-nav">
  <%= render Ui::Celebration::Component.new %>

  <%# ── Header: streak + stars + switch ── %>
  <%= render Ui::KidTopBar::Component.new(profile: current_profile, streak: @streak_days) %>

  <%# ── Greeting block (extracted; complete.turbo_stream replaces this id) ── %>
  <%= render "kid/dashboard/greeting",
             remaining: remaining,
             awaiting_count: @awaiting_tasks.count,
             completed_today_count: @completed_today.count %>

  <%# ── Section heading + counter ── %>
  <div class="flex justify-between items-center mb-3 px-1 shrink-0 z-2">
    <h2 class="font-display text-[16px] font-extrabold m-0" style="color: var(--text);">Missões de hoje</h2>
    <% if total.positive? %>
      <div class="ls-card-3d inline-flex items-center gap-1.5"
           style="background: var(--primary-soft); border: 2px solid var(--primary); padding: 4px 10px; border-radius: 10px; box-shadow: 0 2px 0 var(--primary-2);">
        <span class="font-display text-[11px] font-extrabold tracking-[0.5px] uppercase" style="color: var(--primary-2);">
          <%= done_count %> de <%= total %>
        </span>
        <%= render Ui::Icon::Component.new(:check, size: 12, color: "var(--primary-2)") %>
      </div>
    <% end %>
  </div>

  <%# ── Mission list (above-the-fold) ── %>
  <% pending_visible, pending_extra = @profile_tasks.first(5), @profile_tasks.drop(5) %>
  <div class="flex flex-col gap-3 mb-5 relative z-2">

    <%# Completed (approved today) %>
    <div id="panel-completed" class="contents">
      <% @completed_today.each_with_index do |task, i| %>
        <%= render Ui::MissionCard::Component.new(mission: task, status: "approved", variant: "bubble", index: i) %>
      <% end %>
    </div>

    <%# Awaiting approval ── stays in turbo-stream target id %>
    <div id="panel-waiting" class="contents">
      <% @awaiting_tasks.each_with_index do |task, i| %>
        <%= render Ui::MissionCard::Component.new(mission: task, status: "waiting", variant: "bubble", index: i, id: dom_id(task)) %>
      <% end %>
    </div>

    <%# Pending · flat row, click opens confirmation modal %>
    <div id="panel-pending" class="contents">
      <% pending_visible.each_with_index do |profile_task, i| %>
        <%= render "kid/dashboard/pending_card", profile_task: profile_task, index: i %>
      <% end %>

      <% if pending_extra.any? %>
        <details class="contents" data-controller="">
          <summary class="font-display flex items-center justify-center gap-2 cursor-pointer list-none"
                   style="background: transparent; color: var(--text-muted); border: 2px dashed var(--hairline); border-radius: 14px; padding: 12px 14px; font-size: 13px; font-weight: 800;">
            <%= render Ui::Icon::Component.new(:plus, size: 14, color: "currentColor") %>
            Ver mais <%= pluralize(pending_extra.size, "missão", plural: "missões") %>
          </summary>
          <div class="flex flex-col gap-3 mt-3">
            <% pending_extra.each_with_index do |profile_task, i| %>
              <%= render "kid/dashboard/pending_card", profile_task: profile_task, index: i + pending_visible.size %>
            <% end %>
          </div>
        </details>
      <% end %>
    </div>

    <%# Empty state %>
    <% if total.zero? %>
      <%= render Ui::Empty::Component.new(
            icon: "star",
            title: "Nenhuma missão hoje",
            subtitle: "Um responsável vai adicionar novas missões pra você",
            color: "mint"
          ) %>
    <% end %>
  </div>

  <%# ── Ghost CTA: create custom mission (quiet, secondary affordance) ── %>
  <%= link_to new_kid_mission_path,
        class: "ls-btn-3d anim-press font-display flex items-center justify-center gap-2 w-full text-center mb-5 z-2 shrink-0 no-underline",
        style: "background: var(--surface); color: var(--text-muted); border: 2px dashed var(--hairline); border-radius: 14px; padding: 12px 14px; font-size: 13px; font-weight: 800;" do %>
    <%= render Ui::Icon::Component.new(:plus, size: 16, color: "currentColor") %>
    Fiz algo fora da lista
  <% end %>

  <%# ── Level progress (quiet, non-interactive info block) ── %>
  <div class="mb-5 z-2 shrink-0" style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 16px; padding: 16px;">
    <div class="flex items-center justify-between mb-2.5">
      <div class="flex items-center gap-2">
        <span class="font-display text-[14px] font-extrabold"
              style="background: var(--primary); color: white; padding: 4px 10px; border-radius: 8px;">
          Nível <%= @level %>
        </span>
        <span class="font-display text-[13px] font-extrabold" style="color: var(--text-muted);">
          <%= @level_progress %>/<%= @level_size %>
        </span>
      </div>
      <span class="font-display text-[12px] font-bold" style="color: var(--text);">
        Faltam <strong class="font-extrabold" style="color: var(--primary-2);"><%= @level_remaining %></strong> pra subir
      </span>
    </div>

    <div class="relative overflow-hidden" style="height: 14px; background: var(--hairline); border-radius: 10px;">
      <div class="anim-progress h-full" style="width: <%= @level_pct %>%; background: var(--primary); border-radius: 10px;"></div>
    </div>
  </div>

  <%# ── Wishlist goal card ── %>
  <%= render "kid/wishlist/goal", profile: current_profile %>

  <%# ── Shortcut cards (Academia, Eu curto) ── %>
  <% kid_interests = current_profile.interest_keys(5) %>
  <% interests_title = kid_interests.any? ?
       kid_interests.first(3).map { |k| ProfileInterest::Catalog.emoji_for(k) + " " + ProfileInterest::Catalog.label_for(k) }.join("  ·  ") :
       "Conta pra gente o que você curte!" %>

  <div class="flex flex-col gap-3 mb-5 z-2 relative shrink-0">
    <%= render Ui::ShortcutCard::Component.new(
          url: kid_academy_root_path,
          tint: :primary,
          icon: "search-01",
          eyebrow: "Academia",
          title: "Descubra uma pílula de conhecimento",
          test_id: "kid-academy-card"
        ) %>

    <%= render Ui::ShortcutCard::Component.new(
          url: kid_interests_path,
          tint: :neutral,
          icon: "idea-01",
          eyebrow: "Eu curto",
          title: interests_title,
          test_id: "kid-interests-card"
        ) %>
  </div>

  <%# ── Meta coletiva semanal ── %>
  <div class="relative z-2 mb-5">
    <%= render "shared/family_goal_widget", goal: @family_goal, viewer: current_profile, limit: 1 %>
  </div>

  <%# ── Upcoming weekly/monthly missions ── %>
  <% if @upcoming_missions.any? %>
    <div class="relative z-2 mb-5">
      <%= render "kid/dashboard/upcoming_missions_widget", upcoming: @upcoming_missions %>
    </div>
  <% end %>

</div>
