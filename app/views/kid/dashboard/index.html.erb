<%
  hour     = Time.current.hour
  greeting = case hour when 5..11 then "Bom dia," when 12..17 then "Boa tarde," else "Boa noite," end

  total      = @profile_tasks.count + @awaiting_tasks.count + @completed_today.count
  done_count = @awaiting_tasks.count + @completed_today.count
  remaining  = @profile_tasks.count
%>

<div class="screen screen-enter with-nav">
  <%= render Ui::Celebration::Component.new %>

  <%# ── Header: streak + stars + switch ── %>
  <div class="flex items-center justify-between mb-4 z-2 shrink-0">
    <div class="flex items-center gap-2">
      <% if @streak_days.positive? %>
        <div class="flex items-center gap-1.5 ls-card-3d"
             style="background: var(--surface); border: 2px solid var(--star); padding: 6px 12px; border-radius: 12px; box-shadow: 0 3px 0 var(--star-2);">
          <%= render Ui::Icon::Component.new("fire", size: 18, color: "var(--c-streak)") %>
          <span class="font-display text-[16px] font-extrabold leading-none" style="color: var(--c-streak);"><%= @streak_days %></span>
        </div>
      <% end %>

      <div class="flex items-center gap-1.5 ls-card-3d"
           style="background: var(--surface); border: 2px solid var(--star); padding: 6px 12px; border-radius: 12px; box-shadow: 0 3px 0 var(--star-2);">
        <%= render Ui::Icon::Component.new(:star, size: 18, color: "var(--star)") %>
        <span id="profile_points_<%= current_profile.id %>"
              data-controller="count-up"
              data-count-up-current-value="<%= current_profile.points %>"
              class="font-display text-[16px] font-extrabold leading-none" style="color: var(--c-amber-dark);">
          <span data-count-up-target="display"><%= current_profile.points %></span>
        </span>
      </div>
    </div>

    <%= form_with url: profile_session_path, method: :delete, local: true, class: "contents" do %>
      <button type="submit"
              class="ls-card-3d inline-flex items-center gap-1.5 font-display"
              style="background: var(--surface); border: 2px solid var(--hairline); padding: 6px 12px; border-radius: 12px; box-shadow: 0 3px 0 var(--hairline); color: var(--text-muted); font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">
        <%= render Ui::Icon::Component.new("logout", size: 12, color: "currentColor") %>
        Trocar
      </button>
    <% end %>
  </div>

  <%# ── Greeting block: avatar + headline ── %>
  <div class="flex items-center gap-4 mb-5 px-1 z-2 shrink-0">
    <div class="relative shrink-0">
      <div class="ls-mascot-bounce">
        <%= render Ui::SmileyAvatar::Component.new(kid: current_profile, size: 88) %>
      </div>
      <%= render Ui::Icon::Component.new(:star, size: 14, color: "var(--star)", class: "absolute -top-0.5 -right-1") %>
      <%= render Ui::Icon::Component.new(:star, size: 10, color: "var(--star)", class: "absolute bottom-1 -left-1") %>
    </div>

    <div class="flex-1 min-w-0">
      <div class="font-display text-[11px] font-extrabold tracking-[1px] uppercase mb-1" style="color: var(--c-sky-dark);">
        <%= greeting %> <%= current_profile.name %>!
      </div>
      <h1 class="font-display text-[22px] leading-tight font-extrabold tracking-[-0.01em] m-0" style="color: var(--text);">
        Bora pegar mais ⭐ hoje?
      </h1>
      <p class="text-[13px] font-bold mt-1.5 m-0" style="color: var(--text-muted);">
        <% if remaining.positive? %>
          Você tem <strong style="color: var(--c-sky-dark);"><%= pluralize(remaining, "missão", plural: "missões") %></strong> pra completar
        <% elsif @awaiting_tasks.any? %>
          <strong style="color: var(--c-sky-dark);"><%= pluralize(@awaiting_tasks.count, "missão", plural: "missões") %></strong> esperando carimbo
        <% else %>
          Tudo feito por hoje! 🎉
        <% end %>
      </p>
    </div>
  </div>

  <%# ── Level progress card ── %>
  <div class="ls-card-3d mb-5 z-2 shrink-0"
       style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 16px; padding: 16px 18px; box-shadow: 0 4px 0 rgba(0,0,0,0.08);">
    <div class="flex justify-between items-start mb-2.5 gap-3">
      <div>
        <div class="font-display text-[11px] font-extrabold tracking-[0.5px] uppercase" style="color: var(--text-muted);">Você está no</div>
        <div class="flex items-center gap-2 mt-0.5">
          <div class="font-display text-[14px] font-extrabold"
               style="background: var(--primary); color: white; padding: 4px 10px; border-radius: 8px; box-shadow: 0 2px 0 var(--primary-2);">
            NÍVEL <%= @level %>
          </div>
          <span class="font-display text-[13px] font-extrabold" style="color: var(--primary-2);">→ Nível <%= @level + 1 %></span>
        </div>
      </div>
      <div class="text-right">
        <div class="font-display text-[22px] font-extrabold leading-none" style="color: var(--primary-2);">
          <%= @level_progress %><span class="text-[14px]" style="color: var(--text-soft);">/<%= @level_size %></span>
        </div>
        <div class="font-display text-[10px] font-extrabold tracking-[0.5px] uppercase mt-0.5" style="color: var(--text-muted);">Estrelinhas</div>
      </div>
    </div>

    <div class="relative overflow-hidden" style="height: 18px; background: var(--hairline); border-radius: 10px;">
      <div class="h-full transition-all duration-500 relative"
           style="width: <%= @level_pct %>%; background: linear-gradient(90deg, var(--primary) 0%, var(--primary-soft) 100%); border-radius: 10px;">
        <% if @level_pct.positive? %>
          <div class="absolute right-1.5 top-1/2 -translate-y-1/2">
            <%= render Ui::Icon::Component.new(:star, size: 11, color: "white") %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-1.5 mt-2.5">
      <%= render Ui::Icon::Component.new(:star, size: 14, color: "var(--star)") %>
      <span class="text-[12px] font-bold" style="color: var(--text);">
        Faltam <strong class="font-extrabold" style="color: var(--primary-2);"><%= pluralize(@level_remaining, "estrelinha") %></strong> pra subir!
      </span>
    </div>
  </div>

  <%# ── Section heading + counter ── %>
  <div class="flex justify-between items-center mb-3 px-1 shrink-0 z-2">
    <h2 class="font-display text-[16px] font-extrabold m-0" style="color: var(--text);">Missões de hoje</h2>
    <% if total.positive? %>
      <div class="ls-card-3d inline-flex items-center gap-1.5"
           style="background: var(--primary-soft); border: 2px solid var(--primary); padding: 4px 10px; border-radius: 10px; box-shadow: 0 2px 0 var(--primary-2);">
        <span class="font-display text-[11px] font-extrabold tracking-[0.5px] uppercase" style="color: var(--primary-2);">
          <%= done_count %> de <%= total %> ✓
        </span>
      </div>
    <% end %>
  </div>

  <%# ── Mission list ── %>
  <div class="flex flex-col gap-2.5 mb-5 relative z-2">

    <%# Completed (approved today) %>
    <% @completed_today.each do |task| %>
      <% cat = Ui::Tokens.category_for(task.global_task&.category) %>
      <div class="ls-card-3d flex items-center gap-3.5 px-4 py-3.5"
           style="background: var(--primary-soft); border: 2px solid var(--primary); border-radius: 16px; box-shadow: 0 4px 0 var(--primary-2);">
        <div class="grid place-items-center shrink-0"
             style="width: 48px; height: 48px; border-radius: 12px; background: var(--surface); border: 2px solid var(--primary);">
          <%= render Ui::Icon::Component.new("check", size: 26, color: "var(--primary-2)") %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-display text-[15px] font-extrabold line-through" style="color: var(--primary-2);"><%= task.title %></div>
          <div class="font-display text-[11px] font-extrabold tracking-[0.5px] uppercase mt-0.5" style="color: var(--primary-2);">
            +<%= task.points %> ★ ganhas!
          </div>
        </div>
      </div>
    <% end %>

    <%# Awaiting approval ── stays in turbo-stream target id %>
    <div id="panel-waiting" class="contents">
      <% @awaiting_tasks.each do |task| %>
        <% cat = Ui::Tokens.category_for(task.global_task&.category) %>
        <div id="<%= dom_id(task) %>"
             class="ls-card-3d flex items-center gap-3.5 px-4 py-3.5"
             style="background: var(--primary-soft); border: 2px solid var(--primary); border-radius: 16px; box-shadow: 0 4px 0 var(--primary-2);">
          <div class="grid place-items-center shrink-0"
               style="width: 48px; height: 48px; border-radius: 12px; background: var(--surface); border: 2px solid var(--primary);">
            <%= render Ui::Icon::Component.new("check", size: 26, color: "var(--primary-2)") %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-display text-[15px] font-extrabold line-through" style="color: var(--primary-2);"><%= task.title %></div>
            <div class="font-display text-[11px] font-extrabold tracking-[0.5px] uppercase mt-0.5" style="color: var(--primary-2);">
              Aguardando carimbo
            </div>
          </div>
          <div class="ls-card-3d inline-flex items-center gap-1 shrink-0"
               style="background: var(--surface); border: 2px solid var(--star); padding: 4px 10px; border-radius: 10px; box-shadow: 0 2px 0 var(--star-2);">
            <%= render Ui::Icon::Component.new(:star, size: 13, color: "var(--star)") %>
            <span class="font-display text-[13px] font-extrabold" style="color: var(--c-amber-dark);">+<%= task.points %></span>
          </div>
        </div>
      <% end %>
    </div>

    <%# Pending — flat row, click opens confirmation modal %>
    <% @profile_tasks.each_with_index do |profile_task, i| %>
      <% cat = Ui::Tokens.category_for(profile_task.global_task&.category) %>
      <% tint_soft = Ui::Tokens.tint_soft(cat[:tint]) %>
      <% tint_fg   = Ui::Tokens.tint_fg(cat[:tint]) %>

      <div id="<%= dom_id(profile_task) %>" data-controller="ui-modal">
        <div class="ls-card-3d flex items-center gap-3.5 px-4 py-3.5 cursor-pointer"
             style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 16px; box-shadow: 0 4px 0 rgba(0,0,0,0.08); animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= [i, 5].min * 0.04 %>s both;"
             data-action="click->ui-modal#open"
             data-ui-modal-id-param="modal_<%= dom_id(profile_task) %>">
          <div class="grid place-items-center shrink-0"
               style="width: 48px; height: 48px; border-radius: 12px; background: <%= tint_soft %>; border: 2px solid <%= tint_fg %>;">
            <%= render Ui::Icon::Component.new(cat[:icon], size: 26, color: tint_fg) %>
          </div>

          <div class="flex-1 min-w-0">
            <div class="font-display text-[15px] font-extrabold" style="color: var(--text);"><%= profile_task.title %></div>
            <div class="flex items-center gap-1.5 mt-1">
              <span class="font-display text-[10px] font-extrabold tracking-[0.5px] uppercase px-2 py-0.5 rounded-md"
                    style="background: <%= tint_soft %>; color: <%= tint_fg %>;">
                <%= cat[:label] %>
              </span>
            </div>
          </div>

          <div class="flex items-center gap-2.5 shrink-0">
            <div class="ls-card-3d inline-flex items-center gap-1"
                 style="background: var(--star-soft); border: 2px solid var(--star); padding: 4px 10px; border-radius: 10px; box-shadow: 0 2px 0 var(--star-2);">
              <%= render Ui::Icon::Component.new(:star, size: 13, color: "var(--star)") %>
              <span class="font-display text-[13px] font-extrabold" style="color: var(--c-amber-dark);">+<%= profile_task.points %></span>
            </div>

            <button type="button"
                    class="ls-btn-3d font-display"
                    data-action="click->ui-modal#open"
                    data-ui-modal-id-param="modal_<%= dom_id(profile_task) %>"
                    style="background: var(--primary); color: white; border: 2px solid var(--primary); padding: 8px 14px; border-radius: 12px; box-shadow: 0 3px 0 var(--primary-2); font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">
              Fiz!
            </button>
          </div>
        </div>

        <%# Confirmation modal — reuses existing flow %>
        <%= render Ui::Modal::Component.new(id: "modal_#{dom_id(profile_task)}") do %>
          <div class="flex items-center justify-center flex-col text-center gap-4">
            <%= render Ui::IconTile::Component.new(icon: cat[:icon], color: cat[:tint], size: 88) %>
            <h3 class="font-display text-[26px] leading-tight font-extrabold tracking-[-0.02em] text-foreground"><%= profile_task.title %></h3>
            <div class="flex gap-2.5 justify-center items-center">
              <%= render Ui::Badge::Component.new(variant: cat[:tint], size: "sm", icon: cat[:icon]) do %>
                <%= cat[:label] %>
              <% end %>
              <%= render Ui::Badge::Component.new(variant: "star") do %>
                <%= render Ui::StarValue::Component.new(value: profile_task.points, prefix: "+", size: :sm, color: :gold) %>
              <% end %>
            </div>
            <p class="text-muted-foreground font-bold text-[17px] mt-1">Terminou essa missão? Um responsável vai confirmar.</p>
            <%= form_with url: complete_kid_mission_path(profile_task), method: :patch, class: "w-full" do %>
              <div class="mt-3 text-left">
                <label class="block text-[13px] font-extrabold mb-1.5" style="color: var(--text);">Quer mandar um recado? (opcional)</label>
                <textarea name="submission_comment" rows="2" maxlength="500"
                          placeholder="Conta como foi…"
                          class="w-full px-3 py-2 rounded-[12px] border-2 text-[14px] font-medium"
                          style="border-color: var(--hairline); background: var(--surface); color: var(--text);"></textarea>
              </div>
              <div class="flex gap-3 mt-2 w-full justify-center items-center">
                <%= render Ui::Btn::Component.new(variant: "secondary", type: "button", data: { action: "click->ui-modal#close" }) do %>Ainda não<% end %>
                <%= render Ui::Btn::Component.new(variant: "primary", size: "lg", type: "submit") do %>
                  <%= render Ui::Icon::Component.new("check", size: 20) %> Terminei!
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Empty state %>
    <% if total.zero? %>
      <%= render Ui::Empty::Component.new(
            icon: "star",
            title: "Nenhuma missão hoje",
            subtitle: "Um responsável vai adicionar novas missões pra você",
            color: "mint"
          ) %>
    <% end %>
  </div>

  <%# ── Ghost CTA: create custom mission ── %>
  <%= link_to new_kid_mission_path,
        class: "font-display flex items-center justify-center gap-2 w-full text-center mb-4 z-2 shrink-0 no-underline",
        style: "background: transparent; color: var(--text-muted); border: 2px dashed var(--hairline); border-radius: 14px; padding: 14px 16px; font-size: 13px; font-weight: 800;" do %>
    <%= render Ui::Icon::Component.new(:plus, size: 16, color: "currentColor") %>
    Fez algo fora da lista? Adicionar
  <% end %>

</div>
