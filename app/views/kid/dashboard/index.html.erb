<%
  total      = @profile_tasks.count + @awaiting_tasks.count + @completed_today.count
  done_count = @awaiting_tasks.count + @completed_today.count
  remaining  = @profile_tasks.count
%>

<div class="screen screen-enter with-nav">
  <%# Page's primary heading. Visually-hidden: the progress hero is the visible
      focal point, but the document still needs an h1 for screen readers (WCAG 1.3.1). %>
  <h1 class="sr-only">Início</h1>
  <%= render Ui::Celebration::Component.new %>

  <%# ══ TIER 1 · Onde estou ══ %>
  <%= render "kid/dashboard/progress_hero",
             profile: current_profile,
             streak: @streak_days,
             level: @level,
             level_progress: @level_progress,
             level_size: @level_size,
             level_remaining: @level_remaining,
             level_pct: @level_pct,
             remaining: remaining,
             awaiting_count: @awaiting_tasks.count,
             completed_today_count: @completed_today.count %>

  <%# ══ TIER 2 · O que fazer agora (the loop) ══ %>
  <%= render "kid/dashboard/today_progress", done_count: done_count, total: total %>

  <%# Mission list (above-the-fold) ── %>
  <% pending_visible, pending_extra = @profile_tasks.first(5), @profile_tasks.drop(5) %>
  <div class="flex flex-col gap-3 mb-4 relative z-2">

    <%# Completed (approved today) %>
    <div id="panel-completed" class="contents">
      <% @completed_today.each_with_index do |task, i| %>
        <%= render Ui::MissionCard::Component.new(mission: task, status: "approved", variant: "bubble", index: i) %>
      <% end %>
    </div>

    <%# Awaiting approval ── stays in turbo-stream target id %>
    <div id="panel-waiting" class="contents">
      <% @awaiting_tasks.each_with_index do |task, i| %>
        <%= render Ui::MissionCard::Component.new(mission: task, status: "waiting", variant: "bubble", index: i, id: dom_id(task)) %>
      <% end %>
    </div>

    <%# Pending · flat row, click opens confirmation modal %>
    <div id="panel-pending" class="contents">
      <% pending_visible.each_with_index do |profile_task, i| %>
        <%= render "kid/dashboard/pending_card", profile_task: profile_task, index: i %>
      <% end %>

      <% if pending_extra.any? %>
        <details class="contents">
          <summary class="font-display flex items-center justify-center gap-2 cursor-pointer list-none"
                   style="background: transparent; color: var(--text-muted); border: 1px dashed var(--hairline); border-radius: 14px; padding: 12px 14px; font-size: 13px; font-weight: 800;">
            <%= render Ui::Icon::Component.new(:plus, size: 14, color: "currentColor") %>
            Ver mais <%= pluralize(pending_extra.size, "missão", plural: "missões") %>
          </summary>
          <div class="flex flex-col gap-3 mt-3">
            <% pending_extra.each_with_index do |profile_task, i| %>
              <%= render "kid/dashboard/pending_card", profile_task: profile_task, index: i + pending_visible.size %>
            <% end %>
          </div>
        </details>
      <% end %>
    </div>

    <%# Empty state %>
    <% if total.zero? %>
      <%= render Ui::Empty::Component.new(
            icon: "star",
            title: "Nenhuma missão hoje",
            subtitle: "Um responsável vai adicionar novas missões pra você",
            color: "mint"
          ) %>
    <% end %>
  </div>

  <%# Ghost CTA: create custom mission (quiet, secondary affordance) ── %>
  <%= link_to new_kid_mission_path,
        class: "anim-press font-display flex items-center justify-center gap-2 w-full text-center mb-6 z-2 shrink-0 no-underline",
        style: "background: var(--surface); color: var(--text-muted); border: 1px dashed var(--hairline); border-radius: 14px; padding: 12px 14px; font-size: 13px; font-weight: 800;" do %>
    <%= render Ui::Icon::Component.new(:plus, size: 16, color: "currentColor") %>
    Fiz algo fora da lista
  <% end %>

  <%# ══ TIER 3 · Pra onde ir (secondary, varied rhythm) ══ %>

  <%# Personal goal — wishlist (carries its own mb-5) ── %>
  <%= render "kid/wishlist/goal", profile: current_profile %>

  <%# Explorar — navigational tiles ── %>
  <% kid_interests = current_profile.interest_keys(5) %>
  <% interests_title = kid_interests.any? ?
       kid_interests.first(3).map { |k| ProfileInterest::Catalog.emoji_for(k) + " " + ProfileInterest::Catalog.label_for(k) }.join("  ·  ") :
       "Conta pra gente o que você curte!" %>

  <div class="mb-6 z-2 relative shrink-0">
    <div class="font-display text-[11px] font-extrabold tracking-[1px] uppercase mb-2 px-1" style="color: var(--text-muted);">Explorar</div>
    <div class="flex flex-col gap-3">
      <%= render Ui::ShortcutCard::Component.new(
            url: kid_academy_root_path,
            tint: :primary,
            icon: "search-01",
            eyebrow: "Academia",
            title: "Descubra uma pílula de conhecimento",
            test_id: "kid-academy-card"
          ) %>

      <%= render Ui::ShortcutCard::Component.new(
            url: kid_interests_path,
            tint: :neutral,
            icon: "idea-01",
            eyebrow: "Eu curto",
            title: interests_title,
            test_id: "kid-interests-card"
          ) %>
    </div>
  </div>

  <%# Em equipe & em breve — collective goal + upcoming ── %>
  <% family_goals = Array(@family_goal && @family_goal[:goals]) %>
  <% if family_goals.any? || @upcoming_missions.any? %>
    <div class="z-2 relative shrink-0">
      <div class="font-display text-[11px] font-extrabold tracking-[1px] uppercase mb-2 px-1" style="color: var(--text-muted);">Em equipe &amp; em breve</div>
      <div class="flex flex-col gap-3">
        <%= render "shared/family_goal_widget", goal: @family_goal, viewer: current_profile, limit: 1 %>
        <% if @upcoming_missions.any? %>
          <%= render "kid/dashboard/upcoming_missions_widget", upcoming: @upcoming_missions %>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
