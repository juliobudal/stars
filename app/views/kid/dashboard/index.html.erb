<%
  hour     = Time.current.hour
  greeting = case hour when 5..11 then "Bom dia," when 12..17 then "Boa tarde," else "Boa noite," end

  total      = @profile_tasks.count + @awaiting_tasks.count + @completed_today.count
  done_count = @awaiting_tasks.count + @completed_today.count
  remaining  = @profile_tasks.count
%>

<div class="screen screen-enter with-nav">
  <%= render Ui::Celebration::Component.new %>

  <%# ── Header: streak + stars + switch ── %>
  <%= render Ui::KidTopBar::Component.new(profile: current_profile, streak: @streak_days) %>

  <%# ── Greeting block: avatar + headline ── %>
  <div class="flex items-center gap-4 mb-5 px-1 z-2 shrink-0">
    <div class="relative shrink-0">
      <div class="ls-mascot-bounce">
        <%= render Ui::SmileyAvatar::Component.new(kid: current_profile, size: 88) %>
      </div>
      <%= render Ui::Icon::Component.new(:star, size: 14, color: "var(--star)", class: "absolute -top-0.5 -right-1") %>
      <%= render Ui::Icon::Component.new(:star, size: 10, color: "var(--star)", class: "absolute bottom-1 -left-1") %>
    </div>

    <div class="flex-1 min-w-0">
      <div class="font-display text-[11px] font-extrabold tracking-[1px] uppercase mb-1" style="color: var(--c-sky-dark);">
        <%= greeting %> <%= current_profile.name %>!
      </div>
      <h1 class="font-display text-[22px] leading-tight font-extrabold tracking-[-0.01em] m-0" style="color: var(--text);">
        Bora pegar mais ⭐ hoje?
      </h1>
      <p class="text-[13px] font-bold mt-1.5 m-0" style="color: var(--text-muted);">
        <% if remaining.positive? %>
          Você tem <strong style="color: var(--c-sky-dark);"><%= pluralize(remaining, "missão", plural: "missões") %></strong> pra completar
        <% elsif @awaiting_tasks.any? %>
          <strong style="color: var(--c-sky-dark);"><%= pluralize(@awaiting_tasks.count, "missão", plural: "missões") %></strong> esperando carimbo
        <% else %>
          Tudo feito por hoje! 🎉
        <% end %>
      </p>
    </div>
  </div>

  <%# ── Level progress card ── %>
  <div class="ls-card-3d mb-5 z-2 shrink-0"
       style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 16px; padding: 16px 18px; box-shadow: 0 4px 0 rgba(0,0,0,0.08);">
    <div class="flex justify-between items-start mb-2.5 gap-3">
      <div>
        <div class="font-display text-[11px] font-extrabold tracking-[0.5px] uppercase" style="color: var(--text-muted);">Você está no</div>
        <div class="flex items-center gap-2 mt-0.5">
          <div class="font-display text-[14px] font-extrabold"
               style="background: var(--primary); color: white; padding: 4px 10px; border-radius: 8px; box-shadow: 0 2px 0 var(--primary-2);">
            NÍVEL <%= @level %>
          </div>
          <span class="font-display text-[13px] font-extrabold" style="color: var(--primary-2);">→ Nível <%= @level + 1 %></span>
        </div>
      </div>
      <div class="text-right">
        <div class="font-display text-[22px] font-extrabold leading-none" style="color: var(--primary-2);">
          <%= @level_progress %><span class="text-[14px]" style="color: var(--text-soft);">/<%= @level_size %></span>
        </div>
        <div class="font-display text-[10px] font-extrabold tracking-[0.5px] uppercase mt-0.5" style="color: var(--text-muted);">Estrelinhas</div>
      </div>
    </div>

    <div class="relative overflow-hidden" style="height: 18px; background: var(--hairline); border-radius: 10px;">
      <div class="h-full transition-all duration-500 relative"
           style="width: <%= @level_pct %>%; background: linear-gradient(90deg, var(--primary) 0%, var(--primary-soft) 100%); border-radius: 10px;">
        <% if @level_pct.positive? %>
          <div class="absolute right-1.5 top-1/2 -translate-y-1/2">
            <%= render Ui::Icon::Component.new(:star, size: 11, color: "white") %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-1.5 mt-2.5">
      <%= render Ui::Icon::Component.new(:star, size: 14, color: "var(--star)") %>
      <span class="text-[12px] font-bold" style="color: var(--text);">
        Faltam <strong class="font-extrabold" style="color: var(--primary-2);"><%= pluralize(@level_remaining, "estrelinha") %></strong> pra subir!
      </span>
    </div>
  </div>

  <%# ── Section heading + counter ── %>
  <div class="flex justify-between items-center mb-3 px-1 shrink-0 z-2">
    <h2 class="font-display text-[16px] font-extrabold m-0" style="color: var(--text);">Missões de hoje</h2>
    <% if total.positive? %>
      <div class="ls-card-3d inline-flex items-center gap-1.5"
           style="background: var(--primary-soft); border: 2px solid var(--primary); padding: 4px 10px; border-radius: 10px; box-shadow: 0 2px 0 var(--primary-2);">
        <span class="font-display text-[11px] font-extrabold tracking-[0.5px] uppercase" style="color: var(--primary-2);">
          <%= done_count %> de <%= total %> ✓
        </span>
      </div>
    <% end %>
  </div>

  <%# ── Mission list ── %>
  <div class="flex flex-col gap-2.5 mb-5 relative z-2">

    <%# Completed (approved today) %>
    <% @completed_today.each_with_index do |task, i| %>
      <%= render Ui::MissionCard::Component.new(mission: task, status: "approved", variant: "bubble", index: i) %>
    <% end %>

    <%# Awaiting approval ── stays in turbo-stream target id %>
    <div id="panel-waiting" class="contents">
      <% @awaiting_tasks.each_with_index do |task, i| %>
        <%= render Ui::MissionCard::Component.new(mission: task, status: "waiting", variant: "bubble", index: i, id: dom_id(task)) %>
      <% end %>
    </div>

    <%# Pending — flat row, click opens confirmation modal %>
    <div id="panel-pending" class="contents">
      <% @profile_tasks.each_with_index do |profile_task, i| %>
        <%= render "kid/dashboard/pending_card", profile_task: profile_task, index: i %>
      <% end %>
    </div>

    <%# Empty state %>
    <% if total.zero? %>
      <%= render Ui::Empty::Component.new(
            icon: "star",
            title: "Nenhuma missão hoje",
            subtitle: "Um responsável vai adicionar novas missões pra você",
            color: "mint"
          ) %>
    <% end %>
  </div>

  <%# ── Ghost CTA: create custom mission ── %>
  <%= link_to new_kid_mission_path,
        class: "font-display flex items-center justify-center gap-2 w-full text-center mb-4 z-2 shrink-0 no-underline",
        style: "background: transparent; color: var(--text-muted); border: 2px dashed var(--hairline); border-radius: 14px; padding: 14px 16px; font-size: 13px; font-weight: 800;" do %>
    <%= render Ui::Icon::Component.new(:plus, size: 16, color: "currentColor") %>
    Fez algo fora da lista? Adicionar
  <% end %>

</div>
