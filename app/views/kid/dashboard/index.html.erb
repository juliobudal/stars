<%
  hour     = Time.current.hour
  greeting = case hour when 5..11 then "BOM DIA," when 12..17 then "BOA TARDE," else "BOA NOITE," end

  total      = @profile_tasks.count + @awaiting_tasks.count + @completed_today.count
  done_count = @awaiting_tasks.count + @completed_today.count

  pal = Ui::SmileyAvatar::Component::COLOR_MAP[current_profile.color.to_s] || Ui::SmileyAvatar::Component::COLOR_MAP["primary"]

  next_reward_pct       = @next_reward ? [( current_profile.points.to_f / @next_reward.cost * 100 ).round, 100].min : 0
  next_reward_remaining = @next_reward ? (@next_reward.cost - current_profile.points) : 0

  cat_colors = {
    "casa"   => "var(--c-mint)",  "escola" => "var(--c-lilac)",
    "rotina" => "var(--c-peach)", "saude"  => "var(--c-rose)",
    "geral"  => "var(--c-sky)",   "outro"  => "var(--c-sky)"
  }.freeze
%>

<div class="screen screen-enter with-nav" data-controller="celebration">
  <%= render Ui::Celebration::Component.new %>

  <%# ── Header ── %>
  <div class="row gap-4.5 z-2 shrink-0 items-center mb-8">
    <%= link_to sessions_path,
          class: "w-10 h-10 rounded-full bg-white grid place-items-center shrink-0 shadow-card",
          title: "Trocar perfil" do %>
      <%= render Ui::Icon::Component.new("arrow-left", size: 16, color: "var(--text-muted)") %>
    <% end %>

    <div class="col fg1 gap-0 text-left">
      <div class="eyebrow tracking-[0.28em]"><%= greeting %></div>
      <div class="h-display text-[30px] leading-none"><%= current_profile.name %>!</div>
    </div>

    <div class="row gap-2 shrink-0">
      <div class="bg-star-soft text-foreground py-1.5 px-3 rounded-full font-bold text-[14px] flex items-center gap-1.5">
        <%= render Ui::Icon::Component.new("star", size: 14, color: "var(--star)") %>
        <%= current_profile.points %>
      </div>
      <div class="w-9 h-9 rounded-full grid place-items-center text-[14px] font-extrabold shrink-0 border-2" style="background: <%= pal[:fill] %>; border-color: <%= pal[:ring] %>; color: <%= pal[:ink] %>;">
        <%= current_profile.name.first.upcase %>
      </div>
    </div>
  </div>

  <%# ── Cofrinho card ── %>
  <div class="z-2 mb-6 shrink-0">
    <div class="card px-8 py-7 border-none">
      <div class="row justify-between items-start mb-3.5 gap-3">
        <div class="col gap-1">
          <div class="eyebrow">Minhas estrelinhas</div>
          <div id="profile_points_<%= current_profile.id %>"
               data-controller="count-up"
               data-count-up-current-value="<%= current_profile.points %>"
               class="h-display text-[36px] leading-none mt-1">
            <span data-count-up-target="display"><%= current_profile.points %></span>
            <span class="text-star-2">★</span>
          </div>
        </div>
        <div class="w-12 h-12 rounded-sm bg-star-soft grid place-items-center text-[26px] shrink-0">
          🐷
        </div>
      </div>

      <% if @next_reward %>
        <p class="text-[12px] text-muted-foreground mb-2 font-semibold">
          Próximo: <%= @next_reward.title %> (<%= @next_reward.cost %> ★) — faltam <%= next_reward_remaining %> ★
        </p>
        <div class="progress-track">
          <div class="progress-fill bg-primary" style="width: <%= next_reward_pct %>%;"></div>
        </div>
      <% elsif @awaiting_tasks.any? %>
        <div class="awaiting-badge rounded-full py-1.5 px-3.5 w-fit flex items-center gap-1.5 text-[13px]">
          <%= render Ui::Icon::Component.new("clock", size: 14, color: "var(--c-amber-dark)") %>
          <%= @awaiting_tasks.count %> aguardando aprovação
        </div>
      <% else %>
        <div class="progress-track bg-surface-2">
          <div class="progress-fill bg-star" style="width: <%= total.zero? ? 0 : (done_count.to_f / total * 100).round %>%;"></div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Section heading ── %>
  <div class="text-[15px] font-semibold text-foreground mb-4 shrink-0 z-2">Missões de hoje</div>

  <%# ── Mission list ── %>
  <div class="relative z-2">

    <%# Completed ─────────────────────────────── %>
    <% @completed_today.each do |task| %>
      <% cat_data = Ui::MissionCard::Component::CATEGORIES[task.global_task&.category.to_s] || Ui::MissionCard::Component::CATEGORIES["geral"] %>
      <div class="row pb-6 opacity-75 relative">
        <div class="timeline-divider"></div>
        <div class="w-10 h-10 rounded-full bg-mint-soft border-2 border-mint grid place-items-center shrink-0 z-1">
          <%= render Ui::Icon::Component.new("check", size: 16, color: "var(--c-mint-dark)") %>
        </div>
        <div class="card fg1 px-6 py-5 border-none">
          <div class="row justify-between gap-2">
            <div class="font-bold line-through text-foreground"><%= task.title %></div>
            <span class="text-star-2 font-extrabold text-[13px] shrink-0"><%= task.points %> ★</span>
          </div>
          <div class="mt-3">
            <span class="chip chip-sm chip-mint inline-flex items-center gap-1">
              <%= render Ui::Icon::Component.new("check", size: 10, color: "var(--c-mint-dark)") %>
              Aprovado
            </span>
          </div>
        </div>
      </div>
    <% end %>

    <%# Awaiting ─ wrapped for turbo_stream.prepend ── %>
    <div id="panel-waiting">
      <% @awaiting_tasks.each do |task| %>
        <%= render "kid/dashboard/awaiting_row", task: task %>
      <% end %>
    </div>

    <%# Pending ────────────────────────────────── %>
    <% @profile_tasks.each_with_index do |profile_task, i| %>
      <% cat_data  = Ui::MissionCard::Component::CATEGORIES[profile_task.global_task&.category.to_s] || Ui::MissionCard::Component::CATEGORIES["geral"] %>
      <% node_color = cat_colors[profile_task.global_task&.category.to_s] || cat_colors["geral"] %>
      <% is_current = i == 0 %>

      <div id="<%= dom_id(profile_task) %>" data-controller="ui-modal"
           class="row pb-6 relative">
        <div class="timeline-divider"></div>

        <div class="w-10 h-10 rounded-full bg-white border-2 grid place-items-center shrink-0 z-1 cursor-pointer"
             style="border-color: <%= is_current ? node_color : 'rgba(44,42,58,0.12)' %>; <%= is_current ? "box-shadow:0 0 0 4px #{node_color}33;" : '' %>"
             data-action="click->ui-modal#open"
             data-ui-modal-id-param="modal_<%= dom_id(profile_task) %>">
          <%= render Ui::Icon::Component.new(is_current ? cat_data[:icon] : "lock", size: 16, color: is_current ? node_color : "var(--text-soft)") %>
        </div>

        <div class="card fg1 px-6 py-5 cursor-pointer"
             style="<%= is_current ? "border:2px solid #{node_color};box-shadow:0 2px 0 #{node_color}15,0 6px 12px #{node_color}15;" : 'opacity:0.6;' %>"
             data-action="click->ui-modal#open"
             data-ui-modal-id-param="modal_<%= dom_id(profile_task) %>">
          <div class="row justify-between gap-2">
            <div class="font-bold text-foreground"><%= profile_task.title %></div>
            <span class="text-star-2 font-extrabold text-[13px] shrink-0"><%= profile_task.points %> ★</span>
          </div>
          <div class="mt-3">
            <% if is_current %>
              <span class="chip chip-sm bg-rose-soft text-rose inline-flex items-center gap-1">
                <%= render Ui::Icon::Component.new("star", size: 10, color: "var(--c-rose)") %>
                Agora!
              </span>
            <% else %>
              <span class="chip chip-sm chip-outline">A fazer</span>
            <% end %>
          </div>
        </div>

        <%# Confirmation modal %>
        <%= render Ui::Modal::Component.new(id: "modal_#{dom_id(profile_task)}", title: profile_task.title) do %>
          <div class="center col text-center gap-4">
            <%= render Ui::LogoMark::Component.new(size: 48) %>
            <%= render Ui::IconTile::Component.new(icon: cat_data[:icon], color: cat_data[:color], size: 88) %>
            <h3 class="h-display text-[26px]"><%= profile_task.title %></h3>
            <div class="row gap-2.5 justify-center">
              <%= render Ui::Badge::Component.new(variant: cat_data[:color], size: "sm", icon: cat_data[:icon]) do %>
                <%= cat_data[:label] %>
              <% end %>
              <%= render Ui::Badge::Component.new(variant: "star") do %>
                <%= render Ui::Icon::Component.new("star", size: 14, color: "var(--star-2)") %>
                +<%= profile_task.points %>
              <% end %>
            </div>
            <p class="subtitle mt-1">Terminou essa missão? Um responsável vai confirmar.</p>
            <div class="row gap-3 mt-2 w-full justify-center">
              <%= render Ui::Btn::Component.new(variant: "secondary", data: { action: "click->ui-modal#close" }) do %>Ainda não<% end %>
              <%= button_to complete_kid_mission_path(profile_task), method: :patch, class: "btn btn-primary btn-lg" do %>
                <%= render Ui::Icon::Component.new("check", size: 20) %> Terminei!
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Empty state %>
    <% if total.zero? %>
      <%= render Ui::Empty::Component.new(
            icon: "star",
            title: "Nenhuma missão hoje",
            subtitle: "Um responsável vai adicionar novas missões pra você ✨",
            color: "mint"
          ) %>
    <% end %>

    <%# Finish node %>
    <% if total > 0 %>
      <div class="row items-center mt-2">
        <div class="w-10 h-10 rounded-full bg-star-soft grid place-items-center shrink-0">
          <%= render Ui::LogoMark::Component.new(size: 24) %>
        </div>
        <div class="text-[14px] text-muted-foreground font-bold">+50 ao concluir tudo ✨</div>
      </div>
    <% end %>

  </div>
</div>
