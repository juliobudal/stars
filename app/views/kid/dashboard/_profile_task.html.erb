<%# Kid — Profile task card partial (LittleStars design) %>
<div id="<%= dom_id(profile_task) %>" class="col" style="gap: 8px; animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;">
  <%= render Ui::MissionCard::Component.new(
    mission: profile_task,
    status: "pending",
    variant: "bubble",
    index: 0
  ) %>
  <% if current_profile.family.require_photo? %>
    <%= form_with url: complete_kid_mission_path(profile_task), method: :patch,
        class: "col",
        style: "gap: 8px;",
        data: { turbo_confirm: "Terminou a missão: #{profile_task.title}?" } do |f| %>
      <label style="font-size: 12px; font-weight: 800; color: var(--text-muted); text-align: center;">
        📷 Foto obrigatória como comprovante
      </label>
      <input type="file" name="proof_photo" accept="image/*" capture="environment"
             required
             style="font-size: 13px; color: var(--text-muted);" />
      <button type="submit" class="btn btn-primary w-full">
        <i class="ph-bold ph-check" style="font-size: 20px;"></i> FEITO!
      </button>
    <% end %>
  <% else %>
    <%= button_to complete_kid_mission_path(profile_task), method: :patch,
        class: "btn btn-primary w-full",
        data: { turbo_confirm: "Terminou a missão: #{profile_task.title}?" } do %>
      <i class="ph-bold ph-check" style="font-size: 20px;"></i> FEITO!
    <% end %>
  <% end %>
</div>
