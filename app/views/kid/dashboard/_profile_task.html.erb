<%# Kid — Profile task card partial (LittleStars design) %>
<div id="<%= dom_id(profile_task) %>" class="col gap-2 animate-[slideInCard_0.4s_cubic-bezier(0.34,1.56,0.64,1)_both]">
  <%= render Ui::MissionCard::Component.new(
    mission: profile_task,
    status: "pending",
    variant: "bubble",
    index: 0
  ) %>
  <% if current_profile.family.require_photo? %>
    <%= form_with url: complete_kid_mission_path(profile_task), method: :patch,
        class: "col gap-2",
        data: { turbo_confirm: "Terminou a missão: #{profile_task.title}?" } do |f| %>
      <label class="text-[12px] font-extrabold text-muted-foreground text-center">
        📷 Foto obrigatória como comprovante
      </label>
      <input type="file" name="proof_photo" accept="image/*" capture="environment"
             required
             class="text-[13px] text-muted-foreground" />
      <%= render Ui::Btn::Component.new(variant: "primary", block: true, type: "submit") do %>
        <i class="ph-bold ph-check text-[20px]"></i> FEITO!
      <% end %>
    <% end %>
  <% else %>
    <%= render Ui::Btn::Component.new(variant: "primary", block: true, url: complete_kid_mission_path(profile_task), method: :patch, data: { turbo_confirm: "Terminou a missão: #{profile_task.title}?" }) do %>
      <i class="ph-bold ph-check text-[20px]"></i> FEITO!
    <% end %>
  <% end %>
</div>
