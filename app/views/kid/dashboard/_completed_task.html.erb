<div class="bg-mint-soft p-3.5 rounded-sm border-none flex items-center gap-3 opacity-75">
  <%= category_icon_tag completed_task.global_task.category, class: "w-8 h-8 text-mint-dark opacity-60 shrink-0" %>
  <div class="flex-1 min-w-0">
    <p class="font-bold text-mint-dark line-through text-[15px] m-0"><%= completed_task.title %></p>
    <div class="flex items-center gap-1 text-mint-dark font-extrabold text-[12px] mt-0.5">
      <span>GANHOU +<%= completed_task.points %></span>
      <%= icon_tag "star", class: "w-3.5 h-3.5 text-[var(--star)]" %>
    </div>
  </div>
</div>
