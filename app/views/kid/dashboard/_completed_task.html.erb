<div class="ls-card-3d flex items-center gap-3 p-3.5" style="background: var(--primary-soft); border: 2px solid var(--primary); border-radius: 14px; box-shadow: 0 3px 0 var(--primary-2); opacity: 0.85;">
  <div class="flex items-center justify-center shrink-0 w-[40px] h-[40px] rounded-[10px]" style="background: var(--surface); border: 2px solid var(--primary);">
    <%= category_icon_tag completed_task.global_task.category, class: "w-5 h-5", style: "color: var(--primary-2);" %>
  </div>
  <div class="flex-1 min-w-0">
    <p class="font-extrabold line-through text-[15px] m-0" style="color: var(--primary-2);"><%= completed_task.title %></p>
    <div class="flex items-center gap-1 font-extrabold text-[12px] mt-0.5" style="color: var(--primary-2);">
      <span>GANHOU +<%= completed_task.points %></span>
      <%= icon_tag "star", class: "w-3.5 h-3.5", style: "color: var(--star);" %>
    </div>
  </div>
</div>
