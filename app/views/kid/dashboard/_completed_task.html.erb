<div style="background: var(--c-mint-soft); padding: 14px 16px; border-radius: var(--r-sm); border: none; display: flex; align-items: center; gap: 12px; opacity: 0.75;">
  <%= category_icon_tag completed_task.global_task.category, class: "w-8 h-8", style: "color: var(--c-mint-dark); opacity: 0.6; flex-shrink: 0;" %>
  <div style="flex: 1; min-width: 0;">
    <p style="font-weight: 700; color: var(--c-mint-dark); text-decoration: line-through; font-size: 15px; margin: 0;"><%= completed_task.title %></p>
    <div style="display: flex; align-items: center; gap: 4px; color: var(--c-mint-dark); font-weight: 800; font-size: 12px; margin-top: 2px;">
      <span>GANHOU +<%= completed_task.points %></span>
      <%= icon_tag "star", style: "width: 14px; height: 14px; color: var(--star);" %>
    </div>
  </div>
</div>
