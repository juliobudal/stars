<%# locals: (task:) %>
<div id="<%= dom_id(task) %>" class="relative flex gap-4 pb-6">
  <div class="absolute left-[19px] top-[40px] bottom-0 border-l-2 border-dashed border-[rgba(44,42,58,0.10)]"></div>
  <div class="w-[40px] h-[40px] rounded-full bg-amber-soft border-2 border-[var(--star)] grid place-items-center shrink-0 z-1">
    <%= render Ui::Icon::Component.new("clock", size: 16, color: "var(--star-2)") %>
  </div>
  <div class="bg-surface rounded-card shadow-card flex-1 px-6 py-5">
    <div class="flex items-center justify-between gap-2">
      <div class="font-bold text-foreground"><%= task.title %></div>
      <span class="text-star-2 font-extrabold text-[13px] shrink-0 opacity-50"><%= task.points %> ★</span>
    </div>
    <div class="mt-3">
      <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full font-display font-extrabold text-[11px] tracking-wider uppercase bg-warning-soft text-warning-depth">
        <%= render Ui::Icon::Component.new("clock", size: 10, color: "currentColor") %>
        Aguardando
      </span>
    </div>
  </div>
</div>
