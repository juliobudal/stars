<%# locals: (task:) %>
<div id="<%= dom_id(task) %>"
     class="ls-card-3d flex items-center gap-3.5 px-4 py-3.5"
     style="background: var(--primary-soft); border: 2px solid var(--primary); border-radius: 16px; box-shadow: 0 4px 0 var(--primary-2);">
  <div class="grid place-items-center shrink-0"
       style="width: 48px; height: 48px; border-radius: 12px; background: var(--surface); border: 2px solid var(--primary);">
    <%= render Ui::Icon::Component.new("check", size: 26, color: "var(--primary-2)") %>
  </div>
  <div class="flex-1 min-w-0">
    <div class="font-display text-[15px] font-extrabold line-through" style="color: var(--primary-2);"><%= task.title %></div>
    <div class="font-display text-[11px] font-extrabold tracking-[0.5px] uppercase mt-0.5" style="color: var(--primary-2);">
      Aguardando carimbo
    </div>
  </div>
  <div class="ls-card-3d inline-flex items-center gap-1 shrink-0"
       style="background: var(--surface); border: 2px solid var(--star); padding: 4px 10px; border-radius: 10px; box-shadow: 0 2px 0 var(--star-2);">
    <%= render Ui::Icon::Component.new(:star, size: 13, color: "var(--star)") %>
    <span class="font-display text-[13px] font-extrabold" style="color: var(--c-amber-dark);">+<%= task.points %></span>
  </div>
</div>
