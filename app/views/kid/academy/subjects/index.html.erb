<% content_for(:title) { "Academia" } %>

<div class="screen screen-enter with-nav">
  <div class="px-1 mb-5 shrink-0">
    <div class="flex items-center justify-between gap-2 mb-1">
      <div class="font-display text-[11px] font-extrabold tracking-[1px] uppercase" style="color: var(--c-sky-dark);">
        ACADEMIA
      </div>
      <% if @rank_record %>
        <span class="shrink-0 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full"
              style="background: var(--c-star); color: white; box-shadow: 0 2px 0 var(--star-depth);">
          <%= render Ui::Icon::Component.new(@rank_record.icon.to_sym, size: 12, color: "white") %>
          <span class="font-display text-[10px] font-extrabold uppercase tracking-wide">
            <%= @rank_record.label %>
          </span>
        </span>
      <% else %>
        <span class="shrink-0 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full"
              style="background: var(--surface); border: 2px solid var(--hairline); color: var(--text-muted);">
          <%= render Ui::Icon::Component.new(:sparkle, size: 12, color: "var(--text-muted)") %>
          <span class="font-display text-[10px] font-extrabold uppercase tracking-wide">
            Aprendiz
          </span>
        </span>
      <% end %>
    </div>
    <h1 class="font-display text-[22px] leading-tight font-extrabold tracking-[-0.01em] m-0" style="color: var(--text);">
      Suas áreas de formação
    </h1>
    <p class="text-[13px] font-bold mt-1.5 m-0" style="color: var(--text-muted);">
      Cada aula entrega <strong style="color: var(--c-primary-dark);">1 ideia que muda alguma coisa hoje</strong>.
    </p>
  </div>

  <div id="academy-flash"></div>

  <%# ── Bússola do Explorador (v4 — 3 cards) ─────────────── %>
  <% if @compass_plan && @compass_plan.cards.any? %>
    <section class="mb-5">
      <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-2 px-1" style="color: var(--c-primary-dark);">
        🧭 BÚSSOLA DO EXPLORADOR
      </div>
      <div class="flex flex-col gap-3">
        <% @compass_plan.cards.each_with_index do |card, idx| %>
          <% mission = card.mission %>
          <% subj = mission.subject %>
          <% in_progress = ::Academy::MissionProgress.find_by(learner_id: current_learner.id, mission_id: mission.id)&.status == "in_progress" %>
          <% slot_label = case card.slot
                          when :hot_trail     then "✨ TRILHA QUENTE"
                          when :new_territory then "🌍 TERRITÓRIO NOVO"
                          when :revisit       then "🔄 PADRÃO QUE VOLTOU"
                          else "DESCOBERTA"
                          end %>
          <% featured = idx.zero? %>
          <%= link_to kid_academy_subject_mission_path(subj, mission),
                      data: { action: "click->academy-loading#showLesson" },
                      class: "block ls-card-3d anim-press",
                      style: featured ?
                        "background: linear-gradient(135deg, #{subj.color}, var(--c-star)); color: white; border: 2px solid rgba(0,0,0,0.06); border-radius: 18px; padding: 18px; box-shadow: 0 5px 0 rgba(0,0,0,0.15); text-decoration: none;" :
                        "background: var(--surface); color: var(--text); border: 2px solid var(--hairline); border-radius: 16px; padding: 14px; box-shadow: 0 3px 0 rgba(0,0,0,0.06); text-decoration: none;" do %>
            <div class="flex items-center gap-2 mb-1">
              <span class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase <%= 'opacity-90' if featured %>"
                    style="color: <%= featured ? 'white' : 'var(--text-muted)' %>;">
                <%= in_progress ? "CONTINUE · #{subj.name}" : "#{slot_label} · #{subj.name}" %>
              </span>
            </div>
            <h2 class="font-display <%= featured ? 'text-[18px]' : 'text-[15px]' %> font-extrabold leading-tight m-0 mb-1">
              <%= mission.title %>
            </h2>
            <p class="text-[12px] font-bold italic leading-snug m-0 <%= 'opacity-95' if featured %>"
               style="color: <%= featured ? 'white' : 'var(--text-muted)' %>;">
              <%= featured && mission.hook.present? ? "\"#{mission.hook}\"" : card.reason %>
            </p>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>

  <%# ── Apostas em aberto (v4) ────────────────────────────── %>
  <% if @pending_wagers.any? %>
    <section class="mb-5" data-controller="loading">
      <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-2 px-1" style="color: var(--c-sky-dark);">
        APOSTA EM ABERTO
      </div>
      <div class="flex flex-col gap-3">
        <% @pending_wagers.each do |wager| %>
          <% mission = wager.mission %>
          <%= form_with url: kid_academy_practice_wager_path(wager),
                        method: :patch,
                        local: true,
                        class: "ls-card-3d block",
                        data: { loading_target: "form" } do |f| %>
            <article style="background: var(--c-sky-soft); border: 2px solid var(--c-sky); border-radius: 16px; padding: 14px 16px; box-shadow: 0 4px 0 var(--c-sky-dark);">
              <div class="font-display text-[10px] font-extrabold tracking-[1px] uppercase mb-1" style="color: var(--c-sky-dark);">
                <%= mission.subject.name %>
              </div>
              <h3 class="font-display text-[15px] font-extrabold leading-tight m-0 mb-1" style="color: var(--text);">
                <%= mission.title %>
              </h3>
              <p class="text-[13px] font-bold italic leading-snug m-0 mb-3" style="color: var(--text);">
                "O Guia apostou: <strong><%= wager.guide_bet_count %></strong>. Quantas vezes você fez de verdade?"
              </p>
              <div class="flex items-center gap-2">
                <%= f.number_field :actual_count, min: 0, step: 1, required: true,
                                   placeholder: "número real",
                                   class: "flex-1 px-3 py-2 rounded-xl font-display font-extrabold text-[16px] tabular-nums",
                                   style: "background: var(--surface); border: 2px solid var(--c-sky-dark); color: var(--text);" %>
                <%= f.submit "Reportar",
                             class: "px-4 py-2 rounded-xl font-display font-extrabold text-[13px] anim-press",
                             data: { loading_target: "button" },
                             style: "background: var(--c-sky); color: white; border: 2px solid var(--c-sky-dark); box-shadow: 0 3px 0 var(--c-sky-dark);" %>
              </div>
            </article>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>

  <%# ── Segredos recém-desbloqueados (Phase 8) ───────────── %>
  <% if @fresh_unlocks.any? %>
    <section class="mb-5">
      <% @fresh_unlocks.each do |unlock| %>
        <article class="ls-card-3d"
                 style="background: linear-gradient(135deg, var(--star), var(--star-2)); border: 2px solid var(--star-depth); border-radius: 16px; padding: 14px 16px; box-shadow: 0 4px 0 var(--star-depth); color: white;">
          <div class="flex items-center gap-2 mb-1">
            <%= render Ui::Icon::Component.new(:trophy, size: 16, color: "white") %>
            <span class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase">
              VOCÊ DESTRAVOU UM SEGREDO
            </span>
          </div>
          <h3 class="font-display text-[15px] font-extrabold leading-tight m-0 mb-1">
            <%= unlock.secret.title %>
          </h3>
          <p class="text-[12px] font-bold italic m-0 opacity-95">
            "<%= unlock.secret.teaser %>"
          </p>
        </article>
      <% end %>
    </section>
  <% end %>

  <%# ── Áreas de formação ────────────────────────────────── %>
  <section class="mb-5">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 px-1">
      <% @subjects.each do |subject| %>
        <% skill = @skills[subject.id] %>
        <%
          tier_color = case skill.tier
                       when :master    then "var(--c-star)"
                       when :adept     then "var(--c-primary)"
                       when :apprentice then "var(--c-sky)"
                       else "var(--hairline)"
                       end
        %>
        <%= link_to kid_academy_subject_path(subject), class: "block ls-card-3d anim-press",
                    style: "background: var(--surface); border: 2px solid var(--hairline); border-radius: 16px; padding: 16px; box-shadow: 0 4px 0 rgba(0,0,0,0.08); position: relative; overflow: hidden;" do %>
          <div class="flex items-start gap-3">
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center shrink-0"
                 style="background: <%= subject.color %>; box-shadow: 0 3px 0 rgba(0,0,0,0.08);">
              <%= render Ui::Icon::Component.new(subject.icon.to_sym, size: 26, color: "white") %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <div class="font-display text-[16px] font-extrabold leading-tight" style="color: var(--text);">
                  <%= subject.name %>
                </div>
                <span class="px-2 py-0.5 rounded-full font-display font-extrabold text-[10px] tracking-wide tabular-nums uppercase"
                      style="background: <%= tier_color %>; color: white; box-shadow: 0 1.5px 0 rgba(0,0,0,0.1);">
                  Nv. <%= skill.level %>
                </span>
              </div>
              <div class="text-[12px] font-bold mt-0.5" style="color: var(--text-muted);">
                <%= subject.tagline %>
              </div>

              <div class="mt-2.5 flex items-center gap-2">
                <div class="flex-1 h-2 rounded-full overflow-hidden" style="background: var(--hairline);">
                  <div class="h-full rounded-full transition-all"
                       style="width: <%= skill.percent %>%;
                              background: linear-gradient(90deg, <%= subject.color %>, var(--c-star));"></div>
                </div>
                <span class="text-[11px] font-extrabold tabular-nums" style="color: <%= tier_color %>;">
                  <%= skill.level %>/<%= skill.total %>
                </span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# ── Atlas strip (last minted cards) ────────────────── %>
  <% if @recent_cards.any? %>
    <section class="mb-5">
      <div class="flex items-center justify-between mb-2 px-1">
        <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase" style="color: var(--c-star-dark, var(--c-star));">
          ATLAS · ÚLTIMAS DESCOBERTAS
        </div>
        <%= link_to "Ver tudo →", kid_academy_atlas_path,
                    class: "font-display text-[11px] font-extrabold",
                    style: "color: var(--c-primary-dark);" %>
      </div>
      <div class="flex gap-3 overflow-x-auto pb-2 px-1 -mx-1 snap-x">
        <% @recent_cards.each do |card| %>
          <article class="shrink-0 snap-start ls-card-3d"
                   style="background: var(--surface); border: 2px solid var(--c-star); border-radius: 14px; padding: 12px; box-shadow: 0 4px 0 var(--star-depth); width: 220px;">
            <div class="w-10 h-10 rounded-2xl flex items-center justify-center mb-2"
                 style="background: <%= card.mission.subject.color %>;">
              <%= render Ui::Icon::Component.new(card.illustration_key.to_s.presence&.to_sym || :sparkle, size: 20, color: "white") %>
            </div>
            <div class="font-display text-[9px] font-extrabold tracking-[1px] uppercase mb-1" style="color: var(--text-muted);">
              <%= card.mission.subject.name %>
            </div>
            <p class="font-display text-[12px] font-extrabold leading-snug m-0" style="color: var(--text);">
              <%= card.headline %>
            </p>
            <% if card.source.present? %>
              <div class="mt-2 inline-block px-1.5 py-0.5 rounded-md font-display font-extrabold text-[9px] tracking-wide uppercase"
                   style="background: var(--primary-soft); color: var(--primary-2);">
                <%= card.source %>
              </div>
            <% end %>
          </article>
        <% end %>
      </div>
    </section>
  <% end %>

  <%# ── Elenco shortcut ─────────────────────────────────── %>
  <section class="mb-5">
    <%= link_to kid_academy_cast_path,
                class: "ls-card-3d block",
                style: "background: var(--surface); border: 2px solid var(--hairline); border-radius: 14px; padding: 12px 14px; box-shadow: 0 4px 0 rgba(0,0,0,0.06); text-decoration: none; color: inherit;",
                "data-testid": "kid-cast-shortcut" do %>
      <div class="flex items-center justify-between gap-3">
        <div class="flex items-center gap-3 min-w-0">
          <span aria-hidden="true" style="font-size: 22px;">🎭</span>
          <div class="min-w-0">
            <div class="font-display text-[11px] font-extrabold tracking-[1px] uppercase" style="color: var(--text-muted);">Elenco</div>
            <div class="font-display text-[13px] font-extrabold leading-tight" style="color: var(--text);">
              Quem conta cada aula
            </div>
          </div>
        </div>
        <%= render Ui::Icon::Component.new("chevron-right", size: 18, color: "var(--text-muted)") %>
      </div>
    <% end %>
  </section>

</div>
