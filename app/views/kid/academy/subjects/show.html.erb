<% content_for(:title) { @subject.name } %>

<%
  tier_color = case @skill.tier
               when :master    then "var(--c-star)"
               when :adept     then "var(--c-primary)"
               when :apprentice then "var(--c-sky)"
               else "var(--hairline)"
               end
%>

<div class="screen screen-enter with-nav">
  <div class="flex items-center gap-3 mb-4 px-1">
    <%= link_to kid_academy_subjects_path, class: "w-10 h-10 rounded-full flex items-center justify-center anim-press",
                style: "background: var(--surface); border: 2px solid var(--hairline);" do %>
      <%= render Ui::Icon::Component.new(:chevron_left, size: 18, color: "var(--text)") %>
    <% end %>
    <div class="flex-1 min-w-0">
      <div class="font-display text-[11px] font-extrabold tracking-[1px] uppercase" style="color: var(--c-sky-dark);">
        ÁREA DE FORMAÇÃO
      </div>
      <h1 class="font-display text-[20px] font-extrabold leading-tight m-0 truncate" style="color: var(--text);">
        <%= @subject.name %>
      </h1>
    </div>
    <span class="shrink-0 px-2.5 py-1 rounded-full font-display font-extrabold text-[11px] tabular-nums tracking-wide uppercase"
          style="background: <%= tier_color %>; color: white; box-shadow: 0 2px 0 rgba(0,0,0,0.1);">
      Nv. <%= @skill.level %>
    </span>
  </div>

  <%# ── Skill banner ──────────────────────────────────────── %>
  <div class="ls-card-3d mb-4"
       style="background: <%= @subject.color %>; border: 2px solid rgba(0,0,0,0.08); border-radius: 16px; padding: 14px 16px; box-shadow: 0 4px 0 rgba(0,0,0,0.12); color: white;">
    <div class="flex items-center gap-2 mb-2">
      <%= render Ui::Icon::Component.new(@subject.icon.to_sym, size: 20, color: "white") %>
      <span class="font-display text-[11px] font-extrabold uppercase tracking-[1px] opacity-90">
        <%= @skill.tier_label %>
        <% if @skill.tier != :master %>
          · +<%= @skill.to_master %> pra mestre
        <% end %>
      </span>
    </div>
    <div class="h-2 rounded-full overflow-hidden" style="background: rgba(255,255,255,0.25);">
      <div class="h-full rounded-full transition-all"
           style="width: <%= @skill.percent %>%; background: linear-gradient(90deg, white, var(--c-star));"></div>
    </div>
    <p class="text-[12px] font-bold leading-snug mt-2 mb-0 opacity-95">
      <%= @subject.tagline %>.
    </p>
  </div>

  <%# ── Trilhas (Netflix-style cards) ────────────────────── %>
  <% if @trails.any? %>
    <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-2 px-1" style="color: var(--text-muted);">
      TRILHAS
    </div>
    <div class="flex flex-col gap-3">
      <% @trails.each do |trail| %>
        <% progress = @trail_progress[trail.id] %>
        <% pct = (progress[:ratio] * 100).round %>
        <%= link_to kid_academy_subject_trail_path(@subject, trail),
                    class: "block ls-card-3d surface-card-3d anim-press no-underline" do %>
          <div class="flex items-start gap-3">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0"
                 style="background: <%= @subject.color %>; opacity: 0.85; box-shadow: 0 3px 0 rgba(0,0,0,0.08);">
              <span class="font-display font-extrabold text-[15px]" style="color: white;">
                <%= trail.position %>
              </span>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-display text-[16px] font-extrabold leading-tight" style="color: var(--text);">
                <%= trail.title %>
              </div>
              <% if trail.arc_hook.present? %>
                <p class="text-[12px] font-bold italic leading-snug mt-1 m-0" style="color: var(--text-muted);">
                  "<%= trail.arc_hook %>"
                </p>
              <% end %>
              <div class="mt-2.5 flex items-center gap-2">
                <div class="flex-1 h-1.5 rounded-full overflow-hidden" style="background: var(--hairline);">
                  <div class="h-full rounded-full transition-all"
                       style="width: <%= pct %>%; background: <%= @subject.color %>;"></div>
                </div>
                <span class="text-[11px] font-extrabold tabular-nums shrink-0" style="color: var(--text-muted);">
                  <%= progress[:done] %>/<%= progress[:total] %>
                </span>
              </div>
            </div>
            <%= render Ui::Icon::Component.new(:chevron_right, size: 18, color: "var(--text-muted)") %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="ls-card-3d text-center"
         style="background: var(--c-sky-soft); border: 2px solid var(--c-sky); border-radius: 16px; padding: 18px; color: var(--c-sky-dark);">
      <p class="font-display text-[14px] font-extrabold m-0">
        Trilhas em breve.
      </p>
      <p class="text-[12px] font-bold mt-1 m-0">O Guia está preparando.</p>
    </div>
  <% end %>

  <%# ── Orphan (legacy) missions · for v1 progress continuity ─ %>
  <% if @orphan_missions.any? %>
    <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mt-6 mb-2 px-1" style="color: var(--text-muted);">
      PÍLULAS AVULSAS
    </div>
    <div class="space-y-2">
      <% @orphan_missions.each_with_index do |mission, idx| %>
        <% progress = @orphan_progresses[mission.id] %>
        <% status = progress&.status %>
        <%= link_to kid_academy_subject_mission_path(@subject, mission),
                    data: { action: "click->academy-loading#showLesson" },
                    class: "flex items-center gap-3 ls-card-3d anim-press",
                    style: "background: var(--surface); border: 2px solid var(--hairline); border-radius: 14px; padding: 12px 14px; box-shadow: 0 3px 0 rgba(0,0,0,0.06); text-decoration: none;" do %>
          <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0 font-extrabold text-[15px]"
               style="background: <%= status == 'mastered' ? 'var(--c-star)' : status == 'completed' ? 'var(--c-primary)' : 'var(--c-sky)' %>; color: white; box-shadow: 0 3px 0 rgba(0,0,0,0.08);">
            <% if status == 'mastered' %>
              <%= render Ui::Icon::Component.new(:star, size: 18, color: "white") %>
            <% elsif status == 'completed' %>
              <%= render Ui::Icon::Component.new(:check, size: 18, color: "white") %>
            <% else %>
              <%= idx + 1 %>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-display text-[14px] font-extrabold leading-tight" style="color: var(--text);">
              <%= mission.title %>
            </div>
            <% if mission.hook.present? %>
              <div class="text-[12px] font-bold italic mt-0.5 leading-snug" style="color: var(--text-muted);">
                "<%= mission.hook %>"
              </div>
            <% end %>
          </div>
          <%= render Ui::Icon::Component.new(:chevron_right, size: 18, color: "var(--text-muted)") %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
