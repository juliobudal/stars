<% content_for(:title) { "Elenco da Academia" } %>

<div class="screen screen-enter">
  <header class="sticky top-0 z-30 -mx-4 px-4 pt-3 pb-3 mb-4"
          style="background: linear-gradient(to bottom, var(--surface) 70%, rgba(255,255,255,0));">
    <div class="flex items-center gap-3">
      <%= link_to kid_root_path,
                  "aria-label": "Voltar pro Home",
                  class: "w-10 h-10 rounded-full flex items-center justify-center anim-press shrink-0",
                  style: "background: var(--surface); border: 2px solid var(--hairline); box-shadow: 0 3px 0 rgba(0,0,0,0.06);" do %>
        <%= render Ui::Icon::Component.new(:chevron_left, size: 18, color: "var(--text)") %>
      <% end %>

      <div class="flex-1 min-w-0">
        <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase truncate"
             style="color: var(--primary);">
          Elenco
        </div>
        <h1 class="font-display text-[17px] font-extrabold leading-tight m-0 truncate" style="color: var(--text);">
          Quem conta cada aula
        </h1>
      </div>

      <div class="shrink-0 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full"
           style="background: var(--surface-2, #F7F7F7); border: 2px solid var(--hairline);">
        <span class="font-display text-[12px] font-extrabold" style="color: var(--text);">
          <%= @visited_voice_keys.size %>/<%= @voices.size %>
        </span>
      </div>
    </div>
  </header>

  <p class="font-display text-[13px] mb-4" style="color: var(--text-muted);">
    Cada aula é narrada por uma das cinco vozes do elenco d'O Guia. Conheça quem fala com você.
  </p>

  <ul class="flex flex-col gap-3 list-none p-0 m-0" data-testid="cast-list">
    <% @voices.each do |voice| %>
      <% met = @visited_voice_keys.include?(voice.key) %>
      <% count = @visits_by_voice[voice.key].to_i %>
      <li>
        <article class="ls-card-3d block"
                 style="background: var(--surface); border: 2px solid <%= met ? "var(--primary)" : "var(--hairline)" %>; border-radius: 14px; padding: 14px 16px; box-shadow: 0 4px 0 <%= met ? "var(--primary-2)" : "rgba(0,0,0,0.06)" %>;"
                 data-voice-key="<%= voice.key %>">
          <div class="flex items-start gap-3">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-[28px] shrink-0"
                 style="background: <%= met ? "var(--primary-soft)" : "var(--surface-2, #F7F7F7)" %>; border: 2px solid <%= met ? "var(--primary)" : "var(--hairline)" %>;">
              <%= voice.emoji %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <h2 class="font-display text-[16px] font-extrabold leading-tight m-0" style="color: var(--text);">
                  <%= voice.name %>
                </h2>
                <% if met %>
                  <span class="font-display text-[10px] font-extrabold tracking-[1px] uppercase px-2 py-0.5 rounded-full"
                        style="background: var(--c-mint-soft); color: var(--c-mint-dark); border: 1.5px solid var(--c-mint);">
                    ✓ encontrada
                  </span>
                <% else %>
                  <span class="font-display text-[10px] font-extrabold tracking-[1px] uppercase px-2 py-0.5 rounded-full"
                        style="background: var(--surface-2, #F7F7F7); color: var(--text-muted); border: 1.5px solid var(--hairline);">
                    ainda não
                  </span>
                <% end %>
              </div>
              <p class="font-display text-[12px] m-0 mt-0.5" style="color: var(--text-muted);">
                <%= voice.tagline %>
              </p>
              <% if met %>
                <p class="font-display text-[11px] m-0 mt-1" style="color: var(--primary);">
                  <%= count %> <%= count == 1 ? "lente" : "lentes" %> com essa voz
                </p>
              <% end %>
            </div>
          </div>
        </article>
      </li>
    <% end %>
  </ul>

  <% if @visited_voice_keys.size == @voices.size %>
    <div class="ls-card-3d mt-5 p-4 text-center"
         style="background: var(--c-amber-soft); border: 2px solid var(--c-amber); border-radius: 14px; box-shadow: 0 4px 0 var(--c-amber-dark);">
      <div class="text-[34px] mb-1">🏆</div>
      <div class="font-display text-[14px] font-extrabold" style="color: var(--c-amber-dark);">
        Conheceu todo o elenco!
      </div>
      <p class="font-display text-[12px] m-0 mt-1" style="color: var(--text);">
        Você já ouviu pelo menos uma aula de cada voz d'O Guia. Vai voltar a encontrar todas elas.
      </p>
    </div>
  <% end %>
</div>
