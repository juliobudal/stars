<% content_for(:title) { "Lightning · Resultado" } %>
<%
  copy = case @tier
         when :perfect then { emoji: "🧠✨", title: "Mente brilhante!", body: "5 de 5. Você tá num bom momento de retrieval." }
         when :strong  then { emoji: "⚡",   title: "Quase lá!",        body: "#{@correct} de #{@total}. Repete amanhã pra travar o que escapou." }
         else               { emoji: "🌱",   title: "Vamos com calma",  body: "#{@correct} de #{@total}. O que falta agora é repetir, não estudar." }
         end
%>

<div class="screen screen-enter">
  <div class="ls-card-3d mt-6 mb-4 px-5 py-6 text-center"
       style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 18px; box-shadow: 0 4px 0 rgba(0,0,0,0.08);">
    <div style="font-size: 48px; line-height: 1;"><%= copy[:emoji] %></div>
    <h1 class="font-display text-[22px] font-extrabold mt-3 mb-1" style="color: var(--text);"><%= copy[:title] %></h1>
    <p class="font-display text-[14px] font-bold m-0" style="color: var(--text-muted);"><%= copy[:body] %></p>
    <div class="mt-4 font-display text-[12px] font-extrabold tracking-[0.5px] uppercase" style="color: var(--text-muted);">
      Tempo: <%= @elapsed %>s
    </div>
  </div>

  <% if @is_champion %>
    <div class="ls-card-3d mb-4 px-4 py-3 text-center"
         style="background: var(--c-amber-soft); border: 2px solid var(--c-amber); border-radius: 14px; box-shadow: 0 4px 0 var(--c-amber-dark);"
         data-testid="lightning-champion-badge">
      <div class="text-[28px] mb-1">⚡🏆</div>
      <div class="font-display text-[14px] font-extrabold" style="color: var(--c-amber-dark);">
        Lightning Champion!
      </div>
      <p class="font-display text-[12px] m-0 mt-1" style="color: var(--text);">
        4 rounds com 4+ acertos nos últimos 7 dias. Memória de aço.
      </p>
    </div>
  <% end %>

  <%= link_to kid_root_path,
              class: "ls-btn-3d block text-center",
              style: "background: var(--primary); color: white; padding: 14px 18px; border-radius: 14px; box-shadow: 0 4px 0 var(--primary-2); font-weight: 800; font-family: var(--font-display, Nunito), sans-serif;" do %>
    Voltar pra Jornada
  <% end %>
</div>
