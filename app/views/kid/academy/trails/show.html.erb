<% content_for(:title) { @trail.title } %>

<div class="screen screen-enter with-nav">
  <div class="flex items-center gap-3 mb-3 px-1">
    <%= link_to kid_academy_subject_path(@subject), class: "w-10 h-10 rounded-full flex items-center justify-center anim-press",
                style: "background: var(--surface); border: 2px solid var(--hairline);" do %>
      <%= render Ui::Icon::Component.new(:chevron_left, size: 18, color: "var(--text)") %>
    <% end %>
    <div class="flex-1 min-w-0">
      <div class="font-display text-[11px] font-extrabold tracking-[1px] uppercase" style="color: <%= @subject.color %>;">
        <%= @subject.name %> · TRILHA <%= @trail.position %>
      </div>
      <h1 class="font-display text-[20px] font-extrabold leading-tight m-0 truncate" style="color: var(--text);">
        <%= @trail.title %>
      </h1>
    </div>
  </div>

  <% if @trail.arc_hook.present? %>
    <div class="ls-card-3d mb-4"
         style="background: <%= @subject.color %>; border: 2px solid rgba(0,0,0,0.08); border-radius: 16px; padding: 14px 16px; box-shadow: 0 4px 0 rgba(0,0,0,0.12); color: white;">
      <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-1 opacity-90">
        O ARCO DESTA TRILHA
      </div>
      <p class="font-display text-[15px] font-extrabold leading-snug m-0">
        "<%= @trail.arc_hook %>"
      </p>
    </div>
  <% end %>

  <%# ── Aulas (cards with the powerful question) ────────── %>
  <div class="space-y-3">
    <% @missions.each_with_index do |mission, idx| %>
      <% progress = @progresses[mission.id] %>
      <% status = progress&.status %>
      <% card = @cards[mission.id] %>
      <% prev_mission = @missions[idx - 1] %>
      <% locked = idx > 0 && !@progresses[prev_mission&.id]&.then { |p| p.completed? || p.mastered? } %>

      <%= link_to (locked ? "#" : kid_academy_subject_mission_path(@subject, mission)),
                  data: { action: ("click->academy-loading#showLesson" unless locked) },
                  class: "block ls-card-3d surface-card-3d anim-press no-underline #{'opacity-60 pointer-events-none' if locked}" do %>
        <div class="flex items-start gap-3">
          <div class="w-11 h-11 rounded-full flex items-center justify-center shrink-0 font-extrabold text-[16px]"
               style="background: <%= status == 'mastered' ? 'var(--c-star)' : status == 'completed' ? 'var(--c-primary)' : locked ? 'var(--hairline)' : @subject.color %>; color: white; box-shadow: 0 3px 0 rgba(0,0,0,0.08);">
            <% if status == 'mastered' %>
              <%= render Ui::Icon::Component.new(:star, size: 20, color: "white") %>
            <% elsif status == 'completed' %>
              <%= render Ui::Icon::Component.new(:check, size: 20, color: "white") %>
            <% elsif locked %>
              <%= render Ui::Icon::Component.new(:lock, size: 18, color: "white") %>
            <% else %>
              <%= idx + 1 %>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-display text-[15px] font-extrabold leading-snug" style="color: var(--text);">
              <%= mission.title %>
            </div>
            <% if mission.hook.present? && !locked %>
              <div class="text-[12px] font-bold mt-0.5 italic leading-snug" style="color: var(--text-muted);">
                "<%= mission.hook %>"
              </div>
            <% end %>
            <% if card.present? %>
              <div class="mt-2 inline-flex items-center gap-1 px-2 py-0.5 rounded-full"
                   style="background: var(--c-star); color: white;">
                <%= render Ui::Icon::Component.new(:sparkle, size: 12, color: "white") %>
                <span class="font-display text-[10px] font-extrabold tracking-wide uppercase">
                  Carta no Atlas
                </span>
              </div>
            <% end %>
          </div>
          <% unless locked %>
            <%= render Ui::Icon::Component.new(:chevron_right, size: 18, color: "var(--text-muted)") %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
