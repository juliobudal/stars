<% content_for(:title) { @trail.title } %>

<div class="screen with-nav screen-enter">
  <header class="-mx-4 px-4 pt-3 pb-3 mb-4">
    <div class="flex items-center gap-3">
      <%= link_to kid_academy_root_path,
            "aria-label": "Voltar",
            class: "w-11 h-11 rounded-full flex items-center justify-center anim-press shrink-0",
            style: "background: var(--surface); border: 1px solid var(--hairline); box-shadow: none;" do %>
        <%= render Ui::Icon::Component.new(:back, size: 18, color: "var(--text)") %>
      <% end %>
      <div class="flex-1 min-w-0">
        <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase truncate" style="color: var(--text-muted);">
          Trilha
        </div>
        <h1 class="font-display text-[19px] font-extrabold leading-tight m-0 truncate" style="color: var(--text);">
          <% if (trail_emoji = @trail.emoji.presence) %><span aria-hidden="true"><%= trail_emoji %></span> <% end %><%= @trail.title %>
        </h1>
      </div>
    </div>
    <% if @trail.hook.present? %>
      <p class="font-display text-[13px] leading-snug mt-2 mb-0" style="color: var(--text-muted);">
        <%= @trail.hook %>
      </p>
    <% end %>
  </header>

  <ol class="flex flex-col gap-3 list-none p-0 m-0">
    <% @rows.each_with_index do |row, i| %>
      <%
        lesson = row[:lesson]; status = row[:status]
        locked = status == :locked
        completed = status == :completed
        tile_bg = completed ? "var(--primary-soft)" : (locked ? "var(--surface-2)" : "var(--surface)")
        num_bg = completed ? "var(--primary)" : (locked ? "var(--hairline)" : "var(--star)")
        num_fg = completed || !locked ? "white" : "var(--text-muted)"
      %>
      <li>
        <% inner = capture do %>
          <div class="flex items-center gap-3 p-3.5">
            <div class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center font-display text-[15px] font-extrabold"
                 style="background: <%= num_bg %>; color: <%= num_fg %>; box-shadow: none;">
              <% if completed %>
                <%= render Ui::Icon::Component.new(:check, size: 18, color: "white") %>
              <% elsif locked %>
                <%= render Ui::Icon::Component.new(:lock, size: 16, color: "var(--text-muted)") %>
              <% else %>
                <%= i + 1 %>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <h2 class="font-display text-[15px] font-extrabold leading-tight m-0 truncate" style="color: <%= locked ? 'var(--text-muted)' : 'var(--text)' %>;">
                <%= lesson.title %>
              </h2>
              <p class="font-display text-[12px] leading-snug m-0 mt-0.5 truncate" style="color: var(--text-muted);">
                <%= locked ? "Bloqueada" : lesson.enigma %>
              </p>
            </div>
          </div>
        <% end %>

        <% if locked %>
          <div class="block rounded-[14px] opacity-60" style="background: <%= tile_bg %>; border: 1px solid var(--hairline);">
            <%= inner %>
          </div>
        <% else %>
          <%= link_to kid_academy_trail_lesson_path(@trail, lesson),
                class: "ls-card-3d anim-press block no-underline rounded-[14px]",
                style: "background: #{tile_bg}; border: 1px solid #{completed ? 'var(--primary)' : 'var(--hairline)'}; box-shadow: none;" do %>
            <%= inner %>
          <% end %>
        <% end %>
      </li>
    <% end %>
  </ol>
</div>
