<%# locals: subject, mission, progress %>
<%
  mastered = progress.mastered?
  card        = ::Academy::DiscoveryCard.find_by(learner_id: progress.learner_id, mission_id: mission.id)
  connections = ::Academy::Connections::ForMission
                  .call(mission: mission, learner_id: progress.learner_id, limit: 3)
                  .then { |r| r.success? ? r.data : [] }
%>
<div class="anim-pop-in mt-3 space-y-3">

  <%# ── Banner de conclusão ──────────────────────────────── %>
  <div class="ls-card-3d text-center"
       style="background: <%= mastered ? 'linear-gradient(135deg, var(--star), var(--star-2))' : 'linear-gradient(135deg, var(--primary), var(--primary-2))' %>;
              color: white;
              border: 2px solid rgba(0,0,0,0.06); border-radius: 20px; padding: 18px;
              box-shadow: 0 5px 0 rgba(0,0,0,0.15);">

    <div class="w-14 h-14 rounded-full mx-auto flex items-center justify-center mb-2"
         style="background: rgba(255,255,255,0.25);">
      <%= render Ui::Icon::Component.new(mastered ? :trophy : :check, size: 28, color: "white") %>
    </div>

    <div class="font-display text-[11px] font-extrabold tracking-[2px] uppercase mb-1 opacity-90">
      <%= mastered ? "IMPECÁVEL!" : "AULA CONCLUÍDA" %>
    </div>
    <h2 class="font-display text-[18px] font-extrabold leading-tight m-0">
      <%= mission.title %>
    </h2>
    <% if progress.total_checkpoints.positive? %>
      <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full mt-2"
           style="background: rgba(255,255,255,0.2);">
        <%= render Ui::Icon::Component.new(:target, size: 12, color: "white") %>
        <span class="font-display text-[11px] font-extrabold tabular-nums">
          <%= progress.correct_checkpoints %>/<%= progress.total_checkpoints %> certos
        </span>
      </div>
    <% end %>
  </div>

  <%# ── Carta de descoberta (NEW v2) ─────────────────────── %>
  <% if card.present? %>
    <article class="ls-card-3d"
             style="background: var(--surface); border: 3px solid var(--c-star); border-radius: 18px; padding: 16px; box-shadow: 0 5px 0 #a37100;">
      <div class="flex items-center gap-2 mb-3">
        <%= render Ui::Icon::Component.new(:sparkle, size: 16, color: "var(--c-star)") %>
        <span class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase" style="color: var(--c-star);">
          NOVA CARTA NO ATLAS
        </span>
      </div>

      <div class="flex items-start gap-3 mb-2">
        <div class="w-12 h-12 rounded-2xl flex items-center justify-center shrink-0"
             style="background: <%= subject.color %>; box-shadow: 0 3px 0 rgba(0,0,0,0.08);">
          <%= render Ui::Icon::Component.new(card.illustration_key.to_s.presence&.to_sym || :sparkle, size: 22, color: "white") %>
        </div>
        <p class="font-display text-[15px] font-extrabold leading-snug m-0 flex-1" style="color: var(--text);">
          <%= card.headline %>
        </p>
      </div>

      <% if card.application.present? %>
        <p class="text-[12px] font-bold leading-snug m-0 mt-1" style="color: var(--text-muted);">
          <%= card.application %>
        </p>
      <% end %>
    </article>
  <% end %>

  <%# ── Mini-desafio (v2 challenge_prompt) ───────────────── %>
  <% if mission.challenge? %>
    <article class="ls-card-3d"
             style="background: var(--c-sky-soft); border: 2px solid var(--c-sky); border-radius: 18px; padding: 16px; box-shadow: 0 4px 0 var(--c-sky-dark);">
      <div class="flex items-center gap-2 mb-2">
        <%= render Ui::Icon::Component.new(:bolt, size: 16, color: "var(--c-sky-dark)") %>
        <span class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase" style="color: var(--c-sky-dark);">
          MINI-DESAFIO
        </span>
        <% if mission.challenge_when.present? %>
          <span class="ml-auto px-1.5 py-0.5 rounded-md font-display font-extrabold text-[9px] tracking-wide uppercase"
                style="background: var(--c-sky); color: white;">
            <%= mission.challenge_when.tr("-", " ") %>
          </span>
        <% end %>
      </div>

      <p class="font-display text-[15px] font-extrabold leading-snug m-0 mb-2" style="color: var(--text);">
        "<%= mission.challenge_prompt %>"
      </p>

      <% if mission.challenge_observable.present? %>
        <p class="text-[12px] font-bold italic leading-snug m-0" style="color: var(--text-muted);">
          O que observar: <%= mission.challenge_observable %>
        </p>
      <% end %>
    </article>
  <% end %>

  <%# ── Conexões ("Isso conecta com...") ────────────────── %>
  <% if connections.any? %>
    <article class="ls-card-3d"
             style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 16px; padding: 14px 16px; box-shadow: 0 4px 0 rgba(0,0,0,0.06);">
      <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-2" style="color: var(--text-muted);">
        ESTA SACADA CONVERSA COM…
      </div>
      <div class="flex flex-col gap-2">
        <% connections.each do |connection| %>
          <% other_subject = connection.mission.subject %>
          <%= link_to kid_academy_subject_mission_path(other_subject, connection.mission),
                      data: { action: "click->academy-loading#showLesson" },
                      class: "flex items-center gap-2.5 anim-press",
                      style: "background: var(--bg); border: 1.5px solid var(--hairline); border-radius: 12px; padding: 8px 10px; text-decoration: none;" do %>
            <div class="w-8 h-8 rounded-xl flex items-center justify-center shrink-0"
                 style="background: <%= other_subject.color %>;">
              <%= render Ui::Icon::Component.new(other_subject.icon.to_sym, size: 16, color: "white") %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-display text-[13px] font-extrabold leading-tight" style="color: var(--text);">
                <%= connection.mission.title %>
              </div>
              <div class="text-[10px] font-extrabold tracking-wide uppercase mt-0.5" style="color: <%= connection.same_subject ? 'var(--text-muted)' : other_subject.color %>;">
                <% if !connection.same_subject %>
                  <%= other_subject.name %> ·
                <% end %>
                <%= connection.shared_concepts.first(2).map(&:name).join(" · ") %>
              </div>
            </div>
            <% if connection.has_card %>
              <%= render Ui::Icon::Component.new(:check, size: 14, color: "var(--c-primary)") %>
            <% else %>
              <%= render Ui::Icon::Component.new(:chevron_right, size: 14, color: "var(--text-muted)") %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </article>
  <% end %>

  <%# ── CTAs ─────────────────────────────────────────────── %>
  <div class="flex flex-col gap-2 mt-2">
    <%= link_to kid_academy_atlas_path,
                class: "block w-full px-5 py-3 rounded-2xl font-display font-extrabold text-[14px] anim-press text-center",
                style: "background: var(--c-star); color: white; box-shadow: 0 4px 0 #a37100; border: 2px solid #a37100;" do %>
      Ver meu Atlas →
    <% end %>
    <%= link_to kid_academy_subject_path(subject),
                class: "block w-full px-5 py-2.5 rounded-2xl font-display font-extrabold text-[13px] text-center anim-press",
                style: "background: var(--surface); color: var(--text); border: 2px solid var(--hairline);" do %>
      Voltar para <%= subject.name %>
    <% end %>
  </div>
</div>
