<% content_for(:title) { "Caderno de pílulas" } %>

<div class="screen screen-enter">
  <header class="sticky top-0 z-30 -mx-4 px-4 pt-3 pb-3 mb-4"
          style="background: linear-gradient(to bottom, var(--surface) 70%, rgba(255,255,255,0));">
    <div class="flex items-center gap-3">
      <%= link_to kid_root_path,
                  "aria-label": "Voltar pro Home",
                  class: "w-10 h-10 rounded-full flex items-center justify-center anim-press shrink-0",
                  style: "background: var(--surface); border: 2px solid var(--hairline); box-shadow: 0 3px 0 rgba(0,0,0,0.06);" do %>
        <%= render Ui::Icon::Component.new(:chevron_left, size: 18, color: "var(--text)") %>
      <% end %>

      <div class="flex-1 min-w-0">
        <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase truncate"
             style="color: var(--primary);">
          Caderno
        </div>
        <h1 class="font-display text-[17px] font-extrabold leading-tight m-0 truncate" style="color: var(--text);">
          Pílulas que você tomou
        </h1>
      </div>

      <div class="shrink-0 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full"
           style="background: var(--surface-2); border: 2px solid var(--hairline);">
        <span class="font-display text-[12px] font-extrabold" style="color: var(--text);"><%= @total %></span>
      </div>
    </div>
  </header>

  <% if @pills.empty? %>
    <div class="ls-card-3d p-5 text-center"
         style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 16px; box-shadow: 0 4px 0 rgba(0,0,0,0.04);">
      <div class="text-[40px] mb-2">💊</div>
      <h2 class="font-display text-[15px] font-extrabold m-0 mb-1" style="color: var(--text);">
        Nenhuma pílula ainda
      </h2>
      <p class="font-display text-[13px] m-0" style="color: var(--text-muted);">
        Toma a pílula do dia e ela aparece aqui pra você revisitar quando quiser.
      </p>
      <div class="mt-4">
        <%= link_to "Tomar a pílula do dia →", kid_academy_pill_path,
                    class: "ls-btn-3d inline-block",
                    style: "background: var(--primary); color: white; padding: 12px 18px; border-radius: 12px; box-shadow: 0 4px 0 var(--primary-2); font-weight: 800; font-family: var(--font-display, Nunito), sans-serif; text-decoration: none;" %>
      </div>
    </div>
  <% else %>
    <ul class="flex flex-col gap-3 list-none p-0 m-0" data-testid="pills-index-list">
      <% @pills.each do |pill| %>
        <% concept = pill.lens_cache.concept %>
        <% color_var = "var(--academy-pokedex-#{concept.pokedex_color_key.presence || 'cognitivo'})" %>
        <li>
          <%= link_to kid_academy_pill_path,
                      class: "ls-card-3d block",
                      style: "background: var(--surface); border: 2px solid #{color_var}; border-radius: 14px; padding: 12px 14px; box-shadow: 0 4px 0 color-mix(in oklab, #{color_var} 30%, transparent); text-decoration: none; color: inherit;" do %>
            <div class="flex items-center gap-3">
              <div class="w-11 h-11 rounded-2xl flex items-center justify-center text-[20px] shrink-0"
                   style="background: color-mix(in oklab, <%= color_var %> 18%, var(--surface)); border: 2px solid <%= color_var %>;">
                💊
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-display text-[10px] font-extrabold tracking-[1px] uppercase truncate"
                     style="color: <%= color_var %>;">
                  <%= pill.lens_cache.lens_type.humanize %>
                </div>
                <div class="font-display text-[14px] font-extrabold leading-tight truncate"
                     style="color: var(--text);">
                  <%= concept.name %>
                </div>
                <div class="font-display text-[11px] mt-0.5" style="color: var(--text-muted);">
                  <%= l(pill.created_at.to_date, format: :long) %>
                  <% if pill.shared_with_parent? %>
                    · <span style="color: var(--c-mint-dark);">✓ compartilhada</span>
                  <% end %>
                </div>
              </div>
              <%= render Ui::Icon::Component.new("chevron-right", size: 18, color: color_var) %>
            </div>
          <% end %>
        </li>
      <% end %>
    </ul>

    <% if @has_more || @page > 1 %>
      <div class="flex items-center justify-between gap-3 mt-5">
        <% if @page > 1 %>
          <%= link_to "← Anterior", kid_academy_pills_path(page: @page - 1),
                      class: "ls-btn-3d",
                      style: "background: var(--surface); border: 2px solid var(--hairline); box-shadow: 0 3px 0 rgba(0,0,0,0.06); padding: 10px 14px; border-radius: 12px; color: var(--text); font-weight: 700; font-family: var(--font-display, Nunito), sans-serif; text-decoration: none;" %>
        <% else %>
          <span></span>
        <% end %>

        <% if @has_more %>
          <%= link_to "Próxima →", kid_academy_pills_path(page: @page + 1),
                      class: "ls-btn-3d",
                      style: "background: var(--surface); border: 2px solid var(--hairline); box-shadow: 0 3px 0 rgba(0,0,0,0.06); padding: 10px 14px; border-radius: 12px; color: var(--text); font-weight: 700; font-family: var(--font-display, Nunito), sans-serif; text-decoration: none;" %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
