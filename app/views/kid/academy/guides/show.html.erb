<% content_for(:title) { "O Guia · #{@lesson.title}" } %>
<% color_var = "var(--primary)" %>

<div class="screen no-nav screen-enter">
  <%# ── Header ────────────────────────────────────────────────── %>
  <header class="-mx-4 px-4 pt-3 pb-3 mb-4">
    <div class="flex items-center gap-3">
      <%= link_to kid_academy_trail_lesson_path(@trail, @lesson),
                  "aria-label": "Voltar para a aula",
                  class: "w-11 h-11 rounded-full flex items-center justify-center anim-press shrink-0",
                  style: "background: var(--surface); border: 1px solid var(--hairline); box-shadow: none;" do %>
        <%= render Ui::Icon::Component.new(:back, size: 18, color: "var(--text)") %>
      <% end %>

      <div class="flex-1 min-w-0">
        <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase truncate"
             style="color: <%= color_var %>;">
          <span aria-hidden="true">🦉</span> O GUIA
        </div>
        <h1 class="font-display text-[17px] font-extrabold leading-tight m-0 truncate" style="color: var(--text);">
          <%= @lesson.title %>
        </h1>
      </div>
    </div>
  </header>

  <%# ── Conversation transcript ───────────────────────────────── %>
  <section aria-label="Conversa" class="flex flex-col gap-3 mb-4">
    <% if @messages.empty? %>
      <div class="academy-card p-5 text-center"
           style="background: color-mix(in oklab, <%= color_var %> 10%, var(--surface)); border-color: <%= color_var %>;">
        <div class="text-[28px] mb-1" aria-hidden="true">🦉</div>
        <p class="font-display text-[15px] font-extrabold leading-snug m-0 mb-1" style="color: var(--text);">
          Pergunta o que quiser sobre essa aula.
        </p>
        <p class="font-display text-[13px] leading-snug m-0" style="color: var(--text-muted);">
          O Guia só fala do que tá rolando aqui. 5 perguntas por dia.
        </p>
      </div>
    <% else %>
      <% @messages.each do |msg| %>
        <%= render "message", message: msg, color_var: color_var %>
      <% end %>
    <% end %>
  </section>

  <%# ── Input ─────────────────────────────────────────────────── %>
  <% if @guide_error.present? %>
    <div role="alert" class="academy-card p-3 mb-3 inline-flex items-center gap-2.5"
         style="background: var(--c-coral-soft); border-color: var(--c-coral);">
      <%= render Ui::Icon::Component.new("repeat", size: 16, color: "var(--c-coral-dark)") %>
      <p class="font-display text-[13px] font-extrabold leading-snug m-0" style="color: var(--c-coral-dark);"><%= @guide_error %></p>
    </div>
  <% end %>

  <%= form_with url: kid_academy_trail_lesson_guide_path(@trail, @lesson),
                method: :post, local: true, class: "academy-card p-3" do |f| %>
    <%= f.text_area :content,
                    rows: 3,
                    maxlength: 500,
                    required: true,
                    value: @draft_content,
                    placeholder: "O que você quer entender?",
                    class: "form-input leading-snug" %>
    <div class="flex items-center justify-end mt-3">
      <%= render Ui::Btn::Component.new(variant: "primary", size: "md", type: "submit", data: { turbo_submits_with: "Perguntando…" }) do %>
        Perguntar
        <%= render Ui::Icon::Component.new("arrow-right-01", size: 16, color: "white") %>
      <% end %>
    </div>
  <% end %>
</div>
