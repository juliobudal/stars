<% content_for(:title) { "Revisão · #{@mission.title}" } %>
<%
  mission = @review_stage.mission
  visits  = @review_stage.visits
  color_var = "var(--academy-pokedex-#{mission.concept.pokedex_color_key.presence || 'cognitivo'})"
%>

<div class="screen screen-enter">
  <%# ── Header ────────────────────────────────────────────────── %>
  <header class="-mx-4 px-4 pt-3 pb-3 mb-4">
    <div class="flex items-center gap-3">
      <%= link_to kid_academy_subject_path(@subject),
                  "aria-label": "Voltar para #{@subject.name}",
                  class: "w-10 h-10 rounded-full flex items-center justify-center anim-press shrink-0",
                  style: "background: var(--surface); border: 2px solid var(--hairline); box-shadow: 0 3px 0 rgba(0,0,0,0.06);" do %>
        <%= render Ui::Icon::Component.new(:chevron_left, size: 18, color: "var(--text)") %>
      <% end %>

      <div class="flex-1 min-w-0">
        <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase truncate"
             style="color: <%= color_var %>;">
          <%= @subject.name.upcase %> · REVISÃO
        </div>
        <h1 class="font-display text-[17px] font-extrabold leading-tight m-0 truncate" style="color: var(--text);">
          <%= mission.title %>
        </h1>
      </div>

      <% if ::Academy::Guide::Available.available? %>
        <%= link_to kid_academy_subject_mission_guide_path(@subject, mission),
                    "aria-label": "Falar com O Guia",
                    class: "w-10 h-10 rounded-full flex items-center justify-center anim-press shrink-0 font-display text-[16px]",
                    style: "background: color-mix(in oklab, #{color_var} 18%, var(--surface)); border: 2px solid #{color_var}; color: #{color_var}; box-shadow: 0 3px 0 color-mix(in oklab, #{color_var} 50%, black);" do %>
          🦉
        <% end %>
      <% end %>
    </div>
  </header>

  <%# ── Completion banner ─────────────────────────────────────── %>
  <div class="lens-card p-5 mb-4 text-center"
       style="background: color-mix(in oklab, <%= color_var %> 14%, var(--surface)); border-color: <%= color_var %>;">
    <div class="mx-auto mb-2 inline-flex items-center justify-center w-12 h-12 rounded-full"
         style="background: <%= color_var %>; color: white; box-shadow: 0 3px 0 color-mix(in oklab, <%= color_var %> 60%, black);">
      <span class="font-display text-[22px] font-extrabold">✓</span>
    </div>
    <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-1"
         style="color: <%= color_var %>;">
      Missão completa
      <% if @review_stage.trail_total > 1 %>
        · <%= @review_stage.trail_position %>/<%= @review_stage.trail_total %>
      <% end %>
    </div>
    <p class="font-display text-[14px] leading-snug m-0" style="color: var(--text);">
      <strong><%= @review_stage.total_visits %></strong>
      <%= @review_stage.total_visits == 1 ? "lição percorrida" : "lições percorridas" %>
      sobre <strong><%= mission.concept.name %></strong>.
    </p>
  </div>

  <%# ── A sacada (closure-lens headline) ──────────────────────── %>
  <% if @review_stage.closure_headline.present? %>
    <div class="lens-card p-5 mb-4"
         style="background: var(--surface); border-color: <%= color_var %>;">
      <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-2"
           style="color: <%= color_var %>;">
        ✨ A sacada
      </div>
      <p class="font-display text-[16px] font-extrabold leading-snug m-0" style="color: var(--text);">
        <%= @review_stage.closure_headline %>
      </p>
    </div>
  <% end %>

  <%# ── Pra sua coleção (minted DiscoveryCard) ────────────────── %>
  <% if @review_stage.card.present? %>
    <%= link_to kid_academy_atlas_path,
                class: "block lens-card p-4 mb-4 anim-press",
                style: "background: var(--surface-2); border-color: var(--hairline); text-decoration: none; color: inherit;" do %>
      <div class="flex items-start gap-3">
        <div class="w-11 h-11 rounded-xl shrink-0 flex items-center justify-center font-display text-[20px] font-extrabold"
             style="background: <%= color_var %>; color: white;">
          🃏
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-1"
               style="color: var(--text-muted);">
            Pra sua coleção
          </div>
          <div class="font-display text-[14px] font-extrabold leading-snug" style="color: var(--text);">
            <%= @review_stage.card.headline %>
          </div>
          <div class="font-display text-[11px] mt-1" style="color: var(--text-muted);">
            Toque pra ver no Atlas →
          </div>
        </div>
      </div>
    <% end %>
  <% end %>

  <%# ── Mini-desafio do mundo real → cria ProfileTask ─────────── %>
  <% if mission.challenge? %>
    <article class="ls-card-3d mb-4"
             style="background: var(--c-sky-soft); border: 2px solid var(--c-sky); border-radius: 18px; padding: 16px; box-shadow: 0 4px 0 var(--c-sky-dark);">
      <div class="flex items-center gap-2 mb-2">
        <%= render Ui::Icon::Component.new(:bolt, size: 16, color: "var(--c-sky-dark)") %>
        <span class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase" style="color: var(--c-sky-dark);">
          MINI-DESAFIO
        </span>
        <% if mission.challenge_when.present? %>
          <span class="ml-auto px-1.5 py-0.5 rounded-md font-display font-extrabold text-[9px] tracking-wide uppercase"
                style="background: var(--c-sky); color: white;">
            <%= mission.challenge_when.tr("-", " ") %>
          </span>
        <% end %>
      </div>

      <p class="font-display text-[15px] font-extrabold leading-snug m-0 mb-2" style="color: var(--text);">
        “<%= mission.challenge_prompt %>”
      </p>

      <% if mission.challenge_observable.present? %>
        <p class="text-[12px] font-bold italic leading-snug m-0 mb-3" style="color: var(--text-muted);">
          O que observar: <%= mission.challenge_observable %>
        </p>
      <% end %>

      <% if @challenge_committed %>
        <div class="flex items-center gap-2 px-3 py-2 rounded-xl mt-2"
             style="background: var(--surface); border: 2px solid var(--c-sky);">
          <%= render Ui::Icon::Component.new(:check, size: 16, color: "var(--c-sky-dark)") %>
          <span class="font-display text-[12px] font-extrabold" style="color: var(--c-sky-dark);">
            Mandado pra aprovação. Vale ⭐ 5 quando o responsável aprovar.
          </span>
        </div>
      <% else %>
        <%= button_to commit_challenge_kid_academy_subject_mission_path(@subject, mission),
                      method: :post,
                      form_class: "w-full",
                      class: "w-full px-5 py-3.5 rounded-xl font-display font-extrabold text-[14px] anim-press ls-btn-3d border-0 cursor-pointer",
                      style: "background: var(--c-sky); color: white; box-shadow: 0 4px 0 var(--c-sky-dark);" do %>
          ✓ Fiz isso! Mandar pra aprovação
        <% end %>
      <% end %>
    </article>
  <% end %>

  <%# ── CTA pra próxima missão / voltar pra trilha ────────────── %>
  <% if @review_stage.next_mission.present? %>
    <%= link_to kid_academy_subject_mission_path(@subject, @review_stage.next_mission),
                class: "block w-full mb-4 px-5 py-4 rounded-xl font-display font-extrabold text-[15px] anim-press text-center",
                style: "background: var(--c-primary); color: white; box-shadow: 0 4px 0 color-mix(in oklab, var(--c-primary) 60%, black); text-decoration: none;" do %>
      Próxima missão →
    <% end %>
  <% elsif mission.trail.present? %>
    <%= link_to kid_academy_subject_trail_path(@subject, mission.trail),
                class: "block w-full mb-4 px-5 py-4 rounded-xl font-display font-extrabold text-[15px] anim-press text-center",
                style: "background: var(--surface); color: var(--text); border: 2px solid var(--hairline); box-shadow: 0 4px 0 var(--hairline); text-decoration: none;" do %>
      Voltar pra trilha
    <% end %>
  <% end %>

  <%# ── Visit cards ───────────────────────────────────────────── %>
  <div class="flex flex-col gap-3">
    <% visits.each_with_index do |entry, idx| %>
      <% label = ::Academy::Lens::Catalog.kid_action_label(entry.lens_type.to_sym) %>
      <%= link_to kid_academy_subject_mission_review_visit_path(@subject, mission, entry.visit.id),
                  class: "lens-compare-card flex items-center gap-3",
                  style: "text-decoration: none; color: inherit;" do %>
        <div class="w-12 h-12 rounded-xl flex items-center justify-center text-[22px] shrink-0"
             style="background: color-mix(in oklab, <%= color_var %> 18%, var(--surface)); border: 2px solid <%= color_var %>;">
          <%= label[:emoji] %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase"
               style="color: var(--text-muted);">
            Lição <%= idx + 1 %>
          </div>
          <div class="font-display text-[15px] font-extrabold leading-tight m-0 truncate" style="color: var(--text);">
            <%= label[:action] %>
          </div>
        </div>
        <div class="shrink-0" aria-hidden="true">
          <%= render Ui::Icon::Component.new(:chevron_right, size: 18, color: "var(--text-muted)") %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
