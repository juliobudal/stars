<%#
  Full-viewport overlay shown while Academy is loading.
  Two trigger points (handled by `academy_loading_controller.js`):
    1. Click on a lesson link (initial mission load).
    2. Lens form submit (advance to next lens mid-mission).

  Mounted once at the kid layout level so a single instance covers every
  Academy page. `color_var` is optional · falls back to the Duolingo
  primary green when called outside a mission-coloured context.

  Pílula d'O Guia (citação/versículo/ensinamento) é sorteada por render ·
  ver `Academy::WisdomPills`. Fica fixa durante a espera (criança lê uma
  vez, sem rotação), enquanto a mensagem de progresso acima rotaciona.
%>
<%
  color_var ||= "var(--c-primary)"
  pill = local_assigns[:pill] || Academy::WisdomPills.sample
%>
<div data-academy-loading-target="overlay"
     class="hidden fixed inset-0 z-50 flex items-center justify-center px-6"
     aria-hidden="true" aria-live="polite" role="status"
     style="background: rgba(15, 23, 42, 0.55); backdrop-filter: blur(4px);">
  <div class="w-full max-w-sm text-center px-6 py-7"
       style="background: var(--surface);
              border-radius: 20px;
              border: 2px solid <%= color_var %>;
              box-shadow: 0 6px 0 color-mix(in oklab, <%= color_var %> 60%, black);">
    <div class="mx-auto mb-4 w-14 h-14 rounded-full animate-spin motion-reduce:animate-none"
         style="border: 5px solid var(--hairline); border-top-color: <%= color_var %>;"
         aria-hidden="true"></div>

    <div data-academy-loading-target="message"
         class="font-display text-[15px] font-extrabold leading-snug"
         style="color: var(--text);">
      O Guia está pensando…
    </div>

    <div class="font-display text-[11px] font-extrabold tracking-[0.5px] mt-1.5 uppercase"
         style="color: var(--text-muted);">
      preparando sua aula
    </div>

    <%# Pulsing dots · secondary motion cue, hidden under reduced motion %>
    <div class="flex items-center justify-center gap-1.5 mt-5 motion-reduce:hidden" aria-hidden="true">
      <% 3.times do |i| %>
        <span class="block w-2 h-2 rounded-full ls-loading-dot"
              style="background: <%= color_var %>; animation-delay: <%= i * 0.18 %>s;"></span>
      <% end %>
    </div>

    <%# ── Pílula d'O Guia: citação fixa para a criança ler ──── %>
    <div class="mt-6 pt-5"
         style="border-top: 1.5px dashed var(--hairline);"
         aria-live="off">
      <p class="font-display text-[13px] font-bold leading-snug italic m-0"
         style="color: var(--text);">
        “<%= pill.text %>”
      </p>
      <p class="font-display text-[10px] font-extrabold tracking-[1px] mt-2 uppercase m-0"
         style="color: var(--text-muted);">
        · <%= pill.source %>
      </p>
    </div>
  </div>
</div>
