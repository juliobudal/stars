<% content_for(:title) { @mission.title } %>

<div class="screen screen-enter">
  <div class="flex items-center gap-3 mb-4 px-1">
    <%= link_to kid_academy_subject_path(@subject),
                "aria-label": "Voltar para #{@subject.name}",
                class: "w-10 h-10 rounded-full flex items-center justify-center anim-press shrink-0",
                style: "background: var(--surface); border: 2px solid var(--hairline); box-shadow: 0 3px 0 rgba(0,0,0,0.06);" do %>
      <%= render Ui::Icon::Component.new(:chevron_left, size: 18, color: "var(--text)") %>
    <% end %>
    <div class="flex-1 min-w-0">
      <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase truncate"
           style="color: var(--c-sky-dark);"><%= @subject.name %></div>
      <h1 class="font-display text-[18px] font-extrabold leading-tight m-0 truncate"
          style="color: var(--text);"><%= @mission.title %></h1>
    </div>
  </div>

  <div class="rounded-3xl p-6 text-center"
       style="background: var(--surface); border: 2px solid var(--hairline); box-shadow: 0 4px 0 rgba(0,0,0,0.06);">
    <div class="w-20 h-20 rounded-full mx-auto mb-4 flex items-center justify-center"
         style="background: var(--primary-soft);">
      <%= render Ui::Icon::Component.new(:compass, size: 36, color: "var(--c-primary-dark)") %>
    </div>
    <% if @reason == :lens_generation_failed %>
      <div class="font-display text-[11px] font-extrabold tracking-[1.5px] uppercase mb-2"
           style="color: var(--c-star);">VOLTA EM INSTANTES</div>
      <h2 class="font-display text-[20px] font-extrabold leading-tight m-0 mb-3"
          style="color: var(--text);">A Academia tá pensando.</h2>
      <p class="font-display text-[14px] leading-snug mb-5" style="color: var(--text-muted);">
        Tô preparando uma descoberta nova pra você. Volta daqui a pouco —
        em segundos a próxima ideia tá pronta.
      </p>
    <% else %>
      <div class="font-display text-[11px] font-extrabold tracking-[1.5px] uppercase mb-2"
           style="color: var(--c-star);">EM CONSTRUÇÃO · V5</div>
      <h2 class="font-display text-[20px] font-extrabold leading-tight m-0 mb-3"
          style="color: var(--text);">Em breve, esta missão muda de forma.</h2>
      <p class="font-display text-[14px] leading-snug mb-5" style="color: var(--text-muted);">
        A Academia está aprendendo a te mostrar o mesmo padrão por vários ângulos —
        uma história, um experimento, uma comparação, uma analogia. Falta pouco.
      </p>
    <% end %>
    <div class="flex gap-2 justify-center">
      <%= link_to "Voltar para #{@subject.name}",
                  kid_academy_subject_path(@subject),
                  class: "inline-block px-5 py-2.5 rounded-full font-display font-extrabold text-[14px] anim-press",
                  style: "background: var(--surface); color: var(--text); border: 2px solid var(--hairline); box-shadow: 0 3px 0 rgba(0,0,0,0.06);" %>
      <%= link_to "Tentar de novo",
                  kid_academy_subject_mission_path(@subject, @mission),
                  class: "inline-block px-5 py-2.5 rounded-full font-display font-extrabold text-[14px] anim-press",
                  style: "background: var(--c-primary); color: white; box-shadow: 0 4px 0 var(--primary-2);" %>
    </div>
  </div>
</div>
