<%# locals: concept, payload, color_var, review_mode: false, signal_payload: {}
     Handles scientific + statistical lenses. %>
<%
  review_mode = local_assigns.fetch(:review_mode, false)
  signal_payload = local_assigns.fetch(:signal_payload, {}) || {}
%>
<% if payload["predict_prompt"].present? %>
  <%# Statistical: slider + reveal %>
  <%
    pmin = payload["predict_min"].to_i
    pmax = [payload["predict_max"].to_i, pmin + 1].max
    unit = payload["predict_unit"]
    reveal_value = payload["reveal_value"]
    kid_value = signal_payload["predict_value"].presence
    initial = kid_value ? kid_value.to_i.clamp(pmin, pmax) : ((pmin + pmax) / 2.0).round
  %>
  <div class="lens-card p-5">
    <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-2"
         style="color: <%= color_var %>;">
      <%= review_mode ? "Sua aposta (registrada)" : "Sua aposta" %>
    </div>
    <p class="font-display text-[16px] font-extrabold leading-snug m-0 mb-5" style="color: var(--text);">
      <%= payload["predict_prompt"] %>
    </p>

    <div class="flex items-baseline justify-between mb-2">
      <span class="font-display text-[11px] font-extrabold tracking-wide uppercase" style="color: var(--text-muted);">
        <%= pmin %><%= unit %>
      </span>
      <span class="font-display text-[28px] font-extrabold tabular-nums" style="color: <%= color_var %>;"
            data-lens-stage-target="predictDisplay">
        <%= initial %><span class="text-[14px] ml-1" style="color: var(--text-muted);"><%= unit %></span>
      </span>
      <span class="font-display text-[11px] font-extrabold tracking-wide uppercase" style="color: var(--text-muted);">
        <%= pmax %><%= unit %>
      </span>
    </div>

    <input type="range"
           class="lens-predict-slider"
           min="<%= pmin %>" max="<%= pmax %>" value="<%= initial %>" step="1"
           <% unless review_mode %>
           data-lens-stage-target="predictSlider"
           data-lens-stage-unit-param="<%= unit %>"
           data-action="input->lens-stage#updatePredictDisplay"
           <% end %>
           <%= "disabled" if review_mode %>
           style="--lens-color: <%= color_var %>;"
           aria-label="<%= payload["predict_prompt"] %>">

    <% unless review_mode %>
      <button type="button"
              class="w-full mt-5 px-4 py-3 rounded-xl font-display font-extrabold text-[14px] anim-press ls-btn-3d border-0"
              style="background: <%= color_var %>; color: white; box-shadow: 0 4px 0 color-mix(in oklab, <%= color_var %> 60%, black);"
              data-action="click->lens-stage#revealPredict"
              data-lens-stage-target="predictRevealBtn"
              data-lens-stage-real-param="<%= reveal_value %>"
              data-lens-stage-rmin-param="<%= pmin %>"
              data-lens-stage-rmax-param="<%= pmax %>">
        Ver resposta
      </button>
    <% end %>

    <div class="lens-reveal mt-4" <% unless review_mode %>data-lens-stage-target="predictReveal" hidden<% end %>>
      <div class="rounded-xl p-4"
           style="background: color-mix(in oklab, <%= color_var %> 14%, var(--surface)); border: 2px solid <%= color_var %>;">
        <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-1"
             style="color: <%= color_var %>;">
          Resposta real
        </div>
        <div class="font-display text-[28px] font-extrabold tabular-nums" style="color: var(--text);">
          <%= reveal_value %><span class="text-[14px] ml-1" style="color: var(--text-muted);"><%= unit %></span>
        </div>
        <% if payload["interpretation"].present? %>
          <p class="font-display text-[13px] leading-snug mt-2 m-0" style="color: var(--text);">
            <%= payload["interpretation"] %>
          </p>
        <% end %>
        <% if payload["reveal_source"].present? %>
          <p class="font-display text-[11px] leading-snug mt-2 m-0" style="color: var(--text-muted);">
            Fonte: <%= payload["reveal_source"] %>
          </p>
        <% end %>
      </div>

      <%# Reaction tile · populated by JS on live reveal, by Ruby in review mode %>
      <div data-lens-stage-target="predictReaction"
           class="anim-pop-in"
           <%= 'hidden' unless review_mode && kid_value.present? %>>
        <% if review_mode && kid_value.present? && reveal_value.present? %>
          <% reaction = ::Academy::Lens::PredictReaction.call(
               guess: kid_value.to_f, real: reveal_value.to_f,
               range_min: pmin, range_max: pmax
             ) %>
          <div class="rounded-xl px-3 py-3 mt-3 flex items-start gap-3"
               style="background: var(--surface-2); border: 2px solid var(--hairline);">
            <span style="font-size: 28px; line-height: 1;" aria-hidden="true"><%= reaction.emoji %></span>
            <div class="flex-1 min-w-0">
              <div class="font-display text-[14px] font-extrabold leading-tight" style="color: var(--text);">
                <%= reaction.headline %>
              </div>
              <p class="font-display text-[12px] leading-snug mt-1 m-0" style="color: var(--text-muted);">
                <%= reaction.detail %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% else %>
  <%# Scientific: headline + mechanism_steps + illustration_hint + micro_check %>
  <div class="lens-card p-5">
    <% if payload["headline"].present? %>
      <h2 class="font-display text-[20px] font-extrabold leading-snug m-0 mb-3" style="color: var(--text);">
        <%= payload["headline"] %>
      </h2>
    <% end %>
    <% if payload["illustration_url"].present? %>
      <%= image_tag payload["illustration_url"],
                    alt: payload["headline"].to_s,
                    loading: "lazy",
                    class: "w-full aspect-square object-cover rounded-xl mb-4",
                    style: "border: 2px solid var(--hairline); box-shadow: 0 4px 0 var(--hairline);" %>
    <% elsif payload["illustration_hint"].present? %>
      <p class="font-display text-[13px] leading-snug italic m-0 mb-4" style="color: var(--text-muted);">
        <%= payload["illustration_hint"] %>
      </p>
    <% end %>

    <% if Array(payload["mechanism_steps"]).any? %>
      <ol class="flex flex-col gap-2 m-0 p-0 list-none">
        <% Array(payload["mechanism_steps"]).each_with_index do |step, idx| %>
          <li class="flex items-start gap-3 rounded-xl p-3"
              style="background: var(--surface-2); border: 2px solid var(--hairline);">
            <span class="shrink-0 w-7 h-7 rounded-full flex items-center justify-center font-display text-[13px] font-extrabold"
                  style="background: <%= color_var %>; color: white;">
              <%= idx + 1 %>
            </span>
            <span class="font-display text-[14px] font-bold leading-snug" style="color: var(--text);">
              <%= step %>
            </span>
          </li>
        <% end %>
      </ol>
    <% end %>
  </div>

  <% if payload["micro_check"].is_a?(Hash) %>
    <%= render "kid/academy/missions/lens_micro_check",
               micro_check: payload["micro_check"], color_var: color_var,
               review_mode: review_mode, signal_payload: signal_payload,
               lens_type: local_assigns[:lens_type] %>
  <% end %>
<% end %>
