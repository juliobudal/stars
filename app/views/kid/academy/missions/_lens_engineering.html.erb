<%# locals: concept, payload, color_var, review_mode: false, signal_payload: {} %>
<%
  constraints = Array(payload["constraints"])
  must_pick = payload["must_pick"].to_i.nonzero? || 3
  outcomes = payload["outcomes"].is_a?(Hash) ? payload["outcomes"] : {}
  review_mode = local_assigns.fetch(:review_mode, false)
  signal_payload = local_assigns.fetch(:signal_payload, {}) || {}
  kid_choices = Array(signal_payload["choices"]).map(&:to_s)
%>
<div class="lens-card p-5">
  <% if payload["challenge"].present? %>
    <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-2"
         style="color: <%= color_var %>;">
      Desafio
    </div>
    <p class="font-display text-[15px] font-extrabold leading-snug m-0 mb-4" style="color: var(--text);">
      <%= payload["challenge"] %>
    </p>
  <% end %>

  <div class="rounded-2xl px-3 py-2 mb-3 inline-flex items-center gap-2"
       style="background: var(--primary-soft); color: var(--primary-2);">
    <span class="font-display text-[12px] font-extrabold tracking-wide uppercase">
      Escolha
    </span>
    <span class="font-display text-[16px] font-extrabold tabular-nums"
          data-lens-stage-target="engineeringCount">0</span>
    <span class="font-display text-[12px] font-extrabold tracking-wide" style="opacity: 0.7;">
      / <%= must_pick %>
    </span>
  </div>

  <div class="flex flex-col gap-2"
       data-lens-stage-target="engineeringList"
       data-lens-stage-must-pick-value="<%= must_pick %>"
       data-lens-stage-outcomes-value="<%= outcomes.to_json %>">
    <% constraints.each do |c| %>
      <% picked = review_mode && kid_choices.include?(c["id"].to_s) %>
      <button type="button"
              class="lens-engineering-chip <%= 'lens-engineering-chip--picked' if picked %>"
              <% unless review_mode %>
              data-action="click->lens-stage#pickConstraint"
              data-lens-stage-id-param="<%= c["id"] %>"
              <% end %>
              <%= 'disabled' if review_mode %>
              style="<%= 'background: color-mix(in oklab, ' + color_var + ' 16%, var(--surface)); border-color: ' + color_var + ';' if picked %>">
        <div class="flex items-baseline justify-between gap-2">
          <span class="font-display text-[14px] font-extrabold leading-tight" style="color: var(--text);">
            <%= '✓ ' if picked %><%= c["label"] %>
          </span>
          <span class="font-display text-[10px] font-extrabold tracking-[1px] uppercase shrink-0"
                style="color: var(--text-muted);">
            <%= c["cost"] %>
          </span>
        </div>
      </button>
    <% end %>
  </div>

  <% unless review_mode %>
    <div class="lens-reveal mt-4" data-lens-stage-target="engineeringReveal" hidden>
      <div class="rounded-2xl p-4"
           style="background: color-mix(in oklab, <%= color_var %> 12%, var(--surface)); border: 2px solid <%= color_var %>;">
        <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-1"
             style="color: <%= color_var %>;">
          Consequência
        </div>
        <p class="font-display text-[13px] leading-snug m-0"
           style="color: var(--text);"
           data-lens-stage-target="engineeringRevealText"></p>
      </div>
    </div>
  <% else %>
    <% kid_outcome_key = kid_choices.sort.join('+') %>
    <% kid_outcome = outcomes[kid_outcome_key] %>
    <% if kid_outcome.present? %>
      <div class="lens-reveal mt-4">
        <div class="rounded-2xl p-4"
             style="background: color-mix(in oklab, <%= color_var %> 12%, var(--surface)); border: 2px solid <%= color_var %>;">
          <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-1"
               style="color: <%= color_var %>;">
            Sua consequência (<%= kid_choices.join(' + ') %>)
          </div>
          <p class="font-display text-[13px] leading-snug m-0" style="color: var(--text);">
            <%= kid_outcome %>
          </p>
        </div>
      </div>
    <% end %>
    <% if outcomes.any? %>
      <details class="mt-3">
        <summary class="font-display text-[12px] font-extrabold tracking-[0.5px] cursor-pointer" style="color: var(--text-muted);">
          Outras combinações possíveis
        </summary>
        <div class="flex flex-col gap-2 mt-2">
          <% outcomes.reject { |k, _| k == kid_outcome_key }.each do |combo, text| %>
            <div class="rounded-xl p-3" style="background: var(--surface-2); border: 1.5px solid var(--hairline);">
              <div class="font-display text-[10px] font-extrabold tracking-[1px] uppercase mb-1" style="color: var(--text-muted);">
                <%= combo.split('+').join(' + ') %>
              </div>
              <p class="font-display text-[12px] leading-snug m-0" style="color: var(--text);">
                <%= text %>
              </p>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  <% end %>
</div>
