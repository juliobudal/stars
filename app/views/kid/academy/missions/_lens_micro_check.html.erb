<%# locals: micro_check, color_var, review_mode: false, signal_payload: {}, lens_type: nil %>
<%
  question = micro_check["question"]
  options = Array(micro_check["options"])
  correct_index = micro_check["correct_index"].to_i
  rationale = micro_check["rationale"]
  review_mode = local_assigns.fetch(:review_mode, false)
  signal_payload = local_assigns.fetch(:signal_payload, {}) || {}
  kid_correct = signal_payload["micro_check_correct"]
  kid_correct = nil if kid_correct.nil? || kid_correct == ""

  # Mascot reactions (QW5) · deterministic owl one-liner based on the
  # micro_check text + lens_type. Server pre-renders both buckets; JS in
  # lens_stage_controller unhides whichever matches the kid's answer.
  mascot_lens_type = (local_assigns[:lens_type] || "default").to_s
  mascot_seed = "#{mascot_lens_type}|#{question}"
  mascot_correct = ::Academy::Lens::MascotReaction.for(
    lens_type: mascot_lens_type, correct: true, seed: mascot_seed
  )
  mascot_wrong = ::Academy::Lens::MascotReaction.for(
    lens_type: mascot_lens_type, correct: false, seed: mascot_seed
  )
%>
<% if question.present? && options.any? %>
  <div class="lens-card p-5 mt-3" data-lens-stage-target="microCheckBlock">
    <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-2"
         style="color: <%= color_var %>;">
      Pergunta rápida
    </div>
    <p class="font-display text-[15px] font-extrabold leading-snug m-0 mb-4" style="color: var(--text);">
      <%= question %>
    </p>

    <% if review_mode && !kid_correct.nil? %>
      <div class="rounded-xl px-3 py-2 mb-3 inline-flex items-center gap-2"
           style="background: <%= kid_correct.to_s == 'true' ? 'color-mix(in oklab, var(--success) 22%, var(--surface))' : 'color-mix(in oklab, var(--danger) 22%, var(--surface))' %>;
                  border: 1.5px solid <%= kid_correct.to_s == 'true' ? 'var(--success)' : 'var(--danger)' %>;">
        <span aria-hidden="true"><%= kid_correct.to_s == 'true' ? '✓' : '✗' %></span>
        <span class="font-display text-[12px] font-extrabold tracking-[0.5px]" style="color: var(--text);">
          <%= kid_correct.to_s == 'true' ? 'Você acertou' : 'Você errou. A resposta era a destacada abaixo' %>
        </span>
      </div>
    <% end %>

    <div class="flex flex-col gap-2">
      <% options.each_with_index do |opt, idx| %>
        <% is_correct = (idx == correct_index) %>
        <button type="button"
                class="lens-option-btn <%= 'lens-option-btn--correct' if review_mode && is_correct %>"
                <% unless review_mode %>
                data-action="click->lens-stage#recordMicroCheck"
                data-lens-stage-correct-param="<%= is_correct %>"
                data-lens-stage-index-param="<%= idx %>"
                <% end %>
                <%= 'disabled' if review_mode %>
                style="<%= 'background: color-mix(in oklab, var(--success) 18%, var(--surface)); border-color: var(--success);' if review_mode && is_correct %>">
          <span class="lens-option-btn__bullet"><%= ("A".ord + idx).chr %></span>
          <span class="lens-option-btn__label"><%= opt %></span>
        </button>
      <% end %>
    </div>

    <% if rationale.present? %>
      <div class="lens-reveal mt-3" <% unless review_mode %>data-lens-stage-target="microCheckRationale" hidden<% end %>>
        <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase mb-1"
             style="color: var(--text-muted);">
          Por quê
        </div>
        <p class="font-display text-[13px] leading-snug m-0" style="color: var(--text);">
          <%= rationale %>
        </p>
      </div>
    <% end %>

    <%# Owl mascot reactions (QW5) · JS unhides one based on the answer %>
    <% if mascot_correct %>
      <div data-lens-stage-target="mascotReactionCorrect"
           class="mt-3 flex items-start gap-2.5 px-3 py-2.5 rounded-xl anim-pop-in"
           <%= (review_mode && kid_correct.to_s == "true") ? "" : "hidden" %>
           style="background: color-mix(in oklab, var(--primary) 12%, var(--surface)); border: 2px solid color-mix(in oklab, var(--primary) 45%, var(--hairline));">
        <span aria-hidden="true" style="font-size: 22px; line-height: 1;"><%= mascot_correct.emoji %></span>
        <span class="font-display text-[13px] font-bold leading-snug" style="color: var(--text);">
          <%= mascot_correct.text %>
        </span>
      </div>
    <% end %>

    <% if mascot_wrong %>
      <div data-lens-stage-target="mascotReactionWrong"
           class="mt-3 flex items-start gap-2.5 px-3 py-2.5 rounded-xl anim-pop-in"
           <%= (review_mode && kid_correct.to_s == "false") ? "" : "hidden" %>
           style="background: color-mix(in oklab, var(--danger) 12%, var(--surface)); border: 2px solid color-mix(in oklab, var(--danger) 45%, var(--hairline));">
        <span aria-hidden="true" style="font-size: 22px; line-height: 1;"><%= mascot_wrong.emoji %></span>
        <span class="font-display text-[13px] font-bold leading-snug" style="color: var(--text);">
          <%= mascot_wrong.text %>
        </span>
      </div>
    <% end %>
  </div>
<% end %>
