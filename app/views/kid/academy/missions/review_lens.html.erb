<% content_for(:title) { "Revisão · #{@mission.title}" } %>
<%
  visit = @entry.visit
  cache = @entry.lens_cache
  lens_type = visit.lens_type
  action_label = ::Academy::Lens::Catalog.kid_action_label(lens_type.to_sym)
  color_var = "var(--academy-pokedex-#{@mission.concept.pokedex_color_key.presence || 'cognitivo'})"

  primitive = case lens_type.to_sym
              when :scientific, :statistical    then "predict"
              when :narrative                   then "narrative"
              when :ethical                     then "compare"
              when :analogy_bridge, :historical then "pattern_hunt"
              when :first_person                then "embodied"
              when :engineering                 then "engineering"
              end

  # Find sibling visits for prev/next nav
  sibling_ids = ::Academy::LearnerLensVisit
                  .where(mission_progress_id: @progress.id)
                  .where.not(closed_at: nil)
                  .order(:ordering_position)
                  .pluck(:id)
  idx = sibling_ids.index(visit.id)
  prev_id = idx && idx > 0 ? sibling_ids[idx - 1] : nil
  next_id = idx && idx < sibling_ids.size - 1 ? sibling_ids[idx + 1] : nil
%>

<div class="screen screen-enter lens-review-mode" data-controller="lens-review">
  <%# ── Header ────────────────────────────────────────────────── %>
  <header class="sticky top-0 z-30 -mx-4 px-4 pt-3 pb-3 mb-4"
          style="background: linear-gradient(to bottom, var(--surface) 70%, rgba(255,255,255,0));">
    <div class="flex items-center gap-3">
      <%= link_to kid_academy_subject_mission_path(@subject, @mission),
                  "aria-label": "Voltar para revisão",
                  class: "w-10 h-10 rounded-full flex items-center justify-center anim-press shrink-0",
                  style: "background: var(--surface); border: 2px solid var(--hairline); box-shadow: 0 3px 0 rgba(0,0,0,0.06);" do %>
        <%= render Ui::Icon::Component.new(:chevron_left, size: 18, color: "var(--text)") %>
      <% end %>

      <div class="flex-1 min-w-0">
        <div class="font-display text-[10px] font-extrabold tracking-[1.5px] uppercase truncate"
             style="color: <%= color_var %>;">
          REVISÃO · LIÇÃO <%= (idx || 0) + 1 %> / <%= sibling_ids.size %>
        </div>
        <h1 class="font-display text-[17px] font-extrabold leading-tight m-0 truncate" style="color: var(--text);">
          <%= @mission.title %>
        </h1>
      </div>
    </div>
  </header>

  <%# ── Read-only banner ──────────────────────────────────────── %>
  <div class="rounded-xl px-4 py-2.5 mb-4 flex items-center gap-2"
       style="background: color-mix(in oklab, <%= color_var %> 12%, var(--surface)); border: 1.5px solid color-mix(in oklab, <%= color_var %> 45%, var(--hairline));">
    <span aria-hidden="true">👁️</span>
    <span class="font-display text-[12px] font-extrabold tracking-[0.5px]" style="color: var(--text);">
      Modo revisão: você já completou esta lição
    </span>
  </div>

  <%# ── Body header ───────────────────────────────────────────── %>
  <div class="flex items-center gap-3 mb-4">
    <div class="w-12 h-12 rounded-xl flex items-center justify-center text-[22px]"
         style="background: color-mix(in oklab, <%= color_var %> 18%, var(--surface)); border: 2px solid <%= color_var %>;">
      <%= action_label[:emoji] %>
    </div>
    <div class="flex-1 min-w-0">
      <h2 class="font-display text-[16px] font-extrabold leading-tight m-0" style="color: var(--text);">
        <%= action_label[:action] %>
      </h2>
      <div class="font-display text-[11px] font-extrabold tracking-[0.5px]" style="color: var(--text-muted);">
        sobre <%= @mission.concept.name %>
      </div>
    </div>
  </div>

  <%# ── Lens body (read-only) ─────────────────────────────────── %>
  <div class="lens-stage" data-controller="lens-stage" data-lens-stage-lens-type-value="<%= lens_type %>">
    <% if cache&.payload.present? && primitive %>
      <% interpolated_payload = ::Academy::Lens::InterpolatePayload.render(payload: cache.payload, learner: current_learner) %>
      <%= render "kid/academy/missions/lens_#{primitive}",
                 concept: @mission.concept, payload: interpolated_payload, color_var: color_var,
                 review_mode: true, signal_payload: (visit.signal_payload || {}),
                 lens_type: lens_type %>
    <% else %>
      <div class="lens-card p-5">
        <p class="font-display text-[14px] leading-snug m-0" style="color: var(--text-muted);">
          Conteúdo desta lição não está mais disponível.
        </p>
      </div>
    <% end %>
  </div>

  <%# ── Prev / Next nav ───────────────────────────────────────── %>
  <div class="flex gap-2 mt-5">
    <% if prev_id %>
      <%= link_to "← Anterior",
                  kid_academy_subject_mission_review_visit_path(@subject, @mission, prev_id),
                  class: "flex-1 text-center px-4 py-3 rounded-xl font-display font-extrabold text-[14px] anim-press",
                  style: "background: var(--surface); border: 2px solid var(--hairline); box-shadow: 0 3px 0 var(--hairline); color: var(--text); text-decoration: none;" %>
    <% end %>
    <% if next_id %>
      <%= link_to "Próxima →",
                  kid_academy_subject_mission_review_visit_path(@subject, @mission, next_id),
                  class: "flex-1 text-center px-4 py-3 rounded-xl font-display font-extrabold text-[14px] anim-press",
                  style: "background: var(--primary); color: white; box-shadow: 0 4px 0 var(--primary-2); border: 0; text-decoration: none;" %>
    <% else %>
      <%= link_to "✓ Voltar à revisão",
                  kid_academy_subject_mission_path(@subject, @mission),
                  class: "flex-1 text-center px-4 py-3 rounded-xl font-display font-extrabold text-[14px] anim-press",
                  style: "background: var(--primary); color: white; box-shadow: 0 4px 0 var(--primary-2); border: 0; text-decoration: none;" %>
    <% end %>
  </div>
</div>
