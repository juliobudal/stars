<%# locals: (tier:, payload:) %>
<% ts = (Time.current.to_f * 1000).to_i %>
<div
  id="celebration_<%= ts %>"
  data-fx-event="celebrate"
  data-fx-tier="<%= tier %>"
  data-fx-payload="<%= payload.to_json %>"
  data-fx-dismiss-after="<%= tier.to_sym == :big ? 2700 : 3200 %>"
  class="anim-pop-in"
>
  <% if tier.to_sym == :big %>
    <%= render Ui::Modal::Component.new(title: payload[:message] || "Conquista!", variant: :celebration, id: "celebration_modal_#{ts}") do %>
      <div class="text-center py-4">
        <% if payload[:points] %>
          <p class="text-3xl font-display font-extrabold text-warning inline-flex items-center gap-2 justify-center">
            +<%= payload[:points] %>
            <%= render Ui::Icon::Component.new(:star, size: 26, color: "var(--star)") %>
          </p>
        <% end %>
        <% if payload[:reward_title] %>
          <p class="mt-2 text-lg font-bold"><%= payload[:reward_title] %></p>
        <% end %>
        <% if payload[:days] %>
          <p class="mt-2 text-lg font-bold inline-flex items-center gap-1.5 justify-center">
            <%= payload[:days] %> dias seguidos!
            <%= render Ui::Icon::Component.new("flame", size: 18, color: "var(--c-streak)") %>
          </p>
        <% end %>
        <% if payload[:threshold] %>
          <p class="mt-2 text-lg font-bold inline-flex items-center gap-1.5 justify-center">
            Você passou de <%= payload[:threshold] %>
            <%= render Ui::Icon::Component.new(:star, size: 16, color: "var(--star)") %>
            !
          </p>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <%= render Ui::Toast::Component.new(message: payload[:message] || "✨", variant: :info) %>
  <% end %>
</div>
