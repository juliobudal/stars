<% if affordable_rewards.any? %>
  <div class="flex items-center gap-2 mb-4 px-1">
    <div class="grid place-items-center shrink-0"
         style="width: 24px; height: 24px; background: var(--primary); border-radius: 8px; box-shadow: 0 2px 0 var(--primary-2);">
      <%= render Ui::Icon::Component.new("check", size: 14, color: "white") %>
    </div>
    <h2 class="font-display text-[15px] font-extrabold uppercase tracking-[0.5px] m-0" style="color: var(--primary-2);">Posso resgatar agora!</h2>
  </div>

  <div class="grid grid-cols-2 gap-5 mb-7">
    <% affordable_rewards.each_with_index do |reward, i| %>
      <% icon_name = (reward.respond_to?(:icon) && reward.icon.presence) || reward.category&.icon.presence || "gift" %>
      <% pal = Ui::Tokens.color_palette_entry(reward.category&.color || "lilac") %>
      <div data-filter-tabs-target="item" data-panels="all <%= reward.category_id %>" data-controller="ui-modal">
        <button type="button"
                class="ls-card-3d w-full text-left border-none p-4 flex flex-col gap-3 cursor-pointer relative overflow-hidden"
                style="background: var(--surface); border: 3px solid var(--primary); border-radius: 16px; box-shadow: 0 4px 0 var(--primary-2); animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= [i, 5].min * 0.04 %>s both;"
                data-action="click->ui-modal#open"
                data-ui-modal-id-param="modal_<%= dom_id(reward) %>">
          <div class="absolute top-2 right-2 font-display font-extrabold uppercase tracking-[0.5px]"
               style="background: var(--primary); color: white; font-size: 9px; padding: 3px 7px; border-radius: 6px; box-shadow: 0 2px 0 var(--primary-2);">
            ✓ Pode
          </div>

          <div class="grid place-items-center w-full"
               style="aspect-ratio: 1.4; background: <%= pal[:soft_var] %>; border: 2px solid <%= pal[:fg_var] %>; border-radius: 12px;">
            <%= render Ui::Icon::Component.new(icon_name, size: 48, color: pal[:fg_var]) %>
          </div>

          <div class="font-display text-[14px] font-extrabold leading-tight" style="color: var(--text);">
            <%= reward.title %>
          </div>

          <div class="ls-btn-3d w-full font-display font-extrabold uppercase tracking-[0.5px] inline-flex items-center justify-center gap-1.5"
               style="background: var(--primary); color: white; border: 2px solid var(--primary); padding: 10px; border-radius: 12px; font-size: 12px; box-shadow: 0 4px 0 var(--primary-2);">
            Trocar por
            <span class="inline-flex items-center gap-1">
              <%= render Ui::Icon::Component.new(:star, size: 13, color: "white") %>
              <%= reward.cost %>
            </span>
          </div>
        </button>
      </div>
    <% end %>
  </div>
<% end %>
