<% if redeemed_rewards.any? %>
  <div class="mt-6 mb-5 z-2 relative">
    <div class="font-display text-[18px] font-extrabold mb-3" style="color: var(--text);">Meus prêmios</div>
    <div class="flex flex-col gap-4">
      <% redeemed_rewards.each do |redemption| %>
        <%= render Ui::RedemptionRow::Component.new(redemption: redemption) %>
      <% end %>
    </div>
  </div>
<% end %>
