<%
  tints = ["var(--c-sky-soft)", "var(--c-rose-soft)", "var(--c-mint-soft)", "var(--c-amber-soft)", "var(--c-lilac-soft)"]
  featured = @featured || @rewards&.first
%>
<div class="screen screen-enter-right with-nav" data-controller="celebration">
  <%= render Ui::BgShapes::Component.new(variant: "warm") %>
  <%= render Ui::Celebration::Component.new %>

  <%= render Ui::TopBar::Component.new(
    title: "Lojinha",
    subtitle: "Troque suas estrelinhas por recompensas",
    back_url: kid_root_path
  ) do |bar| %>
    <% bar.with_right_slot do %>
      <%= render Ui::BalanceChip::Component.new(value: current_profile.points, id: "profile_points_#{current_profile.id}") %>
    <% end %>
  <% end %>

  <% if featured %>
    <%= render Ui::FeaturedRewardCard::Component.new(
      reward: featured,
      balance: current_profile.points,
      modal_id: "modal_#{dom_id(featured)}"
    ) %>
  <% end %>

  <%# Section Header %>
  <div class="row-between items-baseline mb-5 mt-5 z-2 relative">
    <div class="h-display text-[18px] text-foreground">O que você quer hoje?</div>
    <span class="text-[12px] font-bold text-muted-foreground"><%= @rewards.size %> prêmios</span>
  </div>

  <div class="mb-4 z-2 relative">
    <%= render Ui::CategoryTabs::Component.new(
      items: [
        { id: "tudo",         label: "Tudo" },
        { id: "telinha",      label: "Telinha" },
        { id: "docinhos",     label: "Docinhos" },
        { id: "passeios",     label: "Passeios" },
        { id: "brinquedos",   label: "Brinquedos" },
        { id: "experiencias", label: "Experiências" }
      ],
      active: "tudo"
    ) %>

    <%# "Tudo" panel — renders the full grid %>
    <div id="panel-tudo" class="col mt-4">
      <% if @rewards.any? %>
        <div class="rewards-grid grid gap-3">
          <% @rewards.each_with_index do |reward, i| %>
            <%= render Ui::RewardTile::Component.new(
              reward: reward,
              balance: current_profile.points,
              tint: tints[i % tints.length],
              index: i,
              modal_id: "modal_#{dom_id(reward)}"
            ) %>
          <% end %>
        </div>
      <% else %>
        <%= render Ui::Empty::Component.new(
          icon: "bag",
          title: "A lojinha está vazia",
          subtitle: "Peça para um responsável adicionar recompensas!",
          color: "rose"
        ) %>
      <% end %>
    </div>

    <%# Category stub panels — filtering not yet available %>
    <% %w[telinha docinhos passeios brinquedos experiencias].each do |tab_id| %>
      <div id="panel-<%= tab_id %>" class="hidden"><!-- filtro não disponível ainda --></div>
    <% end %>
  </div>

  <% if @redeemed_rewards.any? %>
    <div class="mt-8 mb-6 z-2 relative">
      <div class="h-display text-[20px] text-foreground mb-3">Meus prêmios</div>
      <div class="col gap-2.5">
        <% @redeemed_rewards.each do |redemption| %>
          <%= render Ui::RedemptionRow::Component.new(redemption: redemption) %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Reward Modals (one per reward) %>
  <% @rewards.each do |reward| %>
    <% reward_icon = reward.respond_to?(:icon) ? reward.icon.presence : nil %>
    <%= render Ui::Modal::Component.new(id: "modal_#{dom_id(reward)}", title: "Resgatar Recompensa") do %>
      <div class="center col text-center gap-3.5">
        <%= render Ui::LogoMark::Component.new(size: 48) %>
        <div class="flex-center w-[100px] h-[100px] rounded-lg bg-lilac-soft mx-auto">
          <%= render Ui::Icon::Component.new(reward_icon || "gift", size: 56, color: "var(--c-violet-dark)") %>
        </div>
        <h3 class="h-display text-[26px]"><%= reward.title %></h3>
        <div class="row gap-2.5 justify-center">
          <%= render Ui::Badge::Component.new(variant: "star", class: "text-[16px] py-2 px-3.5") do %>
            <%= render Ui::Icon::Component.new("star", size: 16, color: "var(--star-2)") %> <%= reward.cost %>
          <% end %>
        </div>

        <div class="card p-3.5 bg-surface-2 border-none shadow-none w-full">
          <div class="row justify-between font-display font-extrabold">
            <span>Saldo atual</span>
            <span><%= current_profile.points %> ⭐</span>
          </div>
          <div class="row justify-between text-danger font-display font-extrabold mt-1">
            <span>−</span>
            <span><%= reward.cost %> ⭐</span>
          </div>
          <div class="h-[2px] bg-[rgba(26,42,74,0.1)] my-2"></div>
          <div class="row justify-between text-primary font-display font-extrabold text-[18px]">
            <span>Depois</span>
            <span><%= [current_profile.points - reward.cost, 0].max %> ⭐</span>
          </div>
        </div>

        <div class="row gap-3 mt-1.5 w-full justify-center">
          <%= render Ui::Btn::Component.new(variant: "secondary", data: { action: "click->modal#close" }) do %>Cancelar<% end %>
          <%= button_to redeem_kid_reward_path(reward), method: :post, class: "btn btn-primary btn-lg" do %>
            <%= render Ui::Icon::Component.new("gift", size: 20) %> Resgatar!
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
