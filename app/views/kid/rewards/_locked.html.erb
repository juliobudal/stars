<% if locked_rewards.any? %>
  <div class="flex items-center gap-2 mb-4 px-1">
    <div class="grid place-items-center shrink-0"
         style="width: 24px; height: 24px; background: var(--text-soft); border-radius: 8px; box-shadow: 0 2px 0 var(--text-muted);">
      <%= render Ui::Icon::Component.new("lock", size: 13, color: "white") %>
    </div>
    <h2 class="font-display text-[15px] font-extrabold uppercase tracking-[0.5px] m-0" style="color: var(--text-muted);">Continua juntando!</h2>
  </div>

  <div class="grid grid-cols-2 gap-5 mb-7">
    <% locked_rewards.each_with_index do |reward, i| %>
      <% icon_name = (reward.respond_to?(:icon) && reward.icon.presence) || reward.category&.icon.presence || "gift" %>
      <% pal = Ui::Tokens.color_palette_entry(reward.category&.color || "lilac") %>
      <% pct = reward.cost.zero? ? 0 : [(balance.to_f / reward.cost * 100).round, 100].min %>
      <% remaining = reward.cost - balance %>
      <div id="<%= dom_id(reward) %>" class="relative" data-filter-tabs-target="item" data-panels="all <%= reward.category_id %>" data-controller="ui-modal">
        <% pinned_here = current_profile.wishlist_reward_id == reward.id %>
        <% if pinned_here %>
          <%= button_to kid_wishlist_path,
                        method: :delete,
                        form: { class: "absolute top-2 right-2 z-10", data: { turbo: true } },
                        class: "ls-btn-3d inline-flex items-center gap-1 px-2 py-1 rounded-[10px] text-[11px] font-extrabold",
                        style: "background: var(--star-soft); color: var(--c-amber-dark); box-shadow: 0 3px 0 var(--star-2);",
                        aria: { label: "Remover meta" } do %>
            <%= render Ui::Icon::Component.new(:star, size: 12, color: "var(--c-amber-dark)") %>
            Meta
          <% end %>
        <% else %>
          <%= button_to kid_wishlist_path,
                        method: :post,
                        params: { reward_id: reward.id },
                        form: { class: "absolute top-2 right-2 z-10", data: { turbo: true } },
                        class: "ls-btn-3d inline-flex items-center gap-1 px-2 py-1 rounded-[10px] text-[11px] font-bold",
                        style: "background: var(--surface); color: var(--text-muted); border: 2px solid var(--hairline); box-shadow: 0 3px 0 var(--hairline);",
                        aria: { label: "Definir como meta" } do %>
            <%= render Ui::Icon::Component.new(:star, size: 12, color: "var(--text-muted)") %>
            Meta
          <% end %>
        <% end %>
        <button type="button"
                class="ls-card-3d w-full text-left border-none p-4 flex flex-col gap-3 cursor-pointer relative"
                style="background: var(--surface); border: 2px solid var(--hairline); border-radius: 16px; box-shadow: 0 4px 0 rgba(0,0,0,0.08); animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= [i, 5].min * 0.04 %>s both;"
                data-action="click->ui-modal#open"
                data-ui-modal-id-param="modal_<%= dom_id(reward) %>">
          <div class="grid place-items-center w-full"
               style="aspect-ratio: 1.4; background: <%= pal[:soft_var] %>; border: 2px solid <%= pal[:fg_var] %>; border-radius: 12px; opacity: 0.85;">
            <%= render Ui::Icon::Component.new(icon_name, size: 48, color: pal[:fg_var]) %>
          </div>

          <div class="font-display text-[14px] font-extrabold leading-tight" style="color: var(--text);">
            <%= reward.title %>
          </div>

          <div class="overflow-hidden" style="height: 6px; background: var(--hairline); border-radius: 4px;">
            <div class="h-full" style="width: <%= pct %>%; background: <%= pal[:fg_var] %>; border-radius: 4px;"></div>
          </div>

          <div class="flex items-center justify-between">
            <div class="inline-flex items-center gap-1">
              <%= render Ui::Icon::Component.new(:star, size: 12, color: "var(--star)") %>
              <span class="font-display text-[12px] font-extrabold" style="color: var(--text);">
                <%= balance %><span style="color: var(--text-soft);">/<%= reward.cost %></span>
              </span>
            </div>
            <span class="font-display text-[10px] font-extrabold uppercase tracking-[0.5px]" style="color: <%= pal[:fg_var] %>;">
              Falta <%= remaining %>
            </span>
          </div>
        </button>
      </div>
    <% end %>
  </div>
<% end %>
