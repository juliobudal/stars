<%# Trigger Celebration via fx controller (auto-fires on insert via MutationObserver) %>
<%= turbo_stream.append "body" do %>
  <div data-fx-event="celebrate" data-fx-tier="big" class="hidden"></div>
<% end %>

<%# Close any open redeem modal + animate balance count-down.
    Bumping data-count-up-current-value triggers count_up_controller#currentValueChanged → animateTo. %>
<% new_balance = current_profile.reload.points %>
<%= turbo_stream.append "body" do %>
  <script data-redeem-after>
    (() => {
      document.querySelectorAll(".modal-overlay").forEach(o => o.style.display = "none");
      document.body.style.overflow = "auto";
      const el = document.getElementById("profile_points_<%= current_profile.id %>");
      if (el) el.setAttribute("data-count-up-current-value", "<%= new_balance %>");
      document.querySelectorAll("script[data-redeem-after]").forEach(s => s.remove());
    })();
  </script>
<% end %>

<%# Ritual toast %>
<%= turbo_stream.prepend "flash" do %>
  <%= render Ui::Flash::Component.new.tap { |c| flash.now[:notice] = "🎉 Yay! Avisa o papai pra liberar seu prêmio!" } %>
<% end %>
