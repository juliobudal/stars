<%= turbo_stream.remove @profile_task %>
<%= turbo_stream.remove "modal_#{dom_id(@profile_task)}" %>

<%= turbo_stream.prepend "panel-waiting" do %>
  <%= render Ui::MissionCard::Component.new(mission: @profile_task, status: "waiting", variant: "bubble", id: dom_id(@profile_task)) %>
<% end %>

<%
  remaining_count = current_profile.profile_tasks.pending.count
  awaiting_count = current_profile.profile_tasks.awaiting_approval.count
  completed_today_count = current_profile.profile_tasks.approved.for_today.count
%>
<%= turbo_stream.replace "kid_dashboard_greeting" do %>
  <%= render "kid/dashboard/greeting",
             remaining: remaining_count,
             awaiting_count: awaiting_count,
             completed_today_count: completed_today_count %>
<% end %>

<%# Keep the "X de Y" count + progress strip in sync with the greeting. %>
<%= turbo_stream.replace "kid_today_progress" do %>
  <%= render "kid/dashboard/today_progress",
             done_count: awaiting_count + completed_today_count,
             total: remaining_count + awaiting_count + completed_today_count %>
<% end %>

<%= turbo_stream.update "flash" do %>
  <div
    data-controller="flash"
    data-flash-dismiss-after-value="2200"
    class="pointer-events-auto flex items-center gap-2 px-5 py-3 rounded-full text-white font-extrabold text-[15px] shadow-lift anim-pop-in bg-[var(--primary)]"
  >
    <%= render Ui::Icon::Component.new("sparkle", size: 18, color: "white") %>
    <span>Missão enviada para aprovação! 🚀</span>
  </div>
<% end %>
