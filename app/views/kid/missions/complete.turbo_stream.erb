<%= turbo_stream.remove @profile_task %>
<%= turbo_stream.remove "modal_#{dom_id(@profile_task)}" %>

<%= turbo_stream.prepend "panel-waiting" do %>
  <%= render "kid/dashboard/awaiting_row", task: @profile_task %>
<% end %>

<%= turbo_stream.update "flash" do %>
  <div
    data-controller="flash"
    data-flash-dismiss-after-value="2200"
    class="pointer-events-auto flex items-center gap-2 px-5 py-3 rounded-full text-white font-extrabold text-[15px] shadow-lift animate-popIn bg-[var(--primary)]"
  >
    <%= render Ui::Icon::Component.new("sparkle", size: 18, color: "white") %>
    <span>Missão enviada para aprovação! 🚀</span>
  </div>
<% end %>
