<%= turbo_stream.remove @profile_task %>

<%= turbo_stream.prepend "panel-waiting" do %>
  <div id="<%= dom_id(@profile_task) %>">
    <%= render Ui::MissionCard::Component.new(mission: @profile_task, status: "waiting", variant: "bubble", index: 0) %>
  </div>
<% end %>

<%= turbo_stream.update "flash" do %>
  <div
    data-controller="flash"
    data-flash-dismiss-after-value="2200"
    class="pointer-events-auto flex items-center gap-2 px-5 py-3 rounded-full text-white font-extrabold text-[15px] shadow-lift animate-popIn"
    style="background-color: var(--primary);"
  >
    <%= render Ui::Icon::Component.new("sparkle", size: 18, color: "white") %>
    <span>Missão enviada para aprovação! 🚀</span>
  </div>
<% end %>
