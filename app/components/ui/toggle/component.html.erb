<% if form_bound? %>
  <label class="inline-flex cursor-pointer select-none group" aria-label="<%= aria_label %>">
    <input type="hidden" name="<%= name %>" value="0" form="<%= form %>" />
    <input type="checkbox" name="<%= name %>" value="<%= value %>" <%= "checked" if checked %> <%= "form=\"#{form}\"".html_safe if form.present? %> class="sr-only peer" />
    <span class="<%= peer_track_classes %>">
      <span class="<%= peer_thumb_classes %>"></span>
    </span>
  </label>
<% else %>
  <span class="inline-flex select-none" role="switch" aria-checked="<%= checked %>" aria-label="<%= aria_label %>">
    <span class="<%= track_classes %>">
      <span class="<%= thumb_classes %>"></span>
    </span>
  </span>
<% end %>
