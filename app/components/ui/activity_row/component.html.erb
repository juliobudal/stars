<div class="row" style="gap: 14px; padding: 14px 0; <%= with_divider ? 'border-bottom: 1px solid var(--hairline);' : '' %>">
  <% if kid %>
    <%= render Ui::SmileyAvatar::Component.new(kid: kid, size: 34) %>
  <% end %>
  <div class="fg1" style="min-width: 0;">
    <div class="text-label" style="font-size: 13px;">
      <% if kid %><span><%= kid.name %></span> · <% end %><span><%= description %></span>
    </div>
    <% if timestamp %>
      <div class="text-caption" style="margin-top: 2px;">
        <%= time_ago_in_words(timestamp) %> atrás
      </div>
    <% end %>
  </div>
  <span class="h-display" style="font-size: 15px; color: <%= amount_color %>;">
    <%= amount_sign %><%= amount.abs %> ⭐
  </span>
</div>
