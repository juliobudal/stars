<div class="z-content">
  <div role="tablist" class="flex flex-wrap items-center gap-2 mb-5">
    <% items.each do |item|
         is_active = active?(item[:id])
         pill_active   = "background: var(--primary); color: var(--surface-on-primary); border-color: var(--primary); box-shadow: 0 3px 0 var(--primary-2);"
         pill_inactive = "background: var(--surface); color: var(--text-muted); border-color: var(--hairline); box-shadow: 0 3px 0 var(--hairline);"
         badge_active   = "background: var(--overlay-soft); color: var(--surface-on-primary);"
         badge_inactive = "background: var(--surface-muted); color: var(--text-muted);"
    %>
      <button type="button"
              role="tab"
              class="ls-filter-pill flex items-center gap-2 px-4 py-2 rounded-[12px] font-extrabold text-[12px] uppercase tracking-[0.5px] cursor-pointer border-2"
              style="<%= is_active ? pill_active : pill_inactive %>"
              data-active-style="<%= pill_active %>"
              data-inactive-style="<%= pill_inactive %>"
              data-<%= controller %>-target="tab"
              data-action="<%= "click->#{controller}#show" %>"
              data-<%= controller %>-id-param="<%= item[:id] %>"
              aria-selected="<%= is_active %>">
        <% if item[:icon] %>
          <%= render Ui::Icon::Component.new(item[:icon], size: 14, color: "currentColor") %>
        <% end %>
        <%= item[:label] %>
        <% if item[:count] %>
          <span class="ml-1 px-1.5 py-0.5 rounded-[8px] text-[10px] font-extrabold"
                data-pill-badge
                data-active-style="<%= badge_active %>"
                data-inactive-style="<%= badge_inactive %>"
                style="<%= is_active ? badge_active : badge_inactive %>"><%= item[:count] %></span>
        <% end %>
      </button>
    <% end %>
  </div>
</div>
