<div class="z-content">
  <div role="tablist" class="inline-flex items-center gap-1 p-1 bg-surface-2 rounded-full border border-hairline w-fit mb-5">
    <% items.each do |item| %>
      <button type="button"
              role="tab"
              class="flex items-center gap-2 px-4 py-2 rounded-full font-display font-extrabold text-[13px] transition-all duration-200 cursor-pointer border-none <%= active?(item[:id]) ? 'bg-white text-primary shadow-sm' : 'text-muted-foreground hover:text-foreground' %>"
              data-<%= controller %>-target="tab"
              data-action="<%= "click->#{controller}#show" %>"
              data-<%= controller %>-id-param="<%= item[:id] %>"
              aria-selected="<%= active?(item[:id]) %>">
        <% if item[:icon] %>
          <%= render Ui::Icon::Component.new(item[:icon], size: 14, color: "currentColor") %>
        <% end %>
        <%= item[:label] %>
        <% if item[:count] %>
          <span class="ml-1.5 px-1.5 py-0.5 rounded-full bg-primary-soft text-primary text-[10px] font-bold"><%= item[:count] %></span>
        <% end %>
      </button>
    <% end %>
  </div>
</div>
