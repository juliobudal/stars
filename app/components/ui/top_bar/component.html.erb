<div class="flex items-center justify-between mb-5 flex-shrink-0 <%= @options[:class] %>" style="<%= @options[:style] %>">
  <div class="flex items-center gap-3.5">
    <% if @back_url.present? %>
      <%= render Ui::Btn::Component.new(variant: "secondary", size: "icon", url: @back_url) do %>
        <%= render Ui::Icon::Component.new("back", size: 22) %>
      <% end %>
    <% elsif left_action? %>
      <%= left_action %>
    <% end %>

    <div>
      <% if @title.present? %>
        <% heading_tag = @back_url.present? || left_action? ? :h2 : :h1 %>
        <%= content_tag heading_tag, @title, class: "font-display font-extrabold text-[26px] leading-tight text-foreground overflow-hidden text-ellipsis whitespace-nowrap max-w-[380px]" %>
      <% end %>
      <% if @subtitle.present? %>
        <div class="text-muted-foreground font-semibold text-[14px] mt-0.5"><%= @subtitle %></div>
      <% end %>
    </div>
  </div>
  <% if right_slot? %>
    <div><%= right_slot %></div>
  <% end %>
</div>
