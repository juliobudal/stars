<div class="flex items-center justify-between mb-7 flex-shrink-0 <%= @options[:class] %>" style="<%= @options[:style] %>">
  <div class="flex items-center gap-5">
    <% if @back_url.present? %>
      <%= link_to @back_url,
            class: "inline-flex items-center justify-center w-11 h-11 rounded-full bg-surface border border-hairline text-foreground shadow-btn-secondary hover:bg-muted transition-all active:translate-y-[2px]",
            "aria-label": "Voltar" do %>
        <%= render Ui::Icon::Component.new("back", size: 22) %>
      <% end %>
    <% elsif left_action? %>
      <%= left_action %>
    <% end %>

    <div>
      <% if @title.present? %>
        <%# The TopBar title is always the page's primary heading (h1), even with
            a back button: a back affordance doesn't make a page title secondary.
            Visual size is controlled by the class, not the tag (WCAG 1.3.1/2.4.6). %>
        <%= content_tag :h1, @title, id: @title_id.presence, class: "font-display font-extrabold text-[22px] sm:text-[26px] leading-tight text-foreground overflow-hidden text-ellipsis whitespace-nowrap max-w-[60vw] sm:max-w-[380px]" %>
      <% end %>
      <% if @subtitle.present? %>
        <div<%= " id=\"#{@subtitle_id}\"".html_safe if @subtitle_id %> class="text-muted-foreground font-bold text-[14px] mt-0.5"><%= @subtitle %></div>
      <% end %>
    </div>
  </div>
  <% if right_slot? %>
    <div><%= right_slot %></div>
  <% end %>
</div>
