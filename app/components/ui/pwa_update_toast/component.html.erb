<div hidden
     class="pwa-update-toast"
     data-controller="pwa-update">
  <span class="pwa-update-toast__message">Atualização disponível.</span>
  <button type="button"
          class="pwa-update-toast__cta"
          data-action="pwa-update#apply">
    Atualizar
  </button>
  <button type="button"
          class="pwa-update-toast__dismiss"
          data-action="pwa-update#dismiss">
    Depois
  </button>
</div>
