<div hidden
     class="ios-hint"
     data-controller="ios-install-hint">
  <div class="ios-hint__icon" aria-hidden="true">📲</div>
  <div class="ios-hint__body">
    <p class="ios-hint__title">Instalar no iPhone</p>
    <p class="ios-hint__subtitle">
      Toque em <strong>Compartilhar</strong> e depois <strong>Adicionar à Tela de Início</strong>.
    </p>
  </div>
  <button type="button"
          class="ios-hint__dismiss"
          data-action="click->ios-install-hint#dismiss"
          aria-label="Fechar">
    ✕
  </button>
</div>
