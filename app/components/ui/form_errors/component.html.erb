<section role="alert"
         aria-live="polite"
         class="mb-[18px] p-[18px] rounded-card border-2 shadow-card <%= @options[:class] %>"
         style="background: var(--c-rose-soft); border-color: var(--danger);">
  <div class="text-[12px] font-extrabold uppercase tracking-[0.5px] mb-2" style="color: var(--danger-2);">
    <%= @title %>
  </div>
  <ul class="text-[14px] font-bold list-disc ml-5 text-foreground">
    <% messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
  </ul>
</section>
