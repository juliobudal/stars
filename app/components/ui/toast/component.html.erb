<div
  class="anim-fade-up shadow-card rounded-card px-4 py-3 font-bold flex items-center gap-2 <%= variant_classes %>"
  data-fx-event="toast"
  data-fx-variant="<%= variant %>"
  data-fx-dismiss-after="<%= dismiss_after %>"
  role="status"
  aria-live="polite"
>
  <span><%= message %></span>
</div>
