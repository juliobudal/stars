<%
  cat = category_meta
  tint = cat[:tint]
%>
<div class="bg-surface rounded-md p-7 shadow-card relative border-none reward-catalog-card flex flex-col p-5 text-center items-center gap-2.5" data-panels="all <%= reward.category %>">

  <%# Icon tile — 64px centered %>
  <%= render Ui::IconTile::Component.new(icon: reward.icon.presence || "gift", color: tint, size: 64) %>

  <%# Title %>
  <div class="font-display text-[32px] leading-[1.1] font-extrabold tracking-[-0.02em] text-foreground flex items-center justify-center text-[15px] min-h-[2.4em] text-center leading-[1.2]">
    <%= reward.title %>
  </div>

  <%# Category badge %>
  <%= render Ui::Badge::Component.new(variant: tint, size: "sm") do %>
    <%= cat[:label] %>
  <% end %>

  <%# Star cost %>
  <div class="flex items-center justify-center gap-1.5 font-extrabold text-lg text-[var(--star-2)]">
    <%= render Ui::Icon::Component.new("star", size: 18, color: "var(--star)") %>
    <%= reward.cost %>
  </div>

  <%# Actions row %>
  <div class="flex items-center gap-2 w-full mt-1">
    <%= link_to edit_parent_reward_path(reward),
          class: "btn btn-sm flex items-center justify-center flex-1 bg-primary-soft text-primary-2 gap-1.5 rounded-xl no-underline text-[13px]",
          aria: { label: "Editar #{reward.title}" } do %>
      <%= render Ui::Icon::Component.new("pencil", size: 14, color: "currentColor") %>
      Editar
    <% end %>
    <%= button_to parent_reward_path(reward), method: :delete,
          class: "flex items-center justify-center shrink-0 w-9 h-9 p-0 bg-red-soft border-none cursor-pointer text-danger rounded-xl",
          data: { turbo_confirm: "Remover \"#{reward.title}\"?" } do %>
      <%= render Ui::Icon::Component.new("trash", size: 16, color: "var(--danger)") %>
    <% end %>
  </div>
</div>
