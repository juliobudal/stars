<%
  cat = category_meta
  tint = cat[:tint]
%>
<div class="bg-surface rounded-md shadow-card overflow-hidden flex flex-col">

  <%# Icon header strip %>
  <div class="flex items-center justify-center py-5" style="background: var(--c-<%= tint %>-soft, var(--primary-soft));">
    <%= render Ui::IconTile::Component.new(icon: reward.icon.presence || "gift", color: tint, size: 52) %>
  </div>

  <%# Content %>
  <div class="flex flex-col gap-2 p-4 flex-1">
    <div class="font-display font-extrabold text-[15px] text-foreground leading-[1.2] line-clamp-2">
      <%= reward.title %>
    </div>

    <div class="flex items-center justify-between mt-auto pt-1">
      <%= render Ui::Badge::Component.new(variant: tint, size: "sm") do %>
        <%= cat[:label] %>
      <% end %>
      <div class="flex items-center gap-1 font-extrabold text-[15px] text-foreground">
        <%= render Ui::Icon::Component.new("star", size: 14, color: "var(--star)") %>
        <%= reward.cost %>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center gap-2 px-4 pb-4">
    <%= link_to edit_parent_reward_path(reward),
          class: "btn btn-sm flex items-center justify-center flex-1 gap-1.5 bg-primary-soft text-primary-2 rounded-xl no-underline text-[13px] font-bold",
          aria: { label: "Editar #{reward.title}" } do %>
      <%= render Ui::Icon::Component.new("pencil", size: 13, color: "currentColor") %>
      Editar
    <% end %>
    <%= button_to parent_reward_path(reward), method: :delete,
          class: "flex items-center justify-center shrink-0 w-9 h-9 p-0 bg-red-soft border-none cursor-pointer text-danger rounded-xl",
          data: { turbo_confirm: "Remover \"#{reward.title}\"?" } do %>
      <%= render Ui::Icon::Component.new("trash", size: 15, color: "var(--danger)") %>
    <% end %>
  </div>
</div>
