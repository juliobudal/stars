<%
  cat = category_meta
  tint = cat[:tint]
%>
<div class="card reward-catalog-card col" data-panels="all <%= reward.category %>"
     style="padding: 20px; text-align: center; align-items: center; gap: 10px;">

  <%# Icon tile — 64px centered %>
  <%= render Ui::IconTile::Component.new(icon: reward.icon.presence || "gift", color: tint, size: 64) %>

  <%# Title %>
  <div class="h-display flex-center" style="font-size: 15px; min-height: 2.4em; text-align: center; line-height: 1.2;">
    <%= reward.title %>
  </div>

  <%# Category badge %>
  <%= render Ui::Badge::Component.new(variant: tint, size: "sm") do %>
    <%= cat[:label] %>
  <% end %>

  <%# Star cost %>
  <div class="row flex-center" style="gap: 6px; font-weight: 800; font-size: 18px; color: var(--star-2);">
    <%= render Ui::Icon::Component.new("star", size: 18, color: "var(--star)") %>
    <%= reward.cost %>
  </div>

  <%# Actions row %>
  <div class="row" style="gap: 8px; width: 100%; margin-top: 4px;">
    <%= link_to edit_parent_reward_path(reward),
          class: "btn btn-sm flex-center fg1",
          style: "background: var(--primary-soft); color: var(--primary-2); gap: 6px; border-radius: 12px; text-decoration: none; font-size: 13px;",
          aria: { label: "Editar #{reward.title}" } do %>
      <%= render Ui::Icon::Component.new("pencil", size: 14, color: "currentColor") %>
      Editar
    <% end %>
    <%= button_to parent_reward_path(reward), method: :delete,
          class: "flex-center noshrink",
          style: "width: 36px; height: 36px; padding: 0; background: var(--c-red-soft); border: none; cursor: pointer; color: var(--danger); border-radius: 12px;",
          data: { turbo_confirm: "Remover \"#{reward.title}\"?" } do %>
      <%= render Ui::Icon::Component.new("trash", size: 16, color: "var(--danger)") %>
    <% end %>
  </div>
</div>
