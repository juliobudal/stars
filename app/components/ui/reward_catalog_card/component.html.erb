<%
  cat = category_meta
  tint = cat[:tint]
%>
<div class="card reward-catalog-card" data-panels="all <%= reward.category %>"
     style="padding: 16px; border: 1px solid var(--hairline); display: flex; flex-direction: column; gap: 12px; position: relative;">
  <div class="row" style="gap: 12px; align-items: flex-start;">
    <%= render Ui::IconTile::Component.new(icon: reward.icon.presence || "gift", color: tint, size: 56) %>

    <div class="col fg1" style="gap: 4px; min-width: 0;">
      <div class="h-display" style="font-size: 15px; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
        <%= reward.title %>
      </div>
      <div>
        <%= render Ui::Badge::Component.new(variant: tint, size: "sm") do %>
          <%= cat[:label] %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row" style="gap: 10px; justify-content: space-between; align-items: center; border-top: 1px solid var(--hairline); padding-top: 10px;">
    <div class="row" style="gap: 4px; align-items: center;">
      <%= render Ui::Icon::Component.new("star", size: 16, color: "var(--star)") %>
      <span class="h-display" style="font-size: 16px; color: var(--star-2);"><%= reward.cost %></span>
    </div>
    <div class="row" style="gap: 4px;">
      <%= link_to edit_parent_reward_path(reward),
            style: "width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center; color: var(--text-soft);",
            aria: { label: "Editar" } do %>
        <%= render Ui::Icon::Component.new("pencil", size: 14, color: "var(--text-soft)") %>
      <% end %>
      <%= button_to parent_reward_path(reward), method: :delete,
            style: "width: 28px; height: 28px; padding: 0; background: none; border: none; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; color: var(--danger);",
            data: { turbo_confirm: "Remover \"#{reward.title}\"?" } do %>
        <%= render Ui::Icon::Component.new("trash", size: 14, color: "var(--danger)") %>
      <% end %>
    </div>
  </div>
</div>
