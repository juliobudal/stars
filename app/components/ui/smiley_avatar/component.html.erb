<div role="img" aria-label="<%= @kid.respond_to?(:name) ? @kid.name : "" %>"
     class="ui-smiley-avatar"
     data-avatar-palette="<%= palette %>"
     style="width: <%= size %>px; height: <%= size %>px; border-width: <%= [ (size / 21.0).ceil, 2 ].max %>px; border-style: solid; border-radius: 9999px; display: inline-flex; align-items: center; justify-content: center;">
  <i class="hgi-stroke hgi-<%= avatar_slug %>"
     style="font-size: <%= (size * 0.56).round %>px; line-height: 1; display: inline-flex; width: <%= (size * 0.56).round %>px; height: <%= (size * 0.56).round %>px; align-items: center; justify-content: center;"
     aria-hidden="true"></i>
</div>
