<div class="history-entry">
  <div class="row" style="gap: 12px;">
    <div class="flex-center noshrink" style="width: 40px; height: 40px; border-radius: var(--r-full); background: <%= kind[:disc_bg] %>; color: <%= kind[:disc_color] %>;">
      <%= render Ui::Icon::Component.new(kind[:icon], size: 20, color: "currentColor") %>
    </div>
    <div class="col fg1" style="gap: 2px;">
      <div class="text-label" style="font-size: 14px;"><%= log.title %></div>
      <div class="row" style="gap: 5px;">
        <span class="chip chip-sm" style="background: <%= kind[:chip_bg] %>; color: <%= kind[:chip_text] %>; text-transform: uppercase; letter-spacing: 0.04em;"><%= kind[:label] %></span>
        <span class="text-caption" style="font-weight: 500;"><%= log.created_at.strftime("%H:%M") %></span>
      </div>
    </div>
    <div class="h-display noshrink" style="font-size: 15px; color: <%= points_color %>; white-space: nowrap;">
      <%= points_sign %><%= log.points %> ⭐
    </div>
  </div>
</div>
