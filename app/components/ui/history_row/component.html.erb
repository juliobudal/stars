<div style="padding: 12px 14px; <%= with_divider ? 'border-top: 1px solid var(--hairline);' : '' %>">
  <div class="row" style="gap: 12px; align-items: center;">
    <div style="width: 36px; height: 36px; border-radius: var(--r-full); background: <%= kind[:disc_bg] %>; color: <%= kind[:disc_color] %>; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <%= render Ui::Icon::Component.new(kind[:icon], size: 20, color: "currentColor") %>
    </div>
    <div class="col fg1" style="gap: 2px;">
      <div style="font-size: 15px; font-weight: 700; color: var(--text);"><%= log.title %></div>
      <div class="row" style="gap: 5px; align-items: center;">
        <span style="font-size: 10px; font-weight: 800; padding: 1px 7px; border-radius: var(--r-full); background: <%= kind[:chip_bg] %>; color: <%= kind[:chip_text] %>; text-transform: uppercase; letter-spacing: 0.04em;"><%= kind[:label] %></span>
        <span style="font-size: 11px; color: var(--text-muted); font-weight: 500;"><%= log.created_at.strftime("%H:%M") %></span>
      </div>
    </div>
    <div class="h-display" style="font-size: 16px; color: <%= points_color %>; flex-shrink: 0;">
      <%= points_sign %><%= log.points %> ⭐
    </div>
  </div>
</div>
