<div class="bg-surface rounded-md px-4 py-3.5 shadow-card border border-hairline mb-3">
  <div class="flex items-center gap-3">
    <div class="flex items-center justify-center shrink-0 w-10 h-10 rounded-full <%= kind[:disc_bg] %> <%= kind[:disc_color] %>">
      <%= render Ui::Icon::Component.new(kind[:icon], size: 20, color: "currentColor") %>
    </div>
    <div class="flex flex-col flex-1 gap-0.5">
      <div class="text-[14px] font-bold"><%= log.title %></div>
      <div class="flex items-center gap-1.25">
        <%= render Ui::Chip::Component.new(variant: kind[:chip_variant], size: "sm", uppercase: true) do %><%= kind[:label] %><% end %>
        <span class="text-[13px] text-muted-foreground font-bold"><%= log.created_at.strftime("%H:%M") %></span>
      </div>
    </div>
    <div class="shrink-0 whitespace-nowrap <%= points_color %>">
      <%= render Ui::StarValue::Component.new(value: log.points, prefix: points_sign, size: :sm, color: :current, class: "tracking-[-0.02em]") %>
    </div>
  </div>
</div>
