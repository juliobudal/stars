<%# Renders only the tab strip. The #panel-* regions these tabs switch are
    siblings in the consuming view, so the Stimulus controller must live on a
    wrapper that contains BOTH this strip and the panels. Hosting data-controller
    here would capture the click without seeing the panels (FilterChips follows
    the same contract). %>
<div class="cat-tabs" role="tablist">
  <% items.each do |item| %>
    <button
      type="button"
      role="tab"
      id="tab-<%= item[:id] %>"
      aria-controls="panel-<%= item[:id] %>"
      aria-selected="<%= active?(item[:id]) %>"
      data-<%= controller %>-target="tab"
      data-action="click-><%= controller %>#show"
      data-<%= controller %>-id-param="<%= item[:id] %>"
      class="cat-tab <%= 'cat-tab--active' if active?(item[:id]) %>">
      <% if item[:icon] %>
        <%= render Ui::Icon::Component.new(item[:icon], size: 14) %>
      <% end %>
      <%= item[:label] %>
      <% if item[:count] %>
        <span class="badge-count bg-primary/15 text-primary"><%= item[:count] %></span>
      <% end %>
    </button>
  <% end %>
</div>
