<div data-controller="<%= controller %>" style="display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px; scrollbar-width: none; margin-bottom: 12px;">
  <% items.each do |item| %>
    <button
      type="button"
      data-<%= controller %>-target="tab"
      data-action="click-><%= controller %>#show"
      data-<%= controller %>-id-param="<%= item[:id] %>"
      class="tab <%= active?(item[:id]) ? 'active' : '' %>"
      style="white-space: nowrap; font-size: 13px; padding: 8px 18px;">
      <% if item[:icon] %>
        <%= render Ui::Icon::Component.new(item[:icon], size: 14) %>
      <% end %>
      <%= item[:label] %>
      <% if item[:count] %>
        <span class="badge-count" style="background: color-mix(in srgb, var(--primary) 15%, transparent); color: var(--primary);"><%= item[:count] %></span>
      <% end %>
    </button>
  <% end %>
</div>
