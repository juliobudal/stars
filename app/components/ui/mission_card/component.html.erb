<% if @variant == 'ticket' %>
  <div
    class="flex items-center gap-3.5 pop-on-tap anim-tile w-full text-left <%= @options[:class] %>"
    style="
      background: white;
      border-radius: var(--r-xl);
      border: 2px solid var(--hairline);
      box-shadow: var(--shadow-card);
      padding: 14px;
      cursor: <%= status_locked? ? 'default' : 'pointer' %>;
      animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= @index * 0.04 %>s both;
      opacity: <%= status_locked? ? 0.7 : 1 %>;
      position: relative;
      transition: all 0.1s;
      <%= @options[:style] %>
    "
    <%= extra_html_attrs %>
  >
    <%= render Ui::IconTile::Component.new(icon: category_data[:icon], color: category_data[:color], size: 56) %>

    <div class="flex flex-col flex-1 gap-1">
      <div class="font-display text-[17px] leading-tight font-extrabold tracking-[-0.02em] <%= rejected? ? 'line-through' : '' %> text-foreground"><%= @mission.title %></div>
      <div class="flex items-center gap-1.5">
        <%= render Ui::Badge::Component.new(variant: category_data[:color], size: "sm", icon: category_data[:icon]) do %>
          <%= category_data[:label] %>
        <% end %>

        <% if waiting? %>
          <%= render Ui::Badge::Component.new(variant: "peach", size: "sm", icon: "clock") do %>
            Aguardando
          <% end %>
        <% elsif approved? %>
          <%= render Ui::Badge::Component.new(variant: "primary", size: "sm", icon: "check") do %>
            Aprovada
          <% end %>
        <% elsif rejected? %>
          <%= render Ui::Badge::Component.new(variant: "rose", size: "sm", icon: "x") do %>
            Rejeitada
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="flex flex-col items-center justify-center shrink-0 gap-0.5 px-1.5 text-star-2">
      <%= render Ui::StarValue::Component.new(value: points_value, size: :lg, color: :gold, class: "tracking-[-0.02em] flex-col gap-0.5") %>
    </div>
  </div>
<% elsif approved? %>
  <%# bubble — approved (line-through, primary check tile) %>
  <div
    class="ls-card-3d flex items-center gap-3.5 px-4 py-3.5 w-full <%= @options[:class] %>"
    style="
      background: var(--primary-soft);
      border: 2px solid var(--primary);
      border-radius: var(--r-xl);
      box-shadow: 0 4px 0 var(--primary-2);
      animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= [@index, 5].min * 0.04 %>s both;
      <%= @options[:style] %>
    "
    <%= extra_html_attrs %>
  >
    <div class="grid place-items-center shrink-0"
         style="width: 48px; height: 48px; border-radius: 12px; background: var(--surface); border: 2px solid var(--primary);">
      <%= render Ui::Icon::Component.new("check", size: 26, color: "var(--primary-2)") %>
    </div>
    <div class="flex-1 min-w-0">
      <div class="font-display text-[15px] font-extrabold line-through" style="color: var(--primary-2);"><%= @mission.title %></div>
      <div class="font-display text-[11px] font-extrabold tracking-[0.5px] uppercase mt-0.5 inline-flex items-center gap-1" style="color: var(--primary-2);">
        <span>+<%= points_value %></span>
        <%= render Ui::Icon::Component.new(:star, size: 12, color: "var(--star)") %>
        <span>ganhas!</span>
      </div>
    </div>
  </div>
<% elsif rejected? %>
  <%# bubble — rejected (line-through, danger x tile) %>
  <div
    class="ls-card-3d flex items-center gap-3.5 px-4 py-3.5 w-full <%= @options[:class] %>"
    style="
      background: var(--c-rose-soft);
      border: 2px solid var(--danger);
      border-radius: var(--r-xl);
      box-shadow: 0 4px 0 var(--danger-2);
      animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= [@index, 5].min * 0.04 %>s both;
      <%= @options[:style] %>
    "
    <%= extra_html_attrs %>
  >
    <div class="grid place-items-center shrink-0"
         style="width: 48px; height: 48px; border-radius: 12px; background: var(--surface); border: 2px solid var(--danger);">
      <%= render Ui::Icon::Component.new("x", size: 26, color: "var(--danger)") %>
    </div>
    <div class="flex-1 min-w-0">
      <div class="font-display text-[15px] font-extrabold line-through" style="color: var(--danger-2);"><%= @mission.title %></div>
      <div class="font-display text-[11px] font-extrabold tracking-[0.5px] uppercase mt-0.5" style="color: var(--danger-2);">
        Rejeitada
      </div>
    </div>
  </div>
<% else %>
  <%# bubble style — pending / waiting (category-tinted) %>
  <div
    class="pop-on-tap anim-tile w-full text-left flex items-center gap-4 <%= @options[:class] %>"
    style="
      background: <%= waiting? ? (category_data[:color] == 'primary' ? 'var(--primary-soft)' : "var(--c-#{category_data[:color]}-soft)") : 'white' %>;
      border-radius: var(--r-xl);
      border: 2px solid <%= category_data[:color] == 'primary' ? 'var(--primary)' : "var(--c-#{category_data[:color]})" %>;
      box-shadow: 0 4px 0 <%= category_data[:color] == 'primary' ? 'var(--primary-2)' : "var(--c-#{category_data[:color]}-dark)" %>;
      padding: 18px 20px;
      cursor: <%= waiting? ? 'default' : 'pointer' %>;
      animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= [@index, 5].min * 0.04 %>s both;
      opacity: <%= waiting? ? 0.88 : 1 %>;
      transition: all 0.1s;
      <%= @options[:style] %>
    "
    <%= extra_html_attrs %>
  >
    <div class="flex items-center justify-center shrink-0 w-[58px] h-[58px] rounded-full text-white" style="background: <%= category_data[:color] == 'primary' ? 'var(--primary)' : "var(--c-#{category_data[:color]})" %>;">
      <%= render Ui::Icon::Component.new(category_data[:icon], size: 30, color: "white") %>
    </div>

    <div class="flex flex-col flex-1 gap-1">
      <div class="font-display text-[18px] leading-tight font-extrabold tracking-[-0.02em] text-foreground"><%= @mission.title %></div>
      <div class="flex items-center gap-1.5">
        <div class="text-[13px] font-bold text-muted-foreground">
          <%= category_data[:label] %> · <%= @mission.try(:frequency) || "diária" %>
        </div>
      </div>
    </div>

    <div class="flex flex-col items-center justify-center shrink-0 gap-0">
      <% if waiting? %>
        <%= render Ui::Badge::Component.new(variant: "peach", size: "sm", icon: "clock") do %>Aguardando<% end %>
      <% else %>
        <%= render Ui::StarValue::Component.new(value: points_value, size: :lg, color: :gold, class: "text-star-2 tracking-[-0.02em]") %>
      <% end %>
    </div>
  </div>
<% end %>
