<% if @variant == 'ticket' %>
  <div 
    class="row pop-on-tap w-full text-left" 
    style="
      background: white; 
      border-radius: var(--r-md); 
      border: 2px solid rgba(26,42,74,0.08); 
      box-shadow: 0 4px 0 rgba(26,42,74,0.08); 
      padding: 14px; 
      cursor: <%= waiting? ? 'default' : 'pointer' %>; 
      animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= @index * 0.04 %>s both; 
      gap: 14px; 
      opacity: <%= waiting? ? 0.7 : 1 %>; 
      position: relative; 
      transition: all 0.1s;
      <%= @options[:style] %>
    "
    <%= 'disabled' if waiting? %>
    <%= @options.except(:style, :class).map { |k, v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>
  >
    <div class="icon-tile" style="width: 56px; height: 56px; background: <%= category_color[:bg] %>; color: <%= category_color[:fg] %>; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border-radius: var(--r-md);">
      <i class="ph-bold ph-<%= icon_name %>" style="font-size: 30px;"></i>
    </div>
    
    <div class="col fg1" style="gap: 4px;">
      <div class="h-display" style="font-size: 17px;"><%= @mission.title %></div>
      <div class="row" style="gap: 6px;">
        <div class="chip" style="font-size: 11px; padding: 4px 10px; background: <%= category_color[:bg] %>; color: <%= category_color[:fg] %>;">
          <i class="ph-bold ph-<%= icon_name %>" style="font-size: 13px; color: currentColor;"></i> <%= category_name %>
        </div>
        
        <% if waiting? %>
          <div class="chip" style="font-size: 11px; padding: 4px 10px; background: #fff0e5; color: #ff8533;">
            <i class="ph-bold ph-clock" style="font-size: 12px; color: currentColor;"></i> Aguardando
          </div>
        <% end %>
      </div>
    </div>
    
    <div class="col center" style="gap: 2px; padding: 0 6px; flex-shrink: 0;">
      <i class="ph-bold ph-star" style="font-size: 22px; color: var(--star);"></i>
      <div class="h-display" style="font-size: 20px; color: var(--star-2);"><%= points_value %></div>
    </div>
  </div>
<% else %>
  <div 
    class="pop-on-tap w-full text-left row <%= @options[:class] %>" 
    style="
      background: <%= waiting? ? category_color[:bg] : 'white' %>; 
      border-radius: var(--r-lg); 
      border: 3px solid <%= category_color[:fg] %>; 
      box-shadow: 0 5px 0 <%= category_color[:fg] %>; 
      padding: 18px 20px; 
      cursor: <%= waiting? ? 'default' : 'pointer' %>; 
      animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= @index * 0.05 %>s both; 
      gap: 16px; 
      opacity: <%= waiting? ? 0.88 : 1 %>; 
      transition: all 0.1s;
      align-items: center;
      <%= @options[:style] %>
    "
    <%= 'disabled' if waiting? %>
    <%= @options.except(:style, :class).map { |k, v| "#{k}=\"#{v}\"" }.join(" ").html_safe %>
  >
    <div style="width: 58px; height: 58px; border-radius: 50%; background: <%= category_color[:fg] %>; color: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <i class="ph-bold ph-<%= icon_name %>" style="font-size: 30px;"></i>
    </div>
    
    <div class="col fg1" style="gap: 4px;">
      <div class="h-display" style="font-size: 18px;"><%= @mission.title %></div>
      <div class="row" style="gap: 6px;">
        <div style="font-size: 13px; color: var(--text-muted); font-weight: 700;">
          <%= category_name %>
        </div>
      </div>
    </div>
    
    <div class="col center" style="gap: 0; flex-shrink: 0;">
      <% if waiting? %>
        <div class="chip" style="font-size: 12px; padding: 5px 10px; background: #fff0e5; color: #ff8533;">
          <i class="ph-bold ph-clock" style="font-size: 15px; color: currentColor;"></i>
        </div>
      <% else %>
        <div class="row" style="gap: 4px; align-items: center;">
          <i class="ph-fill ph-star" style="font-size: 20px; color: var(--star);"></i>
          <div class="h-display" style="font-size: 22px; color: var(--star-2);"><%= points_value %></div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
