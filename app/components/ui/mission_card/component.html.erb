<% if @variant == 'ticket' %>
  <div
    class="row pop-on-tap w-full text-left <%= @options[:class] %>"
    style="
      background: white;
      border-radius: var(--r-md);
      border: 2px solid rgba(26,42,74,0.08);
      box-shadow: <%= shadow_value %>;
      padding: 14px;
      cursor: <%= waiting? ? 'default' : 'pointer' %>;
      animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= @index * 0.04 %>s both;
      gap: 14px;
      opacity: <%= waiting? ? 0.7 : 1 %>;
      position: relative;
      transition: all 0.1s;
      <%= @options[:style] %>
    "
    <%= extra_html_attrs %>
  >
    <%= render Ui::IconTile::Component.new(icon: category_data[:icon], color: category_data[:color], size: 56) %>

    <div class="col fg1" style="gap: 4px;">
      <div class="h-display" style="font-size: 17px;"><%= @mission.title %></div>
      <div class="row" style="gap: 6px;">
        <%= render Ui::Badge::Component.new(variant: category_data[:color], size: "sm", icon: category_data[:icon]) do %>
          <%= category_data[:label] %>
        <% end %>

        <% if waiting? %>
          <%= render Ui::Badge::Component.new(variant: "peach", size: "sm", icon: "clock") do %>
            Aguardando
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="col center" style="gap: 2px; padding: 0 6px; flex-shrink: 0;">
      <%= render Ui::Icon::Component.new("star", size: 22, color: "var(--star)") %>
      <div class="h-display" style="font-size: 20px; color: var(--star-2);"><%= points_value %></div>
    </div>
  </div>
<% else %>
  <%# bubble style %>
  <div
    class="pop-on-tap w-full text-left row <%= @options[:class] %>"
    style="
      background: <%= waiting? ? (category_data[:color] == 'primary' ? 'var(--primary-soft)' : "var(--c-#{category_data[:color]}-soft)") : 'white' %>;
      border-radius: var(--r-lg);
      border: 3px solid <%= category_data[:color] == 'primary' ? 'var(--primary)' : "var(--c-#{category_data[:color]})" %>;
      box-shadow: <%= shadow_value %>;
      padding: 18px 20px;
      cursor: <%= waiting? ? 'default' : 'pointer' %>;
      animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= [@index, 5].min * 0.04 %>s both;
      gap: 16px;
      opacity: <%= waiting? ? 0.88 : 1 %>;
      transition: all 0.1s;
      align-items: center;
      <%= @options[:style] %>
    "
    <%= extra_html_attrs %>
  >
    <div style="width: 58px; height: 58px; border-radius: 50%; background: <%= category_data[:color] == 'primary' ? 'var(--primary)' : "var(--c-#{category_data[:color]})" %>; color: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <%= render Ui::Icon::Component.new(category_data[:icon], size: 30, color: "white") %>
    </div>

    <div class="col fg1" style="gap: 4px;">
      <div class="h-display" style="font-size: 18px;"><%= @mission.title %></div>
      <div class="row" style="gap: 6px;">
        <div style="font-size: 13px; color: var(--text-muted); font-weight: 700;">
          <%= category_data[:label] %> · <%= @mission.try(:frequency) || "diária" %>
        </div>
      </div>
    </div>

    <div class="col center" style="gap: 0; flex-shrink: 0;">
      <% if waiting? %>
        <%= render Ui::Badge::Component.new(variant: "peach", size: "sm", icon: "clock") %>
      <% else %>
        <div class="row" style="gap: 4px; align-items: center;">
          <%= render Ui::Icon::Component.new("star", size: 20, color: "var(--star)") %>
          <div class="h-display" style="font-size: 22px; color: var(--star-2);"><%= points_value %></div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
