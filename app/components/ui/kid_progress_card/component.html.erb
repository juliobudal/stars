<div data-palette="<%= helpers.palette_for(kid) %>">
  <div class="bg-surface rounded-[16px] border-2 border-hairline p-4 flex items-center gap-4 ls-card-3d"
       style="box-shadow: var(--shadow-card);">

    <div class="relative shrink-0">
      <div class="w-16 h-16 rounded-full grid place-items-center"
           style="background: <%= palette[:fill] %>; box-shadow: 0 4px 0 <%= palette[:ring] %>;">
        <%= render Ui::SmileyAvatar::Component.new(kid: kid, size: 36) %>
      </div>
      <div class="absolute -bottom-1 -right-1 text-white text-[10px] font-extrabold px-2 py-0.5 rounded-[10px] border-[3px] border-white leading-none"
           style="background: var(--success); box-shadow: 0 2px 0 var(--success-2);">N<%= level %></div>
    </div>

    <div class="flex-1 min-w-0">
      <div class="flex items-baseline gap-2.5 mb-2">
        <span class="text-[18px] font-extrabold" style="color: var(--text);"><%= kid.name %></span>
        <span class="text-[12px] font-bold inline-flex items-center gap-1" style="color: var(--text-muted);">
          <span>faltam <%= stars_to_next %></span>
          <%= render Ui::Icon::Component.new(:star, size: 12, color: "var(--star)") %>
          <span>pro nível <%= level + 1 %></span>
        </span>
      </div>

      <div class="h-[14px] rounded-[8px] overflow-hidden mb-3 relative" style="background: var(--hairline);">
        <div class="h-full rounded-[8px]" style="width: <%= xp_progress %>%; background: <%= palette[:fill] %>; box-shadow: inset 0 -3px 0 rgba(0,0,0,0.15);"></div>
      </div>

      <div class="flex flex-wrap gap-x-[18px] gap-y-1 text-[13px] font-extrabold">
        <span class="flex items-center gap-1.5" style="color: var(--c-amber-dark);">
          <%= render Ui::Icon::Component.new("star", size: 14, color: "var(--star)") %>
          <%= points %> saldo
        </span>
        <span class="flex items-center gap-1.5" style="color: var(--c-info-600);">
          <%= render Ui::Icon::Component.new("target", size: 14, color: "var(--c-info-500)") %>
          <%= missions_count %> ativas
        </span>
        <% if wishlist_reward %>
          <span class="flex items-center gap-1.5" style="color: var(--text-muted);">
            <%= render Ui::Icon::Component.new(:gift, size: 14, color: "var(--primary-2)") %>
            Meta: <strong style="color: var(--text);"><%= wishlist_reward.title %></strong>
          </span>
        <% else %>
          <span class="flex items-center gap-1.5 italic" style="color: var(--text-soft);">
            Sem meta
          </span>
        <% end %>
        <% if awaiting_count.to_i > 0 %>
          <span class="flex items-center gap-1.5" style="color: var(--danger-2);">
            <%= render Ui::Icon::Component.new("clock", size: 14, color: "var(--danger)") %>
            <%= awaiting_count %> pendentes
          </span>
        <% end %>
      </div>

      <% if manage %>
        <div class="flex items-center justify-between gap-3 pt-3 mt-3 border-t border-hairline">
          <%= link_to edit_parent_profile_path(kid),
                class: "flex items-center gap-1.5 text-[12px] font-extrabold uppercase tracking-[0.5px] no-underline",
                style: "color: #{palette[:ink]};" do %>
            <%= render Ui::Icon::Component.new("pencil", size: 14, color: palette[:ink]) %>
            Editar
          <% end %>
          <%= button_to parent_profile_path(kid), method: :delete,
                form: { data: { turbo_confirm: "Remover #{kid.name}? Todas as missões e histórico serão perdidos." } },
                class: "inline-flex items-center justify-center w-11 h-11 rounded-[10px] bg-transparent border-0 cursor-pointer text-danger",
                aria: { label: "Remover #{kid.name}" } do %>
            <%= render Ui::Icon::Component.new("trash", size: 18, color: "var(--danger)") %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
