<div class="bg-surface rounded-md p-7 shadow-card relative border-none p-0 overflow-hidden">
  <%# Slim color strip with edit pencil %>
  <div class="h-12 relative shrink-0" style="background: <%= palette[:fill] %>;">
    <%= link_to edit_parent_profile_path(kid),
          class: "flex items-center justify-center absolute top-2.5 right-2.5 w-7 h-7 rounded-full bg-white/70 no-underline",
          aria: { label: "Editar #{kid.name}" } do %>
      <%= render Ui::Icon::Component.new("pencil", size: 14, color: "rgba(0,0,0,0.5)") %>
    <% end %>
  </div>

  <%# Floating avatar + content %>
  <div class="-mt-7.5 px-5 pb-5 relative z-10">
    <%# Avatar %>
    <div class="flex items-center justify-center w-14 h-14 rounded-full border-4 border-white font-extrabold text-[22px] shadow-[0_2px_8px_rgba(44,42,58,0.12)]" style="background: <%= palette[:fill] %>; color: <%= palette[:ink] %>;">
      <%= kid.name.first.upcase %>
    </div>

    <%# Name + streak %>
    <div class="flex items-center justify-between mt-2">
      <div class="font-display text-[32px] leading-[1.1] font-extrabold tracking-[-0.02em] text-foreground text-lg"><%= kid.name %></div>
      <% if streak > 0 %>
        <span class="flex items-center bg-amber-soft text-amber-dark text-xs font-extrabold py-0.5 px-2 rounded-full gap-1">
          <%= render Ui::Icon::Component.new(:fire, size: 14, color: "var(--c-amber-dark)") %> <%= streak %>
        </span>
      <% end %>
    </div>

    <%# 2-col stats %>
    <div class="grid grid-cols-2 gap-2 mt-3">
      <div class="rounded-xl py-2.5 px-3" style="background: <%= palette[:fill] %>;">
        <div class="font-display text-[32px] leading-[1.1] font-extrabold tracking-[-0.02em] text-foreground flex items-center gap-1 text-[15px]"><%= render Ui::Icon::Component.new(:star, size: 15, color: "var(--c-amber-dark)") %> <%= points %></div>
        <div class="text-[13px] text-muted-foreground mt-0.5">Saldo</div>
      </div>
      <div class="rounded-xl py-2.5 px-3" style="background: <%= palette[:fill] %>;">
        <div class="font-display text-[32px] leading-[1.1] font-extrabold tracking-[-0.02em] text-foreground text-[15px]"><%= missions_count %></div>
        <div class="text-[13px] text-muted-foreground mt-0.5">Missões</div>
      </div>
    </div>

    <%# Awaiting badge %>
    <% if awaiting_count > 0 %>
      <div class="awaiting-badge flex items-center gap-1.5 bg-amber-soft text-amber-dark px-3 py-2 rounded-[10px] text-xs font-extrabold mt-2.5">
        <%= render Ui::Icon::Component.new("clock", size: 14, color: "var(--c-amber-dark)") %>
        <%= awaiting_count %> aguardando aprovação
      </div>
    <% end %>
  </div>
</div>
