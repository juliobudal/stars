<div data-palette="<%= helpers.palette_for(kid) %>">
  <%= render Ui::Card::Component.new(padding: "none", class: "overflow-hidden") do %>
  <%# Slim color strip with edit pencil %>
  <div class="h-12 relative z-20 shrink-0" style="background: <%= palette[:fill] %>;">
    <%= link_to edit_parent_profile_path(kid),
          class: "flex items-center justify-center absolute top-2.5 right-2.5 w-7 h-7 rounded-full bg-white/70 no-underline",
          aria: { label: "Editar #{kid.name}" } do %>
      <%= render Ui::Icon::Component.new("pencil", size: 14, color: "rgba(0,0,0,0.5)") %>
    <% end %>
  </div>

  <%# Floating avatar + content %>
  <div class="-mt-7.5 px-5 pb-5 relative z-10">
    <div class="inline-block rounded-full shadow-[0_0_0_4px_white]">
      <%= render Ui::SmileyAvatar::Component.new(kid: kid, size: 56) %>
    </div>

    <%# Name + level + streak %>
    <div class="flex items-start justify-between mt-2 gap-2">
      <div class="min-w-0">
        <%= render Ui::Heading::Component.new(size: :h3, class: "m-0 truncate") do %><%= kid.name %><% end %>
        <div class="text-[11px] font-bold text-muted-foreground uppercase tracking-[0.06em] mt-0.5">Nível <%= level %></div>
      </div>
      <% if streak > 0 %>
        <span class="flex items-center bg-amber-soft text-amber-dark text-xs font-extrabold py-0.5 px-2 rounded-full gap-1 shrink-0">
          <%= render Ui::Icon::Component.new(:fire, size: 14, color: "var(--c-amber-dark)") %> <%= streak %>
        </span>
      <% end %>
    </div>

    <%# 2-col stats %>
    <div class="grid grid-cols-2 gap-2 mt-3">
      <div class="rounded-xl py-2.5 px-3" style="background: <%= palette[:fill] %>;">
        <%= render Ui::StarValue::Component.new(value: points, size: :lg, color: :gold, class: "text-foreground") %>
        <div class="text-[12px] font-bold text-muted-foreground mt-1">Saldo</div>
      </div>
      <div class="rounded-xl py-2.5 px-3" style="background: <%= palette[:fill] %>;">
        <div class="font-display text-[20px] leading-none font-extrabold text-foreground"><%= missions_count %></div>
        <div class="text-[12px] font-bold text-muted-foreground mt-1">Missões</div>
      </div>
    </div>

    <%# Awaiting badge %>
    <% if awaiting_count > 0 %>
      <div class="flex items-center gap-1.5 bg-amber-soft text-amber-dark px-3 py-2 rounded-[10px] text-xs font-extrabold mt-2.5">
        <%= render Ui::Icon::Component.new("clock", size: 14, color: "var(--c-amber-dark)") %>
        <%= awaiting_count %> aguardando aprovação
      </div>
    <% end %>

    <%# Manage actions footer %>
    <% if manage %>
      <div class="flex items-center justify-between gap-3 pt-3 mt-3 border-t border-hairline">
        <%= link_to edit_parent_profile_path(kid),
              class: "flex items-center gap-1.5 text-[13px] font-bold no-underline",
              style: "color: #{palette[:ink]};" do %>
          <%= render Ui::Icon::Component.new("sparkle", size: 14, color: palette[:ink]) %>
          Ver jornada
        <% end %>
        <%= button_to parent_profile_path(kid), method: :delete,
              form: { data: { turbo_confirm: "Remover #{kid.name}? Todas as missões e histórico serão perdidos." } },
              class: "flex items-center bg-transparent border-0 p-0 cursor-pointer text-danger" do %>
          <%= render Ui::Icon::Component.new("trash", size: 14, color: "var(--danger)") %>
        <% end %>
      </div>
    <% end %>
  </div>
  <% end %>
</div>
