<div class="flex flex-col gap-2">
  <% if label.present? %>
    <%= form.label field, label, class: "font-display font-extrabold text-[15px] text-foreground tracking-tight" %>
  <% end %>
  <div class="flex flex-wrap gap-3">
    <% options.each do |col| %>
      <label class="cursor-pointer">
        <%= form.radio_button field, col, class: "peer sr-only", data: input_data %>
        <div class="relative w-10 h-10 rounded-full transition-all peer-checked:ring-4 peer-checked:ring-foreground peer-checked:ring-offset-2 peer-checked:ring-offset-bg-deep peer-checked:[&>span]:opacity-100 hover:scale-110"
             style="background: var(--c-<%= col %>);"
             aria-label="<%= col %>">
          <span class="absolute inset-0 flex items-center justify-center text-white opacity-0 transition-opacity">
            <%= render Ui::Icon::Component.new("check", size: 18, color: "white") %>
          </span>
        </div>
      </label>
    <% end %>
  </div>
</div>
