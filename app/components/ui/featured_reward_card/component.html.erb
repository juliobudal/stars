<div data-controller="ui-modal" class="bg-surface rounded-card shadow-card z-2 grid grid-cols-[1fr_auto] gap-7 items-center mb-4 p-7 overflow-clip">
  <div>
    <span class="inline-flex items-center gap-1 bg-lilac-soft text-violet-dark py-1 px-2.5 rounded-full text-[11px] font-extrabold tracking-widest mb-3"><%= render Ui::Icon::Component.new(:sparkle, size: 12, color: "var(--c-violet-dark)") %> EM DESTAQUE</span>
    <h3 class="font-display text-[26px] leading-tight font-extrabold tracking-[-0.02em] text-foreground m-0 mb-1.5"><%= reward.title %></h3>
    <p class="text-[17px] text-muted-foreground font-semibold m-0 mb-4.5 text-sm font-medium leading-[1.4]">Troque suas estrelinhas por esse prêmio especial.</p>
    <div class="flex items-center flex-wrap gap-3">
      <%= render Ui::Btn::Component.new(variant: "primary", size: "sm", class: "shadow-[0_3px_0_color-mix(in_srgb,var(--c-violet-dark)_25%,transparent)]",
            **(modal_id ? { data: { action: "click->ui-modal#open", ui_modal_id_param: modal_id } } : {})) do %>
        Trocar por <%= render Ui::StarValue::Component.new(value: reward.cost, size: :sm, color: :current) %>
      <% end %>
      <% if can_afford? %>
        <span class="text-xs font-bold text-mint-dark">✓ Você pode pegar essa!</span>
      <% else %>
        <span class="text-[12px] font-bold text-muted-foreground text-xs">Faltam <%= shortfall %> estrelinhas</span>
      <% end %>
    </div>
  </div>
  <div class="flex items-center justify-center shrink-0 w-[140px] h-[140px] rounded-2xl bg-lilac-soft">
    <%= render Ui::Icon::Component.new(reward_icon || "gift", size: 70, color: "var(--c-violet-dark)") %>
  </div>
</div>
