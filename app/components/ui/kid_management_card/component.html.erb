<div class="card" style="padding: 0; overflow: hidden; position: relative;">
  <%# Slim color strip with edit button %>
  <div style="height: 48px; background: <%= bg_soft %>; position: relative; flex-shrink: 0;">
    <%= link_to edit_parent_profile_path(kid),
          style: "position: absolute; top: 10px; right: 10px; width: 28px; height: 28px; border-radius: 50%; background: rgba(255,255,255,0.7); display: inline-flex; align-items: center; justify-content: center; text-decoration: none;",
          aria: { label: "Editar #{kid.name}" } do %>
      <%= render Ui::Icon::Component.new("pencil", size: 14, color: "rgba(0,0,0,0.5)") %>
    <% end %>
  </div>

  <%# Floating avatar + content %>
  <div style="margin-top: -28px; padding: 0 16px 16px;">
    <%# SmileyAvatar floating %>
    <div style="box-shadow: 0 0 0 4px white; border-radius: 50%; display: inline-block;">
      <%= render Ui::SmileyAvatar::Component.new(kid: kid, size: 56) %>
    </div>

    <%# Name + level %>
    <div style="margin-top: 8px; margin-bottom: 12px;">
      <div style="font-family: var(--font-display); font-style: italic; font-size: 18px; font-weight: 700; color: var(--text); line-height: 1.1;">
        <%= kid.name %>
      </div>
      <div style="font-size: 11px; font-weight: 700; color: var(--text-muted); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.06em;">
        Nível <%= level %>
      </div>
    </div>

    <%# 2-col stats %>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px;">
      <div style="background: var(--bg-soft); border-radius: var(--r-sm); padding: 8px 10px; text-align: center;">
        <div style="font-size: 10px; font-weight: 700; letter-spacing: 0.06em; color: var(--text-muted); text-transform: uppercase; margin-bottom: 2px;">Saldo</div>
        <div style="font-size: 15px; font-weight: 800; color: var(--text); display: flex; align-items: center; justify-content: center; gap: 4px;">
          <span style="color: var(--star);">★</span><%= balance %>
        </div>
      </div>
      <div style="background: var(--bg-soft); border-radius: var(--r-sm); padding: 8px 10px; text-align: center;">
        <div style="font-size: 10px; font-weight: 700; letter-spacing: 0.06em; color: var(--text-muted); text-transform: uppercase; margin-bottom: 2px;">Missões</div>
        <div style="font-size: 15px; font-weight: 800; color: var(--text);"><%= missions_count.to_i %></div>
      </div>
    </div>

    <%# Actions %>
    <div style="display: flex; align-items: center; justify-content: space-between; padding-top: 12px; margin-top: 8px; border-top: 1px solid var(--hairline);">
      <%= link_to edit_parent_profile_path(kid),
            style: "display: flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 700; color: #{fg_var}; text-decoration: none;" do %>
        <%= render Ui::Icon::Component.new("sparkle", size: 14, color: fg_var) %>
        Ver jornada
      <% end %>
      <%= button_to parent_profile_path(kid), method: :delete,
            form: { data: { turbo_confirm: "Remover #{kid.name}? Esta ação não pode ser desfeita." } },
            style: "background: none; border: none; padding: 0; cursor: pointer; display: flex; align-items: center; gap: 4px; color: var(--danger);" do %>
        <%= render Ui::Icon::Component.new("trash", size: 14, color: "var(--danger)") %>
      <% end %>
    </div>
  </div>
</div>
