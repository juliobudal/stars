<div data-palette="<%= helpers.palette_for(kid) %>" class="bg-surface rounded-md shadow-card overflow-hidden relative">
  <%# Color strip with edit button %>
  <div class="h-12 relative shrink-0" style="background: <%= bg_soft %>;"></div>
  <%= link_to edit_parent_profile_path(kid),
        class: "flex items-center justify-center absolute top-2.5 right-2.5 w-7 h-7 rounded-full bg-white/70 no-underline z-20",
        aria: { label: "Editar #{kid.name}" } do %>
    <%= render Ui::Icon::Component.new("pencil", size: 14, color: "rgba(0,0,0,0.5)") %>
  <% end %>

  <%# Floating avatar + content %>
  <div class="-mt-7 px-4 pb-4 relative z-10">
    <div class="inline-block rounded-full shadow-[0_0_0_4px_white]">
      <%= render Ui::SmileyAvatar::Component.new(kid: kid, size: 56) %>
    </div>

    <div class="mt-2 mb-3">
      <div class="font-display italic text-[18px] font-bold text-foreground leading-[1.1]"><%= kid.name %></div>
      <div class="text-[11px] font-bold text-muted-foreground uppercase tracking-[0.06em] mt-0.5">Nível <%= level %></div>
    </div>

    <div class="grid grid-cols-2 gap-2">
      <div class="bg-bg-soft rounded-sm py-2 px-2.5 text-center">
        <div class="text-[11px] font-bold text-muted-foreground uppercase tracking-[0.06em] mb-0.5">Saldo</div>
        <div class="flex items-center justify-center gap-1 text-[15px] font-extrabold text-foreground">
          <span class="text-amber-400">★</span><%= balance %>
        </div>
      </div>
      <div class="bg-bg-soft rounded-sm py-2 px-2.5 text-center">
        <div class="text-[11px] font-bold text-muted-foreground uppercase tracking-[0.06em] mb-0.5">Missões</div>
        <div class="text-[15px] font-extrabold text-foreground"><%= missions_count.to_i %></div>
      </div>
    </div>

    <div class="flex items-center justify-between gap-3 pt-3 mt-2 border-t border-hairline">
      <%= link_to edit_parent_profile_path(kid),
            class: "flex items-center gap-1.5 text-[13px] font-bold no-underline",
            style: "color: #{fg_var};" do %>
        <%= render Ui::Icon::Component.new("sparkle", size: 14, color: fg_var) %>
        Ver jornada
      <% end %>
      <%= button_to parent_profile_path(kid), method: :delete,
            form: { data: { turbo_confirm: "Remover #{kid.name}? Esta ação não pode ser desfeita." } },
            class: "flex items-center bg-transparent border-0 p-0 cursor-pointer text-danger" do %>
        <%= render Ui::Icon::Component.new("trash", size: 14, color: "var(--danger)") %>
      <% end %>
    </div>
  </div>
</div>
