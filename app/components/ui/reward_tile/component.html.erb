<button
  type="button"
  class="bg-surface rounded-card shadow-card relative border-none p-1.5 flex flex-col items-stretch gap-2 <%= can_afford? ? 'cursor-pointer opacity-100' : 'cursor-default opacity-60 grayscale-[0.4]' %>"
  <%= "disabled" unless can_afford? %>
  <% if can_afford? && modal_id %>data-action="click->ui-modal#open" data-ui-modal-id-param="<%= modal_id %>"<% end %>
  style="animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= animation_delay %>s both;"
>
  <%# Image area — full-width, colored bg, icon centered %>
  <div class="w-full h-[104px] rounded-sm flex items-center justify-center relative shrink-0" style="background: <%= tint %>;">
    <% if popular %>
      <span class="absolute top-1.5 right-1.5 bg-rose text-white py-0.5 px-[7px] rounded-full text-[10px] font-black tracking-wider">POPULAR</span>
    <% end %>
    <%= render Ui::Icon::Component.new(reward_icon || "gift", size: 40, color: "var(--c-violet-dark)") %>
  </div>

  <%# Title %>
  <div class="text-[13px] font-bold text-foreground leading-[1.2] px-2 pt-1"><%= reward.title %></div>

  <%# Cost + action %>
  <div class="flex items-center justify-between gap-1 px-2 pb-1.5">
    <%= render Ui::StarValue::Component.new(value: reward.cost, size: :sm, color: :gold) %>
    <% if can_afford? %>
      <span class="bg-foreground text-white py-[5px] px-2.5 rounded-full text-[10px] font-black tracking-wider">TROCAR</span>
    <% else %>
      <div class="inline-flex items-center gap-[3px] text-[11px] text-muted-foreground font-bold">
        <%= render Ui::Icon::Component.new("clock", size: 11, color: "var(--text-muted)") %>
        faltam <%= shortfall %>
      </div>
    <% end %>
  </div>
</button>
