<button
  type="button"
  class="card"
  <%= "disabled" unless can_afford? %>
  <% if can_afford? && modal_id %>data-action="click->ui-modal#open" data-ui-modal-id-param="<%= modal_id %>"<% end %>
  style="
    padding: 10px;
    cursor: <%= can_afford? ? 'pointer' : 'default' %>;
    opacity: <%= can_afford? ? 1 : 0.6 %>;
    filter: <%= can_afford? ? 'none' : 'grayscale(0.4)' %>;
    animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= animation_delay %>s both;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 8px;
    background: var(--surface);
    border: none;
    box-shadow: var(--shadow-card);
    position: relative;
  "
>
  <%# Image area — full-width, colored bg, icon centered %>
  <div style="width: 100%; height: 104px; border-radius: var(--r-sm); background: <%= tint %>; display: flex; align-items: center; justify-content: center; position: relative; flex-shrink: 0;">
    <% if popular %>
      <span style="position:absolute; top:6px; right:6px; background:var(--c-rose); color:white; padding:2px 7px; border-radius:var(--r-full); font-size:10px; font-weight:900; letter-spacing:.04em;">POPULAR</span>
    <% end %>
    <%= render Ui::Icon::Component.new(reward_icon || "gift", size: 40, color: "var(--c-violet-dark)") %>
  </div>

  <%# Title %>
  <div style="font-size: 13px; font-weight: 700; color: var(--text); line-height: 1.2;"><%= reward.title %></div>

  <%# Cost + action %>
  <div style="display: flex; align-items: center; justify-content: space-between; gap: 4px;">
    <span style="display:inline-flex; align-items:center; gap:4px; font-weight:800; font-size:13px; color:var(--text);">
      <%= render Ui::Icon::Component.new("star", size: 13, color: "var(--star)") %>
      <%= reward.cost %>
    </span>
    <% if can_afford? %>
      <span style="background:var(--text); color:white; padding:5px 10px; border-radius:var(--r-full); font-size:10px; font-weight:900; letter-spacing:.04em;">TROCAR</span>
    <% else %>
      <div style="display:inline-flex; align-items:center; gap:3px; font-size: 11px; color: var(--text-muted); font-weight: 700;">
        <%= render Ui::Icon::Component.new("clock", size: 11, color: "var(--text-muted)") %>
        faltam <%= shortfall %>
      </div>
    <% end %>
  </div>
</button>
