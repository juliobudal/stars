<button
  type="button"
  class="card"
  <%= "disabled" unless can_afford? %>
  <% if can_afford? && modal_id %>data-action="click->ui-modal#open" data-ui-modal-id-param="<%= modal_id %>"<% end %>
  style="
    padding: 10px 8px;
    text-align: center;
    cursor: <%= can_afford? ? 'pointer' : 'default' %>;
    opacity: <%= can_afford? ? 1 : 0.6 %>;
    filter: <%= can_afford? ? 'none' : 'grayscale(0.4)' %>;
    animation: slideInCard 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) <%= animation_delay %>s both;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    background: var(--surface);
    border: none;
    box-shadow: var(--shadow-card);
    position: relative;
  "
>
  <% if popular %>
    <span style="position:absolute; top:6px; right:6px; background:var(--c-rose); color:white; padding:2px 8px; border-radius:var(--r-full); font-size:10px; font-weight:900; letter-spacing:.04em;">POPULAR</span>
  <% end %>
  <div style="width: 72px; height: 72px; border-radius: var(--r-md); background: <%= tint %>; display: grid; place-items: center; margin: 0 auto 2px;">
    <%= render Ui::Icon::Component.new(reward_icon || "gift", size: 36, color: "var(--c-violet-dark)") %>
  </div>
  <div class="h-display" style="font-size: 14px; color: var(--text); line-height: 1.2;"><%= reward.title %></div>
  <%= render Ui::Badge::Component.new(variant: "star", style: "font-size: 12px; padding: 4px 10px;") do %>
    <%= render Ui::Icon::Component.new("star", size: 13, color: "var(--star-2)") %>
    <%= reward.cost %>
  <% end %>
  <% if can_afford? %>
    <span style="background:var(--primary); color:white; padding:6px 12px; border-radius:var(--r-full); font-size:12px; font-weight:900; box-shadow:0 2px 0 color-mix(in srgb, var(--c-violet-dark) 25%, transparent);">TROCAR</span>
  <% else %>
    <div style="display:inline-flex; align-items:center; gap:4px; font-size: 11px; color: var(--text-muted); font-weight: 700;">
      <%= render Ui::Icon::Component.new("clock", size: 11, color: "var(--text-muted)") %>
      faltam <%= shortfall %> ⭐
    </div>
  <% end %>
</button>
