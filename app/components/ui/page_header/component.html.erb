<header class="flex items-start justify-between gap-4 mb-[22px] z-content shrink-0 <%= @options[:class] %>">
  <div class="flex items-start gap-3 min-w-0">
    <% if left_action? %>
      <div class="shrink-0"><%= left_action %></div>
    <% end %>

    <div class="min-w-0">
      <h1 class="font-display text-[26px] font-extrabold leading-tight tracking-[-0.01em] m-0 mb-1 text-foreground">
        <%= @title %>
      </h1>
      <% if @subtitle.present? %>
        <p class="text-[14px] font-bold m-0 text-muted-foreground"><%= @subtitle %></p>
      <% end %>
    </div>
  </div>

  <% if right_slot? %>
    <div class="shrink-0"><%= right_slot %></div>
  <% end %>
</header>
