<%
  cm = category_meta
  fm = frequency_meta
  tint = cm[:tint]
  freq_tint = fm[:tint]
  row_opacity = mission.active? ? 1 : 0.55
%>
<%= turbo_frame_tag dom_id, target: "_top", class: "mission-row", data: { panels: panel_keys } do %>
  <%# Desktop row (>= md) %>
  <div class="hidden md:grid grid-cols-[2fr_1.3fr_0.8fr_1.4fr_80px_80px] items-center p-3.5 px-5 border-t border-hairline gap-2.5" style="opacity: <%= row_opacity %>;">
    <div class="flex items-center gap-2.5 min-w-0">
      <%= render Ui::IconTile::Component.new(icon: cm[:icon], color: tint, size: 36) %>
      <div class="min-w-0">
        <div class="font-display font-extrabold text-[15px] text-foreground whitespace-nowrap overflow-hidden text-ellipsis"><%= mission.title %></div>
        <div class="text-[11px] font-bold text-muted-foreground mt-[1px]"><%= cm[:label] %></div>
      </div>
    </div>
    <div>
      <%= render Ui::Badge::Component.new(variant: freq_tint, size: "sm") do %>
        <%= fm[:label] %>
      <% end %>
    </div>
    <div class="flex items-center gap-1">
      <%= render Ui::Icon::Component.new("star", size: 14, color: "var(--color-amber-dark)") %>
      <span class="font-display font-extrabold text-[15px] text-star-2"><%= mission.points %></span>
    </div>
    <div class="flex items-center gap-0">
      <% assigned_profiles.first(4).each_with_index do |k, idx| %>
        <span class="<%= idx.zero? ? '' : '-ml-1.5' %>">
          <%= render Ui::KidInitialChip::Component.new(profile: k, size: 24) %>
        </span>
      <% end %>
      <% if assigned_profiles.size > 4 %>
        <span class="flex items-center justify-center -ml-1.5 w-6 h-6 rounded-full bg-muted text-muted-foreground text-[10px] font-extrabold border-2 border-surface">+<%= assigned_profiles.size - 4 %></span>
      <% end %>
    </div>
    <div class="justify-self-center">
      <%= button_to toggle_active_parent_global_task_path(mission), method: :patch,
            form_class: "inline",
            class: "bg-transparent border-none p-0 cursor-pointer",
            aria: { label: mission.active? ? "Desativar missão" : "Ativar missão" } do %>
        <%= render Ui::Toggle::Component.new(checked: mission.active?) %>
      <% end %>
    </div>
    <div class="flex items-center gap-1 justify-end">
      <%= render Ui::Btn::Component.new(variant: "ghost", size: "sm", url: edit_parent_global_task_path(mission), class: "p-1.5", aria: { label: "Editar" }) do %>
        <%= render Ui::Icon::Component.new("pencil", size: 15, color: "var(--text-soft)") %>
      <% end %>
      <%= render Ui::Btn::Component.new(variant: "ghost", size: "sm", url: parent_global_task_path(mission), method: :delete, class: "p-1.5 text-destructive", data: { turbo_confirm: "Remover a missão \"#{mission.title}\"?" }) do %>
        <%= render Ui::Icon::Component.new("trash", size: 15) %>
      <% end %>
    </div>
  </div>

  <%# Mobile card (< md) %>
  <div class="flex md:hidden flex-col bg-surface rounded-card p-3.5 border-t border-hairline gap-2.5 shadow-card" style="opacity: <%= row_opacity %>;">
    <div class="flex items-center gap-2.5">
      <%= render Ui::IconTile::Component.new(icon: cm[:icon], color: tint, size: 36) %>
      <div class="flex flex-col flex-1 gap-0.5 min-w-0">
        <div class="font-display font-extrabold text-[15px] text-foreground whitespace-nowrap overflow-hidden text-ellipsis"><%= mission.title %></div>
        <div class="flex items-center gap-1.5">
          <%= render Ui::Badge::Component.new(variant: freq_tint, size: "sm") do %>
            <%= fm[:label] %>
          <% end %>
          <span class="text-[12px] font-bold text-muted-foreground">★ <%= mission.points %></span>
        </div>
      </div>
      <%= button_to toggle_active_parent_global_task_path(mission), method: :patch,
            form_class: "inline",
            class: "bg-transparent border-none p-0 cursor-pointer",
            aria: { label: mission.active? ? "Desativar missão" : "Ativar missão" } do %>
        <%= render Ui::Toggle::Component.new(checked: mission.active?) %>
      <% end %>
    </div>

    <div class="flex items-center justify-between">
      <div class="flex items-center gap-0">
        <% assigned_profiles.first(4).each_with_index do |k, idx| %>
          <span class="<%= idx.zero? ? '' : '-ml-1.5' %>">
            <%= render Ui::KidInitialChip::Component.new(profile: k, size: 22) %>
          </span>
        <% end %>
      </div>
      <div class="flex items-center gap-1">
        <%= render Ui::Btn::Component.new(variant: "ghost", size: "sm", url: edit_parent_global_task_path(mission), class: "p-1.5", aria: { label: "Editar" }) do %>
          <%= render Ui::Icon::Component.new("pencil", size: 15, color: "var(--text-soft)") %>
        <% end %>
        <%= render Ui::Btn::Component.new(variant: "ghost", size: "sm", url: parent_global_task_path(mission), method: :delete, class: "p-1.5 text-destructive", data: { turbo_confirm: "Remover \"#{mission.title}\"?" }) do %>
          <%= render Ui::Icon::Component.new("trash", size: 15) %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
