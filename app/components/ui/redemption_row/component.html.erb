<div class="row" style="background:var(--surface); border-radius:var(--r-md); padding:14px 16px; gap:16px; box-shadow:var(--shadow-card);">
  <div class="flex-center noshrink" style="width:48px; height:48px; border-radius:var(--r-md); background:var(--c-lilac-soft);">
    <%= render Ui::Icon::Component.new(icon, size: 24, color: "var(--c-violet-dark)") %>
  </div>
  <div class="fg1" style="min-width:0;">
    <div class="h-display" style="font-size:16px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= redemption.title %></div>
    <div class="text-caption" style="font-size:12px;">−<%= redemption.reward.cost %> ⭐</div>
  </div>
  <span class="chip chip-sm" style="background:<%= status[:bg] %>; color:<%= status[:fg] %>; white-space:nowrap;"><%= status[:label] %></span>
</div>
