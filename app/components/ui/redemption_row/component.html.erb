<div class="flex items-center bg-surface rounded-[16px] border border-hairline py-[14px] px-4 gap-4">
  <div class="flex items-center justify-center shrink-0 w-12 h-12 rounded-xl" style="background: var(--c-lilac-soft);">
    <%= render Ui::Icon::Component.new(icon, size: 24, color: "var(--c-lilac-dark)") %>
  </div>
  <div class="flex-1 min-w-0">
    <div class="font-display text-[16px] leading-tight font-extrabold tracking-[-0.02em] text-foreground overflow-hidden text-ellipsis whitespace-nowrap"><%= redemption.title %></div>
    <%= render Ui::StarValue::Component.new(value: redemption.reward.cost, prefix: "−", size: :xs, color: :gold, class: "text-muted-foreground") %>
  </div>
  <%= render Ui::Chip::Component.new(size: "sm", style: "background:#{status[:bg]}; color:#{status[:fg]}; white-space:nowrap;") do %><%= status[:label] %><% end %>
</div>
