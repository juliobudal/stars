<div style="background:var(--surface); border-radius:var(--r-md); padding:14px 16px; display:flex; align-items:center; gap:16px; box-shadow:var(--shadow-card);">
  <div style="width:48px; height:48px; border-radius:var(--r-md); background:var(--c-lilac-soft); display:grid; place-items:center; flex-shrink:0;">
    <%= render Ui::Icon::Component.new(icon, size: 24, color: "var(--c-violet-dark)") %>
  </div>
  <div style="flex:1; min-width:0;">
    <div class="h-display" style="font-size:16px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= redemption.title %></div>
    <div style="font-size:12px; font-weight:700; color:var(--text-muted);">−<%= redemption.reward.cost %> ⭐</div>
  </div>
  <span style="background:<%= status[:bg] %>; color:<%= status[:fg] %>; padding:5px 10px; border-radius:var(--r-full); font-size:11px; font-weight:800; white-space:nowrap;"><%= status[:label] %></span>
</div>
