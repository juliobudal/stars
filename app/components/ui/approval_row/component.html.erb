<div<%= " id=\"#{dom_id}\"".html_safe if dom_id %> class="bg-surface rounded-md p-7 shadow-card relative border-none p-[14px]">
  <div class="flex items-center gap-2.5 mb-2.5">
    <% if bulk? %>
      <input type="checkbox" name="approval_ids[]" value="<%= bulk_value || dom_id %>"
             aria-label="Selecionar"
             data-bulk-select-target="checkbox"
             data-action="change->bulk-select#change"
             style="width: 20px; height: 20px; accent-color: var(--primary); cursor: pointer; flex-shrink: 0;" />
    <% end %>
    <%= render Ui::SmileyAvatar::Component.new(kid: kid, size: 40) %>
    <% if profile_task&.proof_photo&.attached? %>
      <%= image_tag url_for(profile_task.proof_photo.variant(resize_to_limit: [80, 80])),
            alt: "Comprovante",
            style: "width: 80px; height: 80px; object-fit: cover; border-radius: var(--r-md); flex-shrink: 0;" %>
    <% end %>
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-center gap-1.5">
        <span class="font-display text-[32px] leading-[1.1] font-extrabold tracking-[-0.02em] text-foreground text-[15px]"><%= title %></span>
        <% if kid_chip_text.present? %>
          <%= render Ui::Chip::Component.new(size: "sm", style: "background: #{palette[:fill]}; color: #{palette[:ink]}; white-space: nowrap;") do %><%= kid_chip_text %><% end %>
        <% end %>
        <% if category_label.present? %>
          <%= render Ui::Chip::Component.new(size: "sm") do %><%= category_label %><% end %>
        <% end %>
      </div>
      <div class="flex items-center gap-2.5 mt-1">
        <span style="font-size: 12px; font-weight: 800; color: <%= points_color %>;"><%= points_sign %><%= points %> ★</span>
        <% if meta.present? %>
          <span class="text-[11px] font-bold text-muted-foreground"><%= meta %></span>
        <% end %>
      </div>
    </div>
  </div>
  <div class="flex items-center gap-2.5">
    <%= button_to reject_url, method: :patch,
        form_class: "flex-1",
        style: "width: 100%; background: var(--c-red-soft); color: var(--c-red-dark); border: none; border-radius: var(--r-full); padding: 9px 0; font-family: var(--font-display); font-weight: 800; font-size: 13px; cursor: pointer; text-align: center;",
        aria: { label: reject_label },
        data: { turbo_frame: "approvals_list", turbo_confirm: reject_confirm, turbo_submits_with: reject_submits_with }.compact do %>
      <%= reject_label %>
    <% end %>
    <%= button_to approve_url, method: :patch,
        form_class: "flex-1",
        style: "width: 100%; background: var(--primary); color: white; border: none; border-radius: var(--r-full); padding: 9px 0; font-family: var(--font-display); font-weight: 800; font-size: 13px; cursor: pointer; text-align: center;",
        aria: { label: approve_label },
        data: { turbo_frame: "approvals_list", turbo_submits_with: approve_submits_with } do %>
      <%= approve_label %>
    <% end %>
  </div>
</div>
