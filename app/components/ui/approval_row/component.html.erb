<%= tag.div id: dom_id, data: { palette: helpers.palette_for(kid) }, class: "bg-surface rounded-[16px] border border-hairline p-[14px]" do %>
  <% if compact? %>
    <%# ─── Compact (dashboard): single row with inline buttons ─── %>
    <div class="flex items-center gap-3.5">
      <% if bulk? %>
        <label class="flex items-center justify-center w-11 h-11 -my-2 shrink-0 cursor-pointer">
          <input type="checkbox" name="approval_ids[]" value="<%= bulk_value || dom_id %>"
                 aria-label="Selecionar <%= title %>"
                 data-bulk-select-target="checkbox"
                 data-action="change->bulk-select#change"
                 style="width: 20px; height: 20px; accent-color: var(--primary); cursor: pointer;" />
        </label>
      <% end %>
      <% if category_meta %>
        <% tint_color = category_meta[:tint] %>
        <div class="w-[42px] h-[42px] rounded-[12px] grid place-items-center shrink-0 border"
             style="background: <%= Ui::Tokens.tint_soft(tint_color) %>; border-color: <%= Ui::Tokens.tint_fg(tint_color) %>;">
          <%= render Ui::Icon::Component.new(category_meta[:icon], size: 22, color: Ui::Tokens.tint_fg(tint_color)) %>
        </div>
      <% else %>
        <%= render Ui::SmileyAvatar::Component.new(kid: kid, size: 42, decorative: true) %>
      <% end %>
      <div class="flex-1 min-w-0">
        <div class="text-[14px] leading-tight font-extrabold truncate" style="color: var(--text);"><%= title %></div>
        <div class="text-[12px] font-bold mt-0.5 flex flex-wrap items-center gap-x-1.5 gap-y-0.5" style="color: var(--text-muted);">
          <% [kid_chip_text.presence, meta.presence].compact.each_with_index do |part, idx| %>
            <% if idx.positive? %><span style="color: var(--text-soft);">·</span><% end %>
            <span><%= part %></span>
          <% end %>
          <% if (kid_chip_text.presence || meta.presence) %><span style="color: var(--text-soft);">·</span><% end %>
          <span class="inline-flex items-center gap-1">
            vale <%= points %>
            <%= render Ui::Icon::Component.new(:star, size: 11, color: "var(--star)") %>
          </span>
        </div>
      </div>
      <div class="flex gap-2 shrink-0">
        <%= render Ui::Btn::Component.new(
              variant: "secondary", size: "sm", url: reject_url, method: :patch,
              aria: { label: reject_label },
              data: { turbo_frame: "approvals_list", turbo_confirm: reject_confirm, turbo_submits_with: reject_submits_with }.compact
            ) do %><%= reject_label %><% end %>
        <%= render Ui::Btn::Component.new(
              variant: "primary", size: "sm", url: approve_url, method: :patch,
              aria: { label: approve_label },
              data: { turbo_frame: "approvals_list", turbo_submits_with: approve_submits_with }
            ) do %><%= approve_label %><% end %>
      </div>
    </div>
  <% else %>
    <%# ─── Full layout (approvals page): stacked buttons ─── %>
    <div class="flex items-center gap-2.5 mb-2.5">
      <% if bulk? %>
        <label class="flex items-center justify-center w-11 h-11 -my-2 shrink-0 cursor-pointer">
          <input type="checkbox" name="approval_ids[]" value="<%= bulk_value || dom_id %>"
                 aria-label="Selecionar <%= title %>"
                 data-bulk-select-target="checkbox"
                 data-action="change->bulk-select#change"
                 style="width: 20px; height: 20px; accent-color: var(--primary); cursor: pointer;" />
        </label>
      <% end %>
      <%= render Ui::SmileyAvatar::Component.new(kid: kid, size: 40, decorative: true) %>
      <% if profile_task&.proof_photo&.attached? %>
        <%= image_tag url_for(profile_task.proof_photo.variant(resize_to_limit: [80, 80])),
              alt: "Comprovante",
              style: "width: 80px; height: 80px; object-fit: cover; border-radius: var(--r-md); flex-shrink: 0;" %>
      <% end %>
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center gap-1.5">
          <span class="font-display text-[15px] leading-tight font-extrabold tracking-[-0.02em] text-foreground"><%= title %></span>
          <% if kid_chip_text.present? %>
            <%= render Ui::Chip::Component.new(size: "sm", style: "background: #{palette[:fill]}; color: #{palette[:ink]}; white-space: nowrap;") do %><%= kid_chip_text %><% end %>
          <% end %>
          <% if category_label.present? %>
            <%= render Ui::Chip::Component.new(size: "sm") do %><%= category_label %><% end %>
          <% end %>
          <% if custom %>
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-extrabold uppercase tracking-[0.5px]"
                  style="background: var(--star-soft); color: var(--c-amber-dark); border: 1px solid var(--c-amber-dark);">
              Sugerida pela criança
            </span>
          <% end %>
        </div>
        <div class="flex items-center gap-2.5 mt-1">
          <span class="text-xs inline-flex items-center gap-1" style="font-weight: 800; color: <%= points_color %>;">
            <%= points_sign %><%= points %>
            <%= render Ui::Icon::Component.new(:star, size: 12, color: "var(--star)") %>
          </span>
          <% if meta.present? %>
            <span class="text-[11px] font-bold text-muted-foreground"><%= meta %></span>
          <% end %>
        </div>
        <% if submission_comment.present? %>
          <div class="mt-2 px-3 py-2 rounded-[10px] border text-[13px] font-bold flex items-start gap-2"
               style="background: var(--surface-2); border-color: var(--hairline); color: var(--text);">
            <%= render Ui::Icon::Component.new("edit", size: 14, color: "var(--primary-2)", class: "mt-0.5 shrink-0") %>
            <span><%= submission_comment %></span>
          </div>
        <% end %>
      </div>
    </div>
    <div class="flex items-center gap-2.5">
      <%= render Ui::Btn::Component.new(
            variant: "secondary", size: "md", url: reject_url, method: :patch, block: true,
            form_class: "flex-1",
            aria: { label: reject_label },
            data: { turbo_frame: "approvals_list", turbo_confirm: reject_confirm, turbo_submits_with: reject_submits_with }.compact
          ) do %><%= reject_label %><% end %>
      <%= form_with url: approve_url, method: :patch, class: "flex-1",
            data: { turbo_frame: "approvals_list", turbo_submits_with: approve_submits_with } do |f| %>
        <% if points_editable %>
          <div class="flex items-center gap-2 mb-2">
            <label class="text-[12px] font-extrabold" style="color: var(--text-muted);">Pontos:</label>
            <%= f.number_field :points_override, value: points, min: 1, max: 1000,
                  class: "w-20 px-2 py-1 rounded-[8px] border text-[13px] font-bold text-center",
                  style: "border-color: var(--border-control); background: var(--surface); color: var(--text);" %>
          </div>
        <% end %>
        <%= f.submit approve_label,
              class: "ui-btn ui-btn--primary ui-btn--md min-h-[44px] anim-press w-full" %>
      <% end %>
    </div>
  <% end %>
<% end %>
